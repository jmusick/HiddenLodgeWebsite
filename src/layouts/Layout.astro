---
interface Props {
	title?: string;
	description?: string;
}

import { externalLinks } from '../data/externalLinks';
import { Icon } from 'astro-icon/components';
import packageJson from '../../package.json';

const {
	title = 'The Hidden Lodge | WoW Guild',
	description = 'Semi hardcore raiding guild focused on AOTC and Mythic progression.'
} = Astro.props;

const user = Astro.locals.user;
const isAdmin = Astro.locals.isAdmin;
const isGuildMember = Astro.locals.isGuildMember;
const publicNavItems = [
	{ href: '/', label: 'Home' },
	{ href: '/lore', label: 'Lore' },
	{ href: '/roster', label: 'Roster' },
	{ href: '/links', label: 'Links' },
];
const homeNavItem = publicNavItems[0];
const trailingPublicNavItems = publicNavItems.slice(1);

const guildNavItems = [
	{ href: '/raiding', label: 'Raiding' },
	{ href: '/leadership', label: 'Leadership' },
];

const toolsNavItems = [
	...(isGuildMember ? [{ href: '/trinkets', label: 'Trinkets' }] : []),
	...(user ? [{ href: '/professions', label: 'Professions' }] : []),
	...(user ? [{ href: '/loot-history', label: 'Loot' }] : []),
];

const memberNavItems = [
	...(isGuildMember ? [{ href: '/raiders', label: 'Raiders' }] : []),
	...(isGuildMember ? [{ href: '/signup', label: 'Signup' }] : []),
];

const adminNavItems = [
	...(isAdmin ? [{ href: '/admin', label: 'Admin' }] : []),
];

const responsiveMainMenuItems = [...publicNavItems, ...guildNavItems, ...toolsNavItems];

const headerLinkLabels: Record<string, string> = {
	'Raider.IO': 'R.IO',
	'Warcraft Logs': 'WCL',
	WoWProgress: 'WP'
};

const siteVersion = packageJson.version;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700;800&family=Barlow+Condensed:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<div class="background-glow" aria-hidden="true"></div>
		<header class="site-header">
			<div class="container shell">
				<a class="brand" href="/">The Hidden Lodge</a>
				<nav aria-label="Main navigation" class="nav-shell">
					<div class="main-nav-groups">
						<ul class="public-nav" aria-label="Public navigation">
							{homeNavItem && (
								<li>
									<a href={homeNavItem.href}>{homeNavItem.label}</a>
								</li>
							)}
							<li class="nav-dropdown">
								<div class="nav-dropdown-menu">
									<button type="button" class="nav-dropdown-trigger">Guild</button>
									<ul class="dropdown-panel" aria-label="Guild navigation">
										{
											guildNavItems.map((item) => (
												<li>
													<a href={item.href}>{item.label}</a>
												</li>
											))
										}
									</ul>
								</div>
							</li>
							{
								trailingPublicNavItems.map((item) => (
									<li>
										<a href={item.href}>{item.label}</a>
									</li>
								))
							}
						</ul>
						{(memberNavItems.length > 0 || toolsNavItems.length > 0 || adminNavItems.length > 0) && (
							<ul class="member-nav" aria-label="Member navigation">
								{
									memberNavItems.map((item) => (
										<li>
											<a href={item.href}>{item.label}</a>
										</li>
									))
								}
								{toolsNavItems.length > 0 && (
									<li class="nav-dropdown member-tools-dropdown">
										<div class="nav-dropdown-menu">
											<button type="button" class="nav-dropdown-trigger">Tools</button>
											<ul class="dropdown-panel" aria-label="Tools navigation">
												{
													toolsNavItems.map((item) => (
														<li>
															<a href={item.href}>{item.label}</a>
														</li>
													))
												}
											</ul>
										</div>
									</li>
								)}
								{
									adminNavItems.map((item) => (
										<li>
											<a href={item.href}>{item.label}</a>
										</li>
									))
								}
							</ul>
						)}
					</div>
					<details class="responsive-menu">
						<summary aria-label="Open navigation menu">
							<Icon name="lucide:menu" aria-hidden="true" />
							<span>Menu</span>
						</summary>
						<div class="menu-panel" role="menu">
							<div class="menu-section menu-external">
								<p class="menu-heading">Main Menu</p>
								<ul aria-label="Public links menu">
									{
										responsiveMainMenuItems.map((item) => (
											<li>
												<a href={item.href}>{item.label}</a>
											</li>
										))
									}
								</ul>
							</div>
							<div class="menu-section menu-member">
								<p class="menu-heading">Guild</p>
								{memberNavItems.length > 0 && (
									<ul aria-label="Member links menu">
										{
											memberNavItems.map((item) => (
												<li>
													<a href={item.href}>{item.label}</a>
												</li>
											))
										}
									</ul>
								)}
							</div>
							<div class="menu-section menu-external">
								<p class="menu-heading">External Links</p>
								<ul aria-label="External links menu">
									{
										externalLinks.map((link) => (
											<li>
												<a href={link.href} target="_blank" rel="noopener noreferrer">{link.name}</a>
											</li>
										))
									}
								</ul>
							</div>
							<div class="menu-section menu-account">
								<p class="menu-heading">Profile</p>
								<ul aria-label="Account links menu">
									<li>
										{user ? (
											<a href="/profile">Profile ({user.battleTag})</a>
										) : (
											<a href="/auth/login">Login</a>
										)}
									</li>
								</ul>
							</div>
						</div>
					</details>
					<ul class="guild-links" aria-label="Guild external links">
						{
							externalLinks.map((link) => (
								<li>
									<a href={link.href} target="_blank" rel="noopener noreferrer" title={link.name}>
										<img src={link.favicon} alt="" loading="lazy" />
										<span>{headerLinkLabels[link.name] ?? link.name}</span>
									</a>
								</li>
							))
						}
					</ul>
					<div class="user-nav">
						{user ? (
							<a href="/profile" class="user-btn" title="My Profile">
								<Icon name="lucide:user" aria-hidden="true" />
								<span>{user.battleTag}</span>
							</a>
						) : (
							<a href="/auth/login" class="user-btn login-btn">
								<Icon name="lucide:log-in" aria-hidden="true" />
								<span>Login</span>
							</a>
						)}
					</div>
				</nav>
			</div>
		</header>

		<main class="container">
			<slot />
		</main>

		<footer class="container site-footer">
			<p>For Azeroth. For The Hidden Lodge.</p>
			<p class="site-feedback">Found a bug or have a feature request? <a href="https://github.com/jmusick/HiddenLodgeWebsite/issues" target="_blank" rel="noopener noreferrer">Open an issue on GitHub</a>.</p>
			<p class="site-footer-links"><a href="/privacy">Privacy Policy</a></p>
			<p class="site-version">Site version v{siteVersion}</p>
		</footer>
	</body>
</html>

<style>
	:root {
		color-scheme: dark;
		--bg: #050b12;
		--bg-soft: #101a25;
		--bg-panel: rgba(13, 23, 34, 0.78);
		--gold: #d6b06a;
		--gold-bright: #e9c987;
		--steel: #8ca7bb;
		--text: #ebf1f5;
		--muted: #afc1cd;
		--border: rgba(214, 176, 106, 0.4);
		--font-display: 'Cinzel', Georgia, 'Times New Roman', serif;
		--font-body: 'Barlow Condensed', 'Trebuchet MS', sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
		font-family: var(--font-body);
		letter-spacing: 0.02em;
		background:
			radial-gradient(circle at 80% 8%, rgba(214, 176, 106, 0.24), transparent 30%),
			radial-gradient(circle at 18% 24%, rgba(97, 128, 163, 0.2), transparent 36%),
			linear-gradient(180deg, rgba(7, 17, 26, 0.84), rgba(4, 9, 15, 0.98)),
			var(--bg);
		color: var(--text);
	}

	html {
		font-size: 18px;
	}

	:global(h1),
	:global(h2),
	:global(h3) {
		font-family: var(--font-display);
		letter-spacing: 0.04em;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.container {
		max-width: 80rem;
		padding-inline: 1rem;
		margin-inline: auto;
	}

	.background-glow {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: -1;
	}

	.background-glow {
		background:
			repeating-linear-gradient(
				125deg,
				rgba(255, 255, 255, 0.014) 0,
				rgba(255, 255, 255, 0.014) 2px,
				transparent 2px,
				transparent 17px
			),
			radial-gradient(circle at 50% 120%, rgba(214, 176, 106, 0.08), transparent 54%);
	}

	.site-header {
		border-bottom: 1px solid var(--border);
		backdrop-filter: blur(8px);
		background: linear-gradient(180deg, rgba(16, 28, 40, 0.9), rgba(8, 16, 24, 0.7));
		box-shadow: 0 10px 28px rgba(0, 0, 0, 0.28);
		position: sticky;
		top: 0;
		z-index: 10;
	}

	.shell {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding-block: 0.5rem;
	}

	.brand {
		font-family: var(--font-display);
		font-size: 1.22rem;
		font-weight: 800;
		letter-spacing: 0.09em;
		text-transform: uppercase;
		color: var(--gold-bright);
		text-shadow: 0 0 18px rgba(214, 176, 106, 0.28);
		white-space: nowrap;
		flex-shrink: 0;
	}

	nav ul {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.nav-shell {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		flex-wrap: nowrap;
		min-width: 0;
		position: relative;
	}

	.responsive-menu {
		display: none;
		position: relative;
	}

	.responsive-menu summary {
		list-style: none;
		display: inline-flex;
		align-items: center;
		gap: 0.38rem;
		padding: 0.4rem 0.55rem;
		border: 1px solid rgba(214, 176, 106, 0.32);
		border-radius: 0.45rem;
		background: rgba(214, 176, 106, 0.06);
		color: var(--gold-bright);
		font-weight: 700;
		cursor: pointer;
	}

	.responsive-menu summary::-webkit-details-marker {
		display: none;
	}

	.responsive-menu summary [data-icon] {
		width: 1rem;
		height: 1rem;
	}

	.menu-panel {
		position: absolute;
		right: 0;
		top: calc(100% + 0.45rem);
		width: min(16rem, calc(100vw - 1.5rem));
		background: rgba(10, 18, 28, 0.97);
		border: 1px solid rgba(214, 176, 106, 0.34);
		border-radius: 0.55rem;
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
		padding: 0.6rem;
		display: grid;
		gap: 0.5rem;
	}

	.menu-section {
		display: none;
		padding: 0.25rem 0.2rem 0.35rem;
		border-bottom: 1px solid rgba(214, 176, 106, 0.16);
	}

	.menu-section:last-child {
		border-bottom: 0;
	}

	.menu-heading {
		margin: 0 0 0.35rem;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgba(175, 193, 205, 0.82);
	}

	.menu-panel ul {
		display: grid;
		gap: 0.18rem;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.menu-panel a {
		display: block;
		padding: 0.38rem 0.5rem;
		border-radius: 0.4rem;
		font-size: 0.9rem;
		font-weight: 600;
	}

	.main-nav-groups {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		min-width: 0;
	}

	.member-nav {
		padding-left: 0.55rem;
		border-left: 1px solid rgba(214, 176, 106, 0.34);
		background: rgba(214, 176, 106, 0.06);
		border-radius: 0.45rem;
		padding-block: 0.1rem;
		padding-right: 0.1rem;
	}

	.member-nav a {
		color: var(--gold-bright);
		font-weight: 700;
	}

	.member-nav .nav-dropdown-trigger {
		color: var(--gold-bright);
		font-weight: 700;
	}

	.member-nav .nav-dropdown-menu:hover > .nav-dropdown-trigger,
	.member-nav .nav-dropdown-menu:focus-within > .nav-dropdown-trigger,
	.member-nav .nav-dropdown-trigger:hover,
	.member-nav .nav-dropdown-trigger:focus-visible {
		color: var(--gold-bright);
	}

	.guild-links {
		display: flex;
		align-items: center;
		gap: 0.2rem;
		padding-left: 0.45rem;
		border-left: 1px solid rgba(214, 176, 106, 0.3);
	}

	.guild-links a {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.36rem 0.42rem;
		border-radius: 0.42rem;
		border: 1px solid transparent;
		font-size: 0.84rem;
	}

	.guild-links a:hover,
	.guild-links a:focus-visible {
		border-color: rgba(214, 176, 106, 0.45);
		background: rgba(214, 176, 106, 0.09);
	}

	.guild-links img {
		width: 0.95rem;
		height: 0.95rem;
		border-radius: 2px;
	}

	.user-nav {
		display: flex;
		align-items: center;
		padding-left: 0.6rem;
		border-left: 1px solid rgba(214, 176, 106, 0.3);
	}

	.user-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.42rem 0.7rem;
		border-radius: 0.42rem;
		border: 1px solid transparent;
		font-size: 0.9rem;
		color: var(--muted);
		transition: border-color 160ms ease, color 160ms ease, background 160ms ease;
		white-space: nowrap;
		max-width: 12rem;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.user-btn [data-icon] {
		width: 1rem;
		height: 1rem;
		flex-shrink: 0;
	}

	.user-btn:hover,
	.user-btn:focus-visible {
		border-color: rgba(214, 176, 106, 0.45);
		background: rgba(214, 176, 106, 0.09);
		color: var(--text);
	}

	.login-btn {
		color: var(--gold);
	}

	nav a {
		display: inline-block;
		font-weight: 600;
		font-size: 0.95rem;
		line-height: 1;
		padding: 0.42rem 0.54rem;
		border: 1px solid transparent;
		border-radius: 0.45rem;
		color: var(--muted);
		transition: border-color 160ms ease, color 160ms ease, background 160ms ease;
	}

	.public-nav > li {
		position: relative;
	}

	.nav-dropdown-menu {
		position: relative;
	}

	/* Hover bridge keeps the menu open while moving from trigger to panel. */
	.nav-dropdown-menu::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		top: 100%;
		height: 0.42rem;
	}

	.nav-dropdown-trigger {
		display: inline-block;
		font-weight: 600;
		font-size: 0.95rem;
		line-height: 1;
		padding: 0.42rem 0.54rem;
		border: 1px solid transparent;
		border-radius: 0.45rem;
		color: var(--muted);
		transition: border-color 160ms ease, color 160ms ease, background 160ms ease;
		cursor: pointer;
		background: transparent;
		font-family: inherit;
	}

	.nav-dropdown-trigger::after {
		content: '▾';
		font-size: 0.7em;
		margin-left: 0.38rem;
		opacity: 0.88;
	}

	.nav-dropdown-menu .dropdown-panel {
		display: none;
		position: absolute;
		top: 100%;
		left: 0;
		margin-top: 0;
		min-width: 9.2rem;
		padding: 0.32rem;
		border-radius: 0.45rem;
		border: 1px solid rgba(214, 176, 106, 0.36);
		background: rgba(10, 19, 29, 0.97);
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.34);
		z-index: 20;
		gap: 0.18rem;
	}

	.nav-dropdown-menu:hover > .dropdown-panel,
	.nav-dropdown-menu:focus-within > .dropdown-panel {
		display: grid;
	}

	.nav-dropdown-menu:hover > .nav-dropdown-trigger,
	.nav-dropdown-menu:focus-within > .nav-dropdown-trigger,
	.nav-dropdown-trigger:hover,
	.nav-dropdown-trigger:focus-visible {
		border-color: rgba(214, 176, 106, 0.5);
		background: rgba(214, 176, 106, 0.1);
		color: var(--text);
	}

	.nav-dropdown-menu .dropdown-panel a {
		display: block;
		white-space: nowrap;
	}

	@media (max-width: 1120px) {
		.brand {
			font-size: 1.08rem;
			letter-spacing: 0.07em;
		}

		nav a {
			font-size: 0.9rem;
			padding: 0.38rem 0.46rem;
		}

		.guild-links a,
		.user-btn {
			padding: 0.36rem 0.48rem;
		}
	}

	@media (max-width: 1310px) {
		.responsive-menu {
			display: block;
		}

		.nav-shell > .guild-links {
			display: none !important;
			padding-left: 0;
			border-left: 0;
		}

		.responsive-menu .menu-external {
			display: block !important;
		}
	}

	@media (max-width: 1200px) {
		.main-nav-groups > .member-nav,
		.nav-shell > .user-nav {
			display: none !important;
			padding-left: 0;
			border-left: 0;
		}

		.responsive-menu .menu-member {
			display: block !important;
		}

		.responsive-menu .menu-account {
			display: block !important;
		}
	}

	nav a:hover,
	nav a:focus-visible {
		border-color: rgba(214, 176, 106, 0.5);
		background: rgba(214, 176, 106, 0.1);
		color: var(--text);
	}

	main {
		padding-block: 2.5rem;
		animation: fade-in 360ms ease-out;
	}

	.site-footer {
		border-top: 1px solid var(--border);
		padding-block: 1.5rem;
		color: var(--muted);
		font-size: 1rem;
		text-align: center;
		letter-spacing: 0.03em;
	}

	.site-footer p {
		margin: 0;
	}

	.site-footer .site-feedback {
		margin-top: 0.85rem;
		font-size: 0.82rem;
		color: rgba(175, 193, 205, 0.65);
	}

	.site-feedback a {
		color: var(--gold);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.site-feedback a:hover {
		color: var(--gold-bright);
	}

	.site-footer .site-footer-links {
		margin-top: 0.75rem;
		font-size: 0.82rem;
	}

	.site-footer .site-footer-links a {
		color: var(--muted);
		text-decoration: underline;
		text-underline-offset: 2px;
		opacity: 0.7;
	}

	.site-footer .site-footer-links a:hover {
		opacity: 1;
		color: var(--text);
	}

	.site-footer .site-version {
		margin-top: 0.75rem;
		font-size: 0.72rem;
		letter-spacing: 0.04em;
		text-transform: none;
		color: rgba(175, 193, 205, 0.52);
	}

	@keyframes fade-in {
		from {
			opacity: 0;
			transform: translateY(6px);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 800px) {
		.main-nav-groups > .public-nav {
			display: none !important;
		}

		.responsive-menu .menu-public {
			display: block !important;
		}

	}
</style>
