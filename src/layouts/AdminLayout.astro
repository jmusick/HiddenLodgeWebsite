---
interface Props {
	title?: string;
}

import Layout from './Layout.astro';
import { Icon } from 'astro-icon/components';

const { title } = Astro.props;

const currentPath = new URL(Astro.request.url).pathname;

const adminModules = [
	{ href: '/admin/mains', label: 'Mains & Alts', icon: 'lucide:users' },
	{ href: '/admin/roster-teams', label: 'Roster Teams', icon: 'lucide:users-round' },
	{ href: '/admin/raid-signups', label: 'Raid Signups', icon: 'lucide:calendar-plus' },
	{ href: '/admin/log-matching', label: 'Log Matching', icon: 'lucide:scan-search' },
	{ href: '/admin/applications', label: 'Applications', icon: 'lucide:clipboard-list' },
	{ href: '/admin/feedback', label: 'Feedback', icon: 'lucide:message-square-warning' },
	{ href: '/admin/performance-review', label: 'Performance', icon: 'lucide:chart-no-axes-column-increasing' },
	{ href: '/admin/settings', label: 'Settings', icon: 'lucide:settings' },
];

const adminContentModules = [
	{ href: '/admin/raiding', label: 'Raiding Content', icon: 'lucide:swords' },
	{ href: '/admin/links', label: 'Links', icon: 'lucide:external-link' },
];

const isContentModuleActive = adminContentModules.some((module) => currentPath.startsWith(module.href));

const currentAdminModule =
	adminModules.find((module) => currentPath.startsWith(module.href))?.label ??
	(isContentModuleActive ? 'Content' : 'Modules');
---

<Layout title={title}>
	<div class="admin-wrapper">
		<div class="admin-header">
			<div class="admin-header-inner">
				<div class="admin-title-group">
					<Icon name="lucide:shield" class="admin-icon" aria-hidden="true" />
					<span class="admin-title">Admin</span>
				</div>
				<nav class="admin-subnav" aria-label="Admin modules">
					<ul>
						{adminModules.map((m) => (
							<li>
								<a
									href={m.href}
									class:list={['admin-tab', { active: currentPath.startsWith(m.href) }]}
								>
									<Icon name={m.icon} aria-hidden="true" />
									{m.label}
								</a>
							</li>
						))}
						<li class="admin-content-dropdown">
							<div class="admin-content-dropdown-menu">
								<button
									type="button"
									class:list={['admin-tab', 'admin-content-trigger', { active: isContentModuleActive }]}
								>
									<Icon name="lucide:layout-panel-left" aria-hidden="true" />
									Content
								</button>
								<ul class="admin-content-panel" aria-label="Content admin modules">
									{adminContentModules.map((module) => (
										<li>
											<a
												href={module.href}
												class:list={['admin-tab', { active: currentPath.startsWith(module.href) }]}
											>
												<Icon name={module.icon} aria-hidden="true" />
												{module.label}
											</a>
										</li>
									))}
								</ul>
							</div>
						</li>
					</ul>
					<details class="admin-subnav-menu">
						<summary aria-label="Open admin navigation menu">
							<Icon name="lucide:menu" aria-hidden="true" />
							<span>{currentAdminModule}</span>
						</summary>
						<div class="admin-menu-panel" role="menu">
							<ul aria-label="Admin modules menu">
								{adminModules.map((m) => (
									<li>
										<a
											href={m.href}
											class:list={['admin-tab', 'admin-menu-tab', { active: currentPath.startsWith(m.href) }]}
										>
											<Icon name={m.icon} aria-hidden="true" />
											{m.label}
										</a>
									</li>
								))}
								{adminContentModules.map((module) => (
									<li>
										<a
											href={module.href}
											class:list={['admin-tab', 'admin-menu-tab', { active: currentPath.startsWith(module.href) }]}
										>
											<Icon name={module.icon} aria-hidden="true" />
											{module.label}
										</a>
									</li>
								))}
							</ul>
						</div>
					</details>
				</nav>
			</div>
		</div>

		<div class="admin-content">
			<slot />
		</div>
	</div>
</Layout>

<style>
	.admin-wrapper {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.admin-header {
		background: linear-gradient(180deg, rgba(30, 14, 4, 0.6), rgba(20, 10, 2, 0.4));
		border: 1px solid rgba(214, 176, 106, 0.3);
		border-radius: 0.6rem;
		margin-bottom: 1.5rem;
	}

	.admin-header-inner {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		padding: 0.75rem 1rem;
		flex-wrap: nowrap;
	}

	.admin-title-group {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--gold);
		font-family: var(--font-display);
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.admin-icon {
		width: 1.1rem;
		height: 1.1rem;
	}

	.admin-subnav {
		min-width: 0;
		flex: 1;
	}

	.admin-subnav > ul {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		list-style: none;
		padding: 0;
		margin: 0;
		flex-wrap: nowrap;
	}

	.admin-subnav-menu {
		display: none;
		position: relative;
	}

	.admin-content-dropdown {
		position: relative;
	}

	.admin-content-dropdown-menu {
		position: relative;
	}

	/* Hover bridge: keeps panel alive while mouse travels from trigger to panel */
	.admin-content-dropdown-menu::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		top: 100%;
		height: 0.42rem;
	}

	.admin-content-trigger {
		cursor: pointer;
		background: transparent;
		font-family: inherit;
	}

	.admin-content-trigger::after {
		content: '▾';
		font-size: 0.7em;
		margin-left: 0.3rem;
		opacity: 0.88;
	}

	.admin-content-panel {
		display: none;
		position: absolute;
		top: 100%;
		right: 0;
		margin-top: 0;
		min-width: 11rem;
		list-style: none;
		padding: 0.32rem;
		margin: 0;
		border-radius: 0.45rem;
		border: 1px solid rgba(214, 176, 106, 0.36);
		background: rgba(10, 18, 28, 0.97);
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.34);
		z-index: 20;
		gap: 0.18rem;
	}

	.admin-content-panel .admin-tab {
		display: flex;
		width: 100%;
		white-space: nowrap;
		box-sizing: border-box;
	}

	.admin-content-dropdown-menu:hover > .admin-content-panel {
		display: flex;
		flex-direction: column;
	}

	.admin-content-dropdown-menu:hover > .admin-content-trigger {
		border-color: rgba(214, 176, 106, 0.45);
		background: rgba(214, 176, 106, 0.09);
		color: var(--text);
	}

	.admin-subnav-menu summary {
		list-style: none;
		display: inline-flex;
		align-items: center;
		gap: 0.38rem;
		padding: 0.4rem 0.65rem;
		border: 1px solid rgba(214, 176, 106, 0.32);
		border-radius: 0.45rem;
		background: rgba(214, 176, 106, 0.06);
		color: var(--gold-bright);
		font-size: 0.85rem;
		font-weight: 700;
		cursor: pointer;
		white-space: nowrap;
	}

	.admin-subnav-menu summary::-webkit-details-marker {
		display: none;
	}

	.admin-subnav-menu summary [data-icon] {
		width: 0.95rem;
		height: 0.95rem;
	}

	.admin-menu-panel {
		position: absolute;
		right: 0;
		top: calc(100% + 0.45rem);
		width: min(15rem, calc(100vw - 2rem));
		background: rgba(10, 18, 28, 0.97);
		border: 1px solid rgba(214, 176, 106, 0.34);
		border-radius: 0.55rem;
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
		padding: 0.6rem;
		overflow: hidden;
	}

	.admin-menu-panel ul {
		display: grid;
		gap: 0.18rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.admin-menu-tab {
		display: flex;
		width: 100%;
		max-width: 100%;
		box-sizing: border-box;
	}

	.admin-tab {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.4rem 0.75rem;
		border-radius: 0.4rem;
		border: 1px solid transparent;
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--muted);
		transition: border-color 160ms ease, color 160ms ease, background 160ms ease;
	}

	.admin-tab [data-icon] {
		width: 0.95rem;
		height: 0.95rem;
		flex-shrink: 0;
	}

	.admin-tab:hover,
	.admin-tab:focus-visible {
		border-color: rgba(214, 176, 106, 0.45);
		background: rgba(214, 176, 106, 0.09);
		color: var(--text);
	}

	.admin-tab.active {
		border-color: rgba(214, 176, 106, 0.5);
		background: rgba(214, 176, 106, 0.12);
		color: var(--gold-bright);
	}

	.admin-content {
		flex: 1;
	}

	@media (max-width: 600px) {
		.admin-header-inner {
			flex-direction: column;
			align-items: flex-start;
		}

		.admin-subnav {
			width: 100%;
		}

		.admin-subnav > ul {
			display: none !important;
		}

		.admin-subnav-menu {
			display: block;
			align-self: stretch;
		}
	}
</style>
