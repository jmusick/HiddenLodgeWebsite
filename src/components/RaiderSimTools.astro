---
import { env } from 'cloudflare:workers';
import { Icon } from 'astro-icon/components';
import { classColor } from '../lib/wow';
import { getLatestSimsForRaiderByDifficulty } from '../lib/sim-api';
import type { RaiderRaidbotsReportSummary, RaidbotsTableRun } from '../lib/sim-api';
import RaiderRaidbotsReports from './RaiderRaidbotsReports.astro';

interface Props {
  charId: number;
  charName: string;
  charClass: string;
  canManageSim?: boolean;
  showSourceDebug?: boolean;
  raidbotsReports?: RaiderRaidbotsReportSummary[];
  raidbotsTableData?: RaidbotsTableRun[];
}

const { charId, charClass, canManageSim = false, showSourceDebug = false, raidbotsReports = [], raidbotsTableData = [] } = Astro.props as Props;
const accent = classColor(charClass);
const latestByDifficulty = await getLatestSimsForRaiderByDifficulty((env as any).DB, charId);
---

<section class="sim-tools-panel" data-sim-tools-root data-char-id={String(charId)} data-can-manage={canManageSim ? '1' : '0'} aria-label="Sim tools">
  <header class="sim-tools-head" style={`--sim-accent: ${accent}`}>
    <h2 class="sim-tools-title">
      <Icon name="lucide:flask-conical" class="sim-tools-icon" aria-hidden="true" />
      Sim Tools
      <span class="sim-tools-beta">Beta</span>
    </h2>
  </header>

  <RaiderRaidbotsReports
    charId={charId}
    charClass={charClass}
    canManage={canManageSim}
    initialReports={raidbotsReports}
  />
  <p class="sim-source-summary" data-source-summary></p>

  {showSourceDebug && (
    <details class="sim-source-debug" open>
      <summary class="prep-history-summary sim-source-debug-summary">
        Source Debug
        <Icon name="lucide:chevron-down" class="collapse-chevron" aria-hidden="true" />
      </summary>
      <div class="sim-source-debug-wrap">
        <table class="sim-source-debug-table">
          <thead>
            <tr>
              <th>Difficulty</th>
              <th>Active Source</th>
              <th>Active Updated</th>
              <th>Raidbots Updated</th>
              <th>LodgeSim Updated</th>
              <th>Raidbots Rows</th>
              <th>LodgeSim Rows</th>
              <th>Merged Rows</th>
            </tr>
          </thead>
          <tbody data-source-debug-body>
            <tr><td colspan="8">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </details>
  )}

  <div class="sim-view-bar">
    <div class="sim-view-mode-toggle" data-view-mode-toggle>
      <button type="button" class="sim-view-mode-btn is-active" data-view-mode-btn="encounter">Encounter</button>
      <button type="button" class="sim-view-mode-btn" data-view-mode-btn="table">Table</button>
    </div>
    <div class="sim-view-mode-toggle" data-diff-tabs>
      <button type="button" class="sim-view-mode-btn" data-diff-tab="heroic">Heroic</button>
      <button type="button" class="sim-view-mode-btn" data-diff-tab="mythic">Mythic</button>
    </div>
  </div>

  <div data-encounter-view>
    <div class="sim-boss-list" data-encounter-body>
      <p class="sim-tools-empty">Loading recommendations...</p>
    </div>
  </div>

  <div data-table-view style="display:none">
    <div class="sim-tools-table-wrap">
      <table class="sim-tools-table" data-sim-table>
        <thead>
          <tr>
            <th><button type="button" class="sim-sort" data-sort-key="runDifficulty">Run Difficulty</button></th>
            <th><button type="button" class="sim-sort" data-sort-key="slot">Slot</button></th>
            <th><button type="button" class="sim-sort" data-sort-key="item">Item</button></th>
            <th><button type="button" class="sim-sort" data-sort-key="source">Source</button></th>
            <th><button type="button" class="sim-sort" data-sort-key="sourceDifficulty">Source Difficulty</button></th>
            <th><button type="button" class="sim-sort" data-sort-key="ilvl">iLvl</button></th>
            <th><button type="button" class="sim-sort" data-sort-key="delta">Delta DPS</button></th>
            <th><button type="button" class="sim-sort" data-sort-key="pct">Gain %</button></th>
          </tr>
          <tr class="sim-filter-row">
            <th>
              <select data-filter-key="runDifficulty" class="sim-filter-select">
                <option value="">All Runs</option>
                <option value="heroic">Heroic</option>
                <option value="mythic">Mythic</option>
              </select>
            </th>
            <th>
              <select data-filter-key="slot" class="sim-filter-select">
                <option value="">All Slots</option>
              </select>
            </th>
            <th><input data-filter-key="item" class="sim-filter" type="text" placeholder="Search item" /></th>
            <th>
              <select data-filter-key="source" class="sim-filter-select">
                <option value="">All Sources</option>
              </select>
            </th>
            <th>
              <select data-filter-key="sourceDifficulty" class="sim-filter-select">
                <option value="">All</option>
                <option value="normal">Normal</option>
                <option value="heroic">Heroic</option>
                <option value="mythic">Mythic</option>
              </select>
            </th>
            <th></th>
            <th></th>
            <th></th>
          </tr>
        </thead>
        <tbody data-sim-table-body>
          <tr>
            <td colspan="8" class="sim-tools-empty">Loading recommendations...</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <script type="application/json" data-sim-tools-initial>{JSON.stringify(latestByDifficulty)}</script>
  <script type="application/json" data-raidbots-table-initial>{JSON.stringify(raidbotsTableData)}</script>
</section>

<script>
  // @ts-nocheck
  const initSimTools = () => {
    const panel = document.querySelector('[data-sim-tools-root]');
    if (!(panel instanceof HTMLElement)) return;

    const charId = Number(panel.getAttribute('data-char-id') || 0);
    if (!Number.isFinite(charId) || charId <= 0) return;

    const tableBody = panel.querySelector('[data-sim-table-body]');
    const sourceSummary = panel.querySelector('[data-source-summary]');
    const sourceDebugBody = panel.querySelector('[data-source-debug-body]');
    const initialPayload = panel.querySelector('[data-sim-tools-initial]');

    if (!(tableBody instanceof HTMLElement)) return;
    if (!(sourceSummary instanceof HTMLElement)) return;

    let latestRuns = [];
    if (initialPayload instanceof HTMLScriptElement) {
      try {
        const parsed = JSON.parse(initialPayload.textContent || '[]');
        latestRuns = Array.isArray(parsed) ? parsed : [];
      } catch {
        latestRuns = [];
      }
    }

    let raidbotsRuns = [];
    const rbInitTag = panel.querySelector('[data-raidbots-table-initial]');
    if (rbInitTag instanceof HTMLScriptElement) {
      try {
        const parsed = JSON.parse(rbInitTag.textContent || '[]');
        raidbotsRuns = Array.isArray(parsed) ? parsed : [];
      } catch {
        raidbotsRuns = [];
      }
    }
    const getFreshRaidbotsRuns = () => {
      const cutoff = Math.floor(Date.now() / 1000) - (7 * 24 * 60 * 60);
      return raidbotsRuns.filter((run) => Number(run?.updated_at ?? 0) >= cutoff);
    };

    let sortKey = 'delta';
    let sortDir = 'desc';
    let viewMode = 'encounter';
    let encounterDifficulty = 'heroic';

    const filterValues = {
      runDifficulty: '',
      slot: '',
      item: '',
      source: '',
      sourceDifficulty: '',
    };

    const populateSelectOptions = (selector, options, emptyLabel) => {
      const select = panel.querySelector(selector);
      if (!(select instanceof HTMLSelectElement)) return;

      const current = select.value;
      const unique = [...new Set(options.map((v) => String(v || '').trim()).filter(Boolean))]
        .sort((a, b) => a.localeCompare(b, undefined, { sensitivity: 'base' }));

      select.innerHTML = `<option value="">${emptyLabel}</option>`
        + unique.map((value) => `<option value="${esc(value)}">${esc(value)}</option>`).join('');

      if (current && unique.includes(current)) {
        select.value = current;
      }
    };

    const stripSourceDifficultyPrefix = (value) => String(value || '')
      .replace(/^\s*(lfr|normal|heroic|mythic)\s+-\s+/i, '')
      .trim();

    const runOrigin = (run) => String(run?.run_id || '').startsWith('raidbots-') ? 'Raidbots' : 'LodgeSim';

    const mergedWinnerKey = (winner) => {
      const slot = String(winner?.slot || '').trim().toLowerCase();
      const itemId = Number(winner?.item_id ?? NaN);
      if (Number.isFinite(itemId) && itemId > 0) return `${slot}|id:${itemId}`;

      const label = String(winner?.item_label || '').trim().toLowerCase();
      const source = String(winner?.source || '').trim().toLowerCase();
      return `${slot}|label:${label}|src:${source}`;
    };

    const mergeWinnerLists = (lodgeWinners, raidbotsWinners) => {
      const merged = new Map();

      const putWinner = (winner, origin, priority) => {
        const key = mergedWinnerKey(winner);
        const existing = merged.get(key);
        if (existing && existing.priority > priority) return;

        merged.set(key, {
          winner: {
            ...existing?.winner,
            ...winner,
            item_label: winner?.item_label ?? existing?.winner?.item_label ?? null,
            ilvl: winner?.ilvl ?? existing?.winner?.ilvl ?? null,
            simc: winner?.simc ?? existing?.winner?.simc ?? null,
          },
          origin,
          priority,
        });
      };

      for (const winner of Array.isArray(lodgeWinners) ? lodgeWinners : []) {
        putWinner(winner, 'LodgeSim', 0);
      }
      for (const winner of Array.isArray(raidbotsWinners) ? raidbotsWinners : []) {
        putWinner(winner, 'Raidbots', 1);
      }

      return [...merged.values()]
        .map((entry) => ({ ...entry.winner, __origin: entry.origin }))
        .sort((a, b) => Number(b?.delta_dps ?? Number.NEGATIVE_INFINITY) - Number(a?.delta_dps ?? Number.NEGATIVE_INFINITY));
    };

    const getMergedRuns = () => {
      const freshRaidbotsRuns = getFreshRaidbotsRuns();
      const difficulties = ['mythic', 'heroic'];

      return difficulties.flatMap((difficulty) => {
        const lodgeRun = latestRuns.find((run) => String(run?.difficulty || '').toLowerCase() === difficulty) ?? null;
        const raidbotsRun = freshRaidbotsRuns.find((run) => String(run?.difficulty || '').toLowerCase() === difficulty) ?? null;
        if (!lodgeRun && !raidbotsRun) return [];

        const winners = mergeWinnerLists(lodgeRun?.winners ?? [], raidbotsRun?.winners ?? []);
        return [{
          run_id: `merged-${difficulty}`,
          difficulty,
          updated_at: Math.max(Number(lodgeRun?.updated_at ?? 0), Number(raidbotsRun?.updated_at ?? 0)),
          winners,
        }];
      });
    };

    const slotLabel = (value) => {
      const key = String(value || '').trim().toLowerCase();
      const map = {
        main_hand: 'Main Hand',
        off_hand: 'Off Hand',
        trinket1: 'Trinket 1',
        trinket2: 'Trinket 2',
        finger1: 'Finger 1',
        finger2: 'Finger 2',
      };
      if (map[key]) return map[key];
      return key
        .replace(/_/g, ' ')
        .replace(/\b\w/g, (ch) => ch.toUpperCase());
    };

    const parseBonusIds = (simc) => {
      const match = String(simc || '').match(/\bbonus_id=([0-9/]+)/i);
      if (!match) return [];
      return match[1]
        .split('/')
        .map((part) => Number.parseInt(part, 10))
        .filter((n) => Number.isInteger(n));
    };

    const inferSourceDifficulty = (winner) => {
      const ids = parseBonusIds(winner?.simc || '');
      if (ids.includes(4797)) return 'lfr';
      if (ids.includes(4798)) return 'normal';
      if (ids.includes(4800)) return 'mythic';
      if (ids.includes(4799)) return 'heroic';

      const sourceText = String(winner?.source || '').toLowerCase();
      if (sourceText.includes('lfr') || sourceText.includes('raid finder')) return 'lfr';
      if (sourceText.includes('normal')) return 'normal';
      if (sourceText.includes('mythic')) return 'mythic';
      if (sourceText.includes('heroic')) return 'heroic';

      // Live-generated pools can omit bonus_id and use ilevel-only SimC strings.
      // Fall back to ilvl bands so source difficulty remains visible in the table.
      const ilvl = Number.parseInt(String(winner?.ilvl ?? ''), 10);
      if (Number.isInteger(ilvl)) {
        if (ilvl >= 282) return 'mythic';
        if (ilvl >= 272) return 'heroic';
        if (ilvl >= 263) return 'normal';
        if (ilvl >= 250) return 'lfr';
      }

      return 'unknown';
    };

    const formatDifficulty = (value) => {
      const normalized = String(value || '').trim().toLowerCase();
      if (normalized === 'lfr') return 'LFR';
      if (normalized === 'normal') return 'Normal';
      if (normalized === 'mythic') return 'Mythic';
      if (normalized === 'heroic') return 'Heroic';
      return 'Unknown';
    };

    const difficultyRank = (value) => {
      const normalized = String(value || '').trim().toLowerCase();
      if (normalized === 'mythic') return 0;
      if (normalized === 'heroic') return 1;
      if (normalized === 'normal') return 2;
      if (normalized === 'lfr') return 3;
      return 4;
    };

    const formatNumber = (value) => {
      if (value === null || value === undefined || !Number.isFinite(Number(value))) return '—';
      return Number(value).toLocaleString(undefined, { maximumFractionDigits: 0 });
    };

    const formatPct = (value) => {
      if (value === null || value === undefined || !Number.isFinite(Number(value))) return '—';
      return `${Number(value).toFixed(2)}%`;
    };

    const esc = (value) => String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

    const compareValues = (a, b, key) => {
      if (key === 'ilvl' || key === 'delta' || key === 'pct') {
        const na = Number(a ?? Number.NEGATIVE_INFINITY);
        const nb = Number(b ?? Number.NEGATIVE_INFINITY);
        return na - nb;
      }
      if (key === 'runDifficulty' || key === 'sourceDifficulty') {
        return difficultyRank(b) - difficultyRank(a);
      }
      return String(a ?? '').localeCompare(String(b ?? ''), undefined, { sensitivity: 'base' });
    };

    const apiBase = String(import.meta.env.BASE_URL || '/').replace(/\/+$/, '');
    const normalizePath = (path) => (path.startsWith('/') ? path : `/${path}`);
    const apiUrl = (path) => `${apiBase}${normalizePath(path)}`;
    const rootApiUrl = (path) => normalizePath(path);

    const fetchApi = async (path, init) => {
      const primaryUrl = apiUrl(path);
      const primaryResp = await fetch(primaryUrl, init);
      if (primaryResp.status !== 404) return primaryResp;

      const fallbackUrl = rootApiUrl(path);
      if (fallbackUrl === primaryUrl) return primaryResp;
      return fetch(fallbackUrl, init);
    };

    const getActiveRuns = () => getMergedRuns();

    const updateSourceSummary = () => {
      const hasSite = latestRuns.length > 0;
      const hasRaidbots = getFreshRaidbotsRuns().length > 0;
      const mergedRuns = getMergedRuns();
      const latestForDifficulty = (runs, difficulty) => {
        const values = runs
          .filter((run) => String(run?.difficulty || '').toLowerCase() === difficulty)
          .map((run) => Number(run?.updated_at ?? 0))
          .filter((value) => Number.isFinite(value) && value > 0);
        return values.length > 0 ? Math.max(...values) : null;
      };

      const countRowsForDifficulty = (runs, difficulty) => runs
        .filter((run) => String(run?.difficulty || '').toLowerCase() === difficulty)
        .flatMap((run) => Array.isArray(run?.winners) ? run.winners : [])
        .length;

      const describeDifficulty = (difficulty) => {
        const raidbotsUpdated = latestForDifficulty(getFreshRaidbotsRuns(), difficulty);
        const lodgeUpdated = latestForDifficulty(latestRuns, difficulty);
        const raidbotsRows = countRowsForDifficulty(getFreshRaidbotsRuns(), difficulty);
        const lodgeRows = countRowsForDifficulty(latestRuns, difficulty);
        const mergedRows = countRowsForDifficulty(mergedRuns, difficulty);
        const parts = [];
        if (raidbotsUpdated) parts.push(`Raidbots ${new Date(raidbotsUpdated * 1000).toLocaleString()} (${raidbotsRows})`);
        if (lodgeUpdated) parts.push(`LodgeSim ${new Date(lodgeUpdated * 1000).toLocaleString()} (${lodgeRows})`);
        if (parts.length === 0) return `${formatDifficulty(difficulty)}: none`;
        return `${formatDifficulty(difficulty)}: ${parts.join(' + ')} => merged ${mergedRows}`;
      };
      const perDiff = `${describeDifficulty('heroic')} | ${describeDifficulty('mythic')}`;

      if (hasRaidbots && hasSite) {
        sourceSummary.textContent = `Showing merged upgrades: fresh Raidbots rows replace LodgeSim, and LodgeSim fills any remaining gaps. ${perDiff}`;
        return;
      }
      if (hasRaidbots) {
        sourceSummary.textContent = `Showing Raidbots-only upgrades (fresh <= 7 days). ${perDiff}`;
        return;
      }
      if (hasSite) {
        sourceSummary.textContent = `Showing LodgeSim upgrades (Raidbots reports are missing or stale). ${perDiff}`;
        return;
      }
      sourceSummary.textContent = 'No upgrade recommendations are available yet.';
    };

    const getAllRows = () => getActiveRuns().flatMap((run) => {
      const winners = Array.isArray(run?.winners) ? run.winners : [];
      return winners.map((winner) => {
        const sourceDifficulty = inferSourceDifficulty(winner);
        const dataOrigin = String(winner?.__origin || runOrigin(run));
        const sourceDetailText = stripSourceDifficultyPrefix(winner.source || dataOrigin);
        return {
          ...winner,
          runId: run.run_id,
          runUpdatedAt: run.updated_at,
          runDifficulty: String(run.difficulty || 'unknown').toLowerCase(),
          slotText: slotLabel(winner.slot),
          itemText: winner.item_label || `Item #${winner.item_id ?? '—'}`,
          sourceText: dataOrigin,
          sourceDetailText,
          dataOrigin,
          sourceDifficulty,
          ilvlNum: Number.isFinite(Number(winner.ilvl)) ? Number(winner.ilvl) : null,
          deltaNum: Number.isFinite(Number(winner.delta_dps)) ? Number(winner.delta_dps) : null,
          pctNum: Number.isFinite(Number(winner.pct_gain)) ? Number(winner.pct_gain) : null,
        };
      });
    });

    const renderSourceDebug = () => {
      if (!(sourceDebugBody instanceof HTMLElement)) return;

      const rowsFor = (runs, difficulty) => runs
        .filter((run) => String(run?.difficulty || '').toLowerCase() === difficulty)
        .flatMap((run) => Array.isArray(run?.winners) ? run.winners : []);

      const maxUpdatedFor = (runs, difficulty) => {
        const candidates = runs
          .filter((run) => String(run?.difficulty || '').toLowerCase() === difficulty)
          .map((run) => Number(run?.updated_at ?? 0))
          .filter((value) => Number.isFinite(value) && value > 0);
        return candidates.length > 0 ? Math.max(...candidates) : null;
      };

      const fmtDate = (epoch) => (epoch && Number.isFinite(epoch) && epoch > 0)
        ? new Date(epoch * 1000).toLocaleString()
        : '—';

      const freshRaidbots = getFreshRaidbotsRuns();
      const mergedRuns = getMergedRuns();
      const difficulties = ['mythic', 'heroic'];
      sourceDebugBody.innerHTML = difficulties.map((difficulty) => {
        const rbUpdated = maxUpdatedFor(freshRaidbots, difficulty);
        const lsUpdated = maxUpdatedFor(latestRuns, difficulty);
        const rbRows = rowsFor(freshRaidbots, difficulty).length;
        const lsRows = rowsFor(latestRuns, difficulty).length;
        const mergedRows = rowsFor(mergedRuns, difficulty).length;
        const activeSource = rbRows > 0 && lsRows > 0 ? 'Mixed' : (rbRows > 0 ? 'Raidbots' : (lsRows > 0 ? 'LodgeSim' : 'None'));
        const activeUpdated = Math.max(Number(rbUpdated ?? 0), Number(lsUpdated ?? 0)) || null;

        return `
          <tr>
            <td>${esc(formatDifficulty(difficulty))}</td>
            <td>${esc(activeSource)}</td>
            <td>${esc(fmtDate(activeUpdated))}</td>
            <td>${esc(fmtDate(rbUpdated))}</td>
            <td>${esc(fmtDate(lsUpdated))}</td>
            <td>${rbRows}</td>
            <td>${lsRows}</td>
            <td>${mergedRows}</td>
          </tr>
        `;
      }).join('');
    };

    const buildRows = () => {
      const rows = getAllRows();
      populateSelectOptions('[data-filter-key="slot"]', rows.map((row) => row.slotText), 'All Slots');
      populateSelectOptions('[data-filter-key="source"]', rows.map((row) => row.sourceText), 'All Sources');
      if (rows.length === 0) {
        tableBody.innerHTML = '<tr><td colspan="8" class="sim-tools-empty">No recommendations yet for this raider.</td></tr>';
        return;
      }
      const filteredRows = rows
        .filter((row) => {
          const checks = {
            runDifficulty: row.runDifficulty,
            slot: row.slotText,
            item: row.itemText,
            source: row.sourceText,
            sourceDifficulty: row.sourceDifficulty,
          };

          const textMatch = Object.entries(filterValues).every(([key, raw]) => {
            const needle = String(raw || '').trim().toLowerCase();
            if (!needle) return true;
            return String(checks[key] ?? '').toLowerCase().includes(needle);
          });

          if (!textMatch) return false;

          return true;
        });

      filteredRows.sort((a, b) => {
        const av =
          sortKey === 'runDifficulty' ? a.runDifficulty :
          sortKey === 'slot' ? a.slotText :
          sortKey === 'item' ? a.itemText :
          sortKey === 'source' ? a.sourceText :
          sortKey === 'sourceDifficulty' ? a.sourceDifficulty :
          sortKey === 'ilvl' ? a.ilvlNum :
          sortKey === 'delta' ? a.deltaNum :
          a.pctNum;

        const bv =
          sortKey === 'runDifficulty' ? b.runDifficulty :
          sortKey === 'slot' ? b.slotText :
          sortKey === 'item' ? b.itemText :
          sortKey === 'source' ? b.sourceText :
          sortKey === 'sourceDifficulty' ? b.sourceDifficulty :
          sortKey === 'ilvl' ? b.ilvlNum :
          sortKey === 'delta' ? b.deltaNum :
          b.pctNum;

        const cmp = compareValues(av, bv, sortKey);
        return sortDir === 'asc' ? cmp : -cmp;
      });

      if (filteredRows.length === 0) {
        tableBody.innerHTML = '<tr><td colspan="8" class="sim-tools-empty">No rows match your filters.</td></tr>';
        return;
      }

      tableBody.innerHTML = filteredRows
        .map((winner) => {
          const delta = winner.deltaNum;
          const deltaLabel = delta === null || delta === undefined || !Number.isFinite(Number(delta))
            ? '—'
            : `${Number(delta) >= 0 ? '+' : ''}${formatNumber(delta)}`;

          const itemId = Number(winner.item_id ?? 0);
          const wowhead = Number.isInteger(itemId) && itemId > 0 ? `https://www.wowhead.com/item=${itemId}` : null;

          return `
            <tr>
              <td>${esc(formatDifficulty(winner.runDifficulty))}</td>
              <td>${esc(winner.slotText)}</td>
              <td>
                <div class="sim-item-cell">
                  ${wowhead
                    ? `<a class="sim-item-link" href="${esc(wowhead)}" target="_blank" rel="noopener noreferrer">${esc(winner.itemText)}</a>`
                    : `<span>${esc(winner.itemText)}</span>`}
                </div>
              </td>
              <td>
                <div class="sim-table-source-cell">
                  <span class="sim-item-card-source ${esc(winner.dataOrigin === 'Raidbots' ? 'sim-item-card-source--raidbots' : 'sim-item-card-source--lodgesim')}">${esc(winner.sourceText)}</span>
                  <span class="sim-table-source-detail">${esc(winner.sourceDetailText)}</span>
                </div>
              </td>
              <td>${esc(formatDifficulty(winner.sourceDifficulty))}</td>
              <td>${winner.ilvlNum ?? '—'}</td>
              <td>${deltaLabel}</td>
              <td>${formatPct(winner.pctNum)}</td>
            </tr>
          `;
        })
        .join('');

      const headers = panel.querySelectorAll('[data-sort-key]');
      headers.forEach((header) => {
        if (!(header instanceof HTMLElement)) return;
        const key = header.getAttribute('data-sort-key') || '';
        header.removeAttribute('data-sort-dir');
        if (key === sortKey) header.setAttribute('data-sort-dir', sortDir);
      });
    };

    const refreshLatest = async () => {
      try {
        const resp = await fetchApi(`/api/sim/latest?char_id=${encodeURIComponent(charId)}&group_by=difficulty`, {
          headers: { Accept: 'application/json' },
        });
        if (!resp.ok) return;
        const payload = await resp.json();
        latestRuns = Array.isArray(payload?.data) ? payload.data : [];
        updateSourceSummary();
        renderSourceDebug();
        buildActiveView();
      } catch {
        // Keep existing table when refresh fails.
      }
    };

    const getAvailableDifficulties = () => {
      const diffs = new Set(
        getActiveRuns()
          .map((r) => String(r?.difficulty || '').toLowerCase())
          .filter((d) => d === 'heroic' || d === 'mythic')
      );
      // mythic first, then heroic
      const out = [];
      if (diffs.has('mythic')) out.push('mythic');
      if (diffs.has('heroic')) out.push('heroic');
      return out;
    };

    const updateDiffTabs = () => {
      const available = getAvailableDifficulties();
      const tabsBar = panel.querySelector('[data-diff-tabs]');
      if (!(tabsBar instanceof HTMLElement)) return;

      tabsBar.querySelectorAll('[data-diff-tab]').forEach((btn) => {
        if (!(btn instanceof HTMLButtonElement)) return;
        const diff = btn.getAttribute('data-diff-tab');
        btn.style.display = available.includes(diff) ? '' : 'none';
        btn.classList.toggle('is-active', diff === encounterDifficulty);
      });

      // If current encounterDifficulty has no data, switch to first available
      if (available.length > 0 && !available.includes(encounterDifficulty)) {
        encounterDifficulty = available[0];
        tabsBar.querySelectorAll('[data-diff-tab]').forEach((btn) => {
          if (!(btn instanceof HTMLButtonElement)) return;
          btn.classList.toggle('is-active', btn.getAttribute('data-diff-tab') === encounterDifficulty);
        });
      }
    };

    const buildEncounterView = () => {
      const encounterBody = panel.querySelector('[data-encounter-body]');
      if (!(encounterBody instanceof HTMLElement)) return;

      const diffRows = getAllRows().filter((r) => r.runDifficulty === encounterDifficulty);
      if (diffRows.length === 0) {
        const available = getAvailableDifficulties();
        encounterBody.innerHTML = available.length === 0
          ? '<p class="sim-tools-empty">No recommendations yet for this raider.</p>'
          : '<p class="sim-tools-empty">No recommendations for this difficulty.</p>';
        return;
      }

      // Group by boss/source
      const byBoss = new Map();
      for (const row of diffRows) {
        const boss = row.sourceDetailText || 'Unknown Source';
        if (!byBoss.has(boss)) byBoss.set(boss, []);
        byBoss.get(boss).push(row);
      }

      // Sort each group by delta descending
      for (const items of byBoss.values()) {
        items.sort((a, b) => (b.deltaNum ?? -Infinity) - (a.deltaNum ?? -Infinity));
      }

      encounterBody.innerHTML = [...byBoss.entries()].map(([boss, items]) => {
        const cards = items.map((row) => {
          const delta = row.deltaNum;
          const pct = row.pctNum;
          const pctSuffix = pct != null ? ` (${formatPct(pct)})` : '';
          const deltaLabel = delta == null ? '' : (delta >= 0 ? `+${formatNumber(delta)}${pctSuffix}` : `${formatNumber(delta)}${pctSuffix}`);
          const deltaClass = delta == null ? '' : (delta >= 0 ? 'is-positive' : 'is-negative');
          const itemId = Number(row.item_id ?? 0);
          const wowhead = Number.isInteger(itemId) && itemId > 0 ? `https://www.wowhead.com/item=${itemId}` : null;
          const metaParts = [];
          if (row.ilvlNum != null) metaParts.push(String(row.ilvlNum));
          if (row.slotText) metaParts.push(esc(row.slotText));
          const sourceClass = row.dataOrigin === 'Raidbots' ? 'sim-item-card-source--raidbots' : 'sim-item-card-source--lodgesim';

          return `
            <div class="sim-item-card">
              <div class="sim-item-card-body">
                <div class="sim-item-card-head">
                  <span class="sim-item-card-source ${esc(sourceClass)}">${esc(row.dataOrigin)}</span>
                </div>
                ${wowhead
                  ? `<a class="sim-item-card-name" href="${esc(wowhead)}" target="_blank" rel="noopener noreferrer">${esc(row.itemText)}</a>`
                  : `<span class="sim-item-card-name">${esc(row.itemText)}</span>`}
                <span class="sim-item-card-meta">${metaParts.join(' · ')}</span>
              </div>
              ${delta != null ? `<span class="sim-item-card-delta ${esc(deltaClass)}">${esc(deltaLabel)}</span>` : ''}
            </div>
          `;
        }).join('');

        return `
          <section class="sim-boss-section">
            <h4 class="sim-boss-name">${esc(boss)}</h4>
            <div class="sim-item-cards">${cards}</div>
          </section>
        `;
      }).join('');
    };

    const buildActiveView = () => {
      if (viewMode === 'encounter') {
        updateDiffTabs();
        buildEncounterView();
      } else {
        buildRows();
      }
    };

    const setViewMode = (mode) => {
      viewMode = mode;
      panel.querySelectorAll('[data-view-mode-btn]').forEach((btn) => {
        if (!(btn instanceof HTMLButtonElement)) return;
        btn.classList.toggle('is-active', btn.getAttribute('data-view-mode-btn') === mode);
      });
      const encounterView = panel.querySelector('[data-encounter-view]');
      const tableView = panel.querySelector('[data-table-view]');
      const diffTabs = panel.querySelector('[data-diff-tabs]');
      if (encounterView instanceof HTMLElement) encounterView.style.display = mode === 'encounter' ? '' : 'none';
      if (tableView instanceof HTMLElement) tableView.style.display = mode === 'table' ? '' : 'none';
      if (diffTabs instanceof HTMLElement) diffTabs.style.display = mode === 'encounter' ? '' : 'none';
      buildActiveView();
    };

    const sortButtons = panel.querySelectorAll('[data-sort-key]');
    sortButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      button.addEventListener('click', () => {
        const key = button.getAttribute('data-sort-key') || 'delta';
        if (sortKey === key) {
          sortDir = sortDir === 'asc' ? 'desc' : 'asc';
        } else {
          sortKey = key;
          sortDir = key === 'runDifficulty' || key === 'slot' || key === 'item' || key === 'source' || key === 'sourceDifficulty' ? 'asc' : 'desc';
        }
        buildRows();
      });
    });

    const filterInputs = panel.querySelectorAll('[data-filter-key]');
    filterInputs.forEach((input) => {
      if (!(input instanceof HTMLInputElement) && !(input instanceof HTMLSelectElement)) return;
      input.addEventListener('input', () => {
        const key = input.getAttribute('data-filter-key');
        if (!key || !(key in filterValues)) return;
        filterValues[key] = input.value;
        buildRows();
      });
      input.addEventListener('change', () => {
        const key = input.getAttribute('data-filter-key');
        if (!key || !(key in filterValues)) return;
        filterValues[key] = input.value;
        buildRows();
      });
    });

    panel.querySelectorAll('[data-view-mode-btn]').forEach((btn) => {
      if (!(btn instanceof HTMLButtonElement)) return;
      btn.addEventListener('click', () => {
        const mode = btn.getAttribute('data-view-mode-btn');
        if (mode === 'encounter' || mode === 'table') setViewMode(mode);
      });
    });

    panel.querySelectorAll('[data-diff-tab]').forEach((btn) => {
      if (!(btn instanceof HTMLButtonElement)) return;
      btn.addEventListener('click', () => {
        const diff = btn.getAttribute('data-diff-tab');
        if (diff === 'heroic' || diff === 'mythic') {
          encounterDifficulty = diff;
          updateDiffTabs();
          buildEncounterView();
        }
      });
    });

    window.addEventListener('hl-raidbots-updated', (e) => {
      const detail = (e instanceof CustomEvent) ? e.detail : {};
      const newData = Array.isArray(detail?.tableData) ? detail.tableData : [];
      raidbotsRuns = newData;
      updateSourceSummary();
      renderSourceDebug();
      buildActiveView();
    });

    try {
      updateSourceSummary();
      renderSourceDebug();
      const initDiffs = getAvailableDifficulties();
      if (initDiffs.length > 0) encounterDifficulty = initDiffs[0];
      setViewMode('encounter');
      void refreshLatest();
    } catch {
      // Keep panel stable even if one render helper fails.
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSimTools, { once: true });
  } else {
    initSimTools();
  }
</script>

