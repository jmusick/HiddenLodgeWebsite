---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { classColor } from '../lib/wow';
import { loadRaidersViewData } from '../lib/raiders';
import BlinkyWalker from '../components/BlinkyWalker.astro';

const { raiders, totalMembers, readyCount } = await loadRaidersViewData();

const sortedRaiders = [...raiders].sort((a, b) => {
  const scoreA = a.mythicScore ?? -1;
  const scoreB = b.mythicScore ?? -1;
  if (scoreA !== scoreB) return scoreB - scoreA;
  return a.name.localeCompare(b.name);
});

const classOptions = [...new Set(sortedRaiders.map((raider) => raider.className))].sort((a, b) =>
  a.localeCompare(b)
);
const teamOptions = [...new Set(sortedRaiders.flatMap((raider) => raider.teamNames))].sort((a, b) =>
  a.localeCompare(b)
);

function scoreColor(filled: number | null, total: number | null): string {
  if (filled === null || total === null || total === 0) return '';
  const pct = filled / total;
  if (pct >= 1)   return '#a335ee'; // epic purple
  if (pct >= 0.75) return '#0070dd'; // rare blue
  if (pct >= 0.5)  return '#1eff00'; // uncommon green
  return '#ffffff';                  // common white
}

function formatScore(filled: number | null, total: number | null): string {
  if (filled === null || total === null) return '—';
  if (total === 0) return 'N/A';
  return `${Math.round((filled / total) * 100)}% (${filled}/${total})`;
}

function preparednessTotals(raider: (typeof sortedRaiders)[number]): { filled: number | null; total: number | null } {
  // Use 2-week averages if available, otherwise fall back to current values
  const socketedGems = raider.avg30dSocketedGems ?? raider.socketedGems;
  const totalSockets = raider.avg30dTotalSockets ?? raider.totalSockets;
  const enchantedSlots = raider.avg30dEnchantedSlots ?? raider.enchantedSlots;
  const enchantableSlots = raider.avg30dEnchantableSlots ?? raider.enchantableSlots;

  if (
    socketedGems === null ||
    totalSockets === null ||
    enchantedSlots === null ||
    enchantableSlots === null
  ) {
    return { filled: null, total: null };
  }

  return {
    filled: socketedGems + enchantedSlots,
    total: totalSockets + enchantableSlots,
  };
}

function preparednessSortValue(raider: (typeof sortedRaiders)[number]): number {
  const totals = preparednessTotals(raider);
  if (totals.filled === null || totals.total === null || totals.total === 0) return -1;
  return totals.filled / totals.total;
}

function preparednessTierDisplay(filled: number | null, total: number | null): { label: string; color: string } {
  if (filled === null || total === null) return { label: '—', color: '#ffffff' };
  if (total === 0) return { label: 'N/A', color: '#ffffff' };

  const pct = filled / total;
  if (pct >= 1) return { label: 'S Tier', color: '#ff8000' }; // Blizzard orange
  if (pct >= 0.85) return { label: 'A Tier', color: '#a335ee' };
  if (pct >= 0.7) return { label: 'B Tier', color: '#0070dd' };
  if (pct >= 0.4) return { label: 'C Tier', color: '#1eff00' };
  return { label: 'D Tier', color: '#ffffff' };
}

function crestTotalValue(raider: (typeof sortedRaiders)[number]): number | null {
  const adventurer = Math.max(0, raider.adventurerCrests ?? 0);
  const veteran = Math.max(0, raider.veteranCrests ?? 0);
  const champion = Math.max(0, raider.championCrests ?? 0);
  const hero = Math.max(0, raider.heroCrests ?? 0);
  const myth = Math.max(0, raider.mythCrests ?? 0);

  const hasAnyValue =
    raider.adventurerCrests !== null ||
    raider.veteranCrests !== null ||
    raider.championCrests !== null ||
    raider.heroCrests !== null ||
    raider.mythCrests !== null;
  if (!hasAnyValue) return null;

  return adventurer + veteran + champion + hero + myth;
}

function crestSortValue(raider: (typeof sortedRaiders)[number]): number {
  const total = crestTotalValue(raider);
  return total ?? -1;
}

function crestColor(label: string): string {
  if (label === 'M') return '#ff8000';
  if (label === 'H') return '#a335ee';
  if (label === 'C') return '#0070dd';
  if (label === 'V') return '#1eff00';
  return '#ffffff';
}

function crestSummaryParts(raider: (typeof sortedRaiders)[number]): Array<{ label: string; value: number }> {
  const parts: Array<{ label: string; value: number | null }> = [
    { label: 'A', value: raider.adventurerCrests },
    { label: 'V', value: raider.veteranCrests },
    { label: 'C', value: raider.championCrests },
    { label: 'H', value: raider.heroCrests },
    { label: 'M', value: raider.mythCrests },
  ];

  return parts
    .filter((part) => part.value !== null)
    .map((part) => ({ label: part.label, value: part.value as number }));
}

function classAbbrev(className: string): string {
  const normalized = className.trim().toLowerCase();
  const map: Record<string, string> = {
    'death knight': 'DK',
    'demon hunter': 'DH',
    druid: 'DR',
    evoker: 'EV',
    hunter: 'HU',
    mage: 'MA',
    monk: 'MO',
    paladin: 'PA',
    priest: 'PR',
    rogue: 'RO',
    shaman: 'SH',
    warlock: 'WL',
    warrior: 'WR',
  };

  return map[normalized] ?? className.slice(0, 2).toUpperCase();
}

function ilvlColor(itemLevel: number | null): string {
  if (itemLevel === null) return '#ffffff';
  if (itemLevel >= 286) return '#ff8000'; // legendary
  if (itemLevel >= 269) return '#a335ee'; // epic
  if (itemLevel >= 256) return '#0070dd'; // rare
  if (itemLevel >= 243) return '#1eff00'; // uncommon
  return '#ffffff'; // common
}

const VAULT_SLOT_POSITION_WEIGHTS = [1, 1.35, 1.8] as const;

function parseRaidVaultPayload(label: string | null): { options: Array<number | null> } | null {
  if (!label) return null;

  try {
    const parsed = JSON.parse(label) as { vaultRaid?: { options?: unknown } };
    if (!parsed?.vaultRaid || !Array.isArray(parsed.vaultRaid.options)) return null;

    const options = parsed.vaultRaid.options.slice(0, 3).map((value) => {
      const asNumber = Number(value);
      return Number.isFinite(asNumber) && asNumber > 0 ? Math.floor(asNumber) : null;
    });

    while (options.length < 3) options.push(null);
    return { options };
  } catch {
    return null;
  }
}

function raidDifficultyWeight(itemLevel: number | null): number {
  if (itemLevel === null) return 0;
  if (itemLevel >= 272) return 1.45;
  if (itemLevel >= 266) return 1.25;
  if (itemLevel >= 259) return 1.0;
  if (itemLevel >= 252) return 0.75;
  return 0.6;
}

function dungeonDifficultyWeight(itemLevel: number | null): number {
  if (itemLevel === null) return 0;
  if (itemLevel >= 272) return 1.45;
  if (itemLevel >= 269) return 1.3;
  if (itemLevel >= 266) return 1.15;
  if (itemLevel >= 263) return 1.0;
  if (itemLevel >= 259) return 0.85;
  return 0.7;
}

function greatVaultScoreForRaider(raider: (typeof sortedRaiders)[number]): { score: number; color: string } {
  const raidVaultPayload = parseRaidVaultPayload(raider.raidProgressLabel);
  const raidSlots = raidVaultPayload?.options ?? [null, null, null];
  const dungeonSlots = [raider.mythicPlusVaultIlvl1, raider.mythicPlusVaultIlvl2, raider.mythicPlusVaultIlvl3] as const;
  const worldWeeklyObjectives = Math.max(0, raider.worldVaultWeeklyObjectives ?? 0);
  const worldSlotsFilled = [2, 4, 8].filter((required) => worldWeeklyObjectives >= required).length;

  let points = 0;
  let maxPoints = 0;

  for (let i = 0; i < 3; i += 1) {
    const slotWeight = VAULT_SLOT_POSITION_WEIGHTS[i];
    points += raidDifficultyWeight(raidSlots[i]) * slotWeight;
    points += dungeonDifficultyWeight(dungeonSlots[i]) * slotWeight;
    if (worldSlotsFilled > i) {
      points += 0.35 * slotWeight;
    }

    maxPoints += (1.45 + 1.45 + 0.35) * slotWeight;
  }

  const pct = maxPoints > 0 ? Math.max(0, Math.min(1, points / maxPoints)) : 0;
  const score = Math.round(pct * 100);

  if (score >= 95) return { score, color: '#ff8000' };
  if (score >= 85) return { score, color: '#a335ee' };
  if (score >= 70) return { score, color: '#0070dd' };
  if (score >= 40) return { score, color: '#1eff00' };
  return { score, color: '#ffffff' };
}

function attendanceColor(score: number | null): string {
  if (score === null) return '#8ea4b2';
  if (score >= 100) return '#ff8000';
  if (score >= 90) return '#a335ee';
  if (score >= 80) return '#0070dd';
  if (score >= 65) return '#1eff00';
  return '#ffffff';
}

const topItemLevel = sortedRaiders.reduce((best, raider) =>
  (raider.equippedItemLevel ?? -1) > (best?.equippedItemLevel ?? -1) ? raider : best,
  null as (typeof sortedRaiders)[number] | null
);
const topMythicScore = sortedRaiders.reduce((best, raider) =>
  (raider.mythicScore ?? -1) > (best?.mythicScore ?? -1) ? raider : best,
  null as (typeof sortedRaiders)[number] | null
);
const topSingleTarget = sortedRaiders.reduce((best, raider) =>
  (raider.singleTargetDps ?? -1) > (best?.singleTargetDps ?? -1) ? raider : best,
  null as (typeof sortedRaiders)[number] | null
);
const crestCandidates = sortedRaiders.filter((raider) => crestTotalValue(raider) !== null);
const topCrests = crestCandidates.reduce(
  (best, raider) => ((crestTotalValue(raider) ?? -1) > (best ? (crestTotalValue(best) ?? -1) : -1) ? raider : best),
  null as (typeof sortedRaiders)[number] | null
);
const missingUpgradeCandidates = sortedRaiders.filter(
  (raider) => raider.totalUpgradesMissing !== null && raider.totalUpgradesMissing !== undefined
);
const fewestMissingUpgrades = missingUpgradeCandidates.reduce(
  (best, raider) => ((raider.totalUpgradesMissing ?? Number.POSITIVE_INFINITY) < (best?.totalUpgradesMissing ?? Number.POSITIVE_INFINITY) ? raider : best),
  null as (typeof sortedRaiders)[number] | null
);
const topMplusTotal = sortedRaiders.reduce((best, raider) =>
  (raider.mythicPlusRunCount ?? -1) > (best?.mythicPlusRunCount ?? -1) ? raider : best,
  null as (typeof sortedRaiders)[number] | null
);
const topMplusCurrent = sortedRaiders.reduce((best, raider) =>
  (raider.mythicPlusWeeklyRuns ?? -1) > (best?.mythicPlusWeeklyRuns ?? -1) ? raider : best,
  null as (typeof sortedRaiders)[number] | null
);
const topMplusLast = sortedRaiders.reduce((best, raider) =>
  (raider.mythicPlusPrevWeeklyRuns ?? -1) > (best?.mythicPlusPrevWeeklyRuns ?? -1) ? raider : best,
  null as (typeof sortedRaiders)[number] | null
);

const spotlightCards = [
  {
    label: 'Highest Item Level',
    icon: 'lucide:shield',
    value: topItemLevel?.equippedItemLevel ? String(topItemLevel.equippedItemLevel) : '—',
    detail: topItemLevel?.name ?? '—',
    className: topItemLevel?.className ?? '',
  },
  {
    label: 'Highest Simulated DPS',
    icon: 'lucide:crosshair',
    value: topSingleTarget?.singleTargetDps
      ? topSingleTarget.singleTargetDps.toLocaleString(undefined, { maximumFractionDigits: 0 })
      : '—',
    detail: topSingleTarget?.name ?? '—',
    className: topSingleTarget?.className ?? '',
  },
  {
    label: 'Highest M+ Score',
    icon: 'lucide:trophy',
    value: topMythicScore?.mythicScore ? topMythicScore.mythicScore.toLocaleString(undefined, { maximumFractionDigits: 0 }) : '—',
    detail: topMythicScore?.name ?? '—',
    className: topMythicScore?.className ?? '',
  },
  {
    label: 'Most Crests',
    icon: 'lucide:gem',
    value: topCrests ? (crestTotalValue(topCrests) ?? 0).toLocaleString() : '—',
    detail: topCrests?.name ?? '—',
    className: topCrests?.className ?? '',
  },
  {
    label: 'Fewest Missing Upgrades',
    icon: 'lucide:wrench',
    value: fewestMissingUpgrades?.totalUpgradesMissing !== null && fewestMissingUpgrades?.totalUpgradesMissing !== undefined
      ? fewestMissingUpgrades.totalUpgradesMissing.toLocaleString()
      : '—',
    detail: fewestMissingUpgrades?.name ?? '—',
    className: fewestMissingUpgrades?.className ?? '',
  },
];

const mplusWinnerData = {
  total: {
    value: topMplusTotal?.mythicPlusRunCount !== null && topMplusTotal?.mythicPlusRunCount !== undefined
      ? topMplusTotal.mythicPlusRunCount.toLocaleString()
      : '—',
    name: topMplusTotal?.name ?? '—',
    color: topMplusTotal?.className ? classColor(topMplusTotal.className) : '#d8e2e8',
  },
  current: {
    value: topMplusCurrent?.mythicPlusWeeklyRuns !== null && topMplusCurrent?.mythicPlusWeeklyRuns !== undefined
      ? topMplusCurrent.mythicPlusWeeklyRuns.toLocaleString()
      : '—',
    name: topMplusCurrent?.name ?? '—',
    color: topMplusCurrent?.className ? classColor(topMplusCurrent.className) : '#d8e2e8',
  },
  last: {
    value: topMplusLast?.mythicPlusPrevWeeklyRuns !== null && topMplusLast?.mythicPlusPrevWeeklyRuns !== undefined
      ? topMplusLast.mythicPlusPrevWeeklyRuns.toLocaleString()
      : '—',
    name: topMplusLast?.name ?? '—',
    color: topMplusLast?.className ? classColor(topMplusLast.className) : '#d8e2e8',
  },
};
---

<Layout title="The Hidden Lodge | Raiders" description="Guild-member view backed by cached Blizzard character-profile data for roster-team members.">
  <section>
    <h1 class="title-row"><Icon name="lucide:shield-user" class="title-icon" aria-hidden="true" />Raiders</h1>
  </section>

  <section class="spotlights" aria-label="Raiders snapshot">
    {spotlightCards.map(({ label, icon, value, detail, className }) => {
      const color = className ? classColor(className) : '#d8e2e8';
      return (
        <article class="spotlight-card">
          <header class="spotlight-header">
            <Icon name={icon} class="spotlight-icon" aria-hidden="true" />
            <span class="spotlight-label">{label}</span>
          </header>
          <p class="spotlight-value">{value}</p>
          <p class="spotlight-name" style={`color: ${color}`}>{detail}</p>
        </article>
      );
    })}

    <article
      class="spotlight-card"
      id="mplus-winner-card"
      data-total-value={mplusWinnerData.total.value}
      data-total-name={mplusWinnerData.total.name}
      data-total-color={mplusWinnerData.total.color}
      data-current-value={mplusWinnerData.current.value}
      data-current-name={mplusWinnerData.current.name}
      data-current-color={mplusWinnerData.current.color}
      data-last-value={mplusWinnerData.last.value}
      data-last-name={mplusWinnerData.last.name}
      data-last-color={mplusWinnerData.last.color}
    >
      <div class="mplus-winner-topline">
        <header class="spotlight-header">
          <Icon name="lucide:medal" class="spotlight-icon" aria-hidden="true" />
          <span class="spotlight-label">M+ Leader</span>
        </header>
        <select id="spotlight-mplus-select" class="spotlight-metric-select" aria-label="Select M plus winner metric">
          <option value="total">Total</option>
          <option value="current" selected>This Week</option>
          <option value="last">Last Week</option>
        </select>
      </div>
      <p class="spotlight-value" id="mplus-winner-value">{mplusWinnerData.current.value}</p>
      <p class="spotlight-name" id="mplus-winner-name" style={`color: ${mplusWinnerData.current.color}`}>{mplusWinnerData.current.name}</p>
    </article>

    <BlinkyWalker />
  </section>

  <section class="panel">
    <h2 class="title-row"><Icon name="lucide:list" class="title-icon" aria-hidden="true" />Roster Team Raiders ({sortedRaiders.length})</h2>
    <div class="controls" aria-label="Raiders controls">
      <label>
        Search
        <input id="raiders-search" type="search" placeholder="Character name..." autocomplete="off" />
      </label>
      <label>
        Class
        <select id="raiders-class-filter">
          <option value="all">All Classes</option>
          {classOptions.map((className) => <option value={className}>{className}</option>)}
        </select>
      </label>
      <label>
        Team
        <select id="raiders-team-filter">
          <option value="all">All Teams</option>
          {teamOptions.map((teamName) => <option value={teamName}>{teamName}</option>)}
        </select>
      </label>
    </div>

    <div class="table-wrap">
      <div class="pagination-controls">
        <label>
          Per page
          <select id="raiders-page-size">
            <option value="25" selected>25</option>
            <option value="50">50</option>
            <option value="100">100</option>
          </select>
        </label>
        <button id="raiders-prev-page" type="button">Prev</button>
        <span id="raiders-page-info">Page 1</span>
        <button id="raiders-next-page" type="button">Next</button>
        <p id="raiders-count" class="results-count" aria-live="polite">Showing {sortedRaiders.length} raiders</p>
      </div>
      <div class="raiders-table-scroll">
      <table class="raiders-table" id="raiders-table">
        <thead>
          <tr>
            <th><button class="sort-btn" type="button" data-sort-key="name">Name</button></th>
            <th><button class="sort-btn" type="button" data-sort-key="class">Class</button></th>
            <th><button class="sort-btn" type="button" data-sort-key="equippedItemLevel">iLvl</button></th>
            <th><button class="sort-btn" type="button" data-sort-key="singleTargetDps">Sim DPS</button></th>
            <th><button class="sort-btn" type="button" data-sort-key="mythicScore">M+ Score</button></th>
            <th>
              <div class="metric-header">
                <select id="mplus-metric-select" class="metric-select" aria-label="Select which M plus metric to display">
                  <option value="total">M+ Total</option>
                  <option value="current" selected>M+ This Week</option>
                  <option value="last">M+ Last Week</option>
                </select>
                <button class="sort-btn metric-info-btn" type="button" data-sort-key="mplusMetric" data-tooltip="M+ metric column. Use the selector to switch between Total, This Week, and Last Week values; sorting follows the selected metric." aria-label="M plus metric column with selector for total, this week, and last week. Sorting follows the selected metric."><Icon name="lucide:info" class="col-help-icon" aria-hidden="true" /></button>
              </div>
            </th>
            <th><button class="sort-btn" type="button" data-sort-key="vaultScore" data-tooltip="Great Vault Score TL;DR: weighted weekly vault completion normalized to 100. It factors raid rewards, dungeon rewards, and world progress with emphasis on stronger slot outcomes. Click a raider name or score for the full formula details on their profile." aria-label="Great Vault Score. Weighted weekly vault completion normalized to 100. Click a raider name or score for full formula details on their profile.">Vault <Icon name="lucide:info" class="col-help-icon" aria-hidden="true" /></button></th>
            <th><button class="sort-btn" type="button" data-sort-key="crestSort" data-tooltip="Total crests across all types (Adventurer + Veteran + Champion + Hero + Myth). Hover a crest total in the table to see the color-coded type breakdown." aria-label="Crests total across all crest types. Hover a crest total in the table to see the color-coded type breakdown.">Crests <Icon name="lucide:info" class="col-help-icon" aria-hidden="true" /></button></th>
            <th><button class="sort-btn" type="button" data-sort-key="preparednessScore" data-tooltip="Preparedness = 2-week rolling average of (Socketed Gems + Enchanted Slots) / (Total Sockets + Enchantable Slots). Falls back to current snapshot until history accumulates. Tiers: S = 100%, A >= 85%, B >= 70%, C >= 40%, D < 40%." aria-label="Preparedness. Based on a 2-week rolling average of gem and enchant coverage. Formula: (Socketed Gems + Enchanted Slots) / (Total Sockets + Enchantable Slots). Tiers: S equals 100 percent, A 85 percent or higher, B 70 percent or higher, C 40 percent or higher, D below 40 percent.">Preparedness <Icon name="lucide:info" class="col-help-icon" aria-hidden="true" /></button></th>
            <th class="tooltip-priority-col"><button class="sort-btn" type="button" data-sort-key="attendanceScore" data-tooltip="Attendance score starts on 2026-04-02 and is based on signup intent versus Warcraft Logs boss kill participation, normalized per raid night (for example, 1 out of 1 and 6 out of 6 are both full credit). Wipes still count for no-show validation. Bench grants full credit plus bonus." data-tooltip-dir="right" aria-label="Attendance score since April second 2026 from signup intent and Warcraft Logs boss kill participation, normalized per raid night. One out of one and six out of six both grant full credit. Wipes still count for no-show validation. Bench grants full credit plus bonus.">Attendance <Icon name="lucide:info" class="col-help-icon" aria-hidden="true" /></button></th>
          </tr>
        </thead>
        <tbody>
          {sortedRaiders.map((raider) => {
            const color = classColor(raider.className);
            const teamList = raider.teamNames.join(', ');
            const isUnknownClass = raider.className.trim().toLowerCase() === 'unknown';
            const preparedness = preparednessTotals(raider);
            const preparednessTier = preparednessTierDisplay(preparedness.filled, preparedness.total);
            const vaultScore = greatVaultScoreForRaider(raider);
            return (
              <tr
                data-name={raider.name.toLowerCase()}
                data-class={raider.className}
                data-team={teamList}
                data-equipped-item-level={String(raider.equippedItemLevel ?? -1)}
                data-raid-progress-kills={String(raider.raidProgressKills ?? -1)}
                data-mythic-score={String(raider.mythicScore ?? -1)}
                data-attendance-score={String(raider.attendanceScorePercent ?? -1)}
                data-mythic-plus-run-count={String(raider.mythicPlusRunCount ?? -1)}
                data-mythic-plus-weekly-runs={String(raider.mythicPlusWeeklyRuns ?? -1)}
                data-mythic-plus-prev-weekly-runs={String(raider.mythicPlusPrevWeeklyRuns ?? -1)}
                data-single-target-dps={String(raider.singleTargetDps ?? -1)}
                data-tier-pieces-equipped={String(raider.tierPiecesEquipped ?? -1)}
                data-crest-sort={String(crestSortValue(raider))}
                data-total-upgrades-missing={String(raider.totalUpgradesMissing ?? -1)}
                data-preparedness-score={String(preparednessSortValue(raider))}
                data-vault-score={String(vaultScore.score)}
                data-href={`/raiders/${raider.blizzardCharId}`}
                class="clickable-row"
              >
                <td><a href={`/raiders/${raider.blizzardCharId}`} class="name-link"><span class="name-pill" style={`--class-color: ${color}`}>{raider.name}</span></a></td>
                <td>
                  {isUnknownClass ? (
                    <span class="class-icon-wrap" aria-hidden="true"></span>
                  ) : (
                    <span class="class-icon-wrap" title={raider.className} aria-label={raider.className}>
                      {raider.classIconUrl ? (
                        <img
                          src={raider.classIconUrl}
                          alt={raider.className}
                          loading="lazy"
                          decoding="async"
                          class="class-icon-img"
                        />
                      ) : (
                        <span
                          class="class-icon"
                          style={`--class-color: ${color}`}
                          aria-hidden="true"
                        >
                          {classAbbrev(raider.className)}
                        </span>
                      )}
                    </span>
                  )}
                </td>
                <td>
                  <div class="ilvl-cell">
                    <span class="ilvl-main" style={`color: ${ilvlColor(raider.equippedItemLevel)}`}>
                      {raider.equippedItemLevel ?? '—'}
                    </span>
                  </div>
                </td>
                <td>{raider.singleTargetDps ? raider.singleTargetDps.toLocaleString(undefined, { maximumFractionDigits: 0 }) : '—'}</td>
                <td>{raider.mythicScore ? raider.mythicScore.toLocaleString(undefined, { maximumFractionDigits: 0 }) : '—'}</td>
                <td class="mplus-cell" data-mplus-cell>{raider.mythicPlusWeeklyRuns !== null ? raider.mythicPlusWeeklyRuns.toLocaleString() : '—'}</td>
                <td>
                  <a href={`/raiders/${raider.blizzardCharId}`} class="vault-score-link" title="View exact score formula and weighting details on profile">
                    <span class="score-val" style={`color: ${vaultScore.color}`}>{vaultScore.score}</span>
                  </a>
                </td>
                <td>
                  {crestTotalValue(raider) !== null ? (
                    <span
                      class="crest-total"
                      title={`Adventurer: ${raider.adventurerCrests ?? 0}, Veteran: ${raider.veteranCrests ?? 0}, Champion: ${raider.championCrests ?? 0}, Hero: ${raider.heroCrests ?? 0}, Myth: ${raider.mythCrests ?? 0}`}
                    >
                      {crestTotalValue(raider)}
                      <span class="crest-tooltip" role="tooltip" aria-hidden="true">
                        <span class="crest-token crest-token-a">A: {raider.adventurerCrests ?? 0}</span>
                        <span class="crest-token crest-token-v">V: {raider.veteranCrests ?? 0}</span>
                        <span class="crest-token crest-token-c">C: {raider.championCrests ?? 0}</span>
                        <span class="crest-token crest-token-h">H: {raider.heroCrests ?? 0}</span>
                        <span class="crest-token crest-token-m">M: {raider.mythCrests ?? 0}</span>
                      </span>
                    </span>
                  ) : (
                    '—'
                  )}
                </td>
                <td><span class="score-val" style={`color: ${preparednessTier.color}`}>{preparednessTier.label}</span></td>
                <td>
                  {raider.attendanceScorePercent !== null ? (
                    <span
                      class="score-val"
                      style={`color: ${attendanceColor(raider.attendanceScorePercent)}`}
                      title={`${raider.attendanceScoredRaids} scored raids since 2026-04-02${raider.attendanceBenchBonusPoints > 0 ? `, bench bonus +${raider.attendanceBenchBonusPoints.toFixed(1)} points` : ''}`}
                    >
                      {raider.attendanceScorePercent.toFixed(1)}
                    </span>
                  ) : (
                    '—'
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
      </div>
    </div>
    <p class="mplus-metric-note">
      M+ values are best-effort estimates from Blizzard and Raider.IO APIs. Weekly values can undercount when profile run history is capped.
      See
      <a href="https://support.raider.io/kb/frequently-asked-questions/how-does-the-mythic-plus-leaderboard-slash-api-capacity-work" target="_blank" rel="noopener noreferrer">Raider.IO API capacity FAQ</a>.
    </p>
  </section>
</Layout>

<script>
  const pageSizeSelect = document.getElementById('raiders-page-size') as unknown as HTMLSelectElement | null;
  const prevPageBtn = document.querySelector<HTMLButtonElement>('#raiders-prev-page');
  const nextPageBtn = document.querySelector<HTMLButtonElement>('#raiders-next-page');
  const pageInfo = document.querySelector<HTMLSpanElement>('#raiders-page-info');

  let currentPage = 1;
  let pageSize = 25;

  const searchInput = document.querySelector<HTMLInputElement>('#raiders-search');
  const classFilter = document.getElementById('raiders-class-filter') as unknown as HTMLSelectElement | null;
  const teamFilter = document.getElementById('raiders-team-filter') as unknown as HTMLSelectElement | null;
  const mplusMetricSelect = document.getElementById('mplus-metric-select') as unknown as HTMLSelectElement | null;
  const mplusWinnerSelect = document.getElementById('spotlight-mplus-select') as unknown as HTMLSelectElement | null;
  const mplusWinnerCard = document.getElementById('mplus-winner-card') as HTMLElement | null;
  const mplusWinnerValue = document.getElementById('mplus-winner-value') as HTMLParagraphElement | null;
  const mplusWinnerName = document.getElementById('mplus-winner-name') as HTMLParagraphElement | null;
  const countLabel = document.querySelector<HTMLParagraphElement>('#raiders-count');
  const table = document.querySelector<HTMLTableElement>('#raiders-table');
  const tableBody = table?.querySelector('tbody');
  const sortButtons = [...document.querySelectorAll<HTMLButtonElement>('.sort-btn')];

  let sortKey = 'equippedItemLevel';
  let sortDirection = 'desc';
  let mplusMetric: 'total' | 'current' | 'last' = 'current';

  const compareText = (a: string, b: string) => a.localeCompare(b, undefined, { sensitivity: 'base' });

  function getMplusDatasetKey(): 'mythicPlusRunCount' | 'mythicPlusWeeklyRuns' | 'mythicPlusPrevWeeklyRuns' {
    if (mplusMetric === 'current') return 'mythicPlusWeeklyRuns';
    if (mplusMetric === 'last') return 'mythicPlusPrevWeeklyRuns';
    return 'mythicPlusRunCount';
  }

  function formatMplusValue(value: number): string {
    return value >= 0 ? value.toLocaleString() : '—';
  }

  function syncMplusWinnerCard() {
    if (!mplusWinnerCard || !mplusWinnerValue || !mplusWinnerName) return;

    const prefix = mplusMetric;
    const value = mplusWinnerCard.dataset[`${prefix}Value`] ?? '—';
    const name = mplusWinnerCard.dataset[`${prefix}Name`] ?? '—';
    const color = mplusWinnerCard.dataset[`${prefix}Color`] ?? '#d8e2e8';

    mplusWinnerValue.textContent = value;
    mplusWinnerName.textContent = name;
    mplusWinnerName.style.color = color;
  }

  function syncMplusSelectors() {
    if (mplusMetricSelect) mplusMetricSelect.value = mplusMetric;
    if (mplusWinnerSelect) mplusWinnerSelect.value = mplusMetric;
  }

  function setMplusMetric(nextMetric: string) {
    mplusMetric = nextMetric === 'current' || nextMetric === 'last' ? nextMetric : 'total';
    currentPage = 1;
    syncMplusSelectors();
    syncMplusWinnerCard();
    applyFiltersAndSort();
  }

  function syncMplusCells() {
    if (!tableBody) return;
    const metricKey = getMplusDatasetKey();
    const rows = [...tableBody.querySelectorAll('tr')];

    rows.forEach((row) => {
      const cell = row.querySelector<HTMLElement>('[data-mplus-cell]');
      if (!cell) return;
      const metricValue = Number(row.dataset[metricKey] ?? -1);
      cell.textContent = formatMplusValue(metricValue);
    });
  }

  function applyFiltersAndSort() {
    if (!tableBody) return;

    syncMplusCells();

    const query = searchInput?.value.trim().toLowerCase() ?? '';
    const selectedClass = classFilter?.value ?? 'all';
    const selectedTeam = teamFilter?.value ?? 'all';

    const rows = [...tableBody.querySelectorAll('tr')];
    const visibleRows = rows.filter((row) => {
      const rowName = row.dataset.name ?? '';
      const rowClass = row.dataset.class ?? '';
      const rowTeam = row.dataset.team ?? '';

      const matchesSearch = query.length === 0 || rowName.includes(query);
      const matchesClass = selectedClass === 'all' || rowClass === selectedClass;
      const matchesTeam = selectedTeam === 'all' || rowTeam.split(',').map((value) => value.trim()).includes(selectedTeam);

      return matchesSearch && matchesClass && matchesTeam;
    });

    const numericKeys = new Set(['equippedItemLevel', 'raidProgressKills', 'mythicScore', 'attendanceScore', 'singleTargetDps', 'vaultScore', 'crestSort', 'preparednessScore']);

    visibleRows.sort((rowA, rowB) => {
      if (sortKey === 'mplusMetric') {
        const metricKey = getMplusDatasetKey();
        const valueA = Number(rowA.dataset[metricKey] ?? -1);
        const valueB = Number(rowB.dataset[metricKey] ?? -1);
        const order = valueA - valueB;
        return sortDirection === 'asc' ? order : order * -1;
      }

      const toAttr = (key: string) => key.replace(/[A-Z]/g, (char) => `-${char.toLowerCase()}`);
      const valueA = rowA.dataset[toAttr(sortKey)] ?? rowA.dataset[sortKey] ?? '';
      const valueB = rowB.dataset[toAttr(sortKey)] ?? rowB.dataset[sortKey] ?? '';

      const order = numericKeys.has(sortKey)
        ? Number(valueA) - Number(valueB)
        : compareText(valueA, valueB);

      return sortDirection === 'asc' ? order : order * -1;
    });

    const totalPages = Math.max(1, Math.ceil(visibleRows.length / pageSize));
    if (currentPage > totalPages) currentPage = totalPages;
    const startIdx = (currentPage - 1) * pageSize;
    const pageRows = visibleRows.slice(startIdx, startIdx + pageSize);

    rows.forEach((row) => {
      row.hidden = !pageRows.includes(row);
    });

    visibleRows.forEach((row) => tableBody.appendChild(row));

    if (pageInfo) pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
    if (prevPageBtn) prevPageBtn.disabled = currentPage <= 1;
    if (nextPageBtn) nextPageBtn.disabled = currentPage >= totalPages;
    if (countLabel) {
      countLabel.textContent = `Showing ${visibleRows.length} raider${visibleRows.length === 1 ? '' : 's'} (page ${currentPage})`;
    }

    sortButtons.forEach((button) => {
      const isActive = button.dataset.sortKey === sortKey;
      button.setAttribute('aria-sort', isActive ? sortDirection : 'none');
    });
  }

  pageSizeSelect?.addEventListener('change', () => {
    pageSize = Number(pageSizeSelect.value) || 25;
    currentPage = 1;
    applyFiltersAndSort();
  });

  prevPageBtn?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage -= 1;
      applyFiltersAndSort();
    }
  });

  nextPageBtn?.addEventListener('click', () => {
    currentPage += 1;
    applyFiltersAndSort();
  });

  searchInput?.addEventListener('input', () => {
    currentPage = 1;
    applyFiltersAndSort();
  });
  classFilter?.addEventListener('change', () => {
    currentPage = 1;
    applyFiltersAndSort();
  });
  teamFilter?.addEventListener('change', () => {
    currentPage = 1;
    applyFiltersAndSort();
  });

  mplusMetricSelect?.addEventListener('change', () => {
    setMplusMetric(mplusMetricSelect.value);
  });

  mplusWinnerSelect?.addEventListener('change', () => {
    setMplusMetric(mplusWinnerSelect.value);
  });

  sortButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const nextKey = button.dataset.sortKey;
      if (!nextKey) return;

      if (nextKey === sortKey) {
        sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
      } else {
        sortKey = nextKey;
        sortDirection = nextKey === 'name' || nextKey === 'class' ? 'asc' : 'desc';
      }

      applyFiltersAndSort();
    });
  });

  syncMplusSelectors();
  syncMplusWinnerCard();
  applyFiltersAndSort();

  // Make entire rows clickable, but let clicks on existing links/buttons pass through
  tableBody?.addEventListener('click', (event) => {
    const target = event.target as HTMLElement;
    if (target.closest('a, button')) return;
    const row = target.closest<HTMLTableRowElement>('tr[data-href]');
    if (!row?.dataset.href) return;
    window.location.href = row.dataset.href;
  });
</script>

