---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { classColor, factionColor } from '../lib/wow';
import { getSupportedTimeZones, resolveUserTimeZone } from '../lib/time-zones';
import { env } from 'cloudflare:workers';

const user = Astro.locals.user;
if (!user) {
	return Astro.redirect('/auth/login');
}

interface CharacterRow {
	id: number;
	name: string;
	realm: string;
	class_name: string;
	race_name: string;
	faction: string;
	level: number;
	is_main: number;
}

const [settingsResult, charsResult] = await env.DB.batch([
	env.DB.prepare('SELECT time_zone, time_zone_set, nickname, preferred_role FROM users WHERE id = ?').bind(user.id),
	env.DB.prepare(
		'SELECT id, name, realm, class_name, race_name, faction, level, is_main FROM characters WHERE user_id = ? ORDER BY level DESC, name ASC'
	).bind(user.id),
]);

const settings = settingsResult.results?.[0] as { time_zone?: string; time_zone_set?: number; nickname?: string | null; preferred_role?: string | null } | undefined;
const userTimeZone = resolveUserTimeZone(settings);
const userNickname = settings?.nickname ?? null;
const userPreferredRole = settings?.preferred_role ?? null;
const characters: CharacterRow[] = (charsResult.results ?? []) as CharacterRow[];
const mainChar = characters.find((c) => c.is_main === 1) ?? null;
const statusParam = new URL(Astro.request.url).searchParams.get('status');

const timezoneOptions = getSupportedTimeZones();
---

<Layout title="My Profile | The Hidden Lodge">
	<div class="profile-page">
		<header class="profile-header">
			<div class="profile-avatar" aria-hidden="true">
				{user.battleTag.charAt(0).toUpperCase()}
			</div>
			<div class="profile-identity">
				<h1 class="battle-tag">{user.battleTag}</h1>
				{
					mainChar && (
						<p class="main-summary">
							Main:{' '}
							<span style={`color: ${classColor(mainChar.class_name)}`}>
								{mainChar.name}
							</span>
							&nbsp;&mdash;&nbsp;{mainChar.class_name} &middot; {mainChar.realm}
						</p>
					)
				}
			</div>
			<div class="profile-actions">
				<a href="/auth/login" class="refresh-btn">Refresh Blizzard Account Data</a>
				<a href="/auth/logout" class="logout-btn">Log Out</a>
			</div>
		</header>

		<div class="settings-row">
		<section class="nickname-section" aria-labelledby="nickname-heading">
			<div class="section-title-row">
				<h2 id="nickname-heading">Nickname</h2>
			</div>
			{statusParam === 'nickname-updated' && (
				<p class="flash-ok" role="status">Nickname saved.</p>
			)}
			{statusParam === 'nickname-error' && (
				<p class="flash-error" role="alert">Nickname must be 48 characters or fewer.</p>
			)}
			<form method="POST" action="/api/profile/update-nickname" class="nickname-form">
				<label>
					<span>{userNickname ? 'Your nickname:' : 'No nickname set.'}</span>
					<input
						type="text"
						name="nickname"
						value={userNickname ?? ''}
						maxlength="48"
						placeholder="Enter a nickname…"
						autocomplete="off"
						spellcheck="false"
					/>
				</label>
				<button type="submit" class="set-main-btn">
					{userNickname ? 'Update Nickname' : 'Set Nickname'}
				</button>
			</form>
			<small class="setting-help">Displayed instead of your Battle Tag on the signup sheet and roster. Leave blank to use your Battle Tag.</small>
		</section>

		<section class="role-section" aria-labelledby="role-heading">
			<div class="section-title-row">
				<h2 id="role-heading">Preferred Role</h2>
			</div>
			{statusParam === 'role-updated' && (
				<p class="flash-ok" role="status">Preferred role saved.</p>
			)}
			{statusParam === 'role-error' && (
				<p class="flash-error" role="alert">Invalid role selection.</p>
			)}
			<form method="POST" action="/api/profile/update-role" class="role-form">
				<label>
					<span>Default role when signing up for raids:</span>
					<select name="preferred_role" required>
						<option value="tank" selected={userPreferredRole === 'tank'}>Tank</option>
						<option value="healer" selected={userPreferredRole === 'healer'}>Healer</option>
						<option value="melee-dps" selected={userPreferredRole === 'melee-dps'}>Melee DPS</option>
						<option value="ranged-dps" selected={userPreferredRole === 'ranged-dps' || userPreferredRole === null}>Ranged DPS</option>
					</select>
				</label>
				<button type="submit" class="set-main-btn">Save Role</button>
			</form>
			<small class="setting-help">Pre-selects your role when signing up for a raid. You can still change it per signup.</small>
		</section>
	</div>

	<section class="timezone-section" aria-labelledby="timezone-heading">
			<div class="section-title-row">
				<h2 id="timezone-heading">Time Zone</h2>
			</div>
			{statusParam === 'timezone-updated' && (
				<p class="flash-ok" role="status">Time zone saved.</p>
			)}
			{statusParam === 'timezone-error' && (
				<p class="flash-error" role="alert">Could not save time zone. Please try again.</p>
			)}
			<form method="POST" action="/api/profile/update-timezone" class="timezone-form">
				<label>
					<span>Display raid times in:</span>
					<input
						type="search"
						id="timezone-search"
						autocomplete="off"
						spellcheck="false"
						placeholder="Search time zones..."
					/>
					<input
						type="hidden"
						id="timezone-selected"
						value={userTimeZone}
					/>
					<select id="timezone-select" name="time_zone" required>
						{timezoneOptions.map((tz) => (
							<option value={tz} selected={tz === userTimeZone}>{tz}</option>
						))}
					</select>
				</label>
				<button type="submit" class="set-main-btn">Save Time Zone</button>
				<small class="setting-help">Type to filter, then pick from the dropdown list.</small>
			</form>
		</section>

		<section class="characters-section" aria-labelledby="chars-heading">
			<div class="section-title-row">
				<h2 id="chars-heading">Your Characters</h2>
				<span class="char-count">{characters.length} character{characters.length !== 1 ? 's' : ''}</span>
			</div>

			{
				characters.length === 0 ? (
					<p class="empty-state">
						No characters found. Make sure your Battle.net account has WoW characters and try logging
						out and back in to refresh.
					</p>
				) : (
					<ul class="char-list">
						{characters.map((char) => (
							<li
								class:list={['char-card', { 'is-main': char.is_main === 1 }]}
								style={`--faction-bg: ${factionColor(char.faction)}`}
							>
								<div class="char-info">
									<span
										class="char-name"
										style={`color: ${classColor(char.class_name)}`}
									>
										{char.name}
										{char.is_main === 1 && <span class="main-badge">MAIN</span>}
									</span>
									<span class="char-meta">
										{char.race_name} {char.class_name} &middot; Level {char.level} &middot;{' '}
										{char.realm}
									</span>
									<span
										class:list={[
											'faction-tag',
											char.faction === 'Alliance' ? 'alliance' : 'horde',
										]}
									>
										{char.faction}
									</span>
								</div>
								{char.is_main !== 1 && (
									<form method="POST" action="/api/set-main" class="set-main-form">
										<input type="hidden" name="character_id" value={char.id} />
										<button type="submit" class="set-main-btn">Set as Main</button>
									</form>
								)}
							</li>
						))}
					</ul>
				)
			}
		</section>
	</div>
</Layout>

<style>
	.profile-page {
		padding-block: 2rem;
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	/* ── Header ───────────────────────────────────────────────── */
	.profile-header {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		padding: 1.5rem;
		background: var(--bg-panel);
		border: 1px solid var(--border);
		border-radius: 0.5rem;
	}

	.profile-avatar {
		width: 3.5rem;
		height: 3.5rem;
		border-radius: 50%;
		background: linear-gradient(135deg, var(--gold), var(--steel));
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-display);
		font-size: 1.5rem;
		color: var(--bg);
		font-weight: 700;
		flex-shrink: 0;
	}

	.profile-identity {
		flex: 1;
	}

	.battle-tag {
		font-family: var(--font-display);
		font-size: 1.4rem;
		color: var(--gold-bright);
		margin: 0 0 0.25rem;
	}

	.main-summary {
		margin: 0;
		color: var(--muted);
		font-size: 0.95rem;
	}

	.logout-btn {
		font-family: var(--font-body);
		font-size: 0.85rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding: 0.45rem 1rem;
		border: 1px solid var(--border);
		border-radius: 0.25rem;
		color: var(--muted);
		transition: color 0.15s, border-color 0.15s;
	}

	.profile-actions {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.refresh-btn {
		font-family: var(--font-body);
		font-size: 0.8rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		padding: 0.42rem 0.8rem;
		border: 1px solid rgba(214, 176, 106, 0.55);
		border-radius: 0.25rem;
		color: #f3e2be;
		background: rgba(214, 176, 106, 0.1);
		transition: background 0.15s, border-color 0.15s, color 0.15s;
	}

	.refresh-btn:hover {
		background: rgba(214, 176, 106, 0.2);
		border-color: rgba(214, 176, 106, 0.8);
		color: #fff3d5;
	}

	.logout-btn:hover {
		color: var(--text);
		border-color: var(--gold);
	}

	/* ── Characters section ────────────────────────────────────── */
	.section-title-row {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.section-title-row h2 {
		font-family: var(--font-display);
		font-size: 1.1rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--gold);
		margin: 0;
	}

	.char-count {
		font-size: 0.8rem;
		color: var(--muted);
	}

	.empty-state {
		color: var(--muted);
		font-style: italic;
	}

	.char-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.settings-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	@media (max-width: 640px) {
		.settings-row {
			grid-template-columns: 1fr;
		}
	}

	.nickname-section {
		background: var(--bg-panel);
		border: 1px solid var(--border);
		border-radius: 0.5rem;
		padding: 1rem;
	}

	.nickname-form {
		display: flex;
		align-items: flex-end;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.nickname-form label {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		color: var(--muted);
	}

	.nickname-form input[type='text'] {
		background: rgba(9, 18, 28, 0.92);
		color: var(--text);
		border: 1px solid var(--border);
		border-radius: 0.3rem;
		padding: 0.4rem 0.6rem;
		min-width: 20rem;
	}

	.role-section {
		background: var(--bg-panel);
		border: 1px solid var(--border);
		border-radius: 0.5rem;
		padding: 1rem;
	}

	.role-form {
		display: flex;
		align-items: flex-end;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.role-form label {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		color: var(--muted);
	}

	.role-form select {
		background: rgba(9, 18, 28, 0.92);
		color: var(--text);
		border: 1px solid var(--border);
		border-radius: 0.3rem;
		padding: 0.4rem 0.6rem;
		min-width: 12rem;
	}

	.timezone-section {
		background: var(--bg-panel);
		border: 1px solid var(--border);
		border-radius: 0.5rem;
		padding: 1rem;
	}

	.timezone-form {
		display: flex;
		align-items: flex-end;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.timezone-form label {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		color: var(--muted);
	}

	.timezone-form input[type='search'],
	.timezone-form select {
		background: rgba(9, 18, 28, 0.92);
		color: var(--text);
		border: 1px solid var(--border);
		border-radius: 0.3rem;
		padding: 0.4rem 0.6rem;
		min-width: 20rem;
	}

	.setting-help {
		flex-basis: 100%;
		margin-top: -0.2rem;
		color: var(--muted);
		font-size: 0.75rem;
	}

	.timezone-form select {
		max-height: 16rem;
	}

	.flash-ok {
		margin: 0 0 0.6rem;
		color: #73dd9a;
	}

	.flash-error {
		margin: 0 0 0.6rem;
		color: #f49797;
	}

	/* ── Character card ────────────────────────────────────────── */
	.char-card {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.75rem 1rem;
		background: var(--bg-panel);
		border: 1px solid var(--border);
		border-left: 3px solid var(--faction-bg, transparent);
		border-radius: 0.375rem;
		transition: border-color 0.15s;
	}

	.char-card.is-main {
		border-color: var(--gold);
		border-left-color: var(--gold);
		background: rgba(214, 176, 106, 0.06);
	}

	.char-info {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.char-name {
		font-family: var(--font-display);
		font-size: 1rem;
		font-weight: 700;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.main-badge {
		font-size: 0.6rem;
		font-family: var(--font-body);
		letter-spacing: 0.1em;
		background: var(--gold);
		color: var(--bg);
		padding: 0.15em 0.5em;
		border-radius: 0.2rem;
		font-weight: 700;
		vertical-align: middle;
	}

	.char-meta {
		font-size: 0.85rem;
		color: var(--muted);
	}

	.faction-tag {
		font-size: 0.7rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		padding: 0.1em 0.45em;
		border-radius: 0.2rem;
		font-weight: 600;
		width: fit-content;
	}

	.faction-tag.alliance {
		background: rgba(26, 74, 138, 0.45);
		color: #90b8e8;
		border: 1px solid rgba(26, 74, 138, 0.6);
	}

	.faction-tag.horde {
		background: rgba(122, 26, 26, 0.45);
		color: #e89090;
		border: 1px solid rgba(122, 26, 26, 0.6);
	}

	/* ── Set Main button ───────────────────────────────────────── */
	.set-main-form {
		flex-shrink: 0;
	}

	.set-main-btn {
		font-family: var(--font-body);
		font-size: 0.8rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding: 0.4rem 0.9rem;
		background: transparent;
		border: 1px solid var(--border);
		border-radius: 0.25rem;
		color: var(--muted);
		cursor: pointer;
		transition: color 0.15s, border-color 0.15s, background 0.15s;
	}

	.set-main-btn:hover {
		color: var(--bg);
		background: var(--gold);
		border-color: var(--gold);
	}

	@media (max-width: 520px) {
		.profile-header {
			flex-wrap: wrap;
		}

		.char-card {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>

<script>
	const tzSearch = document.getElementById('timezone-search');
	const tzSelect = document.getElementById('timezone-select');
	const tzSelected = document.getElementById('timezone-selected');

	if (tzSearch instanceof HTMLInputElement && tzSelect instanceof HTMLSelectElement) {
		const allTimeZones = Array.from(tzSelect.options).map((option) => option.value);
		let currentValue = tzSelected instanceof HTMLInputElement ? tzSelected.value : 'UTC';

		const renderOptions = (query: string) => {
			const normalizedQuery = query.trim().toLowerCase();
			const filtered = normalizedQuery
				? allTimeZones.filter((zone) => zone.toLowerCase().includes(normalizedQuery))
				: allTimeZones;

			tzSelect.innerHTML = '';
			for (const zone of filtered) {
				const option = document.createElement('option');
				option.value = zone;
				option.textContent = zone;
				if (zone === currentValue) {
					option.selected = true;
				}
				tzSelect.appendChild(option);
			}

			if (tzSelect.options.length === 0) {
				const emptyOption = document.createElement('option');
				emptyOption.value = '';
				emptyOption.textContent = 'No matches';
				emptyOption.disabled = true;
				emptyOption.selected = true;
				tzSelect.appendChild(emptyOption);
			} else if (![...tzSelect.options].some((opt) => opt.selected)) {
				tzSelect.selectedIndex = 0;
				currentValue = tzSelect.value;
			}
		};

		renderOptions('');
		tzSelect.addEventListener('change', () => {
			currentValue = tzSelect.value;
		});
		tzSearch.addEventListener('input', () => renderOptions(tzSearch.value));
	}
</script>
