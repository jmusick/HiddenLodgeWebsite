---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { Icon } from 'astro-icon/components';
import { classColor } from '../../lib/wow';
import {
  ASSIGNED_ROLES,
  allRaidBuffs,
  computeTeamSummary,
  primaryRaidBuff,
  raidBuffDescription,
  tokenArmorType,
  type AssignedRole,
  type TeamMode,
} from '../../lib/raid-teams';

if (!Astro.locals.isAdmin) {
  return Astro.redirect('/');
}

interface TeamRow {
  id: number;
  name: string;
  raid_mode: TeamMode;
  sort_order: number;
}

interface TeamMemberRow {
  team_id: number;
  blizzard_char_id: number;
  assigned_role: AssignedRole;
  name: string;
  nickname: string | null;
  main_character_name: string | null;
  is_alt_of_main: number;
  realm: string;
  class_name: string;
  rank: number;
  is_authenticated: number;
}

interface AvailableMemberRow {
  blizzard_char_id: number;
  name: string;
  nickname: string | null;
  main_character_name: string | null;
  is_alt_of_main: number;
  realm: string;
  class_name: string;
  rank: number;
  level: number;
  is_authenticated: number;
}

const [teamsResult, membersResult, availableResult] = await env.DB.batch([
  env.DB.prepare(
    `SELECT id, name, raid_mode, sort_order
     FROM raid_teams
     WHERE is_archived = 0
     ORDER BY sort_order ASC, name ASC`
  ),
  env.DB.prepare(
    `SELECT
       rtm.team_id,
       rtm.blizzard_char_id,
       rtm.assigned_role,
       rmc.name,
       (
         SELECT u.nickname
         FROM characters c
         JOIN users u ON u.id = c.user_id
         WHERE c.blizzard_char_id = rtm.blizzard_char_id
           AND u.nickname IS NOT NULL
         LIMIT 1
       ) AS nickname,
       (
         SELECT c_main.name
         FROM characters c_self
         JOIN characters c_main ON c_main.user_id = c_self.user_id AND c_main.is_main = 1
         WHERE c_self.blizzard_char_id = rtm.blizzard_char_id
           AND c_main.blizzard_char_id != c_self.blizzard_char_id
         LIMIT 1
       ) AS main_character_name,
       CASE
         WHEN EXISTS (
           SELECT 1
           FROM characters c_self
           JOIN characters c_main ON c_main.user_id = c_self.user_id AND c_main.is_main = 1
           WHERE c_self.blizzard_char_id = rtm.blizzard_char_id
             AND c_main.blizzard_char_id != c_self.blizzard_char_id
         )
         THEN 1 ELSE 0
       END AS is_alt_of_main,
       rmc.realm,
       rmc.class_name,
       rmc.rank,
       CASE
         WHEN EXISTS (SELECT 1 FROM characters c WHERE c.blizzard_char_id = rtm.blizzard_char_id)
         THEN 1 ELSE 0
       END AS is_authenticated
     FROM raid_team_members rtm
     JOIN roster_members_cache rmc ON rmc.blizzard_char_id = rtm.blizzard_char_id
     ORDER BY
       rtm.team_id,
       CASE rtm.assigned_role
         WHEN 'tank' THEN 1
         WHEN 'healer' THEN 2
         WHEN 'melee-dps' THEN 3
         ELSE 4
       END,
       rmc.class_name ASC,
       rmc.name ASC`
  ),
  env.DB.prepare(
    `SELECT
       rmc.blizzard_char_id,
       rmc.name,
       (
         SELECT u.nickname
         FROM characters c
         JOIN users u ON u.id = c.user_id
         WHERE c.blizzard_char_id = rmc.blizzard_char_id
           AND u.nickname IS NOT NULL
         LIMIT 1
       ) AS nickname,
       (
         SELECT c_main.name
         FROM characters c_self
         JOIN characters c_main ON c_main.user_id = c_self.user_id AND c_main.is_main = 1
         WHERE c_self.blizzard_char_id = rmc.blizzard_char_id
           AND c_main.blizzard_char_id != c_self.blizzard_char_id
         LIMIT 1
       ) AS main_character_name,
       CASE
         WHEN EXISTS (
           SELECT 1
           FROM characters c_self
           JOIN characters c_main ON c_main.user_id = c_self.user_id AND c_main.is_main = 1
           WHERE c_self.blizzard_char_id = rmc.blizzard_char_id
             AND c_main.blizzard_char_id != c_self.blizzard_char_id
         )
         THEN 1 ELSE 0
       END AS is_alt_of_main,
       rmc.realm,
       rmc.class_name,
       rmc.rank,
       rmc.level,
       CASE
         WHEN EXISTS (SELECT 1 FROM characters c WHERE c.blizzard_char_id = rmc.blizzard_char_id)
         THEN 1 ELSE 0
       END AS is_authenticated
     FROM roster_members_cache rmc
     WHERE rmc.level = 90
     ORDER BY rmc.class_name ASC, rmc.name ASC`
  ),
]);

const teams = (teamsResult.results ?? []) as TeamRow[];
const allTeamMembers = (membersResult.results ?? []) as TeamMemberRow[];
const availableMembers = (availableResult.results ?? []) as AvailableMemberRow[];

const teamMembersByTeam = new Map<number, TeamMemberRow[]>();
for (const member of allTeamMembers) {
  const arr = teamMembersByTeam.get(member.team_id) ?? [];
  arr.push(member);
  teamMembersByTeam.set(member.team_id, arr);
}

const memberIdsByTeam = new Map<number, Set<number>>();
for (const team of teams) {
  const ids = new Set<number>();
  for (const member of teamMembersByTeam.get(team.id) ?? []) {
    ids.add(member.blizzard_char_id);
  }
  memberIdsByTeam.set(team.id, ids);
}

const classOptions = [...new Set(availableMembers.map((m) => m.class_name))].sort((a, b) => a.localeCompare(b));
const buffOptions = [...new Set(availableMembers.map((m) => primaryRaidBuff(m.class_name)))].sort((a, b) => a.localeCompare(b));

const statusParam = new URL(Astro.request.url).searchParams.get('status');
const openPickerTeamId = Number.parseInt(new URL(Astro.request.url).searchParams.get('open_picker') ?? '', 10);
const shouldKeepPickerOpen = Number.isInteger(openPickerTeamId) && openPickerTeamId > 0;
const statusMessages: Record<string, { type: 'ok' | 'error'; text: string }> = {
  'team-created': { type: 'ok', text: 'Team created.' },
  'team-updated': { type: 'ok', text: 'Team updated.' },
  'team-deleted': { type: 'ok', text: 'Team deleted.' },
  'member-added': { type: 'ok', text: 'Member added to team.' },
  'member-removed': { type: 'ok', text: 'Member removed from team.' },
  'member-updated': { type: 'ok', text: 'Member role updated.' },
  'must-be-90': { type: 'error', text: 'Only level 90 characters can be added.' },
  error: { type: 'error', text: 'Something went wrong. Please try again.' },
};
const flash = statusParam ? (statusMessages[statusParam] ?? null) : null;

const RANK_NAMES: Record<number, string> = {
  0: 'Guild Master',
  1: 'Guild Admin',
  2: 'Guild Officer',
  3: 'Officer Alt',
  4: 'Raider',
};

function rankLabel(rank: number): string {
  return RANK_NAMES[rank] ?? `Rank ${rank}`;
}

function roleLabel(role: AssignedRole): string {
  if (role === 'tank') return 'Tank';
  if (role === 'healer') return 'Healer';
  if (role === 'melee-dps') return 'Melee DPS';
  return 'Ranged DPS';
}
---

<AdminLayout title="Roster Teams | Admin | The Hidden Lodge">
  <div class="roster-teams-page">
    <div class="page-header">
      <div>
        <h1>Roster Teams</h1>
        <p class="page-desc">
          Build multiple raid rosters from level 90 guild members. Officers assign Tank, Healer, Melee DPS, or Ranged DPS when adding members.
          Team mode controls encounter rules only; roster sizes can exceed in-raid participant limits.
        </p>
      </div>
      <div class="stats">
        <span class="stat"><strong>{teams.length}</strong> active teams</span>
        <span class="stat"><strong>{availableMembers.length}</strong> level 90 candidates</span>
      </div>
    </div>

    {flash && (
      <div class:list={['flash', flash.type === 'ok' ? 'flash-ok' : 'flash-error']} role="alert">
        {flash.text}
      </div>
    )}

    <section class="add-team-section">
      <details class="panel" open={teams.length === 0}>
        <summary class="panel-summary">+ Create Team</summary>
        <form method="POST" action="/api/admin/roster-teams/create-team" class="team-form">
          <label class="field">
            <span>Team Name</span>
            <input type="text" name="name" maxlength="80" required placeholder="e.g. Mythic Main Team" />
          </label>
          <label class="field mode-field">
            <span>Mode</span>
            <select name="raid_mode" required>
              <option value="mythic" selected>Mythic</option>
              <option value="flex">Flex</option>
            </select>
          </label>
          <label class="field order-field">
            <span>Sort Order</span>
            <input type="number" name="sort_order" value="0" />
          </label>
          <button type="submit" class="btn btn-primary">Create Team</button>
        </form>
      </details>
    </section>

    {teams.length === 0 ? (
      <p class="empty-state">No roster teams yet. Create your first team above.</p>
    ) : (
      <div class="team-list">
        {teams.map((team) => {
          const members = teamMembersByTeam.get(team.id) ?? [];
          const summary = computeTeamSummary(
            members.map((m) => ({ className: m.class_name, assignedRole: m.assigned_role }))
          );
          const currentCount = members.length;
          const assignedIds = memberIdsByTeam.get(team.id) ?? new Set();
          const availableToAdd = availableMembers.filter((member) => !assignedIds.has(member.blizzard_char_id));

          return (
            <section class="team-card">
              <header class="team-header">
                <div>
                  <h2>{team.name}</h2>
                  <p class="team-subline">
                    {team.raid_mode === 'mythic' ? 'Mythic' : 'Flex'} mode
                    <span aria-hidden="true"> • </span>
                    {currentCount} member{currentCount === 1 ? '' : 's'}
                  </p>
                </div>
                <form
                  method="POST"
                  action="/api/admin/roster-teams/delete-team"
                  onsubmit={`return confirm('Delete team "${team.name}"?')`}
                >
                  <input type="hidden" name="id" value={team.id} />
                  <button type="submit" class="btn btn-danger">Delete Team</button>
                </form>
              </header>

              <details class="team-details" open>
                <summary class="team-details-summary">Team Details</summary>
                <div class="team-details-content">

              <details class="panel">
                <summary class="panel-summary">Edit Team Settings</summary>
                <form method="POST" action="/api/admin/roster-teams/update-team" class="team-form">
                  <input type="hidden" name="id" value={team.id} />
                  <label class="field">
                    <span>Team Name</span>
                    <input type="text" name="name" maxlength="80" required value={team.name} />
                  </label>
                  <label class="field mode-field">
                    <span>Mode</span>
                    <select name="raid_mode" required>
                      <option value="mythic" selected={team.raid_mode === 'mythic'}>Mythic</option>
                      <option value="flex" selected={team.raid_mode === 'flex'}>Flex</option>
                    </select>
                  </label>
                  <label class="field order-field">
                    <span>Sort Order</span>
                    <input type="number" name="sort_order" value={team.sort_order} />
                  </label>
                  <button type="submit" class="btn btn-primary">Save Team</button>
                </form>
              </details>

              <article class="summary-card role-strip-card">
                <h3>Role Count</h3>
                <ul class="role-strip" aria-label="Role counts">
                  <li>
                    <span class="role-chip-label"><Icon name="lucide:shield" aria-hidden="true" />Tank</span>
                    <strong>{summary.roleCounts.tank}</strong>
                  </li>
                  <li>
                    <span class="role-chip-label"><Icon name="lucide:heart-pulse" aria-hidden="true" />Healer</span>
                    <strong>{summary.roleCounts.healer}</strong>
                  </li>
                  <li>
                    <span class="role-chip-label"><Icon name="lucide:swords" aria-hidden="true" />Melee DPS</span>
                    <strong>{summary.roleCounts['melee-dps']}</strong>
                  </li>
                  <li>
                    <span class="role-chip-label"><Icon name="lucide:crosshair" aria-hidden="true" />Ranged DPS</span>
                    <strong>{summary.roleCounts['ranged-dps']}</strong>
                  </li>
                </ul>
              </article>

              <div class="summary-grid">
                <article class="summary-card">
                  <h3>Raid Buff Coverage</h3>
                  {summary.raidBuffs.length === 0 && summary.missingRaidBuffs.length === 0 ? (
                    <p class="muted">No tracked raid buffs yet.</p>
                  ) : (
                    <>
                      <ul class="pill-list coverage-list">
                        {summary.raidBuffCounts.map(({ buff, count }) => (
                          <li class="pill-available buff-tooltip" data-tooltip={raidBuffDescription(buff)} tabindex="0">
                            {buff}
                            <span class="pill-count">{count}</span>
                          </li>
                        ))}
                        {summary.missingRaidBuffs.map((buff) => (
                          <li class="pill-missing buff-tooltip" data-tooltip={raidBuffDescription(buff)} tabindex="0">
                            {buff}
                            <span class="pill-count">0</span>
                          </li>
                        ))}
                      </ul>
                    </>
                  )}
                </article>

                <article class="summary-card">
                  <h3>Class &amp; Token Distribution</h3>
                  <div class="distribution-grid">
                    <section>
                      <h4 class="distribution-title">Token Split</h4>
                      {summary.tokenDistribution.length === 0 ? (
                        <p class="muted">No token data yet.</p>
                      ) : (
                        <ul class="pill-list">
                          {summary.tokenDistribution.map((t) => (
                            <li>{t.token} ({tokenArmorType(t.token)}): {t.count}</li>
                          ))}
                        </ul>
                      )}
                    </section>
                    <section>
                      <h4 class="distribution-title">Class Distribution</h4>
                      {summary.classDistribution.length === 0 ? (
                        <p class="muted">No members assigned yet.</p>
                      ) : (
                        <ul class="pill-list">
                          {summary.classDistribution.map((cls) => (
                            <li>{cls.className}: {cls.count}</li>
                          ))}
                        </ul>
                      )}
                    </section>
                  </div>
                </article>
              </div>

              <div class="table-wrap">
                <h3 class="subheading">Assigned Members</h3>
                {members.length === 0 ? (
                  <p class="muted">No members assigned yet.</p>
                ) : (
                  <table class="data-table">
                    <thead>
                      <tr>
                        <th>Name</th>
                        <th>Class</th>
                        <th>Realm</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      {members.map((member) => (
                        <tr>
                          <td>
                            <strong style={`color: ${classColor(member.class_name)}`}>{member.name}</strong>
                            {member.is_authenticated === 1 && member.nickname && (
                              <span class="nickname-pill">{member.nickname}</span>
                            )}
                            <div class="tiny-meta">{rankLabel(member.rank)}</div>
                            {member.is_alt_of_main === 1 && member.main_character_name && (
                              <div class="alt-note">Alt of {member.main_character_name}</div>
                            )}
                          </td>
                          <td>{member.class_name}</td>
                          <td>{member.realm}</td>
                          <td>
                            <form method="POST" action="/api/admin/roster-teams/update-member-role" class="inline-form">
                              <input type="hidden" name="team_id" value={team.id} />
                              <input type="hidden" name="blizzard_char_id" value={member.blizzard_char_id} />
                              <select name="assigned_role" aria-label={`Role for ${member.name}`}>
                                {ASSIGNED_ROLES.map((role) => (
                                  <option value={role} selected={member.assigned_role === role}>{roleLabel(role)}</option>
                                ))}
                              </select>
                              <button type="submit" class="btn btn-secondary btn-sm">Save</button>
                            </form>
                          </td>
                          <td>
                            <span class:list={['status-pill', member.is_authenticated ? 'ok' : 'warn']}>
                              {member.is_authenticated ? 'Authenticated' : 'Not Logged In'}
                            </span>
                          </td>
                          <td>
                            <form method="POST" action="/api/admin/roster-teams/remove-member">
                              <input type="hidden" name="team_id" value={team.id} />
                              <input type="hidden" name="blizzard_char_id" value={member.blizzard_char_id} />
                              <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                            </form>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                )}
              </div>

              <details
                class="panel member-picker"
                data-team-id={String(team.id)}
                open={shouldKeepPickerOpen && openPickerTeamId === team.id}
              >
                <summary class="panel-summary">+ Add Level 90 Members</summary>

                <div class="picker-controls">
                  <label>
                    Search
                    <input type="search" class="picker-search" placeholder="Character name" autocomplete="off" />
                  </label>
                  <label>
                    Class
                    <select class="picker-class-filter">
                      <option value="all">All Classes</option>
                      {classOptions.map((className) => (
                        <option value={className}>{className}</option>
                      ))}
                    </select>
                  </label>
                  <label>
                    Raid Buff
                    <select class="picker-buff-filter">
                      <option value="all">All Buffs</option>
                      {buffOptions.map((buff) => (
                        <option value={buff}>{buff}</option>
                      ))}
                    </select>
                  </label>
                  <label>
                    Sort By
                    <select class="picker-sort">
                      <option value="name" selected>Name</option>
                      <option value="class">Class</option>
                      <option value="buff">Raid Buff</option>
                    </select>
                  </label>
                </div>

                <div class="table-wrap picker-table-wrap">
                  <table class="data-table picker-table">
                    <thead>
                      <tr>
                        <th>Name</th>
                        <th>Class</th>
                        <th>Raid Buffs</th>
                        <th>Status</th>
                        <th>Add to Team</th>
                      </tr>
                    </thead>
                    <tbody>
                      {availableToAdd.map((member) => {
                        const buffs = allRaidBuffs(member.class_name);
                        const primaryBuff = primaryRaidBuff(member.class_name);
                        return (
                          <tr
                            class="member-row"
                            data-name={member.name.toLowerCase()}
                            data-class={member.class_name}
                            data-buff={primaryBuff}
                          >
                            <td>
                              <strong style={`color: ${classColor(member.class_name)}`}>{member.name}</strong>
                              {member.is_authenticated === 1 && member.nickname && (
                                <span class="nickname-pill">{member.nickname}</span>
                              )}
                              <div class="tiny-meta">{member.realm} · {rankLabel(member.rank)}</div>
                              {member.is_alt_of_main === 1 && member.main_character_name && (
                                <div class="alt-note">Alt of {member.main_character_name}</div>
                              )}
                            </td>
                            <td>{member.class_name}</td>
                            <td>{buffs.length > 0 ? buffs.join(', ') : 'None'}</td>
                            <td>
                              <span class:list={['status-pill', member.is_authenticated ? 'ok' : 'warn']}>
                                {member.is_authenticated ? 'Authenticated' : 'Not Logged In'}
                              </span>
                            </td>
                            <td>
                              <form method="POST" action="/api/admin/roster-teams/add-member" class="inline-form">
                                <input type="hidden" name="team_id" value={team.id} />
                                <input type="hidden" name="blizzard_char_id" value={member.blizzard_char_id} />
                                <select name="assigned_role" aria-label={`Add role for ${member.name}`}>
                                  <option value="tank">Tank</option>
                                  <option value="healer">Healer</option>
                                  <option value="melee-dps">Melee DPS</option>
                                  <option value="ranged-dps" selected>Ranged DPS</option>
                                </select>
                                <button type="submit" class="btn btn-primary btn-sm">Add</button>
                              </form>
                            </td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                  {availableToAdd.length === 0 && (
                    <p class="muted">All level 90 candidates are already on this team.</p>
                  )}
                </div>
              </details>
                </div>
              </details>
            </section>
          );
        })}
      </div>
    )}
  </div>
</AdminLayout>

<script>
  // @ts-nocheck
  const pickers = [...document.querySelectorAll('.member-picker')];

  for (const picker of pickers) {
    const searchInput = picker.querySelector('.picker-search');
    const classFilter = picker.querySelector('.picker-class-filter');
    const buffFilter = picker.querySelector('.picker-buff-filter');
    const sortSelect = picker.querySelector('.picker-sort');
    const tableBody = picker.querySelector('tbody');

    if (
      !(searchInput instanceof HTMLInputElement) ||
      !(classFilter instanceof HTMLSelectElement) ||
      !(buffFilter instanceof HTMLSelectElement) ||
      !(sortSelect instanceof HTMLSelectElement) ||
      !(tableBody instanceof HTMLTableSectionElement)
    ) {
      continue;
    }

    const rows = [...tableBody.querySelectorAll('tr.member-row')];

    /** @param {string} a @param {string} b */
    const compareText = (a, b) => a.localeCompare(b, undefined, { sensitivity: 'base' });

    function applyFilterAndSort() {
      const query = searchInput.value.trim().toLowerCase();
      const classValue = classFilter.value;
      const buffValue = buffFilter.value;
      const sortKey = sortSelect.value;

      const visibleRows = [];
      const hiddenRows = [];

      for (const row of rows) {
        const rowName = row.getAttribute('data-name') || '';
        const rowClass = row.getAttribute('data-class') || '';
        const rowBuff = row.getAttribute('data-buff') || '';

        const matchesQuery = query.length === 0 || rowName.includes(query);
        const matchesClass = classValue === 'all' || rowClass === classValue;
        const matchesBuff = buffValue === 'all' || rowBuff === buffValue;

        if (matchesQuery && matchesClass && matchesBuff) {
          visibleRows.push(row);
        } else {
          hiddenRows.push(row);
        }
      }

      visibleRows.sort((a, b) => {
        const nameA = a.getAttribute('data-name') || '';
        const nameB = b.getAttribute('data-name') || '';
        const classA = a.getAttribute('data-class') || '';
        const classB = b.getAttribute('data-class') || '';
        const buffA = a.getAttribute('data-buff') || '';
        const buffB = b.getAttribute('data-buff') || '';

        if (sortKey === 'class') {
          return compareText(classA, classB) || compareText(nameA, nameB);
        }
        if (sortKey === 'buff') {
          return compareText(buffA, buffB) || compareText(nameA, nameB);
        }
        return compareText(nameA, nameB);
      });

      for (const row of visibleRows) {
        row.hidden = false;
        tableBody.appendChild(row);
      }
      for (const row of hiddenRows) {
        row.hidden = true;
        tableBody.appendChild(row);
      }
    }

    searchInput.addEventListener('input', applyFilterAndSort);
    classFilter.addEventListener('change', applyFilterAndSort);
    buffFilter.addEventListener('change', applyFilterAndSort);
    sortSelect.addEventListener('change', applyFilterAndSort);
    applyFilterAndSort();
  }
</script>

<style>
  .roster-teams-page {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .page-header h1 {
    margin: 0 0 0.35rem;
    font-size: 1.75rem;
    color: var(--gold-bright);
  }

  .page-desc {
    margin: 0;
    color: var(--muted);
    max-width: 70ch;
  }

  .stats {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .stat {
    border: 1px solid rgba(214, 176, 106, 0.35);
    border-radius: 999px;
    padding: 0.2rem 0.7rem;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .stat strong {
    color: var(--gold-bright);
  }

  .flash {
