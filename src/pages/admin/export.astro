---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';

if (!Astro.locals.isAdmin) {
	return Astro.redirect('/');
}

// --- Row types ---
interface GuildUserRow {
	user_id: number;
	battle_tag: string;
	nickname: string | null;
}

interface CharRow {
	user_id: number;
	name: string;
	realm: string;
	class_name: string;
	is_main: number;
	guild_rank: number | null;
}

const [usersResult, charsResult] = await env.DB.batch([
	env.DB.prepare(`
		SELECT DISTINCT u.id AS user_id, u.battle_tag, u.nickname
		FROM users u
		JOIN characters c ON c.user_id = u.id
		JOIN roster_members_cache rmc ON rmc.blizzard_char_id = c.blizzard_char_id
		ORDER BY u.battle_tag
	`),
	env.DB.prepare(`
		SELECT c.user_id, c.name, c.realm, c.class_name, c.is_main,
		       rmc.rank AS guild_rank
		FROM characters c
		JOIN (
		  SELECT DISTINCT ci.user_id FROM characters ci
		  JOIN roster_members_cache r ON r.blizzard_char_id = ci.blizzard_char_id
		) guild_users ON guild_users.user_id = c.user_id
		LEFT JOIN roster_members_cache rmc ON rmc.blizzard_char_id = c.blizzard_char_id
		ORDER BY c.user_id, c.is_main DESC, rmc.rank ASC, c.name ASC
	`),
]);

const guildUsers = (usersResult.results ?? []) as GuildUserRow[];
const allChars = (charsResult.results ?? []) as CharRow[];

const charsByUser = new Map<number, CharRow[]>();
for (const char of allChars) {
	const arr = charsByUser.get(char.user_id) ?? [];
	arr.push(char);
	charsByUser.set(char.user_id, arr);
}

// Build the export: one entry per guild roster character, keyed by character name.
// label = nickname (if set) || main character name || battle_tag
type ExportEntry = {
	character: string;
	realm: string;
	class: string;
	isMain: boolean;
	main: string | null;
	label: string;
	nickname: string | null;
};

const exportEntries: ExportEntry[] = [];

for (const user of guildUsers) {
	const chars = charsByUser.get(user.user_id) ?? [];
	const mainChar = chars.find((c) => c.is_main === 1) ?? null;
	const mainName = mainChar?.name ?? null;
	const label = user.nickname ?? mainName ?? user.battle_tag;

	for (const char of chars) {
		// Only include characters that are on the guild roster
		if (char.guild_rank === null) continue;

		exportEntries.push({
			character: char.name,
			realm: char.realm,
			class: char.class_name,
			isMain: char.is_main === 1,
			main: mainName,
			label,
			nickname: user.nickname,
		});
	}
}

// Sort: mains first, then by label, then by character name
exportEntries.sort((a, b) => {
	if (a.isMain !== b.isMain) return a.isMain ? -1 : 1;
	return a.label.localeCompare(b.label) || a.character.localeCompare(b.character);
});

const exportJson = JSON.stringify(exportEntries, null, 2);
const generatedAt = new Date().toISOString();
---

<AdminLayout title="Export | Admin | The Hidden Lodge">
	<div class="export-page">
		<div class="page-header">
			<div>
				<h1>Export</h1>
				<p class="page-desc">
					Character-to-label mapping for authenticated guild members.
					<strong>Label</strong> = nickname (if set) or the player's chosen main character name.
					Import this into the WoW addon to update guild notes.
				</p>
			</div>
			<div class="page-stats">
				<span class="stat"><strong>{exportEntries.length}</strong> characters</span>
				<span class="stat"><strong>{guildUsers.length}</strong> players</span>
			</div>
		</div>

		<div class="export-meta">
			Generated: <time datetime={generatedAt}>{generatedAt.replace('T', ' ').replace(/\.\d+Z$/, ' UTC')}</time>
		</div>

		<div class="export-actions">
			<button id="btn-copy" class="btn-action">Copy JSON</button>
			<button id="btn-download" class="btn-action btn-secondary">Download .json</button>
		</div>

		<div class="export-summary">
			{exportEntries.filter(e => e.isMain).map(e => (
				<div class="summary-row">
					<span class="char-name">{e.character}</span>
					<span class="realm-name">{e.realm}</span>
					<span class="arrow">→</span>
					<span class="label-value" class:list={[{ 'has-nickname': e.nickname !== null }]}>
						{e.label}
						{e.nickname !== null && <span class="badge">nickname</span>}
					</span>
					<span class="alts-count">
						{(() => {
							const altCount = exportEntries.filter(a => a.main === e.character && !a.isMain).length;
							return altCount > 0 ? `+${altCount} alt${altCount !== 1 ? 's' : ''}` : '';
						})()}
					</span>
				</div>
			))}
		</div>

		<textarea id="export-output" class="export-textarea" readonly spellcheck="false">{exportJson}</textarea>
	</div>
</AdminLayout>

<script>
	const textarea = document.getElementById('export-output') as HTMLTextAreaElement;
	const btnCopy = document.getElementById('btn-copy') as HTMLButtonElement;
	const btnDownload = document.getElementById('btn-download') as HTMLButtonElement;

	btnCopy.addEventListener('click', async () => {
		await navigator.clipboard.writeText(textarea.value);
		btnCopy.textContent = 'Copied!';
		setTimeout(() => { btnCopy.textContent = 'Copy JSON'; }, 2000);
	});

	btnDownload.addEventListener('click', () => {
		const blob = new Blob([textarea.value], { type: 'application/json' });
		const url = URL.createObjectURL(blob);
		const a = document.createElement('a');
		a.href = url;
		a.download = `hidden-lodge-export-${new Date().toISOString().slice(0, 10)}.json`;
		a.click();
		URL.revokeObjectURL(url);
	});
</script>

<style>
	.export-page {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.page-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1rem;
		flex-wrap: wrap;
	}

	h1 {
		font-size: 1.6rem;
		font-weight: 700;
		color: var(--gold);
		margin: 0 0 0.25rem;
	}

	.page-desc {
		color: var(--muted);
		font-size: 0.92rem;
		margin: 0;
		max-width: 54ch;
	}

	.page-stats {
		display: flex;
		gap: 1rem;
		align-items: center;
		flex-shrink: 0;
	}

	.stat {
		font-size: 0.88rem;
		color: var(--muted);
		background: rgba(214, 176, 106, 0.07);
		border: 1px solid rgba(214, 176, 106, 0.15);
		border-radius: 0.4rem;
		padding: 0.3rem 0.65rem;
	}

	.export-meta {
		font-size: 0.82rem;
		color: var(--muted);
	}

	.export-actions {
		display: flex;
		gap: 0.75rem;
	}

	.btn-action {
		padding: 0.5rem 1.1rem;
		border-radius: 0.4rem;
		border: 1px solid rgba(214, 176, 106, 0.5);
		background: rgba(214, 176, 106, 0.12);
		color: var(--gold);
		font-size: 0.9rem;
		cursor: pointer;
		font-family: inherit;
		transition: background 0.15s;
	}

	.btn-action:hover { background: rgba(214, 176, 106, 0.22); }

	.btn-secondary {
		background: transparent;
		color: var(--muted);
		border-color: rgba(214, 176, 106, 0.2);
	}

	.btn-secondary:hover {
		background: rgba(214, 176, 106, 0.07);
		color: var(--gold);
	}

	/* Summary table */
	.export-summary {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		background: rgba(0,0,0,0.2);
		border: 1px solid rgba(214, 176, 106, 0.1);
		border-radius: 0.5rem;
		padding: 0.75rem 1rem;
		max-height: 280px;
		overflow-y: auto;
	}

	.summary-row {
		display: grid;
		grid-template-columns: 14ch 14ch 1.5ch 1fr auto;
		gap: 0.5rem;
		align-items: center;
		font-size: 0.88rem;
		padding: 0.18rem 0;
	}

	.char-name { color: var(--gold); font-weight: 600; }
	.realm-name { color: var(--muted); font-size: 0.82rem; }
	.arrow { color: var(--muted); text-align: center; }

	.label-value { color: #e8e8da; }
	.label-value.has-nickname { color: #a8d8a8; }

	.badge {
		display: inline-block;
		font-size: 0.68rem;
		background: rgba(168, 216, 168, 0.15);
		border: 1px solid rgba(168, 216, 168, 0.3);
		color: #a8d8a8;
		border-radius: 0.3rem;
		padding: 0.05rem 0.35rem;
		margin-left: 0.35rem;
		vertical-align: middle;
	}

	.alts-count {
		font-size: 0.78rem;
		color: var(--muted);
		text-align: right;
	}

	/* Raw JSON textarea */
	.export-textarea {
		width: 100%;
		min-height: 320px;
		background: rgba(0,0,0,0.35);
		border: 1px solid rgba(214, 176, 106, 0.15);
		border-radius: 0.5rem;
		padding: 1rem;
		color: #c8d8c8;
		font-family: 'Consolas', 'Monaco', monospace;
		font-size: 0.8rem;
		line-height: 1.5;
		resize: vertical;
		box-sizing: border-box;
	}

	.export-textarea:focus {
		outline: 1px solid rgba(214, 176, 106, 0.3);
	}
</style>
