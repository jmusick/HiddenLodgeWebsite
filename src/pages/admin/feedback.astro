---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';

if (!Astro.locals.isAdmin) {
  return Astro.redirect('/');
}

interface FeedbackRow {
  id: number;
  display_name: string | null;
  message: string;
  status: 'new' | 'reviewed';
  submitted_at: number;
  reviewed_at: number | null;
}

const pageUrl = new URL(Astro.request.url);
const statusParam = pageUrl.searchParams.get('status');

const feedbackRows = await env.DB
  .prepare(
    `SELECT id, display_name, message, status, submitted_at, reviewed_at
     FROM guild_feedback
     ORDER BY submitted_at DESC`
  )
  .all<FeedbackRow>();

const entries = feedbackRows.results ?? [];
const newCount = entries.filter((entry) => entry.status === 'new').length;
const reviewedCount = entries.length - newCount;

function formatDate(unix: number | null): string {
  if (!unix) return '—';
  return new Date(unix * 1000).toLocaleString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
  });
}
---

<AdminLayout title="Feedback | Admin | The Hidden Lodge">
  <div class="page-header">
    <h1>Guild Feedback</h1>
    <p class="page-desc">{newCount} new · {reviewedCount} reviewed · {entries.length} total</p>
  </div>

  {statusParam === 'ok' && (
    <p class="flash flash-ok" role="status">Feedback status updated.</p>
  )}
  {statusParam === 'error' && (
    <p class="flash flash-error" role="alert">Could not update this feedback entry. Please try again.</p>
  )}

  {entries.length === 0 ? (
    <p class="empty-state">No feedback has been submitted yet.</p>
  ) : (
    <section class="feedback-list" aria-label="Guild feedback submissions">
      {entries.map((entry) => (
        <article class:list={['feedback-card', { reviewed: entry.status === 'reviewed' }]}>
          <header class="feedback-header">
            <div>
              <p class="feedback-meta">Submitted {formatDate(entry.submitted_at)}</p>
              <p class="feedback-name">Name: {entry.display_name?.trim() ? entry.display_name : 'Anonymous'}</p>
            </div>
            <form method="POST" action="/api/admin/feedback/update-status" class="status-form">
              <input type="hidden" name="feedback_id" value={String(entry.id)} />
              <input type="hidden" name="return_to" value="/admin/feedback" />
              <input
                type="hidden"
                name="status"
                value={entry.status === 'new' ? 'reviewed' : 'new'}
              />
              <button type="submit" class:list={['status-btn', { reviewed: entry.status === 'reviewed' }]}>
                {entry.status === 'new' ? 'Mark Reviewed' : 'Reopen'}
              </button>
            </form>
          </header>

          <p class="feedback-message">{entry.message}</p>

          <p class="feedback-footer">
            Status: <strong>{entry.status === 'new' ? 'New' : 'Reviewed'}</strong>
            {entry.status === 'reviewed' && entry.reviewed_at ? ` · Reviewed ${formatDate(entry.reviewed_at)}` : ''}
          </p>
        </article>
      ))}
    </section>
  )}
</AdminLayout>

<style>
  .page-header {
    margin-bottom: 1.2rem;
  }

  .page-header h1 {
    margin: 0 0 0.2rem;
    color: #e8d8b0;
    font-size: 1.6rem;
  }

  .page-desc {
    margin: 0;
    color: #87a0b1;
    font-size: 0.9rem;
  }

  .flash {
    margin: 0 0 1rem;
    padding: 0.55rem 0.7rem;
    border-radius: 0.45rem;
    border: 1px solid;
    font-weight: 600;
  }

  .flash-ok {
    border-color: rgba(45, 189, 126, 0.6);
    background: rgba(45, 189, 126, 0.12);
    color: #9cf0c5;
  }

  .flash-error {
    border-color: rgba(220, 92, 92, 0.6);
    background: rgba(220, 92, 92, 0.12);
    color: #ffb7b7;
  }

  .empty-state {
    color: #7a96a8;
    font-style: italic;
  }

  .feedback-list {
    display: grid;
    gap: 0.85rem;
  }

  .feedback-card {
    border: 1px solid rgba(214, 176, 106, 0.32);
    border-radius: 0.65rem;
    background: rgba(11, 21, 32, 0.78);
    padding: 0.9rem;
  }

  .feedback-card.reviewed {
    border-color: rgba(125, 150, 168, 0.35);
    background: rgba(12, 20, 28, 0.62);
  }

  .feedback-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 0.55rem;
    flex-wrap: wrap;
  }

  .feedback-meta,
  .feedback-name,
  .feedback-footer {
    margin: 0;
    color: #9db2c1;
    font-size: 0.85rem;
  }

  .feedback-name {
    margin-top: 0.14rem;
    color: #c4d1db;
  }

  .status-form {
    margin: 0;
  }

  .status-btn {
    border: 1px solid rgba(214, 176, 106, 0.45);
    border-radius: 0.42rem;
    background: rgba(214, 176, 106, 0.11);
    color: #f1cd89;
    font: inherit;
    font-size: 0.84rem;
    font-weight: 700;
    padding: 0.35rem 0.62rem;
    cursor: pointer;
  }

  .status-btn.reviewed {
    border-color: rgba(125, 150, 168, 0.45);
    background: rgba(125, 150, 168, 0.14);
    color: #cee0ec;
  }

  .status-btn:hover,
  .status-btn:focus-visible {
    filter: brightness(1.08);
  }

  .feedback-message {
    margin: 0;
    white-space: pre-wrap;
    color: #e2ebf1;
    line-height: 1.45;
  }

  .feedback-footer {
    margin-top: 0.55rem;
    padding-top: 0.55rem;
    border-top: 1px solid rgba(214, 176, 106, 0.18);
  }
</style>
