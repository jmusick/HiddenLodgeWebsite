---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { Icon } from 'astro-icon/components';
import { env } from 'cloudflare:workers';
import { classColor } from '../../lib/wow';

// Middleware already guards /admin/* — belt-and-suspenders
if (!Astro.locals.isAdmin) {
	return Astro.redirect('/');
}

const RANK_NAMES: Record<number, string> = {
	0: 'Guild Master',
	1: 'Guild Admin',
	2: 'Guild Officer',
	3: 'Officer Alt',
	4: 'Raider',
	5: 'Trial',
	6: 'Junior Raider',
	7: 'Guild Friend',
	8: 'Alt',
};
function rankLabel(rank: number): string {
	return RANK_NAMES[rank] ?? `Rank ${rank}`;
}

// --- Row types ---
interface GuildUserRow {
	user_id: number;
	battle_tag: string;
	nickname: string | null;
}

interface CharRow {
	user_id: number;
	blizzard_char_id: number;
	name: string;
	realm: string;
	class_name: string;
	level: number;
	is_main: number;
	guild_rank: number | null;
}

interface UnauthedRosterRow {
	blizzard_char_id: number;
	name: string;
	realm: string;
	class_name: string;
	rank: number;
}

interface NoteRow {
	id: number;
	blizzard_char_id: number;
	linked_user_id: number | null;
	note_text: string;
	created_at: number;
	author_name: string;
}

const [usersResult, charsResult, unauthedResult, notesResult, raidTeamResult] = await env.DB.batch([
	env.DB.prepare(`
		SELECT DISTINCT u.id AS user_id, u.battle_tag, u.nickname
		FROM users u
		JOIN characters c ON c.user_id = u.id
		JOIN roster_members_cache rmc ON rmc.blizzard_char_id = c.blizzard_char_id
		ORDER BY u.nickname, u.battle_tag
	`),
	env.DB.prepare(`
		SELECT c.user_id, c.blizzard_char_id, c.name, c.realm, c.class_name, c.level, c.is_main,
		       rmc.rank AS guild_rank
		FROM characters c
		JOIN (
		  SELECT DISTINCT ci.user_id FROM characters ci
		  JOIN roster_members_cache r ON r.blizzard_char_id = ci.blizzard_char_id
		) guild_users ON guild_users.user_id = c.user_id
		LEFT JOIN roster_members_cache rmc ON rmc.blizzard_char_id = c.blizzard_char_id
		ORDER BY c.user_id, c.is_main DESC, rmc.rank ASC, c.level DESC, c.name ASC
	`),
	env.DB.prepare(`
		SELECT rmc.blizzard_char_id, rmc.name, rmc.realm, rmc.class_name, rmc.rank
		FROM roster_members_cache rmc
		WHERE NOT EXISTS (
		  SELECT 1 FROM characters c WHERE c.blizzard_char_id = rmc.blizzard_char_id
		)
		ORDER BY rmc.rank ASC, rmc.name ASC
	`),
	env.DB.prepare(`
		SELECT rn.id, rn.blizzard_char_id, rn.note_text, rn.created_at,
		       COALESCE(au.nickname, au.battle_tag) AS author_name,
		       c.user_id AS linked_user_id
		FROM raider_notes rn
		LEFT JOIN characters c ON c.blizzard_char_id = rn.blizzard_char_id
		JOIN users au ON au.id = rn.author_user_id
		ORDER BY rn.blizzard_char_id ASC, rn.created_at DESC
	`),
	env.DB.prepare(`
		SELECT DISTINCT rtm.blizzard_char_id
		FROM raid_team_members rtm
		JOIN raid_teams rt ON rt.id = rtm.team_id
		WHERE rt.is_archived = 0
	`),
]);

const guildUsers = (usersResult.results ?? []) as GuildUserRow[];
const allChars = (charsResult.results ?? []) as CharRow[];
const unauthed = (unauthedResult.results ?? []) as UnauthedRosterRow[];
const allNotes = (notesResult.results ?? []) as NoteRow[];
const raidTeamCharIds = new Set(
	((raidTeamResult.results ?? []) as { blizzard_char_id: number }[]).map((r) => r.blizzard_char_id)
);

const charsByUser = new Map<number, CharRow[]>();
for (const char of allChars) {
	const arr = charsByUser.get(char.user_id) ?? [];
	arr.push(char);
	charsByUser.set(char.user_id, arr);
}

const notesByUser = new Map<number, NoteRow[]>();
const notesByChar = new Map<number, NoteRow[]>();
for (const note of allNotes) {
	// Always index by char (for unauthed display)
	const charArr = notesByChar.get(note.blizzard_char_id) ?? [];
	charArr.push(note);
	notesByChar.set(note.blizzard_char_id, charArr);
	// Also aggregate by user when the char is linked (for authed display)
	if (note.linked_user_id !== null) {
		const userArr = notesByUser.get(note.linked_user_id) ?? [];
		userArr.push(note);
		notesByUser.set(note.linked_user_id, userArr);
	}
}

function formatNoteDate(unixTs: number): string {
	return new Date(unixTs * 1000).toLocaleString('en-GB', {
		year: 'numeric', month: 'short', day: 'numeric',
		hour: '2-digit', minute: '2-digit',
	});
}

const canDeleteNotes = Astro.locals.isAdmin;

const params = new URL(Astro.request.url).searchParams;
const statusParam = params.get('status');

const statusMessages: Record<string, { type: 'ok' | 'error'; text: string }> = {
	'ok':             { type: 'ok',    text: 'Nickname saved.' },
	'note-added':     { type: 'ok',    text: 'Note saved.' },
	'note-updated':   { type: 'ok',    text: 'Note updated.' },
	'note-deleted':   { type: 'ok',    text: 'Note deleted.' },
	'error':          { type: 'error', text: 'Something went wrong. Please try again.' },
};
const flash = statusParam ? (statusMessages[statusParam] ?? null) : null;
---

<AdminLayout title="Mains & Alts | Admin | The Hidden Lodge">
	<div class="mains-page">
		<div class="page-header">
			<div>
				<h1>Mains &amp; Alts</h1>
				<p class="page-desc">
					Members set their own main via their profile after logging in with Battle.net.
					You can assign a nickname that displays alongside their characters.
				</p>
			</div>
			<div class="page-right">
				<div class="page-stats">
					<span class="stat"><strong>{guildUsers.length}</strong> authenticated</span>
					<span class="stat"><strong>{unauthed.length}</strong> not yet logged in</span>
				</div>
				<input
					id="member-search"
					type="search"
					placeholder="Search nickname, main, character…"
					class="search-input"
					autocomplete="off"
				/>
			</div>
		</div>

		{flash && (
			<div class:list={['flash', flash.type === 'ok' ? 'flash-ok' : 'flash-error']} role="alert">
				{flash.text}
			</div>
		)}

		<!-- ── Authenticated Guild Members ──────────────────────────────────── -->
		<section class="admin-section">
			<h2>
				Authenticated Members
				<span class="count-badge">{guildUsers.length}</span>
			</h2>

			{guildUsers.length === 0 ? (
				<p class="empty-state">No guild members have logged in yet.</p>
			) : (
				<div class="profiles-grid">
					{guildUsers.map((guildUser) => {
						const chars = charsByUser.get(guildUser.user_id) ?? [];
						const mainChar = chars.find((c) => c.is_main === 1 && c.guild_rank !== null) ?? null;
						const guildChars = chars.filter((c) => c.guild_rank !== null);
						const otherChars = chars.filter((c) => c.guild_rank === null);
						const displayName = guildUser.nickname ?? guildUser.battle_tag;
						const notes = notesByUser.get(guildUser.user_id) ?? [];
						const noteCharId = (mainChar ?? guildChars[0])?.blizzard_char_id;

						const searchTerms = [
							guildUser.nickname,
							guildUser.battle_tag,
							...chars.map((c) => c.name),
						].filter(Boolean).join(' ').toLowerCase();

						return (
							<div class="profile-card" data-search={searchTerms}>
								<div class="card-header">
									<div class="card-identity">
										<span class="card-display-name">{displayName}</span>
										{guildUser.nickname && (
											<span class="card-battletag">{guildUser.battle_tag}</span>
										)}
									</div>
									{mainChar ? (
										raidTeamCharIds.has(mainChar.blizzard_char_id) ? (
											<a href={`/raiders/${mainChar.blizzard_char_id}`} class="main-pill" style={`color: ${classColor(mainChar.class_name)}`}>
												{mainChar.name}
											</a>
										) : (
											<span class="main-pill" style={`color: ${classColor(mainChar.class_name)}`}>
												{mainChar.name}
											</span>
										)
									) : (
										<span class="no-main-pill">No main set</span>
									)}
								</div>

								<!-- Tab bar -->
								<div class="card-tabs">
									<button class="card-tab is-active" data-tab="notes" type="button">
										Notes
										{notes.length > 0 && <span class="tab-badge">{notes.length}</span>}
									</button>
									<button class="card-tab" data-tab="chars" type="button">
										Characters
										{guildChars.length > 0 && <span class="tab-badge">{guildChars.length}</span>}
									</button>
								</div>

								<!-- Characters panel -->
								<div class="card-panel" data-panel="chars" style="display:none">
									{guildChars.length > 0 ? (
										<ul class="char-list">
											{guildChars.map((char) => (
												<li class:list={['char-row', { 'is-main': char.is_main === 1 }]}>
													{raidTeamCharIds.has(char.blizzard_char_id) ? (
														<a href={`/raiders/${char.blizzard_char_id}`} class="char-name" style={`color: ${classColor(char.class_name)}`}>
															{char.name}
															{char.is_main === 1 && <span class="main-badge">MAIN</span>}
														</a>
													) : (
														<span class="char-name" style={`color: ${classColor(char.class_name)}`}>
															{char.name}
															{char.is_main === 1 && <span class="main-badge">MAIN</span>}
														</span>
													)}
													<span class="char-meta">
														{char.class_name} &middot; {char.realm}
													</span>
													<span class="char-rank">{rankLabel(char.guild_rank!)}</span>
												</li>
											))}
										</ul>
									) : (
										<p class="panel-empty">No guild characters.</p>
									)}
									{otherChars.length > 0 && (
										<details class="other-chars">
											<summary class="other-toggle">
												{otherChars.length} other character{otherChars.length !== 1 ? 's' : ''} (not in guild)
											</summary>
											<ul class="char-list char-list-dim">
												{otherChars.map((char) => (
													<li class="char-row">
														<span class="char-name" style={`color: ${classColor(char.class_name)}; opacity: 0.6`}>
															{char.name}
														</span>
														<span class="char-meta">{char.class_name} &middot; {char.realm}</span>
													</li>
												))}
											</ul>
										</details>
									)}
								</div>

								<!-- Notes panel -->
								<div class="card-panel" data-panel="notes">
									{notes.length > 1 && (
										<div class="notes-toolbar">
											<button class="sort-btn" data-sort="desc" type="button">Newest ↓</button>
											<input type="search" class="notes-search" placeholder="Filter notes…" autocomplete="off" />
										</div>
									)}
									{notes.length > 0 ? (
										<ul class="notes-list">
											{notes.map((note) => (
												<li class="note-item" data-ts={note.created_at}
													data-note={`${note.author_name} ${note.note_text}`.toLowerCase()}>
													<div class="note-view">
														<div class="note-meta">
															<span class="note-author">{note.author_name}</span>
															<span class="note-date">{formatNoteDate(note.created_at)}</span>
															<span class="note-actions">
																<button type="button" class="btn-note btn-edit-note">Edit</button>
																{canDeleteNotes && (
																	<form method="POST" action="/api/admin/raider-notes/delete" style="display:inline">
																		<input type="hidden" name="id" value={note.id} />
																		<button type="submit" class="btn-note btn-delete" title="Delete note">
																				<Icon name="lucide:trash-2" size={12} />
																			</button>
																	</form>
																)}
															</span>
														</div>
														<p class="note-body">{note.note_text}</p>
													</div>
													<div class="note-edit" style="display:none">
														<form method="POST" action="/api/admin/raider-notes/update" class="note-edit-form">
															<input type="hidden" name="id" value={note.id} />
															<textarea name="note_text" class="note-textarea" rows="3" required>{note.note_text}</textarea>
															<div class="note-edit-actions">
																<button type="button" class="btn-note btn-edit-cancel">Cancel</button>
																<button type="submit" class="btn btn-primary btn-sm">Save</button>
															</div>
														</form>
													</div>
												</li>
											))}
											<li class="notes-no-match" style="display:none">No notes match.</li>
										</ul>
									) : (
										<p class="panel-empty">No notes yet.</p>
									)}
									{noteCharId && (
										<details class="add-note-panel">
											<summary class="add-note-toggle">Add note&hellip;</summary>
											<form method="POST" action="/api/admin/raider-notes/create" class="add-note-form">
												<input type="hidden" name="blizzard_char_id" value={noteCharId} />
												<textarea
													name="note_text"
													class="note-textarea"
													rows="3"
													placeholder={`Note about ${displayName}…`}
													maxlength="1000"
													required
												></textarea>
												<button type="submit" class="btn btn-primary">Save Note</button>
											</form>
										</details>
									)}
								</div>

								<details class="edit-panel">
									<summary class="edit-toggle">Set Nickname</summary>
									<form method="POST" action="/api/admin/update-nickname" class="edit-inner">
										<input type="hidden" name="user_id" value={guildUser.user_id} />
										<input
											type="text"
											name="nickname"
											value={guildUser.nickname ?? ''}
											placeholder={guildUser.battle_tag}
											class="input-sm"
											maxlength="48"
										/>
										<button type="submit" class="btn btn-primary">Save</button>
									</form>
								</details>
							</div>
						);
					})}
				</div>
				<p class="search-empty empty-state" style="display:none">No members match your search.</p>
			)}
		</section>

		<!-- ── Unauthenticated Roster Members ───────────────────────────────── -->
		{unauthed.length > 0 && (
			<section class="admin-section">
				<h2>
					Not Yet Logged In
					<span class="count-badge">{unauthed.length}</span>
				</h2>
				<p class="section-desc">
					These roster members haven't authenticated with Battle.net yet. Notes added here will
					automatically appear on their profile once they log in and link their character.
				</p>
				<div class="profiles-grid">
					{unauthed.map((char) => {
						const notes = notesByChar.get(char.blizzard_char_id) ?? [];
						const unauthedSearch = char.name.toLowerCase();
						return (
							<div class="profile-card unauthed-card" data-search={unauthedSearch}>
								<div class="card-header">
									<div class="card-identity">
										{raidTeamCharIds.has(char.blizzard_char_id) ? (
											<a href={`/raiders/${char.blizzard_char_id}`} class="card-display-name" style={`color: ${classColor(char.class_name)}`}>
												{char.name}
											</a>
										) : (
											<span class="card-display-name" style={`color: ${classColor(char.class_name)}`}>
												{char.name}
											</span>
										)}
										<span class="card-battletag">{char.class_name} &middot; {char.realm}</span>
									</div>
									<span class="no-main-pill">{rankLabel(char.rank)}</span>
								</div>

								<div class="card-panel">
									{notes.length > 1 && (
										<div class="notes-toolbar">
											<button class="sort-btn" data-sort="desc" type="button">Newest ↓</button>
											<input type="search" class="notes-search" placeholder="Filter notes…" autocomplete="off" />
										</div>
									)}
									{notes.length > 0 ? (
										<ul class="notes-list">
											{notes.map((note) => (
												<li class="note-item" data-ts={note.created_at}
													data-note={`${note.author_name} ${note.note_text}`.toLowerCase()}>
													<div class="note-view">
														<div class="note-meta">
															<span class="note-author">{note.author_name}</span>
															<span class="note-date">{formatNoteDate(note.created_at)}</span>
															<span class="note-actions">
																<button type="button" class="btn-note btn-edit-note">Edit</button>
																{canDeleteNotes && (
																	<form method="POST" action="/api/admin/raider-notes/delete" style="display:inline">
																		<input type="hidden" name="id" value={note.id} />
																		<button type="submit" class="btn-note btn-delete" title="Delete note">
																			<Icon name="lucide:trash-2" size={12} />
																		</button>
																	</form>
																)}
															</span>
														</div>
														<p class="note-body">{note.note_text}</p>
													</div>
													<div class="note-edit" style="display:none">
														<form method="POST" action="/api/admin/raider-notes/update" class="note-edit-form">
															<input type="hidden" name="id" value={note.id} />
															<textarea name="note_text" class="note-textarea" rows="3" required>{note.note_text}</textarea>
															<div class="note-edit-actions">
																<button type="button" class="btn-note btn-edit-cancel">Cancel</button>
																<button type="submit" class="btn btn-primary btn-sm">Save</button>
															</div>
														</form>
													</div>
												</li>
											))}
											<li class="notes-no-match" style="display:none">No notes match.</li>
										</ul>
									) : (
										<p class="panel-empty">No notes yet.</p>
									)}
									<details class="add-note-panel">
										<summary class="add-note-toggle">Add note&hellip;</summary>
										<form method="POST" action="/api/admin/raider-notes/create" class="add-note-form">
											<input type="hidden" name="blizzard_char_id" value={char.blizzard_char_id} />
											<textarea
												name="note_text"
												class="note-textarea"
												rows="3"
												placeholder={`Note about ${char.name}…`}
												maxlength="1000"
												required
											></textarea>
											<button type="submit" class="btn btn-primary">Save Note</button>
										</form>
									</details>
								</div>
							</div>
						);
					})}
				</div>
				<p class="search-empty empty-state" style="display:none">No members match your search.</p>
			</section>
		)}
	</div>
</AdminLayout>

<script>
	// Search
	const input = document.getElementById('member-search') as HTMLInputElement | null;
	if (input) {
		input.addEventListener('input', () => {
			const q = input.value.trim().toLowerCase();
			document.querySelectorAll<HTMLElement>('.profiles-grid').forEach((grid) => {
				let visible = 0;
				grid.querySelectorAll<HTMLElement>('.profile-card').forEach((card) => {
					const match = !q || (card.dataset.search ?? '').includes(q);
					card.style.display = match ? '' : 'none';
					if (match) visible++;
				});
				const emptyEl = grid.parentElement?.querySelector<HTMLElement>('.search-empty');
				if (emptyEl) emptyEl.style.display = visible === 0 ? '' : 'none';
			});
		});
	}

	// Tab switching
	document.querySelectorAll<HTMLElement>('.card-tabs').forEach((tabs) => {
		const card = tabs.closest('.profile-card')!;
		tabs.querySelectorAll<HTMLButtonElement>('.card-tab').forEach((tab) => {
			tab.addEventListener('click', () => {
				const target = tab.dataset.tab;
				tabs.querySelectorAll('.card-tab').forEach((t) => t.classList.toggle('is-active', t === tab));
				card.querySelectorAll<HTMLElement>('.card-panel').forEach((panel) => {
					panel.style.display = panel.dataset.panel === target ? '' : 'none';
				});
			});
		});
	});

	// Filter notes
	document.querySelectorAll<HTMLInputElement>('.notes-search').forEach((input) => {
		input.addEventListener('input', () => {
			const q = input.value.trim().toLowerCase();
			const list = input.closest('.card-panel')!.querySelector<HTMLElement>('.notes-list')!;
			const items = list.querySelectorAll<HTMLElement>('.note-item');
			let visible = 0;
			items.forEach((item) => {
				const match = !q || (item.dataset.note ?? '').includes(q);
				item.style.display = match ? '' : 'none';
				if (match) visible++;
			});
			const noMatch = list.querySelector<HTMLElement>('.notes-no-match');
			if (noMatch) noMatch.style.display = visible === 0 ? '' : 'none';
		});
	});

	// Sort notes
	document.querySelectorAll<HTMLButtonElement>('.sort-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			const panel = btn.closest('.card-panel')!;
			const list = panel.querySelector<HTMLElement>('.notes-list');
			if (!list) return;
			const isDesc = btn.dataset.sort === 'desc';
			const newSort = isDesc ? 'asc' : 'desc';
			btn.dataset.sort = newSort;
			btn.textContent = newSort === 'desc' ? 'Newest ↓' : 'Oldest ↑';
			const items = [...list.querySelectorAll<HTMLElement>(':scope > .note-item')];
			items.sort((a, b) => {
				const ta = parseInt(a.dataset.ts ?? '0', 10);
				const tb = parseInt(b.dataset.ts ?? '0', 10);
				return newSort === 'desc' ? tb - ta : ta - tb;
			});
			items.forEach((i) => list.appendChild(i));
		});
	});

	// Inline note editing
	document.querySelectorAll<HTMLButtonElement>('.btn-edit-note').forEach((btn) => {
		btn.addEventListener('click', () => {
			const item = btn.closest('.note-item')!;
			(item.querySelector('.note-view') as HTMLElement).style.display = 'none';
			(item.querySelector('.note-edit') as HTMLElement).style.display = '';
		});
	});
	// Delete confirmation
	document.querySelectorAll<HTMLButtonElement>('.btn-delete').forEach((btn) => {
		btn.addEventListener('click', (e) => {
			if (!confirm('Delete this note?')) e.preventDefault();
		});
	});

	document.querySelectorAll<HTMLButtonElement>('.btn-edit-cancel').forEach((btn) => {
		btn.addEventListener('click', () => {
			const item = btn.closest('.note-item')!;
			(item.querySelector('.note-view') as HTMLElement).style.display = '';
			(item.querySelector('.note-edit') as HTMLElement).style.display = 'none';
		});
	});
</script>

<style>
	.mains-page {
		display: flex;
