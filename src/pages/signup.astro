                                      <form method="POST" action="/api/admin/raid-signups/update-signup-role" class="role-admin-form">
                                        <input type="hidden" name="signup_id" value={row.id!} />
                                        <input type="hidden" name="return_to" value={Astro.url.pathname + Astro.url.search} />
                                        <select name="signup_role" required>
                                          {ROLE_OPTIONS.map((opt) => (
                                            <option value={opt.value} selected={opt.value === row.signup_role}>{opt.label}</option>
