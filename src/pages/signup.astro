      </section>
    )}

    {characters.length === 0 ? (
      <p class="flash flash-error">
        No level 90 synced characters found for your account. Log out and back in to resync before signing up.
      </p>
    ) : (
      <div class="calendar-grid" role="grid" aria-label="Raid calendar">
        {['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'].map((day) => (
          <div class="weekday-head" role="columnheader">{day}</div>
        ))}

        {dayCells.map((cell) => (
          <section
            class:list={['day-cell', { 'is-outside': !cell.inMonth, 'is-selected': selectedDayCell?.isoDate === cell.isoDate }]}
            role="gridcell"
            aria-label={cell.isoDate}
          >
            <div class="day-top">
              <a href={`/signup?ym=${ymParam ?? `${year}-${String(monthIndex + 1).padStart(2, '0')}`}&day=${cell.isoDate}`} class="day-link">
                <span class="day-num">{cell.dayNumber}</span>
              </a>
            </div>

            <div class="day-raids">
              {cell.raids.length === 0 ? (
                <p class="no-raids">No raids</p>
              ) : (
                cell.raids.map((raid) => {
                  const signup = signupsByRaidKey.get(raid.key) ?? null;
                  const localTime = formatEpochInTimeZone(raid.displayStartsAtUtc, userTimeZone);
                  const localDay = dayKeyInTimeZone(raid.displayStartsAtUtc, userTimeZone);

                  return (
                    <article
                      class:list={[
                        'raid-card',
                        raid.kind === 'primary' ? 'raid-primary' : 'raid-adhoc',
                        { 'raid-next-main': nextPrimaryRaidKeys.has(raid.key) },
                      ]}
                    >
                      {nextPrimaryRaidKeys.has(raid.key) && <p class="raid-highlight-tag">Next Main Raid</p>}
                      <p class="raid-title">{raid.title}</p>
                      <p class="raid-time">{localTime}</p>
                      {localDay !== cell.isoDate && <p class="tz-shift">Local date: {localDay}</p>}
                      {raid.notes && <p class="raid-notes">{raid.notes}</p>}

                      {signup ? (
                        <div class="signup-state">
                          <p class="signed-as">
                            {signup.signup_status === 'coming' ? 'Signed up' : signup.signup_status === 'tentative' ? 'Tentative' : signup.signup_status === 'late' ? 'Late' : 'Absent'} as <strong>{signup.character_name}</strong>
                          </p>
                          <form method="POST" action="/api/signup/create" class="status-toggle-form">
                            <input type="hidden" name="raid_kind" value={raid.kind} />
                            {raid.kind === 'primary' ? (
                              <>
                                <input type="hidden" name="primary_schedule_id" value={raid.primaryScheduleId!} />
                                <input type="hidden" name="occurrence_start_utc" value={raid.startsAtUtc} />
                              </>
                            ) : (
                              <input type="hidden" name="ad_hoc_raid_id" value={raid.adHocRaidId!} />
                            )}
                            <input type="hidden" name="character_id" value={signup.character_id} />
                            <input type="hidden" name="signup_role" value={signup.signup_role} />
                            <input type="hidden" name="return_to" value={Astro.url.pathname + Astro.url.search} />
                            {signup.signup_status !== 'coming' && (
                              <button
                                type="submit"
                                name="attendance_status"
                                value="coming"
                                class:list={['btn', 'btn-sign']}
                              >
                                Signup
                              </button>
                            )}
                            {signup.signup_status !== 'tentative' && (
                              <button
                                type="submit"
                                name="attendance_status"
                                value="tentative"
                                class:list={['btn', 'btn-tentative']}
                              >
                                Tentative
                              </button>
                            )}
                            {signup.signup_status !== 'late' && (
                              <button
                                type="submit"
                                name="attendance_status"
                                value="late"
                                class:list={['btn', 'btn-late']}
                                onclick="return validateLateSignup(this.form)"
                                title="If you're marked as late, please indicate when you expect to arrive."
                              >
                                Late
                              </button>
                            )}
                            {signup.signup_status !== 'absent' && (
                              <button
                                type="submit"
                                name="attendance_status"
                                value="absent"
                                class:list={['btn', 'btn-absent']}
                              >
                                Absent
                              </button>
                            )}
                          </form>
                          <form method="POST" action="/api/signup/update-note" class="signup-notes-form">
                            <input type="hidden" name="signup_id" value={signup.id} />
                            <input type="hidden" name="return_to" value={Astro.url.pathname + Astro.url.search} />
                            <label class="signup-notes-small">
                              <span class="sr-only">Notes</span>
                              <textarea 
                                name="signup_notes" 
                                class="signup-notes-inline" 
                                rows="1"
                              >{signup.signup_notes ?? ''}</textarea>
                            </label>
                            <button type="submit" class="btn btn-compact">Update Note</button>
                          </form>
                          <form method="POST" action="/api/signup/cancel" class="cancel-form">
                            <input type="hidden" name="raid_kind" value={raid.kind} />
                            {raid.kind === 'primary' ? (
                              <>
                                <input type="hidden" name="primary_schedule_id" value={raid.primaryScheduleId!} />
                                <input type="hidden" name="occurrence_start_utc" value={raid.startsAtUtc} />
                              </>
                            ) : (
                              <input type="hidden" name="ad_hoc_raid_id" value={raid.adHocRaidId!} />
                            )}
                            <input type="hidden" name="return_to" value={Astro.url.pathname + Astro.url.search} />
                            <button type="submit" class="btn btn-cancel">Cancel</button>
                          </form>
                        </div>
                      ) : (
                        <form method="POST" action="/api/signup/create" class="signup-form">
                          <input type="hidden" name="raid_kind" value={raid.kind} />
                          {raid.kind === 'primary' ? (
                            <>
                              <input type="hidden" name="primary_schedule_id" value={raid.primaryScheduleId!} />
                              <input type="hidden" name="occurrence_start_utc" value={raid.startsAtUtc} />
                            </>
                          ) : (
                            <input type="hidden" name="ad_hoc_raid_id" value={raid.adHocRaidId!} />
                          )}
                          <input type="hidden" name="return_to" value={Astro.url.pathname + Astro.url.search} />

                          <label>
                            <span class="sr-only">Character</span>
                            <select name="character_id" required>
                              {characters.map((char) => (
                                <option value={char.id} selected={char.id === defaultCharacterId}>
                                  {char.name} ({char.class_name})
                                </option>
                              ))}
                            </select>
                          </label>
                          <label>
                            <span class="sr-only">Role</span>
                            <select name="signup_role" required>
                              {ROLE_OPTIONS.map((role) => (
                                <option value={role.value} selected={role.value === userPreferredRole}>{role.label}</option>
                              ))}
                            </select>
                          </label>
                          <div class="status-toggle-form">
                            <button type="submit" name="attendance_status" value="coming" class="btn btn-sign">Signup</button>
                            <button type="submit" name="attendance_status" value="tentative" class="btn btn-tentative">Tentative</button>
                            <button type="submit" name="attendance_status" value="late" class="btn btn-late" onclick="return validateLateSignup(this.form)" title="If you're marked as late, please indicate when you expect to arrive.">Late</button>
                            <button type="submit" name="attendance_status" value="absent" class="btn btn-absent">Absent</button>
                          </div>
                          <label>
                            <span class="signup-notes-label">Notes</span>
                            <textarea name="signup_notes" class="signup-notes-field" rows="2"></textarea>
                          </label>
                        </form>
                      )}
                    </article>
                  );
                })
              )}
            </div>
          </section>
        ))}
      </div>
    )}
  </div>
</Layout>

<script>
  function validateLateSignup(form: HTMLFormElement): boolean {
    const notesField = form.querySelector('textarea[name="signup_notes"]') as HTMLTextAreaElement | null;
    if (!notesField || !notesField.value.trim()) {
      alert('Please add a note indicating when you will arrive.');
      if (notesField) notesField.focus();
      return false;
    }
    return true;
  }

  function setupSignupsTable(table: HTMLTableElement): void {
    const tbody = table.tBodies[0];
    if (!tbody) return;
    const resetButton = table.parentElement?.querySelector('.reset-filters-btn') as HTMLButtonElement | null;
    const initialRows = Array.from(tbody.rows);

    const getCellValue = (row: HTMLTableRowElement, col: number): string => {
      const cell = row.cells[col];
      if (!cell) return '';
      const dataValue = (cell as HTMLTableCellElement).dataset.value;
      return (dataValue ?? cell.textContent ?? '').trim().toLowerCase();
    };

    const applyFilters = (): void => {
      const rows = Array.from(tbody.rows);
      const filters = Array.from(table.querySelectorAll('.col-filter')) as Array<HTMLInputElement | HTMLSelectElement>;

      for (const row of rows) {
        let visible = true;
        for (const filter of filters) {
          const colAttr = filter.dataset.filterCol;
          if (!colAttr) continue;
          const col = Number(colAttr);
          const filterValue = filter.value.trim().toLowerCase();
          if (!filterValue) continue;
          const cellValue = getCellValue(row, col);
          const isSelectFilter = filter instanceof HTMLSelectElement;
          const matches = isSelectFilter ? cellValue === filterValue : cellValue.includes(filterValue);
          if (!matches) {
            visible = false;
            break;
          }
        }
        row.style.display = visible ? '' : 'none';
      }
    };

    const clearSortIndicators = (): void => {
      const sortButtons = Array.from(table.querySelectorAll('.sort-btn')) as HTMLButtonElement[];
      sortButtons.forEach((btn) => {
        btn.removeAttribute('aria-sort');
      });
    };

    const sortByColumn = (col: number): void => {
      const currentCol = table.dataset.sortCol ? Number(table.dataset.sortCol) : -1;
      const nextDir = currentCol === col && table.dataset.sortDir === 'asc' ? 'desc' : 'asc';
      table.dataset.sortCol = String(col);
      table.dataset.sortDir = nextDir;

      const rows = Array.from(tbody.rows);
      rows.sort((a, b) => {
        const aVal = getCellValue(a, col);
        const bVal = getCellValue(b, col);
        const cmp = aVal.localeCompare(bVal, undefined, { numeric: true, sensitivity: 'base' });
        return nextDir === 'asc' ? cmp : -cmp;
      });

      rows.forEach((row) => tbody.appendChild(row));
      clearSortIndicators();
      const activeSort = table.querySelector(`.sort-btn[data-sort-col="${col}"]`) as HTMLButtonElement | null;
      if (activeSort) {
        activeSort.setAttribute('aria-sort', nextDir);
      }
      applyFilters();
    };

    const sortButtons = Array.from(table.querySelectorAll('.sort-btn')) as HTMLButtonElement[];
    sortButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const colAttr = btn.dataset.sortCol;
        if (!colAttr) return;
        sortByColumn(Number(colAttr));
      });
    });

    const filters = Array.from(table.querySelectorAll('.col-filter')) as Array<HTMLInputElement | HTMLSelectElement>;
    filters.forEach((filter) => {
      filter.addEventListener('input', applyFilters);
      filter.addEventListener('change', applyFilters);
    });

    if (resetButton) {
      resetButton.addEventListener('click', () => {
        filters.forEach((filter) => {
          filter.value = '';
        });
        initialRows.forEach((row) => tbody.appendChild(row));
        delete table.dataset.sortCol;
        delete table.dataset.sortDir;
        clearSortIndicators();
        applyFilters();
      });
    }
  }

  // Make functions available globally
  (window as any).validateLateSignup = validateLateSignup;

  const sortableTables = document.querySelectorAll('.js-signups-table');
  sortableTables.forEach((table) => setupSignupsTable(table as HTMLTableElement));
</script>

<style>
  .signup-page {
    padding-block: 1.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 100%;
    overflow-x: clip;
  }

  .signup-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .signup-header h1 {
    margin: 0 0 0.35rem;
    color: var(--gold-bright);
  }

  .signup-header p {
    margin: 0;
    color: var(--muted);
    max-width: 72ch;
  }

  .signup-intro {
    white-space: normal;
    max-width: 72ch;
  }

  .summary-hint {
    margin-top: 0.35rem;
    color: #9dc7e8;
    font-size: 0.86rem;
    font-weight: 600;
  }

  .month-nav {
    display: grid;
    grid-template-columns: max-content minmax(14rem, auto) max-content;
    gap: 0.6rem;
    align-items: stretch;
    padding: 0.45rem 0.55rem;
    border: 1px solid rgba(214, 176, 106, 0.35);
    border-radius: 0.6rem;
    background: linear-gradient(135deg, rgba(33, 50, 70, 0.55), rgba(16, 28, 42, 0.78));
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2), inset 0 0 0 1px rgba(214, 176, 106, 0.14);
    width: fit-content;
    max-width: 100%;
  }

  .month-title-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-width: 0;
    padding: 0.35rem 0.75rem;
    border-radius: 0.55rem;
    background: linear-gradient(180deg, rgba(214, 176, 106, 0.25), rgba(214, 176, 106, 0.1));
    border: 1px solid rgba(214, 176, 106, 0.52);
  }

  .month-title {
    font-family: var(--font-display);
    color: var(--gold-bright);
    font-size: clamp(1rem, 1.5vw, 1.32rem);
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.35), 0 0 20px rgba(214, 176, 106, 0.32);
    text-align: center;
  }

  .month-btn {
    border: 1px solid var(--border);
    border-radius: 0.45rem;
    padding: 0.3rem 0.56rem;
    color: #d6e0e8;
    background: rgba(8, 15, 24, 0.8);
    font-weight: 700;
    letter-spacing: 0.01em;
    font-size: 0.78rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 5.2rem;
    white-space: nowrap;
  }

  .month-btn:hover,
  .month-btn:focus-visible {
    color: var(--text);
    border-color: var(--gold);
  }

  .flash {
    margin: 0;
    padding: 0.45rem 0.7rem;
    border-radius: 0.35rem;
    font-weight: 600;
  }

  .flash-ok {
    background: rgba(0, 180, 80, 0.12);
    border: 1px solid rgba(0, 180, 80, 0.4);
    color: #6fdb91;
  }

  .flash-error {
    background: rgba(180, 30, 30, 0.12);
    border: 1px solid rgba(180, 30, 30, 0.4);
    color: #f47e7e;
  }

  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 0.45rem;
  }

  .weekday-head {
    color: var(--gold);
    text-align: center;
    font-weight: 700;
    letter-spacing: 0.06em;
    font-size: 0.82rem;
    text-transform: uppercase;
    padding: 0.25rem 0;
  }

  .day-cell {
    background: var(--bg-panel);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.55rem;
    min-height: 14rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .day-cell.is-outside {
    opacity: 0.56;
  }

  .day-cell.is-selected {
    border-color: rgba(214, 176, 106, 0.8);
    box-shadow: inset 0 0 0 1px rgba(214, 176, 106, 0.22);
  }

  .day-top {
    display: flex;
    justify-content: flex-end;
  }

  .day-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(214, 176, 106, 0.5);
    background: rgba(214, 176, 106, 0.14);
    min-width: 1.9rem;
    min-height: 1.9rem;
    padding: 0.08rem;
    color: var(--gold-bright);
  }

  .day-link:hover,
  .day-link:focus-visible {
    background: rgba(214, 176, 106, 0.28);
    border-color: rgba(214, 176, 106, 0.9);
    box-shadow: 0 0 0 2px rgba(214, 176, 106, 0.2);
    outline: none;
  }

  .day-cell.is-selected .day-link {
    border-color: rgba(214, 176, 106, 1);
    background: rgba(214, 176, 106, 0.34);
    box-shadow: 0 0 0 2px rgba(214, 176, 106, 0.26);
  }

  .day-num {
    font-size: 1rem;
    color: var(--gold-bright);
    font-weight: 700;
  }

  .day-raids {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .no-raids {
    margin: 0.2rem 0 0;
    font-size: 0.8rem;
    color: rgba(215, 225, 233, 0.45);
  }

  .raid-card {
    border: 1px solid rgba(214, 176, 106, 0.25);
    border-radius: 0.4rem;
    padding: 0.45rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    background: rgba(10, 19, 29, 0.8);
    min-width: 0;
    overflow: hidden;
  }

  .raid-primary {
    box-shadow: inset 0 0 0 1px rgba(214, 176, 106, 0.18);
  }

  .raid-adhoc {
    border-color: rgba(115, 163, 212, 0.4);
    box-shadow: inset 0 0 0 1px rgba(115, 163, 212, 0.15);
  }

  .raid-next-main {
    border-color: rgba(214, 176, 106, 0.9);
    box-shadow: inset 0 0 0 1px rgba(214, 176, 106, 0.4), 0 0 0 1px rgba(214, 176, 106, 0.35), 0 8px 18px rgba(214, 176, 106, 0.15);
    background: linear-gradient(180deg, rgba(38, 28, 12, 0.68), rgba(10, 19, 29, 0.9));
  }

  .raid-highlight-tag {
    margin: 0;
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    border-radius: 999px;
    border: 1px solid rgba(214, 176, 106, 0.7);
    background: rgba(214, 176, 106, 0.18);
    color: #f6ddb0;
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.15rem 0.42rem;
  }

  .raid-title,
  .raid-time,
  .raid-notes,
  .signed-as,
  .tz-shift {
    margin: 0;
  }

  .raid-title {
    font-weight: 700;
    color: var(--gold-bright);
    line-height: 1.25;
  }

  .raid-time {
    color: #d8e2e8;
    font-size: 0.84rem;
  }

  .tz-shift {
    color: #8db3d6;
    font-size: 0.74rem;
  }

  .raid-notes {
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1.3;
  }

  .signup-state,
  .signup-form {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .status-toggle-form {
    display: flex;
    flex-direction: column;
    gap: 0.32rem;
  }

  .status-toggle-form .btn {
    width: 100%;
  }

  .cancel-form {
    width: 100%;
  }

  .cancel-form .btn {
    width: 100%;
  }

  .signed-as {
    font-size: 0.8rem;
    color: #9fd0aa;
  }

  .day-summary {
    border: 1px solid var(--border);
    border-radius: 0.55rem;
    background: var(--bg-panel);
    padding: 0.8rem;
    min-width: 0;
    max-width: 100%;
    overflow-x: clip;
  }

  .day-summary h2 {
    margin: 0 0 0.5rem;
    color: var(--gold);
    font-size: 1.05rem;
  }

  .summary-raid-list {
    display: grid;
    gap: 0.65rem;
    min-width: 0;
  }

  .summary-raid-card {
    border: 1px solid rgba(214, 176, 106, 0.32);
    border-radius: 0.45rem;
    padding: 0.65rem;
    background: rgba(7, 15, 24, 0.85);
    min-width: 0;
    max-width: 100%;
  }

  .summary-raid-card h3 {
    margin: 0;
    color: var(--gold-bright);
    font-size: 0.95rem;
  }

  .summary-raid-time,
  .summary-counts,
  .summary-empty {
    margin: 0.3rem 0 0;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .summary-members {
    list-style: none;
    margin: 0.55rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.3rem;
  }

  .summary-members li {
    border: 1px solid rgba(214, 176, 106, 0.2);
    border-radius: 0.32rem;
    padding: 0.28rem 0.38rem;
    display: flex;
    justify-content: space-between;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .member-main {
    display: grid;
    gap: 0.12rem;
  }

  .member-name {
    color: var(--text);
    font-weight: 700;
    font-size: 0.8rem;
  }

  .member-meta,
  .member-owner {
    color: var(--muted);
    font-size: 0.75rem;
  }

  .summary-override-form {
    display: inline-flex;
    align-items: center;
    gap: 0.22rem;
    margin-left: auto;
  }

  .summary-override-form select {
    background: rgba(7, 16, 26, 0.92);
    color: var(--text);
    border: 1px solid rgba(214, 176, 106, 0.35);
    border-radius: 0.3rem;
    padding: 0.2rem 0.38rem;
    font-size: 0.72rem;
    line-height: 1.2;
    min-width: 7.5rem;
  }

  .count-absent {
    color: #e87c7c;
  }

  .absent-section {
    margin-top: 0.55rem;
  }

  .absent-toggle {
    color: var(--muted);
    font-size: 0.8rem;
    cursor: pointer;
    user-select: none;
    list-style: none;
  }

  .absent-toggle::-webkit-details-marker {
    display: none;
  }

  .absent-toggle::before {
    content: '▶ ';
    font-size: 0.65rem;
    opacity: 0.7;
  }

  details[open] .absent-toggle::before {
    content: '▼ ';
  }

  .absent-members {
    list-style: none;
    margin: 0.3rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.2rem;
  }

  .absent-groups {
    margin-top: 0.3rem;
    display: grid;
    gap: 0.42rem;
  }

  .absent-class-group {
    border: 1px solid rgba(232, 124, 124, 0.12);
    border-radius: 0.3rem;
    padding: 0.3rem 0.38rem;
    background: rgba(16, 10, 10, 0.25);
  }

  .absent-class-heading {
    margin: 0;
    font-size: 0.74rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: rgba(220, 194, 194, 0.86);
  }

  .absent-member {
    border: 1px solid rgba(232, 124, 124, 0.1);
    border-radius: 0.28rem;
    padding: 0.22rem 0.38rem;
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
    opacity: 0.86;
    background: rgba(10, 6, 6, 0.18);
  }

  .absent-member .member-name {
    font-size: 0.78rem;
    color: rgba(215, 225, 233, 0.7);
    font-weight: 600;
  }

  .absent-member .member-meta {
    font-size: 0.72rem;
  }

  .summary-override-form .btn-compact {
    padding: 0.2rem 0.45rem;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
  }

  .summary-grid {
    margin-top: 0.55rem;
    display: grid;
    gap: 0.45rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .summary-grid article {
    border: 1px solid rgba(214, 176, 106, 0.24);
    border-radius: 0.35rem;
    padding: 0.45rem;
    background: rgba(5, 12, 20, 0.78);
  }

  .summary-grid h4 {
    margin: 0 0 0.3rem;
    color: var(--gold);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .summary-grid p {
    margin: 0.2rem 0;
    color: var(--muted);
    font-size: 0.78rem;
  }

  .pill-list,
  .mini-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .mini-list {
    display: grid;
    gap: 0.2rem;
  }

  .mini-list li {
    color: var(--muted);
    font-size: 0.74rem;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.12rem 0.36rem;
    border-radius: 999px;
    border: 1px solid rgba(120, 170, 220, 0.35);
    background: rgba(120, 170, 220, 0.12);
    color: #b9d9f5;
    font-size: 0.68rem;
  }

  .pill-missing {
    border-color: rgba(220, 90, 90, 0.4);
    background: rgba(220, 90, 90, 0.12);
    color: #efb2b2;
  }

  .pill-count {
    color: var(--text);
    font-weight: 700;
  }

  .buff-tooltip {
    position: relative;
  }

  .buff-tooltip::after {
    content: attr(data-tooltip);
    position: absolute;
    left: 50%;
    bottom: calc(100% + 0.35rem);
    transform: translateX(-50%);
    background: rgba(5, 10, 18, 0.96);
    color: #dbe8f1;
    border: 1px solid rgba(214, 176, 106, 0.32);
    border-radius: 0.3rem;
    padding: 0.26rem 0.38rem;
    width: max-content;
    max-width: 14rem;
    font-size: 0.66rem;
    line-height: 1.25;
    opacity: 0;
    pointer-events: none;
    transition: opacity 140ms ease;
    z-index: 4;
  }

  .buff-tooltip:hover::after,
  .buff-tooltip:focus-visible::after {
    opacity: 1;
  }

  .signup-form select {
    width: 100%;
    font-size: 0.78rem;
    background: rgba(5, 12, 19, 0.9);
    color: var(--text);
    border: 1px solid rgba(214, 176, 106, 0.4);
    border-radius: 0.28rem;
    padding: 0.28rem 0.4rem;
  }

  .btn {
    font-size: 0.74rem;
    border-radius: 0.28rem;
    border: 1px solid transparent;
    padding: 0.3rem 0.45rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
    cursor: pointer;
  }

  .btn-sign {
    border-color: rgba(102, 194, 102, 0.6);
    background: rgba(102, 194, 102, 0.14);
    color: #9fd0aa;
  }

  .btn-sign:hover {
    background: rgba(102, 194, 102, 0.25);
  }

  .btn-sign.active {
    border-color: rgba(102, 194, 102, 0.85);
    background: rgba(102, 194, 102, 0.28);
    color: #b8e6b8;
  }

  .btn-tentative {
    border-color: rgba(112, 171, 220, 0.6);
    background: rgba(112, 171, 220, 0.14);
    color: #a9d4f5;
  }

  .btn-tentative:hover {
    background: rgba(112, 171, 220, 0.25);
  }

  .btn-tentative.active {
    border-color: rgba(112, 171, 220, 0.85);
    background: rgba(112, 171, 220, 0.28);
    color: #b8d9ff;
  }

  .btn-cancel {
    border-color: rgba(220, 85, 85, 0.6);
    background: rgba(220, 85, 85, 0.14);
    color: #f5a5a5;
  }

  .btn-cancel:hover {
    background: rgba(220, 85, 85, 0.25);
  }

  .btn-status {
    border-color: rgba(214, 176, 106, 0.4);
    background: rgba(214, 176, 106, 0.07);
    color: var(--muted);
  }

  .btn-status.active {
    border-color: rgba(214, 176, 106, 0.7);
    background: rgba(214, 176, 106, 0.2);
    color: var(--gold-bright);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 1080px) {
    .calendar-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .weekday-head {
      display: none;
    }

    .signup-intro {
      white-space: normal;
      max-width: 72ch;
    }
  }

  @media (max-width: 620px) {
    .month-nav {
      width: 100%;
      grid-template-columns: 1fr;
      gap: 0.45rem;
      padding: 0.45rem;
    }

    .month-title-wrap {
      min-width: 0;
      flex-wrap: wrap;
      padding: 0.3rem 0.5rem;
    }

    .month-btn {
      min-height: 2rem;
      min-width: 0;
    }

    .month-title {
      font-size: 1.1rem;
    }

    .calendar-grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .day-cell {
      min-height: auto;
    }

    .summary-grid {
      grid-template-columns: 1fr;
    }
  }

  /* New button styles for expanded statuses */
  .btn-late {
    border-color: rgba(255, 153, 51, 0.6);
    background: rgba(255, 153, 51, 0.14);
    color: #ffb366;
  }

  .btn-late:hover {
    background: rgba(255, 153, 51, 0.25);
  }

  .btn-late.active {
    border-color: rgba(255, 153, 51, 0.85);
    background: rgba(255, 153, 51, 0.28);
    color: #ffc266;
  }

  .btn-absent {
    border-color: rgba(232, 124, 124, 0.6);
    background: rgba(232, 124, 124, 0.14);
    color: #f47e7e;
  }

  .btn-absent:hover {
    background: rgba(232, 124, 124, 0.25);
  }

  .btn-absent.active {
    border-color: rgba(232, 124, 124, 0.85);
    background: rgba(232, 124, 124, 0.28);
    color: #ff9999;
  }

  /* Signup notes styling */
  .signup-notes-field,
  .signup-notes-inline {
    background: rgba(7, 16, 26, 0.92);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 0.3rem;
    padding: 0.45rem;
    font-family: inherit;
    font-size: 0.85rem;
    line-height: 1.4;
    resize: vertical;
    box-sizing: border-box;
    min-width: 0;
    width: 100%;
    max-width: 100%;
  }

  .signup-notes-field:focus,
  .signup-notes-inline:focus {
    outline: none;
    border-color: rgba(214, 176, 106, 0.6);
    box-shadow: 0 0 0 2px rgba(214, 176, 106, 0.15);
  }

  .signup-notes-label {
    color: var(--muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 0.25rem;
  }

  .required {
    color: #f47e7e;
  }

  .signup-notes-hint {
    color: var(--muted);
    font-size: 0.7rem;
    margin-top: 0.25rem;
    display: block;
    line-height: 1.3;
  }

  .signup-notes-form {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .signup-notes-form .signup-notes-small {
    margin-top: 0;
  }

  .btn-compact {
    padding: 0.28rem 0.55rem;
    font-size: 0.7rem;
    width: 100%;
    align-self: stretch;
  }

  .signup-notes-small {
    margin-top: 0.35rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
    width: 100%;
  }

  label {
    display: block;
    min-width: 0;
  }

  .signup-notes-inline {
    width: 100%;
  }

  /* Signups table styles */
  .signups-table-wrapper {
    overflow-x: hidden;
    max-width: 100%;
    margin-top: 0.85rem;
    border: 1px solid rgba(214, 176, 106, 0.24);
    border-radius: 0.65rem;
    background: rgba(5, 10, 16, 0.55);
  }

  .table-controls {
    display: flex;
    justify-content: flex-end;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid rgba(214, 176, 106, 0.18);
    background: rgba(15, 28, 43, 0.55);
  }

  .signups-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    font-size: 0.8rem;
  }

  .signups-table thead {
    background: rgba(15, 28, 43, 0.88);
    border-bottom: 1px solid var(--border);
  }

  .signups-table thead th {
    background: rgba(15, 28, 43, 0.88);
    position: sticky;
    top: 0;
    z-index: 1;
  }

  .signups-table th {
    color: #d8e2e8;
    text-align: left;
    padding: 0.58rem 0.65rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    font-size: 0.78rem;
    min-width: 0;
    border-bottom: 1px solid rgba(214, 176, 106, 0.18);
  }

  .sort-btn {
    width: 100%;
    border: 0;
    background: transparent;
    cursor: pointer;
    color: #e4c27a;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    font-size: 0.78rem;
    text-align: left;
    padding: 0;
    display: inline-block;
  }

  .sort-btn::after {
    content: ' \21C5';
    font-size: 0.64rem;
    opacity: 0.6;
    margin-left: 0.22rem;
  }

  .sort-btn[aria-sort='asc']::after {
    content: ' \25B2';
    opacity: 1;
  }

  .sort-btn[aria-sort='desc']::after {
    content: ' \25BC';
    opacity: 1;
  }

  .sort-btn:hover,
  .sort-btn:focus-visible {
    color: #f1d9a9;
    text-decoration: underline;
    text-underline-offset: 2px;
    outline: none;
  }

  .filter-row th {
    padding: 0.4rem 0.55rem 0.55rem;
    background: rgba(8, 17, 28, 0.82);
  }

  .col-filter {
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    min-width: 0;
    background: rgba(7, 14, 22, 0.85);
    color: var(--text);
    border: 1px solid rgba(214, 176, 106, 0.42);
    border-radius: 0.45rem;
    padding: 0 0.5rem;
    height: 1.85rem;
    font-size: 0.82rem;
    text-transform: none;
    letter-spacing: normal;
  }

  .signups-table td {
    padding: 0.58rem 0.65rem;
    border-bottom: 1px solid rgba(109, 109, 109, 0.2);
    min-width: 0;
    color: #d8e2e8;
    font-size: 0.9rem;
    vertical-align: top;
  }

  .signups-table tbody tr:last-child td {
    border-bottom: none;
  }

  .signups-table tbody tr:hover {
    background: rgba(214, 176, 106, 0.08);
  }

  .col-character {
    font-weight: 600;
    width: 14%;
  }

  .character-name {
    font-weight: 700;
  }

  .col-owner {
    color: var(--muted);
    font-size: 0.75rem;
    width: 14%;
    overflow-wrap: anywhere;
