---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { env } from 'cloudflare:workers';
import {
  dayKeyInTimeZone,
  formatEpochInTimeZone,
  monthGridUtc,
  parseUtcTime,
  parseYm,
  shouldScheduleOccurOnUtcDate,
  type AdHocRaid,
  type PrimarySchedule,
} from '../lib/raid-signups';
import {
  computeTeamSummary,
  raidBuffDescription,
  tokenArmorType,
  type AssignedRole,
} from '../lib/raid-teams';
import { resolveUserTimeZone } from '../lib/time-zones';
import { fallbackClassIconUrl } from '../lib/class-icons';
import { classColor } from '../lib/wow';

const user = Astro.locals.user!;
const isAdmin = Astro.locals.isAdmin;

interface CharacterRow {
  id: number;
  name: string;
  realm: string;
  class_name: string;
  level: number;
  is_main: number;
}

interface SignupRow {
  id: number;
  raid_kind: 'primary' | 'adhoc';
  primary_schedule_id: number | null;
  ad_hoc_raid_id: number | null;
  occurrence_start_utc: number | null;
  character_id: number;
  character_name: string;
  signup_status: 'coming' | 'tentative' | 'late' | 'absent';
  signup_role: AssignedRole;
  signup_notes: string | null;
}

interface DaySummarySignupRow {
  id: number | null;
  raid_kind: 'primary' | 'adhoc';
  primary_schedule_id: number | null;
  ad_hoc_raid_id: number | null;
  occurrence_start_utc: number | null;
  signed_up_at: number;
  signup_status: 'coming' | 'tentative' | 'late' | 'absent';
  signup_role: AssignedRole;
  signup_notes: string | null;
  character_id: number;
  character_name: string;
  class_name: string;
  nickname: string | null;
  battle_tag: string | null;
  blizzard_char_id: number | null;
  user_id: number | null;
  isSigned: boolean;
}

interface RosterMemberRow {
  blizzard_char_id: number;
  character_name: string;
  class_name: string;
  nickname: string | null;
  user_id: number | null;
}

interface MainCharacterRow {
  user_id: number;
  main_character_name: string;
}

interface BenchOverrideRow {
  raid_ref_key: string;
  occurrence_start_utc: number;
  blizzard_char_id: number;
}

const ROLE_OPTIONS: Array<{ value: AssignedRole; label: string }> = [
  { value: 'tank', label: 'Tank' },
  { value: 'healer', label: 'Healer' },
  { value: 'melee-dps', label: 'Melee DPS' },
  { value: 'ranged-dps', label: 'Ranged DPS' },
];

function roleLabel(role: AssignedRole): string {
  return ROLE_OPTIONS.find((opt) => opt.value === role)?.label ?? role;
}

function classAbbrev(className: string): string {
  const normalized = className.trim().toLowerCase();
  const map: Record<string, string> = {
    'death knight': 'DK',
    'demon hunter': 'DH',
    druid: 'DR',
    evoker: 'EV',
    hunter: 'HU',
    mage: 'MA',
    monk: 'MO',
    paladin: 'PA',
    priest: 'PR',
    rogue: 'RO',
    shaman: 'SH',
    warlock: 'WL',
    warrior: 'WR',
  };

  return map[normalized] ?? className.slice(0, 2).toUpperCase();
}

function signupStatusLabel(row: DaySummarySignupRow): string {
  if (!row.isSigned) return 'Not Signed Up';
  if (row.signup_status === 'coming') return 'Signed Up';
  if (row.signup_status === 'tentative') return 'Tentative';
  if (row.signup_status === 'late') return 'Late';
  return 'Absent';
}


const ymParam = new URL(Astro.request.url).searchParams.get('ym');
const parsedYm = parseYm(ymParam);
const now = new Date();
const year = parsedYm?.year ?? now.getUTCFullYear();
const monthIndex = parsedYm?.monthIndex ?? now.getUTCMonth();

const grid = monthGridUtc(year, monthIndex);
const gridStartEpoch = Math.floor(grid.gridStart.getTime() / 1000);
const gridEndEpoch = Math.floor(grid.gridEndExclusive.getTime() / 1000);

const [settingsResult, charsResult, schedulesResult, adHocResult, signupsResult, officerResult] = await env.DB.batch([
  env.DB.prepare('SELECT time_zone, time_zone_set, preferred_role FROM users WHERE id = ?').bind(user.id),
  env.DB.prepare(
     `SELECT id, name, realm, class_name, level, is_main
     FROM characters
     WHERE user_id = ?
       AND level = 90
     ORDER BY is_main DESC, name ASC`
  ).bind(user.id),
  env.DB.prepare(
    `SELECT id, name, weekday_utc, start_time_utc, duration_minutes, repeat_cycle, created_at, is_active
     FROM primary_raid_schedules
     WHERE is_active = 1
     ORDER BY weekday_utc ASC, start_time_utc ASC, name ASC`
  ),
  env.DB.prepare(
    `SELECT id, name, starts_at_utc, duration_minutes, notes, is_active
     FROM ad_hoc_raids
     WHERE is_active = 1
       AND starts_at_utc >= ?
       AND starts_at_utc < ?
     ORDER BY starts_at_utc ASC, name ASC`
  ).bind(gridStartEpoch, gridEndEpoch),
  env.DB.prepare(
    `SELECT rs.id, rs.raid_kind, rs.primary_schedule_id, rs.ad_hoc_raid_id, rs.occurrence_start_utc,
            rs.character_id, c.name AS character_name, rs.signup_status, rs.signup_role, rs.signup_notes
     FROM raid_signups rs
     JOIN characters c ON c.id = rs.character_id
     WHERE rs.user_id = ?`
  ).bind(user.id),
  env.DB.prepare(
    `SELECT 1 AS can_override
     FROM characters c
     JOIN roster_members_cache rmc ON rmc.blizzard_char_id = c.blizzard_char_id
     WHERE c.user_id = ?
       AND rmc.rank IN (0, 1, 2, 3)
     LIMIT 1`
  ).bind(user.id),
]);

const userSettings = settingsResult.results?.[0] as { time_zone?: string; time_zone_set?: number; preferred_role?: string | null } | undefined;
const userTimeZone = resolveUserTimeZone(userSettings);
const userPreferredRole = (userSettings?.preferred_role as AssignedRole | null | undefined) ?? 'ranged-dps';
const characters = (charsResult.results ?? []) as CharacterRow[];
const primarySchedules = (schedulesResult.results ?? []) as PrimarySchedule[];
const adHocRaids = (adHocResult.results ?? []) as AdHocRaid[];
const signupRows = (signupsResult.results ?? []) as SignupRow[];
const isOfficer = Boolean(officerResult.results?.[0]);
const canOverrideAnyRole = isAdmin || isOfficer;

const defaultCharacterId = characters.find((c) => c.is_main === 1)?.id ?? characters[0]?.id ?? null;

const PRIMARY_SCHEDULE_TIME_ZONE = 'America/New_York';
const WEEKDAY_SHORT_TO_INDEX: Record<string, number> = {
  Sun: 0,
  Mon: 1,
  Tue: 2,
  Wed: 3,
  Thu: 4,
  Fri: 5,
  Sat: 6,
};

const tzWeekMinuteFormatter = new Intl.DateTimeFormat('en-US', {
  timeZone: PRIMARY_SCHEDULE_TIME_ZONE,
  weekday: 'short',
  hour: '2-digit',
  minute: '2-digit',
  hourCycle: 'h23',
});

function weekMinuteInPrimaryTimeZone(epochSeconds: number): number {
  const parts = tzWeekMinuteFormatter.formatToParts(new Date(epochSeconds * 1000));
  const weekdayShort = parts.find((p) => p.type === 'weekday')?.value ?? 'Sun';
  const hour = Number.parseInt(parts.find((p) => p.type === 'hour')?.value ?? '0', 10);
  const minute = Number.parseInt(parts.find((p) => p.type === 'minute')?.value ?? '0', 10);
  const weekday = WEEKDAY_SHORT_TO_INDEX[weekdayShort] ?? 0;
  return weekday * 24 * 60 + hour * 60 + minute;
}

function adjustedPrimaryDisplayStartUtc(schedule: PrimarySchedule, startsAtUtc: number): number {
  const parsedTime = parseUtcTime(schedule.start_time_utc);
  if (!parsedTime) return startsAtUtc;

  const referenceSundayUtc = Math.floor(Date.UTC(2024, 0, 7, 0, 0, 0, 0) / 1000);
  const referenceSlotUtc =
    referenceSundayUtc +
    schedule.weekday_utc * 24 * 60 * 60 +
    (parsedTime.hour * 60 + parsedTime.minute) * 60;

  const intendedWeekMinute = weekMinuteInPrimaryTimeZone(referenceSlotUtc);
  const actualWeekMinute = weekMinuteInPrimaryTimeZone(startsAtUtc);

  let diffMinutes = actualWeekMinute - intendedWeekMinute;
  while (diffMinutes > 7 * 24 * 60 / 2) diffMinutes -= 7 * 24 * 60;
  while (diffMinutes < -(7 * 24 * 60 / 2)) diffMinutes += 7 * 24 * 60;

  if (Math.abs(diffMinutes) > 120 || diffMinutes === 0) return startsAtUtc;
  return startsAtUtc - diffMinutes * 60;
}

interface CalendarRaid {
  key: string;
  kind: 'primary' | 'adhoc';
  title: string;
  startsAtUtc: number;
  displayStartsAtUtc: number;
  durationMinutes: number;
  notes: string | null;
  primaryScheduleId: number | null;
  adHocRaidId: number | null;
}

const raidsByUtcDay = new Map<string, CalendarRaid[]>();
const allRaids: CalendarRaid[] = [];
const raidsByKey = new Map<string, CalendarRaid>();
const canonicalPrimaryRaidKeyByOccurrenceKey = new Map<string, string>();
const primaryRaidsByScheduleId = new Map<number, CalendarRaid[]>();

function primaryRaidKey(scheduleId: number, occurrenceStartUtc: number): string {
  return `primary:${scheduleId}:${occurrenceStartUtc}`;
}

function resolveRaidKey(raidKind: 'primary' | 'adhoc', scheduleOrRaidId: number, occurrenceStartUtc?: number | null): string {
  if (raidKind === 'primary') {
    const key = primaryRaidKey(scheduleOrRaidId, occurrenceStartUtc ?? 0);
    const exact = canonicalPrimaryRaidKeyByOccurrenceKey.get(key);
    if (exact) return exact;

    const candidateRaids = primaryRaidsByScheduleId.get(scheduleOrRaidId) ?? [];
    if (occurrenceStartUtc) {
      let bestRaid: CalendarRaid | null = null;
      let bestDelta = Number.POSITIVE_INFINITY;

      for (const raid of candidateRaids) {
        const delta = Math.abs(raid.startsAtUtc - occurrenceStartUtc);
        if (delta < bestDelta) {
          bestRaid = raid;
          bestDelta = delta;
        }
      }

      // Legacy stored primary occurrences can drift several hours from the currently generated UTC occurrence.
      if (bestRaid && bestDelta <= 12 * 3600) {
        return bestRaid.key;
      }
    }

    return key;
  }

  return `adhoc:${scheduleOrRaidId}`;
}

function addRaidToDay(raid: CalendarRaid): void {
  const dayKey = dayKeyInTimeZone(raid.displayStartsAtUtc, userTimeZone);
  const arr = raidsByUtcDay.get(dayKey) ?? [];
  arr.push(raid);
  raidsByUtcDay.set(dayKey, arr);
  allRaids.push(raid);
  raidsByKey.set(raid.key, raid);
}

function signupDeltaForRaid(raidKey: string, occurrenceStartUtc?: number | null): number {
  if (!occurrenceStartUtc) return Number.POSITIVE_INFINITY;
  const raid = raidsByKey.get(raidKey);
  if (!raid) return Number.POSITIVE_INFINITY;
  return Math.abs(raid.startsAtUtc - occurrenceStartUtc);
}

for (let cursor = new Date(grid.gridStart); cursor < grid.gridEndExclusive; cursor = new Date(cursor.getTime() + 86400000)) {
  const dayStartEpoch = Math.floor(cursor.getTime() / 1000);
  for (const schedule of primarySchedules) {
    if (!shouldScheduleOccurOnUtcDate(schedule, cursor)) continue;
    const parsedTime = parseUtcTime(schedule.start_time_utc);
    if (!parsedTime) continue;

    const startsAtUtc = dayStartEpoch + parsedTime.hour * 3600 + parsedTime.minute * 60;
    const displayStartsAtUtc = adjustedPrimaryDisplayStartUtc(schedule, startsAtUtc);
    const canonicalKey = primaryRaidKey(schedule.id, startsAtUtc);
    canonicalPrimaryRaidKeyByOccurrenceKey.set(canonicalKey, canonicalKey);
    canonicalPrimaryRaidKeyByOccurrenceKey.set(primaryRaidKey(schedule.id, displayStartsAtUtc), canonicalKey);

    const raid: CalendarRaid = {
      key: canonicalKey,
      kind: 'primary',
      title: schedule.name,
      startsAtUtc,
      displayStartsAtUtc,
      durationMinutes: schedule.duration_minutes,
      notes: null,
      primaryScheduleId: schedule.id,
      adHocRaidId: null,
    };

    const scheduleRaids = primaryRaidsByScheduleId.get(schedule.id) ?? [];
    scheduleRaids.push(raid);
    primaryRaidsByScheduleId.set(schedule.id, scheduleRaids);
    addRaidToDay(raid);
  }
}

for (const raid of adHocRaids) {
  addRaidToDay({
    key: `adhoc:${raid.id}`,
    kind: 'adhoc',
    title: raid.name,
    startsAtUtc: raid.starts_at_utc,
    displayStartsAtUtc: raid.starts_at_utc,
    durationMinutes: raid.duration_minutes,
    notes: raid.notes,
    primaryScheduleId: null,
    adHocRaidId: raid.id,
  });
}

for (const [key, raids] of raidsByUtcDay.entries()) {
  raids.sort((a, b) => a.displayStartsAtUtc - b.displayStartsAtUtc || a.title.localeCompare(b.title));
  raidsByUtcDay.set(key, raids);
}

const nowEpoch = Math.floor(Date.now() / 1000);
const nextPrimaryRaidKeys = new Set(
  allRaids
    .filter((raid) => raid.kind === 'primary' && raid.startsAtUtc >= nowEpoch)
    .sort((a, b) => a.startsAtUtc - b.startsAtUtc)
    .slice(0, 2)
    .map((raid) => raid.key)
);

const signupsByRaidKey = new Map<string, SignupRow>();
for (const row of signupRows) {
  if (row.raid_kind === 'primary' && row.primary_schedule_id && row.occurrence_start_utc) {
    const raidKey = resolveRaidKey('primary', row.primary_schedule_id, row.occurrence_start_utc);
    const existing = signupsByRaidKey.get(raidKey);
    if (!existing) {
      signupsByRaidKey.set(raidKey, row);
      continue;
    }

    const existingDelta = signupDeltaForRaid(raidKey, existing.occurrence_start_utc);
    const nextDelta = signupDeltaForRaid(raidKey, row.occurrence_start_utc);
    if (nextDelta < existingDelta || (nextDelta === existingDelta && row.id > existing.id)) {
      signupsByRaidKey.set(raidKey, row);
    }
  }
  if (row.raid_kind === 'adhoc' && row.ad_hoc_raid_id) {
    signupsByRaidKey.set(resolveRaidKey('adhoc', row.ad_hoc_raid_id), row);
  }
}

const dayCells: Array<{ isoDate: string; dayNumber: number; inMonth: boolean; raids: CalendarRaid[] }> = [];
for (let cursor = new Date(grid.gridStart); cursor < grid.gridEndExclusive; cursor = new Date(cursor.getTime() + 86400000)) {
  const isoDate = cursor.toISOString().slice(0, 10);
  dayCells.push({
    isoDate,
    dayNumber: cursor.getUTCDate(),
    inMonth: cursor.getUTCMonth() === monthIndex,
    raids: raidsByUtcDay.get(isoDate) ?? [],
  });
}

const monthTitle = grid.monthStart.toLocaleDateString('en-US', { month: 'long', year: 'numeric', timeZone: 'UTC' });
const statusParam = new URL(Astro.request.url).searchParams.get('status');
const selectedDay = new URL(Astro.request.url).searchParams.get('day');
const selectedDayCell = selectedDay ? dayCells.find((cell) => cell.isoDate === selectedDay) ?? null : null;
const selectedDayDisplayRaids = selectedDay
  ? allRaids.filter((raid) => dayKeyInTimeZone(raid.displayStartsAtUtc, userTimeZone) === selectedDay)
  : [];
const selectedDayRaids = (selectedDayDisplayRaids.length > 0
  ? selectedDayDisplayRaids
  : selectedDayCell?.raids ?? []
).sort((a, b) => a.displayStartsAtUtc - b.displayStartsAtUtc || a.title.localeCompare(b.title));

let selectedDaySummaryRows: DaySummarySignupRow[] = [];
let allRosterMembers: RosterMemberRow[] = [];
const mainCharacterNameByUserId = new Map<number, string>();
const benchOverrideKeySet = new Set<string>();
if (selectedDayCell) {
  const selectedDayStart = Math.floor(new Date(`${selectedDayCell.isoDate}T00:00:00.000Z`).getTime() / 1000);
  const selectedDayEnd = selectedDayStart + 86400;
  const summaryWindowStart = selectedDayStart - 86400;
  const summaryWindowEnd = selectedDayEnd + 86400;

  const [result, rosterResult, mainsResult, benchResult] = await env.DB.batch([
    env.DB.prepare(
      `SELECT
        rs.id,
        rs.raid_kind,
        rs.primary_schedule_id,
        rs.ad_hoc_raid_id,
        rs.occurrence_start_utc,
        rs.signed_up_at,
        rs.signup_status,
        rs.signup_role,
        rs.signup_notes,
        c.id AS character_id,
        c.name AS character_name,
        c.class_name,
        c.blizzard_char_id,
        u.nickname,
        u.battle_tag,
        rs.user_id
      FROM raid_signups rs
      JOIN characters c ON c.id = rs.character_id
      JOIN users u ON u.id = rs.user_id
      LEFT JOIN ad_hoc_raids ahr ON ahr.id = rs.ad_hoc_raid_id
      WHERE (
        rs.raid_kind = 'primary'
        AND rs.occurrence_start_utc >= ?
        AND rs.occurrence_start_utc < ?
      )
      OR (
        rs.raid_kind = 'adhoc'
        AND ahr.starts_at_utc >= ?
        AND ahr.starts_at_utc < ?
      )`
    ).bind(summaryWindowStart, summaryWindowEnd, summaryWindowStart, summaryWindowEnd),
    env.DB.prepare(
      `SELECT DISTINCT
        rtm.blizzard_char_id,
        rmc.name AS character_name,
        rmc.class_name,
        (
          SELECT u2.id
          FROM characters c2
          JOIN users u2 ON u2.id = c2.user_id
          WHERE c2.blizzard_char_id = rtm.blizzard_char_id
          LIMIT 1
        ) AS user_id,
        (
          SELECT u2.nickname
          FROM characters c2
          JOIN users u2 ON u2.id = c2.user_id
          WHERE c2.blizzard_char_id = rtm.blizzard_char_id
            AND u2.nickname IS NOT NULL
          LIMIT 1
        ) AS nickname
      FROM raid_team_members rtm
      JOIN roster_members_cache rmc ON rmc.blizzard_char_id = rtm.blizzard_char_id
      ORDER BY rmc.class_name ASC, rmc.name ASC`
    ),
    env.DB.prepare(
      `SELECT user_id, name AS main_character_name
       FROM characters
       WHERE is_main = 1`
    ),
    env.DB.prepare(
      `SELECT raid_ref_key, occurrence_start_utc, blizzard_char_id
       FROM raid_attendance_overrides
       WHERE override_kind = 'bench'
         AND occurrence_start_utc >= ?
         AND occurrence_start_utc < ?`
    ).bind(summaryWindowStart, summaryWindowEnd),
  ]);

  selectedDaySummaryRows = (result.results ?? []) as any[];
  selectedDaySummaryRows = selectedDaySummaryRows.map((r) => ({ ...r, isSigned: true }));
  allRosterMembers = (rosterResult.results ?? []) as RosterMemberRow[];
  const mainRows = (mainsResult.results ?? []) as MainCharacterRow[];
  for (const row of mainRows) {
    mainCharacterNameByUserId.set(row.user_id, row.main_character_name);
  }
  const benchRows = (benchResult.results ?? []) as BenchOverrideRow[];
  for (const row of benchRows) {
    benchOverrideKeySet.add(`${row.raid_ref_key}|${row.occurrence_start_utc}|${row.blizzard_char_id}`);
  }
}

const daySummaryByRaidKey = new Map<string, DaySummarySignupRow[]>();
for (const row of selectedDaySummaryRows) {
  const raidKey =
    row.raid_kind === 'primary' && row.primary_schedule_id && row.occurrence_start_utc
      ? resolveRaidKey('primary', row.primary_schedule_id, row.occurrence_start_utc)
      : row.raid_kind === 'adhoc' && row.ad_hoc_raid_id
        ? resolveRaidKey('adhoc', row.ad_hoc_raid_id)
        : null;

  if (!raidKey) continue;
  const arr = daySummaryByRaidKey.get(raidKey) ?? [];
  const rowIdentity = row.blizzard_char_id ?? row.character_id;
  const existingIndex = arr.findIndex((entry) => (entry.blizzard_char_id ?? entry.character_id) === rowIdentity);

  if (existingIndex === -1) {
    arr.push(row);
    daySummaryByRaidKey.set(raidKey, arr);
    continue;
  }

  const existing = arr[existingIndex];
  const existingDelta = signupDeltaForRaid(raidKey, existing.occurrence_start_utc);
  const nextDelta = signupDeltaForRaid(raidKey, row.occurrence_start_utc);
  if (
    nextDelta < existingDelta ||
    (nextDelta === existingDelta && (row.signed_up_at > existing.signed_up_at || row.id! > existing.id!))
  ) {
    arr[existingIndex] = row;
  }

  daySummaryByRaidKey.set(raidKey, arr);
}

// Merge roster members with signups for complete member list
const getRaidMembers = (raidKey: string): DaySummarySignupRow[] => {
  const signups = daySummaryByRaidKey.get(raidKey) ?? [];
  const signedUpCharIds = new Set(
    signups
      .map((r) => r.blizzard_char_id)
      .filter((id): id is number => typeof id === 'number' && id > 0)
  );

  // Combine signed up and unsigned members
  const allMembers: DaySummarySignupRow[] = [
    ...signups,
    ...allRosterMembers
      .filter((m) => !signedUpCharIds.has(m.blizzard_char_id))
      .map((m) => ({
        id: null,
        raid_kind: 'primary' as const,
        primary_schedule_id: null,
        ad_hoc_raid_id: null,
        occurrence_start_utc: null,
        signed_up_at: 0,
        signup_status: 'absent' as const,
        signup_role: 'ranged-dps' as AssignedRole,
        signup_notes: null,
        character_id: 0,
        character_name: m.character_name,
        class_name: m.class_name,
        blizzard_char_id: m.blizzard_char_id,
        user_id: m.user_id,
        nickname: m.nickname,
        battle_tag: null,
        isSigned: false,
      }))
  ];

  return allMembers.sort((a, b) => {
    if (a.isSigned !== b.isSigned) return b.isSigned ? 1 : -1;
    if (a.signed_up_at !== b.signed_up_at) return a.signed_up_at - b.signed_up_at;
    return a.character_name.localeCompare(b.character_name);
  });
};
---

<Layout title="Signup | The Hidden Lodge" description="Raid signup calendar for guild members.">
  <div class="signup-page">
    <header class="signup-header">
      <div>
        <h1>Raid Signup</h1>
        <p class="signup-intro">Choose your character and sign up directly from the calendar. Times are shown in <strong>{userTimeZone}</strong>.</p>
        <p class="summary-hint">Click any date number in the calendar to load that day&apos;s raid summary.</p>
      </div>
      <nav class="month-nav" aria-label="Calendar month navigation">
        <a href={`/signup?ym=${grid.prevYm}`} class="month-btn month-btn-prev">&larr; Prev</a>
        <span class="month-title-wrap">
          <span class="month-title" aria-live="polite">{monthTitle}</span>
        </span>
        <a href={`/signup?ym=${grid.nextYm}`} class="month-btn month-btn-next">Next &rarr;</a>
      </nav>
    </header>

    {statusParam === 'signed' && <p class="flash flash-ok">Signup saved.</p>}
    {statusParam === 'canceled' && <p class="flash flash-ok">Signup removed.</p>}
    {statusParam === 'signup-role-updated' && <p class="flash flash-ok">Signup role updated.</p>}
    {statusParam === 'bench-updated' && <p class="flash flash-ok">Bench override saved.</p>}
    {statusParam === 'bench-cleared' && <p class="flash flash-ok">Bench override removed.</p>}
    {statusParam === 'note-updated' && <p class="flash flash-ok">Note updated.</p>}
    {statusParam === 'error' && <p class="flash flash-error">Could not save signup. Please try again.</p>}

    {selectedDayCell && (
      <section class="day-summary" aria-labelledby="day-summary-heading">
        <h2 id="day-summary-heading">Raid Summary for {selectedDayCell.isoDate}</h2>
        {selectedDayRaids.length === 0 ? (
          <p class="summary-empty">No raids scheduled for this day.</p>
        ) : (
          <div class="summary-raid-list">
            {selectedDayRaids.map((raid) => {
              const allMembers = getRaidMembers(raid.key);
              const raidRefKey = raid.kind === 'primary' ? `primary:${raid.primaryScheduleId}` : `adhoc:${raid.adHocRaidId}`;
              const raidOccurrenceStartUtc = raid.kind === 'primary' ? raid.startsAtUtc : raid.startsAtUtc;
              const signedMembers = allMembers.filter((m) => m.isSigned);
              const summary = computeTeamSummary(
                signedMembers.map((row) => ({ className: row.class_name, assignedRole: row.signup_role }))
              );
              const comingCount = signedMembers.filter((r) => r.signup_status === 'coming').length;
              const tentativeCount = signedMembers.filter((r) => r.signup_status === 'tentative').length;
              const lateCount = signedMembers.filter((r) => r.signup_status === 'late').length;
              const absentCount = signedMembers.filter((r) => r.signup_status === 'absent').length;
              const notSignedCount = allMembers.filter((m) => !m.isSigned).length;

              return (
                <article class="summary-raid-card">
                  <h3>{raid.title}</h3>
                  <p class="summary-raid-time">{formatEpochInTimeZone(raid.displayStartsAtUtc, userTimeZone)}</p>
                  <p class="summary-counts">
                    Coming: <strong>{comingCount}</strong> &middot; Tentative: <strong>{tentativeCount}</strong> &middot; Late: <strong>{lateCount}</strong> &middot; Absent: <strong>{absentCount}</strong> &middot; Not Signed: <strong class="count-absent">{notSignedCount}</strong>
                  </p>

                  {signedMembers.length === 0 ? (
                    <p class="summary-empty">No member signups yet.</p>
                  ) : (
                    <>
                      <div class="summary-grid">
                        <article>
                          <h4>Role Count</h4>
                          <p>Tank: <strong>{summary.roleCounts.tank}</strong></p>
                          <p>Healer: <strong>{summary.roleCounts.healer}</strong></p>
                          <p>Melee DPS: <strong>{summary.roleCounts['melee-dps']}</strong></p>
                          <p>Ranged DPS: <strong>{summary.roleCounts['ranged-dps']}</strong></p>
                        </article>
                        <article>
                          <h4>Raid Buff Coverage</h4>
                          <ul class="pill-list">
                            {summary.raidBuffCounts.map(({ buff, count }) => (
                              <li class="pill buff-tooltip" data-tooltip={raidBuffDescription(buff)}>
                                {buff}
                                <span class="pill-count">{count}</span>
                              </li>
                            ))}
                            {summary.missingRaidBuffs.map((buff) => (
                              <li class="pill pill-missing buff-tooltip" data-tooltip={raidBuffDescription(buff)}>
                                {buff}
                                <span class="pill-count">0</span>
                              </li>
                            ))}
                          </ul>
                        </article>
                        <article>
                          <h4>Class Breakdown</h4>
                          <ul class="mini-list">
                            {summary.classDistribution.map((item) => (
                              <li>{item.className}: {item.count}</li>
                            ))}
                          </ul>
                        </article>
                        <article>
                          <h4>Token Breakdown</h4>
                          <ul class="mini-list">
                            {summary.tokenDistribution.map((item) => (
                              <li>
                                {item.token} ({tokenArmorType(item.token)}): {item.count}
                              </li>
                            ))}
                          </ul>
                        </article>
                      </div>

                      <div class="signups-table-wrapper">
                        <div class="table-controls">
                          <button type="button" class="btn-mini reset-filters-btn">Reset Filters</button>
                        </div>
                        <table class="signups-table js-signups-table">
                          <thead>
                            <tr>
                              <th><button type="button" class="sort-btn" data-sort-col="0">Character</button></th>
                              <th><button type="button" class="sort-btn" data-sort-col="1">Owner</button></th>
                              <th><button type="button" class="sort-btn" data-sort-col="2">Class</button></th>
                              <th><button type="button" class="sort-btn" data-sort-col="3">Role</button></th>
                              <th><button type="button" class="sort-btn" data-sort-col="4">Status</button></th>
                              <th><button type="button" class="sort-btn" data-sort-col="5">Selected At</button></th>
                              <th><button type="button" class="sort-btn" data-sort-col="6">Notes</button></th>
                              <th><button type="button" class="sort-btn" data-sort-col="7">Bench</button></th>
                            </tr>
                            <tr class="filter-row">
                              <th><input type="text" class="col-filter" data-filter-col="0" placeholder="Filter" /></th>
                              <th><input type="text" class="col-filter" data-filter-col="1" placeholder="Filter" /></th>
                              <th>
                                <select class="col-filter" data-filter-col="2">
                                  <option value="">All</option>
                                  <option value="death knight">Death Knight</option>
                                  <option value="demon hunter">Demon Hunter</option>
                                  <option value="druid">Druid</option>
                                  <option value="evoker">Evoker</option>
                                  <option value="hunter">Hunter</option>
                                  <option value="mage">Mage</option>
                                  <option value="monk">Monk</option>
                                  <option value="paladin">Paladin</option>
                                  <option value="priest">Priest</option>
                                  <option value="rogue">Rogue</option>
                                  <option value="shaman">Shaman</option>
                                  <option value="warlock">Warlock</option>
                                  <option value="warrior">Warrior</option>
                                  <option value="unknown">Unknown</option>
                                </select>
                              </th>
                              <th>
                                <select class="col-filter" data-filter-col="3">
                                  <option value="">All</option>
                                  {ROLE_OPTIONS.map((role) => (
                                    <option value={role.label.toLowerCase()}>{role.label}</option>
                                  ))}
                                </select>
                              </th>
                              <th>
                                <select class="col-filter" data-filter-col="4">
                                  <option value="">All</option>
                                  <option value="signed up">Signed Up</option>
                                  <option value="tentative">Tentative</option>
                                  <option value="late">Late</option>
                                  <option value="absent">Absent</option>
                                  <option value="not signed up">Not Signed Up</option>
                                </select>
                              </th>
                              <th><input type="text" class="col-filter" data-filter-col="5" placeholder="Filter" /></th>
                              <th><input type="text" class="col-filter" data-filter-col="6" placeholder="Filter" /></th>
                              <th><input type="text" class="col-filter" data-filter-col="7" placeholder="Filter" /></th>
                            </tr>
                          </thead>
                          <tbody>
                            {allMembers.map((row) => {
                              const statusLabel = signupStatusLabel(row);
                              const mainCharacterName = row.user_id ? mainCharacterNameByUserId.get(row.user_id) ?? '' : '';
                              const ownerText = row.nickname ?? ((mainCharacterName && mainCharacterName !== row.character_name) ? mainCharacterName : '');
                              const roleText = roleLabel(row.signup_role);
                              const notesText = row.signup_notes ?? '';
                              const selectedAtText = row.isSigned ? formatEpochInTimeZone(row.signed_up_at, userTimeZone) : '—';
                              const classIconUrl = fallbackClassIconUrl(row.class_name);
                              const unknownClass = row.class_name.trim().toLowerCase() === 'unknown';
                              const canEditRole = row.isSigned && (canOverrideAnyRole || row.user_id === user.id);
                              const benchKey = `${raidRefKey}|${raidOccurrenceStartUtc}|${row.blizzard_char_id ?? 0}`;
                              const isBench = (row.blizzard_char_id ?? 0) > 0 && benchOverrideKeySet.has(benchKey);

                              return (
