                                  </td>
                                  <td class="col-selected-at" data-value={row.isSigned ? String(row.signed_up_at) : ''}>{selectedAtText}</td>
                                  <td class="col-notes" data-value={notesText.toLowerCase()}>{notesText}</td>
                                  <td class="col-bench" data-value={isBench ? 'bench' : ''}>
                                    {canOverrideAnyRole && (row.blizzard_char_id ?? 0) > 0 ? (
                                      <form method="POST" action="/api/admin/attendance/toggle-bench" class="bench-admin-form">
                                        <input type="hidden" name="return_to" value={Astro.url.pathname + Astro.url.search} />
                                        <input type="hidden" name="raid_kind" value={raid.kind} />
                                        {raid.kind === 'primary' ? (
                                          <input type="hidden" name="primary_schedule_id" value={raid.primaryScheduleId!} />
                                        ) : (
                                          <input type="hidden" name="ad_hoc_raid_id" value={raid.adHocRaidId!} />
                                        )}
                                        <input type="hidden" name="occurrence_start_utc" value={raidOccurrenceStartUtc} />
                                        <input type="hidden" name="blizzard_char_id" value={row.blizzard_char_id!} />
                                        <input type="hidden" name="bench_action" value={isBench ? 'clear' : 'set'} />
                                        <button
                                          type="submit"
                                          class:list={['btn-mini', { 'btn-bench-active': isBench }]}
