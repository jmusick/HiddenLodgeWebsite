---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="The Hidden Lodge | Recruitment" description="Open classes and raid recruitment info for The Hidden Lodge.">
  <section>
    <h1 class="title-row"><Icon name="lucide:users" class="title-icon" aria-hidden="true" />Recruitment</h1>
    <p>
      We recruit players who value consistency, preparation, and a positive progression mindset.
      Exceptional applicants are always welcome.
    </p>
  </section>

  <section class="panel">
    <h2 class="title-row"><Icon name="lucide:target" class="title-icon" aria-hidden="true" />Current Needs</h2>
    <p class="panel-text">We are not actively recruiting for any specific class or role at this time. However, we are always open to exceptional players who bring skill, dedication, and a great attitude.</p>
  </section>

  <section class="panel">
    <h2 class="title-row"><Icon name="lucide:scroll-text" class="title-icon" aria-hidden="true" />How to Apply</h2>
    <p class="panel-text">Head to our <a href="https://raider.io/guilds/us/illidan/Hidden%20Lodge/" target="_blank" rel="noopener noreferrer">Raider.IO guild page</a> and submit an application through there.</p>
  </section>
</Layout>

<style>
  h1 {
    margin-top: 0;
    font-size: clamp(2rem, 3.1vw, 2.95rem);
  }

  p {
    max-width: 70ch;
    color: #d8e2e8;
    font-size: 1.05rem;
  }

  .panel {
    margin-top: 1rem;
    border: 1px solid rgba(214, 176, 106, 0.38);
    border-radius: 0.75rem;
    background:
      linear-gradient(155deg, rgba(214, 176, 106, 0.08), transparent 45%),
      rgba(11, 21, 32, 0.78);
    padding: 1rem;
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.22);
  }

  h2 {
    margin: 0;
    color: #e4c27a;
  }

  .title-row {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .title-icon {
    width: 1rem;
    height: 1rem;
    color: #f1d9a9;
  }

  .panel-text {
    margin: 0.6rem 0 0;
    font-size: 1rem;
    line-height: 1.6;
    color: #d8e2e8;
  }

  ol li a {
    color: #e4c27a;
    text-underline-offset: 3px;
  }

  ol li a:hover {
    color: #f1d9a9;
  }

  ul,
  ol {
    margin: 0.8rem 0 0;
    padding-left: 1.1rem;
    line-height: 1.6;
    color: #d8e2e8;
  }
</style>
