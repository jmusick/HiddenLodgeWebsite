                      <td>
                        <div>{row.worldSlotsFilled}/3</div>
                        <small class="history-subtext">Objectives: {row.worldWeeklyObjectives ?? 0}</small>
                      </td>
                      <td><strong>{row.totalSlotsFilled}/9</strong></td>
                      <td><span class="tier-badge" style={`color: ${score.color}; border-color: ${score.color}40`}>{score.score}/100</span></td>
                      <td>{new Date(row.snapshotTs * 1000).toLocaleDateString(undefined, { month: 'short', day: 'numeric' })}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        ) : (
          <p class="raid-progress-empty">No Great Vault history recorded yet. Weekly snapshots accumulate as raider refresh runs.</p>
        )}
      </details>

    </div>
  </section>

  {Astro.locals.isAdmin && (raidbotsDbDiag !== null || raidbotsTableError !== null) && (
    <div style="font-size: 11px; color: #8ea4b2; margin: 4px 16px 0; font-family: monospace; line-height: 1.6;">
      <strong>Raidbots DB diag (charId={raider.blizzardCharId}):</strong>
