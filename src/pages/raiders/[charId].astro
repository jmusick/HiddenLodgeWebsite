          | tables-ok: reports={String(raidbotsDbDiag.tableNamesHasReports)} scores={String(raidbotsDbDiag.tableNamesHasScores)}
          | statuses: {raidbotsDbDiag.statuses}
          | joined(all/ok/ok+fresh): {raidbotsDbDiag.joinedRowsAll}/{raidbotsDbDiag.joinedRowsOk}/{raidbotsDbDiag.joinedRowsOkFresh}
          | difficulties: {raidbotsDbDiag.difficulties}
        </span>
      )}
      {raidbotsTableError !== null && (
        <span style="color: #ff6b6b;"> | tableData error: {raidbotsTableError}</span>
      )}
    </div>
  )}
  <section>
    <RaiderSimTools
      charId={raider.blizzardCharId}
      charName={raider.name}
      charClass={raider.className}
      canManageSim={canManageSim}
      showSourceDebug={Boolean(Astro.locals.isAdmin)}
      raidbotsTableData={raidbotsTableData}
    />
  </section>
</Layout>

<script>
  document.addEventListener('click', (event) => {
    const target = event.target as HTMLElement;
    const link = target.closest<HTMLAnchorElement>('a.stat-anchor[href^="#"]');
    if (!link) return;

    const hash = link.getAttribute('href');
    if (!hash || hash.length < 2) return;
    const anchorTarget = document.querySelector<HTMLElement>(hash);
    if (!anchorTarget) return;

    event.preventDefault();

    // Keep anchors below the sticky top nav.
    const top = Math.max(0, anchorTarget.getBoundingClientRect().top + window.scrollY - 92);
    window.scrollTo({ top, behavior: 'smooth' });

    if (window.history?.replaceState) {
      window.history.replaceState(null, '', hash);
    }
  });
</script>

