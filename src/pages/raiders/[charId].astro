---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { env } from 'cloudflare:workers';
import { classColor } from '../../lib/wow';
import { getRaiderByCharId, getRaiderGear, getRaiderMedia, getPreparednessHistory, getProgressionHistory, getVaultHistory } from '../../lib/raiders';
import { isCharacterOwner } from '../../lib/auth';
import { getLatestSingleTargetForRaiders, getLatestSimsForRaiderByDifficulty, getRaiderRaidbotsTableData } from '../../lib/sim-api';
import { attendanceScoringStartUtc, attendanceStatusLabel, getAttendanceSummaryMap } from '../../lib/attendance';
import { RAID_PROGRESS_TARGET_GROUPS } from '../../data/raidProgressTargets';
import RaiderSimTools from '../../components/RaiderSimTools.astro';

const { charId } = Astro.params;
const id = Number(charId);
if (!charId || !Number.isFinite(id)) {
  return new Response('Not found', { status: 404 });
}

const [raider, media, preparednessHistory, progressionHistory, vaultHistory, gear] = await Promise.all([
  getRaiderByCharId(id),
  getRaiderMedia(id),
  getPreparednessHistory(id),
  getProgressionHistory(id),
  getVaultHistory(id),
  getRaiderGear(id),
]);
if (!raider) {
  return new Response('Not found', { status: 404 });
}
const { portrait, fullBody } = media;
const nowEpoch = Math.floor(Date.now() / 1000);

await Promise.all([
  getLatestSingleTargetForRaiders((env as any).DB, [id], { maxAgeSeconds: 14 * 24 * 60 * 60 }),
  getLatestSimsForRaiderByDifficulty((env as any).DB, id, { maxAgeSeconds: 14 * 24 * 60 * 60 }),
]);

const attendanceSummaryMap = await getAttendanceSummaryMap((env as any).DB, { includeBreakdownFor: [id] });
const attendanceSummary = attendanceSummaryMap.get(id) ?? null;
const attendanceBreakdown = attendanceSummary?.breakdown ?? [];
const attendanceStartLabel = new Date(attendanceScoringStartUtc() * 1000).toLocaleDateString(undefined, {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

function authLabel(state: string): string {
  if (state === 'ready') return 'Profile Ready';
  if (state === 'expired') return 'Profile Stale';
  if (state === 'unavailable') return 'Profile Unavailable';
  return 'Profile Pending';
}

function authStatusTitle(state: string): string {
  if (state === 'ready') return 'Blizzard profile and equipment data were fetched successfully.';
  if (state === 'expired') return 'Blizzard profile data exists, but it is stale and needs refresh.';
  if (state === 'unavailable') return 'Blizzard profile data could not be fetched.';
  return 'Blizzard profile data has not been fetched yet.';
}

function formatProfileFetchedAt(timestamp: number | null): string | null {
  if (!timestamp) return null;

  return new Date(timestamp * 1000).toLocaleString(undefined, {
    month: 'short',
    day: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
  });
}

function formatProfileFetchedAtTitle(timestamp: number | null): string | null {
  if (!timestamp) return null;

  return new Date(timestamp * 1000).toLocaleString(undefined, {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
    second: '2-digit',
  });
}

function scoreColor(filled: number | null, total: number | null): string {
  if (filled === null || total === null || total === 0) return 'inherit';
  const pct = filled / total;
  if (pct >= 1)    return '#a335ee';
  if (pct >= 0.75) return '#0070dd';
  if (pct >= 0.5)  return '#1eff00';
  return '#ffffff';
}

function simDifficultyLabel(value: string): string {
  const normalized = value.trim().toLowerCase();
  if (normalized === 'mythic') return 'Mythic';
  if (normalized === 'heroic') return 'Heroic';
  return 'Unknown';
}

function formatScore(filled: number | null, total: number | null): string {
  if (filled === null || total === null) return '—';
  if (total === 0) return 'N/A';
  return `${Math.round((filled / total) * 100)}% (${filled}/${total})`;
}

function crestColor(label: string): string {
  if (label === 'Myth') return '#ff8000';
  if (label === 'Hero') return '#a335ee';
  if (label === 'Champion') return '#0070dd';
  if (label === 'Veteran') return '#1eff00';
  return '#ffffff';
}

function crestShortLabel(label: string): string {
  if (label === 'Adventurer') return 'Adv';
  if (label === 'Veteran') return 'Vet';
  if (label === 'Champion') return 'Champ';
  if (label === 'Hero') return 'Hero';
  if (label === 'Myth') return 'Myth';
  return label;
}

function attendanceColor(score: number | null): string {
  if (score === null) return '#8ea4b2';
  if (score >= 100) return '#ff8000';
  if (score >= 90) return '#a335ee';
  if (score >= 80) return '#0070dd';
  if (score >= 65) return '#1eff00';
  return '#ffffff';
}

type VaultTrack = 'Mythic' | 'Heroic' | 'Champion' | 'Veteran' | 'Normal' | 'Raid Finder' | null;

function vaultTrackFromIlvl(itemLevel: number | null): VaultTrack {
  if (itemLevel === null) return null;
  if (itemLevel >= 272) return 'Mythic';
  if (itemLevel >= 266) return 'Heroic';
  if (itemLevel >= 263) return 'Champion';
  if (itemLevel >= 259) return 'Veteran';
  return null;
}

function raidVaultTrackFromIlvl(itemLevel: number | null): VaultTrack {
  if (itemLevel === null) return null;
  if (itemLevel >= 272) return 'Mythic';
  if (itemLevel >= 266) return 'Heroic';
  if (itemLevel >= 259) return 'Normal';
  if (itemLevel >= 252) return 'Raid Finder';
  return null;
}

function vaultTrackColor(track: VaultTrack): string {
  if (track === 'Mythic') return '#ff8000';
  if (track === 'Heroic') return '#a335ee';
  if (track === 'Normal') return '#0070dd';
  if (track === 'Raid Finder') return '#1eff00';
  if (track === 'Champion') return '#0070dd';
  if (track === 'Veteran') return '#1eff00';
  return '#8ea4b2';
}

interface GreatVaultOption {
  itemLevel: number | null;
  unlocked: boolean;
}

interface GreatVaultRow {
  label: string;
  objectivePrefix: string;
  sourceNote: string;
  options: GreatVaultOption[];
}

interface RaidVaultPayload {
  weeklyBossKills: number;
  options: Array<number | null>;
}

const crestCards = [
  { label: 'Adventurer', value: raider.adventurerCrests },
  { label: 'Veteran', value: raider.veteranCrests },
  { label: 'Champion', value: raider.championCrests },
  { label: 'Hero', value: raider.heroCrests },
  { label: 'Myth', value: raider.mythCrests },
];

const crestTotal = [
  raider.adventurerCrests,
  raider.veteranCrests,
  raider.championCrests,
  raider.heroCrests,
  raider.mythCrests,
].some((value) => value !== null)
  ? Math.max(0, raider.adventurerCrests ?? 0)
    + Math.max(0, raider.veteranCrests ?? 0)
    + Math.max(0, raider.championCrests ?? 0)
    + Math.max(0, raider.heroCrests ?? 0)
    + Math.max(0, raider.mythCrests ?? 0)
  : null;

function preparednessTotals(record: NonNullable<typeof raider>) {
  const socketedGems = record.avg30dSocketedGems ?? record.socketedGems;
  const totalSockets = record.avg30dTotalSockets ?? record.totalSockets;
  const enchantedSlots = record.avg30dEnchantedSlots ?? record.enchantedSlots;
  const enchantableSlots = record.avg30dEnchantableSlots ?? record.enchantableSlots;

  if (
    socketedGems === null ||
    totalSockets === null ||
    enchantedSlots === null ||
    enchantableSlots === null
  ) {
    return { filled: null, total: null };
  }

  return {
    filled: socketedGems + enchantedSlots,
    total: totalSockets + enchantableSlots,
  };
}

function preparednessTierDisplay(filled: number | null, total: number | null): { label: string; color: string } {
  if (filled === null || total === null) return { label: '—', color: '#ffffff' };
  if (total === 0) return { label: 'N/A', color: '#ffffff' };

  const pct = filled / total;
  if (pct >= 1) return { label: 'S Tier', color: '#ff8000' };
  if (pct >= 0.85) return { label: 'A Tier', color: '#a335ee' };
  if (pct >= 0.7) return { label: 'B Tier', color: '#0070dd' };
  if (pct >= 0.4) return { label: 'C Tier', color: '#1eff00' };
  return { label: 'D Tier', color: '#ffffff' };
}

const VAULT_SLOT_POSITION_WEIGHTS = [1, 1.35, 1.8] as const;

function raidDifficultyWeight(itemLevel: number | null): number {
  if (itemLevel === null) return 0;
  if (itemLevel >= 272) return 1.45; // Mythic
  if (itemLevel >= 266) return 1.25; // Heroic
  if (itemLevel >= 259) return 1.0;  // Normal
  if (itemLevel >= 252) return 0.75; // Raid Finder
  return 0.6;
}

function dungeonDifficultyWeight(itemLevel: number | null): number {
  if (itemLevel === null) return 0;
  if (itemLevel >= 272) return 1.45; // Mythic-track reward (e.g. +10)
  if (itemLevel >= 269) return 1.3;
  if (itemLevel >= 266) return 1.15;
  if (itemLevel >= 263) return 1.0;
  if (itemLevel >= 259) return 0.85;
  return 0.7;
}

function greatVaultWeightedScore(row: {
  raidSlot1Ilvl: number | null;
  raidSlot2Ilvl: number | null;
  raidSlot3Ilvl: number | null;
  dungeonSlot1Ilvl: number | null;
  dungeonSlot2Ilvl: number | null;
  dungeonSlot3Ilvl: number | null;
  worldSlotsFilled: number;
}): { points: number; maxPoints: number; pct: number } {
  const raidSlots = [row.raidSlot1Ilvl, row.raidSlot2Ilvl, row.raidSlot3Ilvl] as const;
  const dungeonSlots = [row.dungeonSlot1Ilvl, row.dungeonSlot2Ilvl, row.dungeonSlot3Ilvl] as const;

  let points = 0;
  let maxPoints = 0;

  for (let i = 0; i < 3; i += 1) {
    const slotWeight = VAULT_SLOT_POSITION_WEIGHTS[i];
    points += raidDifficultyWeight(raidSlots[i]) * slotWeight;
    points += dungeonDifficultyWeight(dungeonSlots[i]) * slotWeight;

    // Max assumes Mythic-equivalent raid + dungeon slots.
    maxPoints += 1.45 * slotWeight;
    maxPoints += 1.45 * slotWeight;

    // World contributes much less than raid/dungeon, but still counts.
    if ((row.worldSlotsFilled ?? 0) > i) {
      points += 0.35 * slotWeight;
    }
    maxPoints += 0.35 * slotWeight;
  }

  const pct = maxPoints > 0 ? Math.max(0, Math.min(1, points / maxPoints)) : 0;
  return { points, maxPoints, pct };
}

function greatVaultScoreDisplay(row: {
  raidSlot1Ilvl: number | null;
  raidSlot2Ilvl: number | null;
  raidSlot3Ilvl: number | null;
  dungeonSlot1Ilvl: number | null;
  dungeonSlot2Ilvl: number | null;
  dungeonSlot3Ilvl: number | null;
  worldSlotsFilled: number;
}): { score: number; color: string } {
  const { pct } = greatVaultWeightedScore(row);
  const score = Math.round(pct * 100);

  if (score >= 95) return { score, color: '#ff8000' };
  if (score >= 85) return { score, color: '#a335ee' };
  if (score >= 70) return { score, color: '#0070dd' };
  if (score >= 40) return { score, color: '#1eff00' };
  return { score, color: '#ffffff' };
}

const preparedness = preparednessTotals(raider);
const preparednessTier = preparednessTierDisplay(preparedness.filled, preparedness.total);

function parseRaidVaultPayload(label: string | null): RaidVaultPayload | null {
  if (!label) return null;

  try {
    const parsed = JSON.parse(label) as { vaultRaid?: { weeklyBossKills?: unknown; options?: unknown } };
    if (!parsed?.vaultRaid || !Array.isArray(parsed.vaultRaid.options)) return null;

    const options = parsed.vaultRaid.options
      .slice(0, 3)
      .map((value) => {
        const asNumber = Number(value);
        return Number.isFinite(asNumber) && asNumber > 0 ? Math.floor(asNumber) : null;
      });

    while (options.length < 3) options.push(null);

    const weeklyBossKillsRaw = Number(parsed.vaultRaid.weeklyBossKills ?? 0);
    const weeklyBossKills = Number.isFinite(weeklyBossKillsRaw) ? Math.max(0, Math.floor(weeklyBossKillsRaw)) : 0;

    return { weeklyBossKills, options };
  } catch {
    return null;
  }
}

const raidVaultPayload = parseRaidVaultPayload(raider.raidProgressLabel);
const worldWeeklyObjectives = Math.max(0, raider.worldVaultWeeklyObjectives ?? 0);

const greatVaultRows: GreatVaultRow[] = [
  {
    label: 'Raid',
    objectivePrefix: 'Defeat',
    sourceNote: raidVaultPayload
      ? `Live weekly raid kills: ${raidVaultPayload.weeklyBossKills}`
      : 'No weekly raid kill payload yet',
    options: (raidVaultPayload?.options ?? [null, null, null]).map((itemLevel) => ({
      itemLevel,
      unlocked: itemLevel !== null,
    })),
  },
  {
    label: 'Dungeon',
    objectivePrefix: 'Complete',
    sourceNote: 'Live from Raider.IO weekly highest-level keys',
    options: [raider.mythicPlusVaultIlvl1, raider.mythicPlusVaultIlvl2, raider.mythicPlusVaultIlvl3].map((itemLevel) => ({
      itemLevel,
      unlocked: itemLevel !== null,
    })),
  },
  {
    label: 'World',
    objectivePrefix: 'Complete',
    sourceNote: `Live weekly world objectives (delves): ${worldWeeklyObjectives}`,
    options: [2, 4, 8].map((required) => ({
      itemLevel: null,
      unlocked: worldWeeklyObjectives >= required,
    })),
  },
];

const greatVaultFilledSlots = greatVaultRows.reduce(
  (sum, row) => sum + row.options.filter((option) => option.unlocked).length,
  0
);

const currentGreatVaultScore = greatVaultScoreDisplay({
  raidSlot1Ilvl: raidVaultPayload?.options[0] ?? null,
  raidSlot2Ilvl: raidVaultPayload?.options[1] ?? null,
  raidSlot3Ilvl: raidVaultPayload?.options[2] ?? null,
  dungeonSlot1Ilvl: raider.mythicPlusVaultIlvl1,
  dungeonSlot2Ilvl: raider.mythicPlusVaultIlvl2,
  dungeonSlot3Ilvl: raider.mythicPlusVaultIlvl3,
  worldSlotsFilled: [2, 4, 8].filter((required) => worldWeeklyObjectives >= required).length,
});

const greatVaultSlotTotal = greatVaultRows.length * 3;
const greatVaultMissingSlots = Math.max(0, greatVaultSlotTotal - greatVaultFilledSlots);

const VAULT_OPTION_TARGETS = [1, 2, 3] as const;

function vaultObjectiveText(row: GreatVaultRow, index: number): string {
  const target = VAULT_OPTION_TARGETS[index] ?? index + 1;
  if (row.label === 'Raid') {
    return `${row.objectivePrefix} ${target * 2} bosses`;
  }
  if (row.label === 'Dungeon') {
    return `${row.objectivePrefix} ${target === 1 ? 1 : target === 2 ? 4 : 8} dungeons`;
  }
  return `${row.objectivePrefix} ${target === 1 ? 2 : target === 2 ? 4 : 8} world objectives`;
}

interface RaidProgressMatrixRow {
  mode: 'L' | 'N' | 'H' | 'M';
  cells: string[];
}

interface RaidProgressMatrix {
  headers: string[];
  rows: RaidProgressMatrixRow[];
}

function parseRaidProgressMatrix(label: string | null): RaidProgressMatrix | null {
  if (!label) return null;

  try {
    const parsed = JSON.parse(label) as RaidProgressMatrix;
    if (!parsed || !Array.isArray(parsed.headers) || !Array.isArray(parsed.rows)) return null;

    const headers = parsed.headers
      .map((header) => String(header).trim().toUpperCase())
      .filter(Boolean);
    if (headers.length === 0) return null;

    const rows = parsed.rows
      .map((row) => ({
        mode: String(row.mode ?? '').toUpperCase() as 'L' | 'N' | 'H' | 'M',
        cells: Array.isArray(row.cells) ? row.cells.map((cell) => String(cell).trim()) : [],
      }))
      .filter((row) => ['L', 'N', 'H', 'M'].includes(row.mode));

    if (rows.length === 0) return null;

    const normalizedRows = rows.map((row) => {
      const cells = row.cells.slice(0, headers.length);
      while (cells.length < headers.length) cells.push('0/0');
      return { mode: row.mode, cells } as RaidProgressMatrixRow;
    });

    return { headers, rows: normalizedRows };
  } catch {
    return null;
  }
}

const RAID_NAME_BY_CODE = new Map(
  RAID_PROGRESS_TARGET_GROUPS.flatMap((group) =>
    group.raids.map((raid) => [raid.code.toUpperCase(), raid.raidName] as const)
  )
);

function fullRaidName(code: string): string {
  return RAID_NAME_BY_CODE.get(code.toUpperCase()) ?? code;
}

function fullDifficultyName(mode: 'L' | 'N' | 'H' | 'M'): string {
  if (mode === 'L') return 'Raid Finder';
  if (mode === 'N') return 'Normal';
  if (mode === 'H') return 'Heroic';
  return 'Mythic';
}

function formatVaultWeekLabel(weekStartTs: number, weekEndTs: number): string {
  const start = new Date(weekStartTs * 1000);
  const end = new Date((weekEndTs - 1) * 1000);
  const startLabel = start.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
  const endLabel = end.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
  return `${startLabel} - ${endLabel}`;
}

const color = classColor(raider.className);
const pageTitle = `${raider.name} — ${raider.realm} | The Hidden Lodge`;
const raidProgressMatrix = parseRaidProgressMatrix(raider.raidProgressLabel);
const warcraftLogsUrl = `https://www.warcraftlogs.com/character/id/${raider.blizzardCharId}`;
const canManageSim = Boolean(
  Astro.locals.user && (
    Astro.locals.isAdmin || await isCharacterOwner((env as any).DB, Astro.locals.user.id, raider.blizzardCharId)
  )
);
let raidbotsTableError: string | null = null;
const raidbotsTableData = await getRaiderRaidbotsTableData((env as any).DB, raider.blizzardCharId).catch((e: unknown) => {
  raidbotsTableError = String((e instanceof Error ? e.message : null) ?? e ?? 'unknown error');
  return [] as Awaited<ReturnType<typeof getRaiderRaidbotsTableData>>;
});

type RaidbotsDbDiag = {
  reportCount: number; scoreCount: number; latestFetchedAt: number | null;
  tableNamesHasReports: boolean; tableNamesHasScores: boolean;
  statuses: string; joinedRowsAll: number; joinedRowsOk: number;
  joinedRowsOkFresh: number; difficulties: string;
};
let raidbotsDbDiag: RaidbotsDbDiag | null = null;
if (Astro.locals.isAdmin) {
  try {
    const diagDb = (env as any).DB as import('@cloudflare/workers-types').D1Database;
    const cutoff = Math.floor(Date.now() / 1000) - 7 * 24 * 60 * 60;
    const [reportRow, scoreRow, tableNamesResult, statusResult, joinedAll, joinedOk, joinedOkFresh, diffResult] = await Promise.all([
      diagDb.prepare('SELECT COUNT(*) AS cnt, MAX(fetched_at) AS latest FROM sim_raidbots_reports WHERE blizzard_char_id = ?')
        .bind(raider.blizzardCharId).first<{ cnt: number; latest: number | null }>(),
      diagDb.prepare('SELECT COUNT(*) AS cnt FROM sim_raidbots_item_scores WHERE blizzard_char_id = ?')
        .bind(raider.blizzardCharId).first<{ cnt: number }>(),
      diagDb.prepare("SELECT name FROM sqlite_master WHERE type = 'table'").all<{ name: string }>(),
      diagDb.prepare('SELECT status, COUNT(*) AS cnt FROM sim_raidbots_reports WHERE blizzard_char_id = ? GROUP BY status')
        .bind(raider.blizzardCharId).all<{ status: string; cnt: number }>(),
      diagDb.prepare('SELECT COUNT(*) AS cnt FROM sim_raidbots_item_scores sis JOIN sim_raidbots_reports srr ON srr.id = sis.raidbots_report_id WHERE (sis.blizzard_char_id = ? OR srr.blizzard_char_id = ?)')
        .bind(raider.blizzardCharId, raider.blizzardCharId).first<{ cnt: number }>(),
      diagDb.prepare("SELECT COUNT(*) AS cnt FROM sim_raidbots_item_scores sis JOIN sim_raidbots_reports srr ON srr.id = sis.raidbots_report_id WHERE (sis.blizzard_char_id = ? OR srr.blizzard_char_id = ?) AND srr.status = 'ok'")
        .bind(raider.blizzardCharId, raider.blizzardCharId).first<{ cnt: number }>(),
      diagDb.prepare("SELECT COUNT(*) AS cnt FROM sim_raidbots_item_scores sis JOIN sim_raidbots_reports srr ON srr.id = sis.raidbots_report_id WHERE (sis.blizzard_char_id = ? OR srr.blizzard_char_id = ?) AND srr.status = 'ok' AND srr.fetched_at >= ?")
        .bind(raider.blizzardCharId, raider.blizzardCharId, cutoff).first<{ cnt: number }>(),
      diagDb.prepare('SELECT COALESCE(sis.difficulty, srr.difficulty) AS diff, COUNT(*) AS cnt FROM sim_raidbots_item_scores sis JOIN sim_raidbots_reports srr ON srr.id = sis.raidbots_report_id WHERE sis.blizzard_char_id = ? GROUP BY diff')
        .bind(raider.blizzardCharId).all<{ diff: string | null; cnt: number }>(),
    ]);
    const tableNames = new Set((tableNamesResult.results ?? []).map((r) => r.name));
    raidbotsDbDiag = {
      reportCount: reportRow?.cnt ?? 0,
      scoreCount: scoreRow?.cnt ?? 0,
      latestFetchedAt: reportRow?.latest ?? null,
      tableNamesHasReports: tableNames.has('sim_raidbots_reports'),
      tableNamesHasScores: tableNames.has('sim_raidbots_item_scores'),
      statuses: (statusResult.results ?? []).map((r) => `${r.status}:${r.cnt}`).join(', ') || 'none',
      joinedRowsAll: joinedAll?.cnt ?? 0,
      joinedRowsOk: joinedOk?.cnt ?? 0,
      joinedRowsOkFresh: joinedOkFresh?.cnt ?? 0,
      difficulties: (diffResult.results ?? []).map((r) => `${r.diff ?? 'null'}:${r.cnt}`).join(', ') || 'none',
    };
  } catch { /* ignore diagnostic errors */ }
}
const blizzardArmoryUrl = raider.realmSlug
  ? `https://worldofwarcraft.blizzard.com/en-us/character/us/${encodeURIComponent(raider.realmSlug)}/${encodeURIComponent(raider.name.toLowerCase())}/`
  : null;
const raiderIoUrl = raider.realmSlug
  ? `https://raider.io/characters/us/${encodeURIComponent(raider.realmSlug)}/${encodeURIComponent(raider.name)}`
  : null;
const profileFetchedAtLabel = formatProfileFetchedAt(raider.lastCheckedAt);
const profileFetchedAtTitle = formatProfileFetchedAtTitle(raider.lastCheckedAt);
const profileFetchedAtIso = raider.lastCheckedAt ? new Date(raider.lastCheckedAt * 1000).toISOString() : null;
const leftGearSlots = ['HEAD', 'NECK', 'SHOULDER', 'BACK', 'CHEST', 'WRIST'];
const rightGearSlots = ['HANDS', 'WAIST', 'LEGS', 'FEET', 'FINGER_1', 'FINGER_2', 'TRINKET_1', 'TRINKET_2'];
const weaponSlots = ['MAIN_HAND', 'OFF_HAND'];
const gearBySlot = new Map(gear.map((entry) => [entry.slotKey, entry]));

function enchantAffixState(item: (typeof gear)[number] | undefined): { missing: boolean; tooltip: string; label: string } {
  if (!item?.itemName || !item.canEnchant) {
    return { missing: false, tooltip: 'Enchant not available for this item', label: 'Enchant not available for this item' };
  }
  if (item.enchantments.length > 0) {
    const primary = item.enchantments[0]?.trim() || 'Enchant applied';
    return { missing: false, tooltip: primary, label: `Enchant details: ${primary}` };
  }
  return { missing: true, tooltip: 'Missing enchant', label: 'Missing enchant' };
}

function gemAffixState(item: (typeof gear)[number] | undefined): { missing: boolean; tooltip: string; label: string } {
  if (!item?.itemName || !item.canGem) {
    return { missing: false, tooltip: 'No gem socket on this item', label: 'No gem socket on this item' };
  }
  if (item.gems.length > 0) {
    const joined = item.gems.join(' | ');
    return { missing: false, tooltip: joined, label: `Gem details: ${item.gems.join(', ')}` };
  }
  return { missing: true, tooltip: 'Missing gems', label: 'Missing gems' };
}
---

<Layout title={pageTitle}>
  <section>
    <a href="/raiders" class="back-link">
      <Icon name="lucide:arrow-left" aria-hidden="true" />
      Back to Raiders
    </a>

    <header class="raider-header">
      {portrait
