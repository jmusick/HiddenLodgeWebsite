                      : vaultTrackFromIlvl(option.itemLevel);
                    const unlocked = option.unlocked;
                    const trackLabel = track ?? (unlocked ? 'Unlocked' : 'Locked');
                    const rewardLabel = option.itemLevel !== null
                      ? `iLvl ${option.itemLevel}`
                      : unlocked
                        ? null
                        : '—';
                    return (
                      <article class:list={[
                        'vault-option-card',
                        { 'vault-option-card-unlocked': unlocked, 'vault-option-card-locked': !unlocked },
                      ]} role="listitem">
                        <div class="vault-option-state" aria-hidden="true">
