                        <p class="vault-objective">{vaultObjectiveText(row, index)}</p>
                        <div class="vault-reward-track" style={`color: ${vaultTrackColor(track)}`}>
                          {trackLabel}
                        </div>
                        {rewardLabel !== null && <div class="vault-item-level">{rewardLabel}</div>}
                      </article>
                    );
                  })}
                </div>
