                  <th style="color: #1eff00">V</th>
                  <th style="color: #0070dd">C</th>
                  <th style="color: #a335ee">H</th>
                  <th style="color: #ff8000">M</th>
                  <th>Missing</th>
                  <th>Missing Δ</th>
                </tr>
              </thead>
              <tbody>
                {progressionHistory.map((row, i) => {
                  const prev = progressionHistory[i + 1];
                  const missingDelta = (row.totalUpgradesMissing !== null && prev?.totalUpgradesMissing !== null && prev?.totalUpgradesMissing !== undefined)
                    ? row.totalUpgradesMissing - prev.totalUpgradesMissing
                    : null;
                  return (
                    <tr>
                      <td class="date-col">{new Date(row.recordedAt * 1000).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })}</td>
                      <td>{row.adventurerCrests ?? '—'}</td>
