                      <td class:list={['delta-col', { 'delta-pos': missingDelta !== null && missingDelta < 0, 'delta-neg': missingDelta !== null && missingDelta > 0 }]}>
                        {missingDelta === null ? '—' : missingDelta > 0 ? `+${missingDelta}` : String(missingDelta)}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        ) : (
          <p class="raid-progress-empty">No crests/upgrades history recorded yet. History accumulates with each cron refresh.</p>
        )}
      </details>

