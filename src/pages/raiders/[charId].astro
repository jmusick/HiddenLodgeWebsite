                    <tr>
                      <td class="date-col">{new Date(row.occurrenceStartUtc * 1000).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })}</td>
                      <td>{attendanceStatusLabel(row.signupStatus)}</td>
                      <td>
                        <span class="attendance-boss-summary">{row.bossKillsPresent}/{row.totalBosses}</span>
                        <span class="attendance-result-pills" aria-label={`Raid result: ${row.bossWipes} wipes`}>
                          <span class="attendance-result-pill attendance-result-pill-wipe">{row.bossWipes}W</span>
                        </span>
                      </td>
                      <td>{row.isBench ? 'Yes' : '—'}</td>
                      <td>
                        {row.pointsEarned.toFixed(1)} / {row.pointsPossible}
                        {row.benchBonusPoints > 0 && <small class="history-subtext"> (+{row.benchBonusPoints.toFixed(1)})</small>}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <details class="vault-score-formula attendance-score-formula">
              <summary class="vault-score-formula-toggle">
                <span class="vault-score-formula-label-wrap">
                  <Icon name="lucide:calculator" class="vault-score-formula-icon" aria-hidden="true" />
                  <span>Score Formula</span>
                  <span class="vault-score-formula-subtitle">(how attendance score is calculated)</span>
                </span>
                <span class="vault-score-formula-chevron" aria-hidden="true">▼</span>
              </summary>
              <div class="vault-score-formula-body">
                <p>Attendance score is normalized to 100 points per raid and then averaged across scored raids.</p>
                <p>Per raid points = 100 * signupWeight * participationRatio, unless marked bench or Coming no-show.</p>
                <p>participationRatio = bossKillsPresent / totalBossKills for that raid night.</p>
                <p>Special rule: if signupStatus is Coming, parsed attendance data exists, and no participation is detected (kills or wipe attempts), per raid points = -30.</p>
                <p>Final attendance score = (sum of per raid points / (100 * scoredRaids)) * 100.</p>
                <p>Bench override awards full 100 points and adds +12 bonus points for that raid.</p>
                <div class="vault-formula-table-wrap">
                  <table class="vault-formula-table" aria-label="Attendance status weights">
                    <thead>
                      <tr>
                        <th>Signup Status</th>
                        <th>Weight</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr><td>Coming</td><td>1.00</td></tr>
                      <tr><td>Coming (Confirmed No Show)</td><td>-30 points</td></tr>
                      <tr><td>Tentative</td><td>0.90</td></tr>
                      <tr><td>Late</td><td>0.90</td></tr>
                      <tr><td>Absent</td><td>0.80</td></tr>
                      <tr><td>Unsigned</td><td>0.30</td></tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </details>
          </>
        ) : (
          <p class="raid-progress-empty">No scored attendance raids yet. Attendance starts at {attendanceStartLabel} after logs are parsed.</p>
        )}
      </details>

      <details class="preparedness-history-panel panel preparedness-history-panel-two-week">
        <summary class="prep-history-summary" aria-label="Preparedness history">
          <Icon name="lucide:history" class="raid-progress-icon" aria-hidden="true" />
          Preparedness History
          <span class="history-subtitle">(2-week rolling)</span>
          <Icon name="lucide:chevron-down" class="collapse-chevron" aria-hidden="true" />
        </summary>
        {preparednessHistory.length > 0 ? (
          <div class="prep-history-table-wrap">
            <table class="prep-history-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Gems</th>
                  <th>Enchants</th>
                  <th>Combined</th>
                  <th>Tier</th>
                </tr>
              </thead>
              <tbody>
                {preparednessHistory.map((row) => {
                  const combinedFilled = row.socketedGems !== null && row.enchantedSlots !== null ? row.socketedGems + row.enchantedSlots : null;
                  const combinedTotal = row.totalSockets !== null && row.enchantableSlots !== null ? row.totalSockets + row.enchantableSlots : null;
                  const combinedPct = combinedFilled !== null && combinedTotal && combinedTotal > 0 ? combinedFilled / combinedTotal : null;

                  const tierLabel = combinedPct === null ? '—'
                    : combinedPct >= 1 ? 'S'
                    : combinedPct >= 0.85 ? 'A'
                    : combinedPct >= 0.7 ? 'B'
                    : combinedPct >= 0.4 ? 'C'
                    : 'D';
                  const tierColor = combinedPct === null ? '#b0c4d0'
                    : combinedPct >= 1 ? '#ff8000'
                    : combinedPct >= 0.85 ? '#a335ee'
                    : combinedPct >= 0.7 ? '#0070dd'
                    : combinedPct >= 0.4 ? '#1eff00'
                    : '#ffffff';

                  return (
                    <tr>
                      <td class="date-col">{new Date(row.recordedAt * 1000).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })}</td>
                      <td style={`color: ${scoreColor(row.socketedGems, row.totalSockets)}`}>{formatScore(row.socketedGems, row.totalSockets)}</td>
                      <td style={`color: ${scoreColor(row.enchantedSlots, row.enchantableSlots)}`}>{formatScore(row.enchantedSlots, row.enchantableSlots)}</td>
                      <td style={`color: ${scoreColor(combinedFilled, combinedTotal)}`}>{formatScore(combinedFilled, combinedTotal)}</td>
                      <td><span class="tier-badge" style={`color: ${tierColor}; border-color: ${tierColor}40`}>{tierLabel}</span></td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        ) : (
          <p class="raid-progress-empty">No preparedness history recorded yet. History accumulates with each cron refresh.</p>
        )}
      </details>

      <details class="preparedness-history-panel panel">
        <summary class="prep-history-summary" aria-label="Item Level history">
          <Icon name="lucide:shield" class="raid-progress-icon" aria-hidden="true" />
          Item Level History
          <span class="history-subtitle">(4-week rolling)</span>
          <Icon name="lucide:chevron-down" class="collapse-chevron" aria-hidden="true" />
        </summary>
        {progressionHistory.length > 0 ? (
          <div class="prep-history-table-wrap">
            <table class="prep-history-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Equipped iLvl</th>
                  <th>Change</th>
                </tr>
              </thead>
              <tbody>
                {progressionHistory.map((row, i) => {
                  const prev = progressionHistory[i + 1];
                  const delta = (row.equippedItemLevel !== null && prev?.equippedItemLevel !== null && prev?.equippedItemLevel !== undefined)
                    ? row.equippedItemLevel - prev.equippedItemLevel
                    : null;
                  return (
                    <tr>
                      <td class="date-col">{new Date(row.recordedAt * 1000).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })}</td>
                      <td>{row.equippedItemLevel ?? '—'}</td>
                      <td class:list={['delta-col', { 'delta-pos': delta !== null && delta > 0, 'delta-neg': delta !== null && delta < 0 }]}>
                        {delta === null ? '—' : delta > 0 ? `+${delta}` : String(delta)}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        ) : (
          <p class="raid-progress-empty">No item level history recorded yet. History accumulates with each cron refresh.</p>
        )}
      </details>

      <details class="preparedness-history-panel panel">
        <summary class="prep-history-summary" aria-label="M+ Score history">
          <Icon name="lucide:trophy" class="raid-progress-icon" aria-hidden="true" />
          M+ Score History
          <span class="history-subtitle">(4-week rolling)</span>
          <Icon name="lucide:chevron-down" class="collapse-chevron" aria-hidden="true" />
        </summary>
        {progressionHistory.length > 0 ? (
          <div class="prep-history-table-wrap">
            <table class="prep-history-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>M+ Score</th>
                  <th>Change</th>
                </tr>
              </thead>
              <tbody>
                {progressionHistory.map((row, i) => {
                  const prev = progressionHistory[i + 1];
                  const delta = (row.mythicScore !== null && prev?.mythicScore !== null && prev?.mythicScore !== undefined)
                    ? Math.round(row.mythicScore - prev.mythicScore)
                    : null;
                  return (
                    <tr>
                      <td class="date-col">{new Date(row.recordedAt * 1000).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })}</td>
                      <td>{row.mythicScore !== null ? row.mythicScore.toLocaleString(undefined, { maximumFractionDigits: 0 }) : '—'}</td>
                      <td class:list={['delta-col', { 'delta-pos': delta !== null && delta > 0, 'delta-neg': delta !== null && delta < 0 }]}>
                        {delta === null ? '—' : delta > 0 ? `+${delta}` : String(delta)}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        ) : (
          <p class="raid-progress-empty">No M+ score history recorded yet. History accumulates with each cron refresh.</p>
        )}
      </details>

      <details class="preparedness-history-panel panel">
        <summary class="prep-history-summary" aria-label="Crests and upgrades history">
          <Icon name="lucide:coins" class="raid-progress-icon" aria-hidden="true" />
          Crests &amp; Upgrades History
          <span class="history-subtitle">(4-week rolling)</span>
          <Icon name="lucide:chevron-down" class="collapse-chevron" aria-hidden="true" />
        </summary>
        {progressionHistory.length > 0 ? (
          <div class="prep-history-table-wrap">
            <table class="prep-history-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th style="color: #ffffff">A</th>
                  <th style="color: #1eff00">V</th>
                  <th style="color: #0070dd">C</th>
                  <th style="color: #a335ee">H</th>
                  <th style="color: #ff8000">M</th>
                  <th>Missing</th>
                  <th>Missing Δ</th>
                </tr>
              </thead>
              <tbody>
                {progressionHistory.map((row, i) => {
                  const prev = progressionHistory[i + 1];
                  const missingDelta = (row.totalUpgradesMissing !== null && prev?.totalUpgradesMissing !== null && prev?.totalUpgradesMissing !== undefined)
                    ? row.totalUpgradesMissing - prev.totalUpgradesMissing
                    : null;
                  return (
                    <tr>
                      <td class="date-col">{new Date(row.recordedAt * 1000).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })}</td>
