    position: absolute;
    left: 50%;
    bottom: calc(100% + 0.45rem);
    transform: translateX(-50%);
    min-width: 12rem;
    max-width: 20rem;
    padding: 0.35rem 0.45rem;
    border-radius: 0.35rem;
    border: 1px solid rgba(214, 176, 106, 0.45);
    background: rgba(2, 7, 12, 0.95);
    color: #dfeef9;
    font-size: 0.72rem;
    line-height: 1.25;
    text-align: left;
    white-space: normal;
    z-index: 20;
    pointer-events: none;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.45);
  }

  .armory-affix[data-tooltip]:hover::before,
  .armory-affix[data-tooltip]:focus-visible::before {
    content: '';
    position: absolute;
    left: 50%;
    bottom: calc(100% + 0.16rem);
    transform: translateX(-50%);
    border-left: 0.3rem solid transparent;
    border-right: 0.3rem solid transparent;
    border-top: 0.3rem solid rgba(214, 176, 106, 0.45);
    z-index: 21;
    pointer-events: none;
  }

  .armory-empty {
    margin: 0;
    color: #607685;
    font-size: 0.86rem;
    line-height: 1.23;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .armory-weapons {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.4rem;
  }

  .full-body-col {
    width: 100%;
    height: 32rem;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid rgba(214, 176, 106, 0.32);
    background: rgba(5, 10, 16, 0.6);
  }

  .full-body-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transform: translateY(-6%) scale(1.08);
    transform-origin: center top;
    display: block;
  }

  .external-profile-panel {
    border: 1px solid rgba(214, 176, 106, 0.32);
    border-radius: 0.75rem;
    background:
      linear-gradient(155deg, rgba(214, 176, 106, 0.07), transparent 50%),
      rgba(11, 21, 32, 0.78);
    padding: 0.65rem;
  }

  .external-profile-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(0, 1fr));
    gap: 0.45rem;
  }

  .external-profile-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.32rem;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    border: 1px solid rgba(109, 172, 229, 0.3);
    background: rgba(60, 119, 172, 0.16);
    color: #cfe3f4;
    font-size: 0.76rem;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }

  .external-profile-link:hover {
    background: rgba(109, 172, 229, 0.24);
    border-color: rgba(145, 198, 245, 0.48);
    color: #e4f3ff;
  }

  .external-profile-icon {
    width: 0.78rem;
    height: 0.78rem;
    flex-shrink: 0;
    border-radius: 0.16rem;
    object-fit: contain;
  }

  .stats-col {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .panel {
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
    border: 1px solid rgba(214, 176, 106, 0.32);
    border-radius: 0.75rem;
    background:
      linear-gradient(155deg, rgba(214, 176, 106, 0.07), transparent 50%),
      rgba(11, 21, 32, 0.78);
  }

  .stats-col > section,
  .stats-col > details {
    max-width: 100%;
    min-width: 0;
  }

  /* ── Stat cards ── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .stat-card {
    border: 1px solid rgba(214, 176, 106, 0.32);
    border-radius: 0.75rem;
    background:
      linear-gradient(155deg, rgba(214, 176, 106, 0.07), transparent 50%),
      rgba(11, 21, 32, 0.78);
    padding: 1rem 1.1rem;
  }

  .stat-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #b0c4d0;
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }

  .stat-icon {
    width: 0.95rem;
    height: 0.95rem;
    flex-shrink: 0;
  }

  .stat-anchor {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: rgba(214, 176, 106, 0.55);
  }

  .stat-anchor:hover {
    color: #f1d9a9;
    text-decoration-color: currentColor;
  }

  .stat-value {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.2rem, 2.5vw, 1.7rem);
    font-weight: 700;
    color: #f1d9a9;
    line-height: 1;
  }

  .mplus-metric-note {
    margin: 0.7rem 0 0.95rem;
    color: #9fb5c2;
    font-size: 0.8rem;
    line-height: 1.4;
  }

  .mplus-metric-note a {
    color: #f3cf94;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .mplus-metric-note a:hover {
    color: #ffe1b0;
  }

  .raid-progress-panel {
    padding: 1rem 1.1rem;
    overflow-x: hidden;
  }

  .raid-progress-title {
    margin: 0 0 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: #f1d9a9;
    font-size: 1.05rem;
    letter-spacing: 0.02em;
  }

  .raid-progress-icon {
    width: 1rem;
    height: 1rem;
  }

  .raid-progress-grid-lg {
    display: grid;
    grid-template-columns: minmax(5.9rem, 0.9fr) repeat(var(--raid-cols), minmax(0, 1fr));
    gap: 0.35rem;
    font-size: 0.9rem;
    line-height: 1.15;
    width: 100%;
    min-width: 100%;
  }

  .raid-grid-lg-cell {
    border: 1px solid rgba(109, 172, 229, 0.28);
    border-radius: 0.45rem;
    padding: 0.34rem 0.38rem;
    text-align: center;
    white-space: nowrap;
    box-sizing: border-box;
    overflow: hidden;
    background: rgba(60, 119, 172, 0.14);
    color: #cfe3f4;
    font-weight: 700;
  }

  .raid-grid-lg-cell.raid-grid-lg-head {
    background: rgba(214, 176, 106, 0.18);
    color: #f3ddb0;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-size: 0.76rem;
    border-color: rgba(214, 176, 106, 0.38);
    white-space: normal;
    overflow-wrap: anywhere;
    line-height: 1.2;
  }

  .raid-grid-lg-cell.raid-grid-lg-head.starts-col-two {
    grid-column: 2;
  }

  .raid-grid-lg-cell.mode-col {
    background: rgba(148, 165, 178, 0.2);
    color: #dbe6ef;
    border-color: rgba(171, 188, 201, 0.34);
    font-weight: 800;
    letter-spacing: 0.03em;
    text-align: left;
    padding-left: 0.55rem;
  }

  .raid-progress-empty {
    margin: 0;
    color: #b0c4d0;
    font-size: 0.95rem;
  }

  .vault-summary-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.55rem;
    margin-bottom: 0.72rem;
  }

  .vault-summary-card {
    border: 1px solid rgba(109, 172, 229, 0.28);
    border-radius: 0.55rem;
    background: rgba(60, 119, 172, 0.14);
    padding: 0.52rem 0.62rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .vault-summary-label {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #9fb5c2;
  }

  .vault-summary-value {
    color: #f1d9a9;
    font-size: 1.05rem;
    font-family: 'Cinzel', serif;
    line-height: 1;
  }

  .vault-board {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .vault-track-row {
    display: grid;
    grid-template-columns: minmax(8rem, 0.9fr) minmax(0, 1fr);
    gap: 0.55rem;
    align-items: stretch;
  }

  .vault-track-meta {
    border: 1px solid rgba(214, 176, 106, 0.26);
    border-radius: 0.55rem;
    padding: 0.58rem 0.62rem;
    background: linear-gradient(155deg, rgba(214, 176, 106, 0.18), rgba(49, 30, 12, 0.24));
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.24rem;
  }

  .vault-track-title {
    margin: 0;
    color: #f4deaf;
    font-family: 'Cinzel', serif;
    font-size: 1.03rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .vault-track-source {
    margin: 0;
    color: #c8b48f;
    font-size: 0.72rem;
    line-height: 1.25;
  }

  .vault-option-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.45rem;
  }

  .vault-option-card {
    position: relative;
    border: 1px solid rgba(109, 172, 229, 0.24);
    border-radius: 0.55rem;
    padding: 0.5rem 0.58rem;
    background: linear-gradient(160deg, rgba(95, 70, 36, 0.2), rgba(14, 22, 33, 0.82));
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 0.16rem;
    min-height: 5.05rem;
  }

  .vault-option-card-unlocked {
    border-color: rgba(214, 176, 106, 0.42);
    box-shadow: inset 0 0 0 1px rgba(214, 176, 106, 0.16);
  }

  .vault-option-card-locked {
    border-color: rgba(118, 132, 145, 0.3);
    background: linear-gradient(160deg, rgba(32, 41, 52, 0.54), rgba(10, 17, 26, 0.86));
  }

  .vault-option-state {
    position: absolute;
    top: 0.35rem;
    right: 0.36rem;
    width: 1rem;
    height: 1rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.24);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(10, 17, 26, 0.55);
  }

  .vault-option-state-icon {
    width: 0.66rem;
    height: 0.66rem;
    color: #a8c8db;
  }

  .vault-option-card-unlocked .vault-option-state {
    border-color: rgba(62, 190, 104, 0.48);
    background: rgba(22, 56, 28, 0.72);
  }

  .vault-option-card-unlocked .vault-option-state-icon {
    color: #4dde77;
  }

  .vault-option-card-locked .vault-option-state-icon {
    color: #8ea4b2;
  }

  .vault-objective {
    margin: 0;
    color: #d9c8a0;
    font-size: 0.71rem;
    line-height: 1.2;
    max-width: 92%;
  }

  .vault-reward-track {
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1;
    margin-top: 0.12rem;
  }

  .vault-item-level {
    display: block;
    max-width: 100%;
    font-family: 'Cinzel', serif;
    color: #f1d9a9;
    font-size: 0.9rem;
    line-height: 1.05;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .vault-score-formula {
    margin: 0.62rem 0 0;
    border: 1px solid rgba(109, 172, 229, 0.28);
    border-radius: 0.55rem;
    background: rgba(60, 119, 172, 0.1);
    overflow: hidden;
  }

  .attendance-score-formula {
    margin: 0.72rem 1.1rem 0.95rem;
  }

  .vault-score-formula-toggle {
    list-style: none;
    cursor: pointer;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    margin: 0;
    width: 100%;
    padding: 0.52rem 0.72rem;
    border-radius: 0;
    border-bottom: 1px solid rgba(109, 172, 229, 0.22);
    background: rgba(60, 119, 172, 0.14);
    color: #f1d9a9;
    font-size: 0.82rem;
    transition: background 0.15s ease;
    gap: 0.5rem;
    position: relative;
    box-sizing: border-box;
  }

  .vault-score-formula-toggle::-webkit-details-marker {
    display: none;
  }

  .vault-score-formula-toggle:hover {
    background: rgba(60, 119, 172, 0.22);
  }

  .vault-score-formula-label-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.36rem;
    min-width: 0;
    flex-wrap: wrap;
    flex: 1;
  }

  .vault-score-formula-icon {
    width: 0.85rem;
    height: 0.85rem;
    color: #e4cf9e;
    flex-shrink: 0;
  }

  .vault-score-formula-label-wrap > span:first-of-type {
    color: #f1d9a9;
    font-family: 'Cinzel', serif;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .vault-score-formula-subtitle {
    color: #a8bfce;
    font-size: 0.72rem;
    letter-spacing: 0.01em;
    text-transform: none;
    font-family: sans-serif;
    line-height: 1.2;
  }

  .vault-score-formula-chevron {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.35rem;
    height: 1.2rem;
    padding: 0 0.2rem;
    border-radius: 999px;
    border: 1px solid rgba(214, 176, 106, 0.38);
    background: rgba(214, 176, 106, 0.12);
    font-size: 0.68rem;
    line-height: 1;
    color: #f2ddb0;
    text-shadow: 0 0 6px rgba(214, 176, 106, 0.25);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  details.vault-score-formula[open] .vault-score-formula-chevron {
    transform: rotate(180deg);
  }

  details.vault-score-formula:not([open]) .vault-score-formula-toggle {
    border-bottom-color: transparent;
  }

  .vault-score-formula-body {
    padding: 0.45rem 0.75rem 0.62rem;
    color: #b8cad6;
    font-size: 0.76rem;
    line-height: 1.35;
  }

  .vault-score-formula-body p {
    margin: 0 0 0.28rem;
  }

  .vault-formula-table-wrap {
    margin-top: 0.42rem;
    overflow-x: auto;
  }

  .vault-formula-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.73rem;
    line-height: 1.28;
    min-width: 26rem;
  }

  .vault-formula-table th,
  .vault-formula-table td {
    padding: 0.24rem 0.38rem;
    border: 1px solid rgba(109, 172, 229, 0.18);
    text-align: left;
    vertical-align: top;
    white-space: nowrap;
  }

  .vault-formula-table th {
    color: #f1d9a9;
    background: rgba(214, 176, 106, 0.12);
    font-size: 0.69rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .vault-formula-table td {
    color: #c9d7e0;
    white-space: normal;
  }

  .vault-formula-table tbody tr:nth-child(even) {
    background: rgba(60, 119, 172, 0.08);
  }

  .crest-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .crest-cell {
    border: 1px solid rgba(214, 176, 106, 0.22);
    border-radius: 0.55rem;
    padding: 0.65rem 0.75rem;
    background: rgba(214, 176, 106, 0.08);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .crest-name {
    color: #d8e2e8;
    font-size: 0.88rem;
    font-weight: 600;
  }

  .crest-value {
    color: #f3ddb0;
    font-family: 'Cinzel', serif;
    font-size: 1rem;
  }

  /* ── Sync info ── */
  .sync-info {
    padding: 0.75rem 1rem;
  }

  /* ── Preparedness History ── */
  .preparedness-history-panel {
    padding: 0;
    display: block;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
    overflow: hidden;
  }

  .prep-history-summary {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    width: 100%;
    box-sizing: border-box;
    padding: 1rem 1.1rem;
    cursor: pointer;
    list-style: none;
    color: #f1d9a9;
    font-family: 'Cinzel', serif;
    font-size: 1.05rem;
    letter-spacing: 0.02em;
    user-select: none;
    border-radius: 0.75rem;
    transition: background 0.15s;
  }

  .prep-history-summary::-webkit-details-marker {
    display: none;
  }

  .prep-history-summary::marker {
    content: '';
  }

  .prep-history-summary:hover {
    background: rgba(214, 176, 106, 0.06);
  }

  .attendance-boss-summary {
    display: inline-block;
    margin-right: 0.45rem;
    font-weight: 600;
  }

  .attendance-result-pills {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
    vertical-align: middle;
  }

  .attendance-result-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.4rem;
    padding: 0.12rem 0.45rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.03em;
  }

  .attendance-result-pill-wipe {
    color: #f0c07f;
    background: rgba(173, 96, 31, 0.16);
    border-color: rgba(240, 192, 127, 0.3);
  }

  details.preparedness-history-panel[open] .prep-history-summary {
    border-bottom: 1px solid rgba(214, 176, 106, 0.18);
    border-radius: 0.75rem 0.75rem 0 0;
  }

  .collapse-chevron {
    width: 1rem;
    height: 1rem;
    margin-left: auto;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  details.preparedness-history-panel[open] .collapse-chevron {
    transform: rotate(180deg);
  }

  .prep-history-table-wrap,
  .preparedness-history-panel > .raid-progress-empty {
    padding: 0.75rem 1.1rem 1rem;
  }

  .history-subtitle {
    font-size: 0.78rem;
    color: #b0c4d0;
    font-family: sans-serif;
    font-weight: 400;
    letter-spacing: 0.02em;
    text-transform: none;
    margin-left: 0.25rem;
  }

  .history-note {
    margin: 0;
    padding: 0.75rem 1.1rem 0;
    color: #d8e2e8;
    font-size: 0.88rem;
    line-height: 1.4;
  }

  .history-note + .prep-history-table-wrap {
    padding-top: 0.45rem;
  }

  .history-subtext {
    display: block;
    margin-top: 0.15rem;
    color: #9fb5c2;
    font-size: 0.76rem;
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  .prep-history-table-wrap {
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
    overflow-x: auto;
    max-height: 23rem;
    overflow-y: auto;
    scrollbar-gutter: stable;
  }

  .preparedness-history-panel-two-week .prep-history-table-wrap {
    max-height: none;
    overflow-y: visible;
  }

  .prep-history-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .prep-history-table thead th {
    text-align: left;
    padding: 0.35rem 0.65rem;
    color: #b0c4d0;
    font-size: 0.79rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px solid rgba(214, 176, 106, 0.22);
    white-space: nowrap;
  }

  .prep-history-table tbody tr {
    border-bottom: 1px solid rgba(109, 172, 229, 0.1);
    transition: background 0.1s;
  }

  .prep-history-table tbody tr:last-child {
    border-bottom: none;
  }

  .prep-history-table tbody tr:hover {
    background: rgba(214, 176, 106, 0.06);
  }

  .prep-history-table tbody td {
    padding: 0.38rem 0.65rem;
    color: #d8e2e8;
    font-weight: 600;
    white-space: nowrap;
  }

  .date-col {
    color: #b0c4d0 !important;
    font-weight: 400 !important;
    font-size: 0.86rem;
  }

  .delta-col {
    font-variant-numeric: tabular-nums;
  }

  .delta-pos {
    color: #1eff00 !important;
  }

  .delta-neg {
    color: #ff6b6b !important;
  }

  .tier-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.1rem 0.55rem;
    border-radius: 999px;
    border: 1px solid;
    font-family: 'Cinzel', serif;
    font-size: 0.82rem;
    font-weight: 700;
    min-width: 2rem;
  }

  .sync-text {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #b0c4d0;
    font-size: 0.9rem;
  }

  .sync-text strong {
    color: #d8e2e8;
  }

  .sync-icon {
    width: 0.95rem;
    height: 0.95rem;
    flex-shrink: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 1320px) {
    .body-layout {
      flex-direction: column;
    }

    .character-col,
    .stats-col {
      width: 100%;
    }

    .character-col {
      max-width: 100%;
    }
  }

  @media (max-width: 1040px) {
    .armory-wrap {
