            <div class="vault-score-formula-body">
              <p>
                Great Vault score is a weighted completion score normalized to 100.
              </p>
              <p>
                Score = round((earnedPoints / maxPoints) * 100)
              </p>
              <div class="vault-formula-table-wrap">
                <table class="vault-formula-table" aria-label="Great Vault score weights">
                  <thead>
                    <tr>
                      <th>Group</th>
                      <th>Range / Slot</th>
                      <th>Weight</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr><td>Slot Multiplier</td><td>Slot 1</td><td>1.00</td></tr>
                    <tr><td>Slot Multiplier</td><td>Slot 2</td><td>1.35</td></tr>
                    <tr><td>Slot Multiplier</td><td>Slot 3</td><td>1.80</td></tr>
                    <tr><td>Raid</td><td>272+</td><td>1.45</td></tr>
                    <tr><td>Raid</td><td>266-271</td><td>1.25</td></tr>
                    <tr><td>Raid</td><td>259-265</td><td>1.00</td></tr>
                    <tr><td>Raid</td><td>252-258</td><td>0.75</td></tr>
                    <tr><td>Raid</td><td>&lt;252</td><td>0.60</td></tr>
                    <tr><td>Dungeon</td><td>272+</td><td>1.45</td></tr>
                    <tr><td>Dungeon</td><td>269-271</td><td>1.30</td></tr>
                    <tr><td>Dungeon</td><td>266-268</td><td>1.15</td></tr>
                    <tr><td>Dungeon</td><td>263-265</td><td>1.00</td></tr>
                    <tr><td>Dungeon</td><td>259-262</td><td>0.85</td></tr>
                    <tr><td>Dungeon</td><td>&lt;259</td><td>0.70</td></tr>
                    <tr><td>World</td><td>Unlocked slot</td><td>0.35</td></tr>
                  </tbody>
                </table>
              </div>
              <div class="vault-formula-table-wrap">
                <table class="vault-formula-table" aria-label="Great Vault score math and color bands">
                  <thead>
                    <tr>
                      <th>Component</th>
                      <th>Value</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr><td>Per-slot points</td><td>(raidWeight + dungeonWeight + worldWeight) * slotMultiplier</td></tr>
                    <tr><td>Per-slot max base</td><td>1.45 + 1.45 + 0.35 = 3.25</td></tr>
                    <tr><td>Total maxPoints</td><td>3.25 * (1.00 + 1.35 + 1.80) = 13.4875</td></tr>
                    <tr><td>World unlock thresholds</td><td>2 / 4 / 8 objectives</td></tr>
                    <tr><td>Color bands</td><td>95-100 orange, 85-94 purple, 70-84 blue, 40-69 green, 0-39 white</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
