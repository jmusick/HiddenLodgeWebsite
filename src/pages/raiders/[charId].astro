---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { env } from 'cloudflare:workers';
import { classColor } from '../../lib/wow';
import { getRaiderByCharId, getRaiderGear, getRaiderMedia, getPreparednessHistory, getProgressionHistory } from '../../lib/raiders';
import { isCharacterOwner } from '../../lib/auth';
import { getLatestDroptimizerForRaiders, getLatestSingleTargetForRaiders } from '../../lib/sim-api';
import { RAID_PROGRESS_TARGET_GROUPS } from '../../data/raidProgressTargets';
import RaiderSimTools from '../../components/RaiderSimTools.astro';

const { charId } = Astro.params;
const id = Number(charId);
if (!charId || !Number.isFinite(id)) {
  return new Response('Not found', { status: 404 });
}

const [raider, media, preparednessHistory, progressionHistory, gear] = await Promise.all([
  getRaiderByCharId(id),
  getRaiderMedia(id),
  getPreparednessHistory(id),
  getProgressionHistory(id),
  getRaiderGear(id),
]);
if (!raider) {
  return new Response('Not found', { status: 404 });
}
const { portrait, fullBody } = media;
const nowEpoch = Math.floor(Date.now() / 1000);

const [singleTargetMap, droptimizerMap] = await Promise.all([
  getLatestSingleTargetForRaiders((env as any).DB, [id], { maxAgeSeconds: 14 * 24 * 60 * 60 }),
  getLatestDroptimizerForRaiders((env as any).DB, [id], { maxAgeSeconds: 14 * 24 * 60 * 60 }),
]);
const singleTargetSnapshot = singleTargetMap.get(id) ?? null;
const droptimizerSnapshot = droptimizerMap.get(id) ?? null;

function authLabel(state: string): string {
  if (state === 'ready') return 'Loaded';
  if (state === 'expired') return 'Stale';
  if (state === 'unavailable') return 'Unavailable';
  return 'Pending';
}

function scoreColor(filled: number | null, total: number | null): string {
  if (filled === null || total === null || total === 0) return 'inherit';
  const pct = filled / total;
  if (pct >= 1)    return '#a335ee';
  if (pct >= 0.75) return '#0070dd';
  if (pct >= 0.5)  return '#1eff00';
  return '#ffffff';
}

function freshnessBadge(updatedAt: number | null): { label: string; className: string } {
  if (!updatedAt || updatedAt <= 0) return { label: 'missing', className: 'missing' };
  const age = Math.max(0, nowEpoch - updatedAt);
  if (age <= 24 * 60 * 60) return { label: 'fresh', className: 'fresh' };
  if (age <= 2 * 24 * 60 * 60) return { label: 'aging', className: 'aging' };
  return { label: 'stale', className: 'stale' };
}

function formatScore(filled: number | null, total: number | null): string {
  if (filled === null || total === null) return '—';
  if (total === 0) return 'N/A';
  return `${Math.round((filled / total) * 100)}% (${filled}/${total})`;
}

function crestColor(label: string): string {
  if (label === 'Myth') return '#ff8000';
  if (label === 'Hero') return '#a335ee';
  if (label === 'Champion') return '#0070dd';
  if (label === 'Veteran') return '#1eff00';
  return '#ffffff';
}

const crestCards = [
  { label: 'Adventurer', value: raider.adventurerCrests },
  { label: 'Veteran', value: raider.veteranCrests },
  { label: 'Champion', value: raider.championCrests },
  { label: 'Hero', value: raider.heroCrests },
  { label: 'Myth', value: raider.mythCrests },
].filter((entry) => entry.value !== null);

interface RaidProgressMatrixRow {
  mode: 'L' | 'N' | 'H' | 'M';
  cells: string[];
}

interface RaidProgressMatrix {
  headers: string[];
  rows: RaidProgressMatrixRow[];
}

function parseRaidProgressMatrix(label: string | null): RaidProgressMatrix | null {
  if (!label) return null;

  try {
    const parsed = JSON.parse(label) as RaidProgressMatrix;
    if (!parsed || !Array.isArray(parsed.headers) || !Array.isArray(parsed.rows)) return null;

    const headers = parsed.headers
      .map((header) => String(header).trim().toUpperCase())
      .filter(Boolean);
    if (headers.length === 0) return null;

    const rows = parsed.rows
      .map((row) => ({
        mode: String(row.mode ?? '').toUpperCase() as 'L' | 'N' | 'H' | 'M',
        cells: Array.isArray(row.cells) ? row.cells.map((cell) => String(cell).trim()) : [],
      }))
      .filter((row) => ['L', 'N', 'H', 'M'].includes(row.mode));

    if (rows.length === 0) return null;

    const normalizedRows = rows.map((row) => {
      const cells = row.cells.slice(0, headers.length);
      while (cells.length < headers.length) cells.push('0/0');
      return { mode: row.mode, cells } as RaidProgressMatrixRow;
    });

    return { headers, rows: normalizedRows };
  } catch {
    return null;
  }
}

const RAID_NAME_BY_CODE = new Map(
  RAID_PROGRESS_TARGET_GROUPS.flatMap((group) =>
    group.raids.map((raid) => [raid.code.toUpperCase(), raid.raidName] as const)
  )
);

function fullRaidName(code: string): string {
  return RAID_NAME_BY_CODE.get(code.toUpperCase()) ?? code;
}

function fullDifficultyName(mode: 'L' | 'N' | 'H' | 'M'): string {
  if (mode === 'L') return 'Raid Finder';
  if (mode === 'N') return 'Normal';
  if (mode === 'H') return 'Heroic';
  return 'Mythic';
}

const color = classColor(raider.className);
const pageTitle = `${raider.name} — ${raider.realm} | The Hidden Lodge`;
const stFresh = freshnessBadge(singleTargetSnapshot?.updated_at ?? null);
const dropFresh = freshnessBadge(droptimizerSnapshot?.updated_at ?? null);
const raidProgressMatrix = parseRaidProgressMatrix(raider.raidProgressLabel);
const warcraftLogsUrl = `https://www.warcraftlogs.com/character/id/${raider.blizzardCharId}`;
const canManageSim = Boolean(
  Astro.locals.user && (
    Astro.locals.isAdmin || await isCharacterOwner((env as any).DB, Astro.locals.user.id, raider.blizzardCharId)
  )
);
const blizzardArmoryUrl = raider.realmSlug
  ? `https://worldofwarcraft.blizzard.com/en-us/character/us/${encodeURIComponent(raider.realmSlug)}/${encodeURIComponent(raider.name.toLowerCase())}/`
  : null;
const raiderIoUrl = raider.realmSlug
  ? `https://raider.io/characters/us/${encodeURIComponent(raider.realmSlug)}/${encodeURIComponent(raider.name)}`
  : null;
const leftGearSlots = ['HEAD', 'NECK', 'SHOULDER', 'BACK', 'CHEST', 'WRIST'];
const rightGearSlots = ['HANDS', 'WAIST', 'LEGS', 'FEET', 'FINGER_1', 'FINGER_2', 'TRINKET_1', 'TRINKET_2'];
const weaponSlots = ['MAIN_HAND', 'OFF_HAND'];
const gearBySlot = new Map(gear.map((entry) => [entry.slotKey, entry]));

function enchantAffixState(item: (typeof gear)[number] | undefined): { missing: boolean; tooltip: string; label: string } {
  if (!item?.itemName || !item.canEnchant) {
    return { missing: false, tooltip: 'Enchant not available for this item', label: 'Enchant not available for this item' };
  }
  if (item.enchantments.length > 0) {
    const primary = item.enchantments[0]?.trim() || 'Enchant applied';
    return { missing: false, tooltip: primary, label: `Enchant details: ${primary}` };
  }
  return { missing: true, tooltip: 'Missing enchant', label: 'Missing enchant' };
}

function gemAffixState(item: (typeof gear)[number] | undefined): { missing: boolean; tooltip: string; label: string } {
  if (!item?.itemName || !item.canGem) {
    return { missing: false, tooltip: 'No gem socket on this item', label: 'No gem socket on this item' };
  }
  if (item.gems.length > 0) {
    const joined = item.gems.join(' | ');
    return { missing: false, tooltip: joined, label: `Gem details: ${item.gems.join(', ')}` };
  }
  return { missing: true, tooltip: 'Missing gems', label: 'Missing gems' };
}
---

<Layout title={pageTitle}>
  <section>
    <a href="/raiders" class="back-link">
      <Icon name="lucide:arrow-left" aria-hidden="true" />
      Back to Raiders
    </a>

    <header class="raider-header">
      {portrait
        ? <img src={portrait} alt="" class="header-portrait" aria-hidden="true" />
        : <div class="raider-avatar" style={`--class-color: ${color}`} aria-hidden="true">{raider.name.charAt(0).toUpperCase()}</div>
      }
      <div class="raider-identity">
        <h1 class="raider-name" style={`color: ${color}`}>{raider.name}</h1>
        <p class="raider-subtitle">{raider.className} &middot; {raider.realm}</p>
        {raider.teamNames.length > 0 && (
          <div class="team-list">
            {raider.teamNames.map((team) => <span class="team-chip">{team}</span>)}
          </div>
        )}
      </div>
      <div class="raider-status">
        <span class:list={['status-badge', raider.authState]}>{authLabel(raider.authState)}</span>
      </div>
    </header>
  </section>

  <section class="body-layout" aria-label="Raider detail">
    {(fullBody || warcraftLogsUrl || raiderIoUrl) && (
      <div class="character-col">
        {fullBody && gear.length > 0 ? (
          <div class="armory-wrap" aria-label="Character and equipped gear">
            <div class="armory-gear-col" aria-label="Left equipment column">
              {leftGearSlots.map((slotKey) => {
                const item = gearBySlot.get(slotKey);
                const wowhead = item?.itemId ? `https://www.wowhead.com/item=${item.itemId}` : null;
                const enchantState = enchantAffixState(item);
                const gemState = gemAffixState(item);

                return (
                  <article class="armory-gear-row">
                    {item?.itemName ? (
                      <>
                        <div class="armory-item-top">
                          {wowhead ? (
                            <a href={wowhead} target="_blank" rel="noopener noreferrer" class="armory-item" style={`color: ${item.qualityColor}`}>
                              {item.itemName}
                            </a>
                          ) : (
                            <p class="armory-item" style={`color: ${item.qualityColor}`}>{item.itemName}</p>
                          )}
                        </div>
                        <div class="armory-item-bottom">
                          <p class="armory-meta">iLvl {item.itemLevel ?? '—'}</p>
                          {(item.canEnchant || item.canGem) && (
                            <div class="armory-affixes" aria-label="Item enhancements">
                              {item.canEnchant && (
                                <span
                                  class:list={[
                                    'armory-affix',
                                    'armory-affix-enchant',
                                    { 'armory-affix-missing': enchantState.missing },
                                  ]}
                                  data-tooltip={enchantState.tooltip}
                                  aria-label={enchantState.label}
                                >
                                  <Icon name="lucide:wand-sparkles" class="armory-affix-icon" aria-hidden="true" />
                                </span>
                              )}
                              {item.canGem && (
                                <span
                                  class:list={[
                                    'armory-affix',
                                    'armory-affix-gem',
                                    { 'armory-affix-missing': gemState.missing },
                                  ]}
                                  data-tooltip={gemState.tooltip}
                                  aria-label={gemState.label}
                                >
                                  <Icon name="lucide:gem" class="armory-affix-icon" aria-hidden="true" />
                                </span>
                              )}
                            </div>
                          )}
                        </div>
                      </>
                    ) : (
                      <>
                        <div class="armory-item-top">
                          <p class="armory-empty">—</p>
                        </div>
                        <div class="armory-item-bottom">
                          <p class="armory-meta">iLvl —</p>
                        </div>
                      </>
                    )}
                  </article>
                );
              })}
            </div>

            <div class="armory-model-col">
              <div class="full-body-col">
                <img src={fullBody} alt={`${raider.name} character render`} class="full-body-img" />
              </div>

              <div class="armory-weapons" aria-label="Weapon slots">
                {weaponSlots.map((slotKey) => {
                  const item = gearBySlot.get(slotKey);
                  const wowhead = item?.itemId ? `https://www.wowhead.com/item=${item.itemId}` : null;
                  const enchantState = enchantAffixState(item);
                  const gemState = gemAffixState(item);

                  return (
                    <article class="armory-weapon-row">
                      {item?.itemName ? (
                        <>
                          <div class="armory-item-top">
                            {wowhead ? (
                              <a href={wowhead} target="_blank" rel="noopener noreferrer" class="armory-item" style={`color: ${item.qualityColor}`}>
                                {item.itemName}
                              </a>
                            ) : (
                              <p class="armory-item" style={`color: ${item.qualityColor}`}>{item.itemName}</p>
                            )}
                          </div>
                          <div class="armory-item-bottom">
                            <p class="armory-meta">iLvl {item.itemLevel ?? '—'}</p>
                            {(item.canEnchant || item.canGem) && (
                              <div class="armory-affixes" aria-label="Item enhancements">
                                {item.canEnchant && (
                                  <span
                                    class:list={[
                                      'armory-affix',
                                      'armory-affix-enchant',
                                      { 'armory-affix-missing': enchantState.missing },
                                    ]}
                                    data-tooltip={enchantState.tooltip}
                                    aria-label={enchantState.label}
                                  >
                                    <Icon name="lucide:wand-sparkles" class="armory-affix-icon" aria-hidden="true" />
                                  </span>
                                )}
                                {item.canGem && (
                                  <span
                                    class:list={[
                                      'armory-affix',
                                      'armory-affix-gem',
                                      { 'armory-affix-missing': gemState.missing },
                                    ]}
                                    data-tooltip={gemState.tooltip}
                                    aria-label={gemState.label}
                                  >
                                    <Icon name="lucide:gem" class="armory-affix-icon" aria-hidden="true" />
                                  </span>
                                )}
                              </div>
                            )}
                          </div>
                        </>
                      ) : (
                        <>
                          <div class="armory-item-top">
                            <p class="armory-empty">—</p>
                          </div>
                          <div class="armory-item-bottom">
                            <p class="armory-meta">iLvl —</p>
                          </div>
                        </>
                      )}
                    </article>
                  );
                })}
              </div>
            </div>

            <div class="armory-gear-col" aria-label="Right equipment column">
              {rightGearSlots.map((slotKey) => {
                const item = gearBySlot.get(slotKey);
                const wowhead = item?.itemId ? `https://www.wowhead.com/item=${item.itemId}` : null;
                const enchantState = enchantAffixState(item);
                const gemState = gemAffixState(item);

                return (
                  <article class="armory-gear-row">
                    {item?.itemName ? (
                      <>
                        <div class="armory-item-top">
                          {wowhead ? (
                            <a href={wowhead} target="_blank" rel="noopener noreferrer" class="armory-item" style={`color: ${item.qualityColor}`}>
                              {item.itemName}
                            </a>
                          ) : (
                            <p class="armory-item" style={`color: ${item.qualityColor}`}>{item.itemName}</p>
                          )}
                        </div>
                        <div class="armory-item-bottom">
                          <p class="armory-meta">iLvl {item.itemLevel ?? '—'}</p>
                          {(item.canEnchant || item.canGem) && (
                            <div class="armory-affixes" aria-label="Item enhancements">
                              {item.canEnchant && (
                                <span
                                  class:list={[
                                    'armory-affix',
                                    'armory-affix-enchant',
                                    { 'armory-affix-missing': enchantState.missing },
                                  ]}
                                  data-tooltip={enchantState.tooltip}
                                  aria-label={enchantState.label}
                                >
                                  <Icon name="lucide:wand-sparkles" class="armory-affix-icon" aria-hidden="true" />
                                </span>
                              )}
                              {item.canGem && (
                                <span
                                  class:list={[
                                    'armory-affix',
                                    'armory-affix-gem',
                                    { 'armory-affix-missing': gemState.missing },
                                  ]}
                                  data-tooltip={gemState.tooltip}
                                  aria-label={gemState.label}
                                >
                                  <Icon name="lucide:gem" class="armory-affix-icon" aria-hidden="true" />
                                </span>
                              )}
                            </div>
                          )}
                        </div>
                      </>
                    ) : (
                      <>
                        <div class="armory-item-top">
                          <p class="armory-empty">—</p>
                        </div>
                        <div class="armory-item-bottom">
                          <p class="armory-meta">iLvl —</p>
                        </div>
                      </>
                    )}
                  </article>
                );
              })}
            </div>
          </div>
        ) : fullBody && (
          <div class="full-body-col">
            <img src={fullBody} alt={`${raider.name} character render`} class="full-body-img" />
          </div>
        )}
        <div class="external-profile-panel" aria-label="External profiles">
          <div class="external-profile-links">
            {blizzardArmoryUrl && (
              <a href={blizzardArmoryUrl} target="_blank" rel="noopener noreferrer" class="external-profile-link">
                <img
                  src="https://www.google.com/s2/favicons?sz=64&domain_url=https://worldofwarcraft.blizzard.com"
                  alt=""
                  class="external-profile-icon"
                  loading="lazy"
                  decoding="async"
                  aria-hidden="true"
                />
                Blizzard Armory
              </a>
            )}
            <a href={warcraftLogsUrl} target="_blank" rel="noopener noreferrer" class="external-profile-link">
              <img
                src="https://www.google.com/s2/favicons?sz=64&domain_url=https://www.warcraftlogs.com"
                alt=""
                class="external-profile-icon"
                loading="lazy"
                decoding="async"
                aria-hidden="true"
              />
              Warcraft Logs
            </a>
            {raiderIoUrl && (
              <a href={raiderIoUrl} target="_blank" rel="noopener noreferrer" class="external-profile-link">
                <img
                  src="https://www.google.com/s2/favicons?sz=64&domain_url=https://raider.io"
                  alt=""
                  class="external-profile-icon"
                  loading="lazy"
                  decoding="async"
                  aria-hidden="true"
                />
                Raider.IO
              </a>
            )}
          </div>
        </div>
      </div>
    )}
    <div class="stats-col">
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">
            <Icon name="lucide:shield" class="stat-icon" aria-hidden="true" />
            Equipped Item Level
          </div>
          <div class="stat-value">{raider.equippedItemLevel ?? '—'}</div>
        </div>

        <div class="stat-card">
          <div class="stat-label">
            <Icon name="lucide:layers" class="stat-icon" aria-hidden="true" />
            Average Item Level
          </div>
          <div class="stat-value">{raider.averageItemLevel ?? '—'}</div>
        </div>

        <div class="stat-card">
          <div class="stat-label">
            <Icon name="lucide:trophy" class="stat-icon" aria-hidden="true" />
            M+ Score
          </div>
          <div class="stat-value">
            {raider.mythicScore ? raider.mythicScore.toLocaleString(undefined, { maximumFractionDigits: 0 }) : '—'}
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-label">
            <Icon name="lucide:star" class="stat-icon" aria-hidden="true" />
            Tier Pieces
          </div>
          <div class="stat-value">{raider.tierPiecesEquipped ?? '—'}</div>
        </div>

        <div class="stat-card">
          <div class="stat-label">
            <Icon name="lucide:arrow-up-circle" class="stat-icon" aria-hidden="true" />
            Missing Crest Upgrades
          </div>
          <div class="stat-value">{raider.totalUpgradesMissing ?? '—'}</div>
        </div>

      </div>

      <section class="raid-progress-panel panel" aria-label="Crests earned">
        <h2 class="raid-progress-title">
          <Icon name="lucide:coins" class="raid-progress-icon" aria-hidden="true" />
          Crests Earned
        </h2>
        {crestCards.length > 0 ? (
          <div class="crest-grid">
            {crestCards.map((crest) => (
              <div class="crest-cell">
                <span class="crest-name" style={`color: ${crestColor(crest.label)}`}>{crest.label}</span>
                <strong class="crest-value" style={`color: ${crestColor(crest.label)}`}>{crest.value}</strong>
              </div>
            ))}
          </div>
        ) : (
          <p class="raid-progress-empty">No crest data available yet.</p>
        )}
      </section>

      <section class="raid-progress-panel panel" aria-label="Raid progress">
        <h2 class="raid-progress-title">
          <Icon name="lucide:swords" class="raid-progress-icon" aria-hidden="true" />
          Raid Progress
        </h2>
        {raidProgressMatrix ? (
          <div class="raid-progress-grid-lg" style={`--raid-cols: ${raidProgressMatrix.headers.length}`}>
            {raidProgressMatrix.headers.map((header, index) => (
              <div class:list={['raid-grid-lg-cell', 'raid-grid-lg-head', { 'starts-col-two': index === 0 }]}>{fullRaidName(header)}</div>
            ))}

            {raidProgressMatrix.rows.map((row) => (
              <>
                <div class="raid-grid-lg-cell mode-col">{fullDifficultyName(row.mode)}</div>
                {row.cells.map((cell) => (
                  <div class="raid-grid-lg-cell">{cell}</div>
                ))}
              </>
            ))}
          </div>
        ) : (
          <p class="raid-progress-empty">No tracked raid progress available yet.</p>
        )}
      </section>

      <details class="preparedness-history-panel panel">
        <summary class="prep-history-summary" aria-label="Preparedness history">
          <Icon name="lucide:history" class="raid-progress-icon" aria-hidden="true" />
          Preparedness History
          <span class="history-subtitle">(2-week rolling)</span>
          <Icon name="lucide:chevron-down" class="collapse-chevron" aria-hidden="true" />
        </summary>
        {preparednessHistory.length > 0 ? (
          <div class="prep-history-table-wrap">
            <table class="prep-history-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Gems</th>
                  <th>Enchants</th>
                  <th>Combined</th>
                  <th>Tier</th>
                </tr>
              </thead>
              <tbody>
                {preparednessHistory.map((row) => {
                  const combinedFilled = row.socketedGems !== null && row.enchantedSlots !== null ? row.socketedGems + row.enchantedSlots : null;
                  const combinedTotal = row.totalSockets !== null && row.enchantableSlots !== null ? row.totalSockets + row.enchantableSlots : null;
                  const combinedPct = combinedFilled !== null && combinedTotal && combinedTotal > 0 ? combinedFilled / combinedTotal : null;

                  const tierLabel = combinedPct === null ? '—'
                    : combinedPct >= 1 ? 'S'
                    : combinedPct >= 0.85 ? 'A'
                    : combinedPct >= 0.7 ? 'B'
                    : combinedPct >= 0.4 ? 'C'
                    : 'D';
                  const tierColor = combinedPct === null ? '#b0c4d0'
                    : combinedPct >= 1 ? '#ff8000'
                    : combinedPct >= 0.85 ? '#a335ee'
                    : combinedPct >= 0.7 ? '#0070dd'
                    : combinedPct >= 0.4 ? '#1eff00'
                    : '#ffffff';

                  return (
                    <tr>
                      <td class="date-col">{new Date(row.recordedAt * 1000).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })}</td>
                      <td style={`color: ${scoreColor(row.socketedGems, row.totalSockets)}`}>{formatScore(row.socketedGems, row.totalSockets)}</td>
                      <td style={`color: ${scoreColor(row.enchantedSlots, row.enchantableSlots)}`}>{formatScore(row.enchantedSlots, row.enchantableSlots)}</td>
                      <td style={`color: ${scoreColor(combinedFilled, combinedTotal)}`}>{formatScore(combinedFilled, combinedTotal)}</td>
                      <td><span class="tier-badge" style={`color: ${tierColor}; border-color: ${tierColor}40`}>{tierLabel}</span></td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        ) : (
