        )}
      </details>

      <details class="preparedness-history-panel panel">
        <summary class="prep-history-summary" aria-label="Item Level history">
          <Icon name="lucide:shield" class="raid-progress-icon" aria-hidden="true" />
          Item Level History
          <span class="history-subtitle">(4-week rolling)</span>
          <Icon name="lucide:chevron-down" class="collapse-chevron" aria-hidden="true" />
        </summary>
        {progressionHistory.length > 0 ? (
          <div class="prep-history-table-wrap">
            <table class="prep-history-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Equipped iLvl</th>
                  <th>Change</th>
                </tr>
              </thead>
              <tbody>
                {progressionHistory.map((row, i) => {
                  const prev = progressionHistory[i + 1];
                  const delta = (row.equippedItemLevel !== null && prev?.equippedItemLevel !== null && prev?.equippedItemLevel !== undefined)
                    ? row.equippedItemLevel - prev.equippedItemLevel
                    : null;
                  return (
                    <tr>
                      <td class="date-col">{new Date(row.recordedAt * 1000).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })}</td>
                      <td>{row.equippedItemLevel ?? '—'}</td>
                      <td class:list={['delta-col', { 'delta-pos': delta !== null && delta > 0, 'delta-neg': delta !== null && delta < 0 }]}>
                        {delta === null ? '—' : delta > 0 ? `+${delta}` : String(delta)}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        ) : (
          <p class="raid-progress-empty">No item level history recorded yet. History accumulates with each cron refresh.</p>
        )}
      </details>

      <details class="preparedness-history-panel panel">
        <summary class="prep-history-summary" aria-label="M+ Score history">
