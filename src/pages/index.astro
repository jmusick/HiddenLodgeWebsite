---
import Layout from '../layouts/Layout.astro';
import SectionCard from '../components/SectionCard.astro';
import { externalLinks } from '../data/externalLinks';
---

<Layout title="The Hidden Lodge | Home" description="A semi hardcore WoW raiding guild focused on AOTC and Mythic progression.">
	<section class="hero">
		<img
			src="/images/guild-banner.png"
			alt="The Hidden Lodge — For Azeroth. For the Hidden Lodge."
			class="banner-img"
		/>
		<div class="hero-foot">
			<p class="lead">
				We raid with purpose, clear Heroic for AOTC, and push into Mythic with a team-first mentality.
			</p>
			<div class="actions">
				<a href="/recruitment" class="cta">Apply to Raid</a>
				<a href="#guild-links" class="ghost">Guild Links</a>
			</div>
		</div>
	</section>

	<section class="grid">
		<SectionCard title="Raid Schedule" body="Thu / Fri 9:00 PM – 12:00 AM Eastern, with common optional alt raid nights on the side for extra loot, practice, or light chaos." icon="lucide:clock-3" />
		<SectionCard title="Primary Goal" body="Get Ahead of the Curve each tier, then move into Mythic progression without turning raid night into a second job. We take the game seriously, but not to the point of making everyone miserable." icon="lucide:trophy" />
		<SectionCard title="Culture" body="We like having fun together, joking around, and keeping raid nights enjoyable, but when the pull starts we lock in and handle business." icon="lucide:shield" />
	</section>

	<section class="rules-panel" aria-labelledby="guild-rules-title">
		<h2 id="guild-rules-title">Guild Rules</h2>
		<ul class="rules-list">
			<li>Respect the guild. Do not harass people, do not start drama, and do not make things weird for no reason.</li>
			<li>This is a 21+ guild. If you still need permission to stay up late, this is not the roster for you.</li>
			<li>No slurs. That includes the N-word and anything adjacent to it.</li>
			<li>Do not spam. Use the right Discord and guild channels so useful information does not get buried under nonsense.</li>
			<li>Guild leadership will handle disputes, and their call is final. Court is adjourned.</li>
			<li>Your main character must be in the guild if you want to raid with the guild.</li>
		</ul>
	</section>

	<section class="resource-panel" id="guild-links">
		<h2>Guild Links</h2>
		<div class="resource-grid">
			{
				externalLinks.map((link) => (
					<a class="resource-card" href={link.href} target="_blank" rel="noopener noreferrer">
						<img src={link.favicon} alt="" loading="lazy" />
						<div>
							<h3>{link.name}</h3>
							<p>{link.description}</p>
						</div>
					</a>
				))
			}
		</div>
	</section>
</Layout>

<style>
	.hero {
		padding: 0;
		border: 1px solid rgba(214, 176, 106, 0.38);
		border-radius: 0.9rem;
		overflow: hidden;
	}

	.banner-img {
		display: block;
		width: 100%;
		height: auto;
	}

	.hero-foot {
		padding: 1.1rem 1.2rem 1.35rem;
		border-top: 1px solid rgba(214, 176, 106, 0.25);
		background:
			linear-gradient(165deg, rgba(214, 176, 106, 0.06), transparent 42%),
			rgba(10, 20, 30, 0.92);
	}

	.lead {
		max-width: 64ch;
		font-size: 1.14rem;
		color: #d4dfe6;
	}

	.actions {
		display: flex;
		gap: 0.85rem;
		margin-top: 1.3rem;
		flex-wrap: wrap;
	}

	.cta,
	.ghost {
		display: inline-block;
		padding: 0.72rem 1.08rem;
		border-radius: 0.5rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.cta {
		border: 1px solid rgba(233, 201, 135, 0.66);
		background: linear-gradient(180deg, #e4c27a, #c59a4f);
		color: #1a2734;
		box-shadow: inset 0 1px 0 rgba(255, 243, 217, 0.5), 0 8px 22px rgba(0, 0, 0, 0.25);
	}

	.ghost {
		border: 1px solid rgba(214, 176, 106, 0.5);
		background: rgba(17, 30, 41, 0.62);
		color: #e8eff3;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1.35rem;
	}

	@media (max-width: 900px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}

	.resource-panel {
		margin-top: 1.3rem;
		padding: 1rem;
		border-radius: 0.8rem;
		border: 1px solid rgba(214, 176, 106, 0.35);
		background: rgba(10, 20, 30, 0.72);
	}

	.rules-panel {
		margin-top: 1.3rem;
		padding: 1rem;
		border-radius: 0.8rem;
		border: 1px solid rgba(214, 176, 106, 0.35);
		background:
			linear-gradient(160deg, rgba(214, 176, 106, 0.08), transparent 50%),
			rgba(10, 20, 30, 0.72);
	}

	.resource-panel h2,
	.rules-panel h2 {
		margin: 0 0 0.8rem;
		font-size: 1.35rem;
		color: #e4c27a;
	}

	.rules-list {
		margin: 0;
		padding-left: 1.2rem;
		display: grid;
		gap: 0.7rem;
		color: #d4dfe6;
	}

	.rules-list li {
		line-height: 1.55;
	}

	.resource-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.8rem;
	}

	.resource-card {
		display: grid;
		grid-template-columns: auto 1fr;
		align-items: start;
		gap: 0.65rem;
		padding: 0.75rem;
		border-radius: 0.6rem;
		border: 1px solid rgba(214, 176, 106, 0.35);
		background: linear-gradient(160deg, rgba(214, 176, 106, 0.08), transparent 45%), rgba(9, 18, 28, 0.72);
	}

	.resource-card img {
		width: 1.15rem;
		height: 1.15rem;
		border-radius: 2px;
		margin-top: 0.2rem;
	}

	.resource-card h3 {
		margin: 0;
		font-size: 1.05rem;
		color: #f0d39d;
	}

	.resource-card p {
		margin: 0.28rem 0 0;
		font-size: 0.96rem;
		color: #d4dfe6;
	}

	@media (max-width: 900px) {
		.resource-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
