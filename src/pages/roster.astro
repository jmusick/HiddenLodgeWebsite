---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

const GUILD_REALM_SLUG = 'illidan';
const GUILD_NAME_SLUG = 'hidden-lodge';
const REGION = 'us';

const clientId = import.meta.env.BLIZZARD_CLIENT_ID;
const clientSecret = import.meta.env.BLIZZARD_CLIENT_SECRET;

interface GuildRosterMember {
  character: {
    name: string;
    id: number;
    realm: { slug: string; name?: string };
    level?: number;
    playable_class?: { name?: string };
    playable_race?: { name?: string };
  };
  rank: number;
}

interface EnrichedMember {
  name: string;
  realm: string;
  className: string;
  raceName: string;
  level: number;
  rank: number;
}

const CLASS_COLORS: Record<string, string> = {
  'Death Knight': '#C41E3A',
  'Demon Hunter': '#A330C9',
  'Druid': '#FF7C0A',
  'Evoker': '#33937F',
  'Hunter': '#AAD372',
  'Mage': '#3FC7EB',
  'Monk': '#00FF98',
  'Paladin': '#F48CBA',
  'Priest': '#FFFFFF',
  'Rogue': '#FFF468',
  'Shaman': '#0070DD',
  'Warlock': '#8788EE',
  'Warrior': '#C69B3A',
};

function formatRealmFromSlug(slug: string): string {
  return slug
    .split('-')
    .filter(Boolean)
    .map((part) => part[0]?.toUpperCase() + part.slice(1))
    .join(' ');
}

const delay = (ms: number) => new Promise((resolve) => setTimeout(resolve, ms));

let members: EnrichedMember[] = [];
let errorMessage = '';

if (!clientId || !clientSecret) {
  errorMessage = 'Blizzard API credentials are not configured. Set BLIZZARD_CLIENT_ID and BLIZZARD_CLIENT_SECRET in your environment.';
} else {
  try {
    const credentials = btoa(`${clientId}:${clientSecret}`);
    const tokenRes = await fetch('https://oauth.battle.net/token', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        Authorization: `Basic ${credentials}`,
      },
      body: 'grant_type=client_credentials',
    });
    if (!tokenRes.ok) {
      throw new Error(`Failed to obtain Blizzard access token (HTTP ${tokenRes.status})`);
    }

    const { access_token } = await tokenRes.json();

    let rosterRes: Response | null = null;
    for (let attempt = 1; attempt <= 5; attempt += 1) {
      rosterRes = await fetch(
        `https://${REGION}.api.blizzard.com/data/wow/guild/${GUILD_REALM_SLUG}/${GUILD_NAME_SLUG}/roster?namespace=profile-${REGION}&locale=en_US`,
        { headers: { Authorization: `Bearer ${access_token}` } }
      );

      if (rosterRes.ok) {
        break;
      }

      const retryable = rosterRes.status === 429 || rosterRes.status >= 500;
      if (!retryable || attempt === 5) {
        break;
      }

      const retryAfterHeader = rosterRes.headers.get('retry-after');
      const retryAfterSeconds = retryAfterHeader ? Number(retryAfterHeader) : 0;
      const backoff = retryAfterSeconds > 0 ? retryAfterSeconds * 1000 : attempt * 1500;
      await delay(backoff);
    }

    if (!rosterRes?.ok) {
      if (rosterRes?.status === 429) {
        throw new Error('Blizzard API rate limit reached (HTTP 429). Please wait a minute and refresh.');
      }
      throw new Error(`Blizzard guild roster request failed (HTTP ${rosterRes?.status ?? 'unknown'})`);
    }

    const data = await rosterRes.json();
    const rosterMembers: GuildRosterMember[] = Array.isArray(data.members) ? data.members : [];

    members = rosterMembers.map((member) => ({
      name: member.character.name,
      realm: member.character.realm.name ?? formatRealmFromSlug(member.character.realm.slug),
      className: member.character.playable_class?.name ?? 'Unknown',
      raceName: member.character.playable_race?.name ?? 'Unknown',
      level: Number(member.character.level ?? 0),
      rank: member.rank,
    }));
  } catch (err) {
    errorMessage = err instanceof Error ? err.message : 'Unable to load roster from Blizzard API.';
  }
}

const sortedMembers = [...members].sort((a, b) => {
  if (a.rank !== b.rank) return a.rank - b.rank;
  return a.name.localeCompare(b.name);
});

const classOptions = [...new Set(sortedMembers.map((member) => member.className))].sort((a, b) =>
  a.localeCompare(b)
);

const rankOptions = [...new Set(sortedMembers.map((member) => member.rank))].sort((a, b) => a - b);

const maxLevelMembers = sortedMembers.filter((member) => member.level === 90).length;
const officerCount = sortedMembers.filter((member) => member.rank <= 1).length;
const uniqueRealmCount = new Set(sortedMembers.map((member) => member.realm)).size;
const uniqueRaceCount = new Set(sortedMembers.map((member) => member.raceName)).size;

const spotlights = [
  { label: 'Max Level', icon: 'lucide:swords', value: String(maxLevelMembers), detail: 'Level 90 characters' },
  { label: 'Officers', icon: 'lucide:shield', value: String(officerCount), detail: 'Guild ranks 0-1' },
  { label: 'Realms', icon: 'lucide:map', value: String(uniqueRealmCount), detail: 'Represented on the roster' },
  { label: 'Races', icon: 'lucide:footprints', value: String(uniqueRaceCount), detail: 'Different allied faces' },
];
---

<Layout title="The Hidden Lodge | Roster" description="Full guild roster sourced live from the Blizzard API.">
  <section>
    <h1 class="title-row"><Icon name="lucide:users-round" class="title-icon" aria-hidden="true" />Roster</h1>
    <p>
      Live roster sourced directly from the Blizzard API with lightweight guild data to stay within Cloudflare Worker limits.
    </p>
  </section>

  {!errorMessage && (
    <section class="spotlights" aria-label="Top players">
      {spotlights.map(({ label, icon, detail, value }) => {
        return (
          <article class="spotlight-card">
            <header class="spotlight-header">
              <Icon name={icon} class="spotlight-icon" aria-hidden="true" />
              <span class="spotlight-label">{label}</span>
            </header>
            <p class="spotlight-value">{value}</p>
            <p class="spotlight-name">{detail}</p>
          </article>
        );
      })}
    </section>
  )}

  {
    errorMessage ? (
      <section class="panel error-panel">
        <h2 class="title-row"><Icon name="lucide:triangle-alert" class="title-icon" aria-hidden="true" />Roster Unavailable</h2>
        <p class="panel-text">{errorMessage}</p>
      </section>
    ) : (
      <section class="panel">
        <h2 class="title-row"><Icon name="lucide:list" class="title-icon" aria-hidden="true" />Guild Members ({sortedMembers.length})</h2>
        <div class="controls" aria-label="Roster controls">
          <label>
            Search
            <input id="roster-search" type="search" placeholder="Character name..." autocomplete="off" />
          </label>
          <label>
            Class
            <select id="roster-class-filter">
              <option value="all">All Classes</option>
              {
                classOptions.map((className) => (
                  <option value={className}>{className}</option>
                ))
              }
            </select>
          </label>
          <label>
            Rank
            <select id="roster-rank-filter">
              <option value="all">All Ranks</option>
              {
                rankOptions.map((rank) => (
                  <option value={String(rank)}>{rank}</option>
                ))
              }
            </select>
          </label>
          <label>
            Level
            <select id="roster-level-filter">
              <option value="90" selected>Level 90</option>
              <option value="all">All Levels</option>
            </select>
          </label>
        </div>

        <div class="table-wrap">
          <div class="pagination-controls">
            <label>
              Per page
              <select id="roster-page-size">
                <option value="25" selected>25</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="200">200</option>
              </select>
            </label>
            <button id="roster-prev-page" type="button">Prev</button>
            <span id="roster-page-info">Page 1</span>
            <button id="roster-next-page" type="button">Next</button>
            <p id="roster-count" class="results-count" aria-live="polite">Showing {sortedMembers.length} members</p>
          </div>
          <table class="roster-table" id="roster-table">
            <thead>
              <tr>
                <th><button class="sort-btn" type="button" data-sort-key="name">Name</button></th>
                <th><button class="sort-btn" type="button" data-sort-key="class">Class</button></th>
                <th><button class="sort-btn" type="button" data-sort-key="race">Race</button></th>
                <th><button class="sort-btn" type="button" data-sort-key="realm">Realm</button></th>
                <th><button class="sort-btn" type="button" data-sort-key="level">Level</button></th>
                <th><button class="sort-btn" type="button" data-sort-key="rank">Rank</button></th>
                <th>Raider.IO</th>
              </tr>
            </thead>
            <tbody>
              {
                sortedMembers.map((member) => {
                  const classColor = CLASS_COLORS[member.className] ?? '#d8e2e8';
                  return (
                    <tr
                      data-name={member.name.toLowerCase()}
                      data-class={member.className}
                      data-race={member.raceName}
                      data-realm={member.realm}
                      data-level={String(member.level)}
                      data-rank={String(member.rank)}
                    >
                      <td><span class="name-pill" style={`--class-color: ${classColor}`}>{member.name}</span></td>
                      <td>{member.className}</td>
                      <td>{member.raceName}</td>
                      <td>{member.realm}</td>
                      <td>{member.level}</td>
                      <td>{member.rank}</td>
                      <td>
                        {member.name && member.realm ? (
                          <a
                            href={`https://raider.io/characters/us/${encodeURIComponent(member.realm.replace(/[' ]/g, '') )}/${encodeURIComponent(member.name)}`}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="rio-link"
                          >View</a>
                        ) : '—'}
                      </td>
                    </tr>
                  );
                })
              }
            </tbody>
          </table>
        </div>
      </section>
    )
  }
</Layout>

<script>
  const pageSizeSelect = document.querySelector<HTMLSelectElement>('#roster-page-size');
  const prevPageBtn = document.querySelector<HTMLButtonElement>('#roster-prev-page');
  const nextPageBtn = document.querySelector<HTMLButtonElement>('#roster-next-page');
  const pageInfo = document.querySelector<HTMLSpanElement>('#roster-page-info');

  let currentPage = 1;
  let pageSize = 25;

  const searchInput = document.querySelector<HTMLInputElement>('#roster-search');
  const classFilter = document.querySelector<HTMLSelectElement>('#roster-class-filter');
  const rankFilter = document.querySelector<HTMLSelectElement>('#roster-rank-filter');
  const levelFilter = document.querySelector<HTMLSelectElement>('#roster-level-filter');
  const countLabel = document.querySelector<HTMLParagraphElement>('#roster-count');
  const table = document.querySelector<HTMLTableElement>('#roster-table');
  const tableBody = table?.querySelector('tbody');
  const sortButtons = [...document.querySelectorAll<HTMLButtonElement>('.sort-btn')];

  let sortKey = 'rank';
  let sortDirection = 'asc';

  const compareText = (a: string, b: string) => a.localeCompare(b, undefined, { sensitivity: 'base' });

  function applyFiltersAndSort() {
    if (!tableBody) return;

    const query = searchInput?.value.trim().toLowerCase() ?? '';
    const selectedClass = classFilter?.value ?? 'all';
    const selectedRank = rankFilter?.value ?? 'all';
    const selectedLevel = levelFilter?.value ?? '90';

    const rows = [...tableBody.querySelectorAll('tr')];
    const visibleRows = rows.filter((row) => {
      const rowName = row.dataset.name ?? '';
      const rowClass = row.dataset.class ?? '';
      const rowRank = row.dataset.rank ?? '';
      const rowLevel = row.dataset.level ?? '';

      const matchesSearch = query.length === 0 || rowName.includes(query);
      const matchesClass = selectedClass === 'all' || rowClass === selectedClass;
      const matchesRank = selectedRank === 'all' || rowRank === selectedRank;
      const matchesLevel = selectedLevel === 'all' || rowLevel === selectedLevel;

      return matchesSearch && matchesClass && matchesRank && matchesLevel;
    });

    rows.forEach((row) => {
      row.hidden = !visibleRows.includes(row);
    });

  visibleRows.sort((rowA, rowB) => {
      const toAttr = (key: string) => key.replace(/[A-Z]/g, (c) => `-${c.toLowerCase()}`);
      const valueA = rowA.dataset[toAttr(sortKey)] ?? rowA.dataset[sortKey] ?? '';
      const valueB = rowB.dataset[toAttr(sortKey)] ?? rowB.dataset[sortKey] ?? '';
      const isNumericSort = sortKey === 'level' || sortKey === 'rank';

      let order = 0;
      if (isNumericSort) {
        order = Number(valueA) - Number(valueB);
      } else {
        order = compareText(valueA, valueB);
      }

      return sortDirection === 'asc' ? order : order * -1;
    });

      const totalPages = Math.max(1, Math.ceil(visibleRows.length / pageSize));
      if (currentPage > totalPages) currentPage = totalPages;
      const startIdx = (currentPage - 1) * pageSize;
      const endIdx = startIdx + pageSize;
      const pageRows = visibleRows.slice(startIdx, endIdx);

      rows.forEach((row) => {
        row.hidden = !pageRows.includes(row);
      });

      if (pageInfo) pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
      if (prevPageBtn) prevPageBtn.disabled = currentPage <= 1;
      if (nextPageBtn) nextPageBtn.disabled = currentPage >= totalPages;

    visibleRows.forEach((row) => tableBody.appendChild(row));
    if (countLabel) {
        countLabel.textContent = `Showing ${visibleRows.length} member${visibleRows.length === 1 ? '' : 's'} (page ${currentPage})`;
    }

    sortButtons.forEach((button) => {
      const isActive = button.dataset.sortKey === sortKey;
      button.setAttribute('aria-sort', isActive ? sortDirection : 'none');
    });
  }

    pageSizeSelect?.addEventListener('change', () => {
      pageSize = Number(pageSizeSelect.value) || 25;
      currentPage = 1;
      applyFiltersAndSort();
    });

    prevPageBtn?.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage -= 1;
        applyFiltersAndSort();
      }
    });

    nextPageBtn?.addEventListener('click', () => {
      currentPage += 1;
      applyFiltersAndSort();
    });

  searchInput?.addEventListener('input', applyFiltersAndSort);
  classFilter?.addEventListener('change', applyFiltersAndSort);
  rankFilter?.addEventListener('change', applyFiltersAndSort);
  levelFilter?.addEventListener('change', applyFiltersAndSort);

  sortButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const nextKey = button.dataset.sortKey;
      if (!nextKey) return;

      if (nextKey === sortKey) {
        sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
      } else {
        sortKey = nextKey;
        sortDirection = 'asc';
      }

      applyFiltersAndSort();
    });
  });

  applyFiltersAndSort();
</script>

<style>
  h1 {
    margin-top: 0;
    font-size: clamp(2rem, 3.1vw, 2.95rem);
  }

  p {
    max-width: 70ch;
    color: #d8e2e8;
    font-size: 1.05rem;
  }

  .panel {
    margin-top: 1rem;
    border: 1px solid rgba(214, 176, 106, 0.38);
    border-radius: 0.75rem;
    background:
      linear-gradient(155deg, rgba(214, 176, 106, 0.08), transparent 45%),
      rgba(11, 21, 32, 0.78);
    padding: 1rem;
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.22);
  }

  h2 {
    margin: 0;
    color: #e4c27a;
  }

  .title-row {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .title-icon {
    width: 1rem;
    height: 1rem;
    color: #f1d9a9;
  }

  .panel-text {
    margin: 0.75rem 0 0;
  }

  .controls {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.65rem;
    align-items: end;
  }

  .controls label {
    display: grid;
    gap: 0.4rem;
    color: #e7d9bc;
    font-size: 0.86rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .controls input,
  .controls select {
    border: 1px solid rgba(214, 176, 106, 0.4);
    border-radius: 0.45rem;
    background: rgba(7, 14, 22, 0.85);
    color: #d8e2e8;
    padding: 0.5rem 0.6rem;
    font-size: 0.94rem;
  }

  .results-count {
    margin: 0 0 0 auto;
    text-align: right;
    font-size: 0.95rem;
    color: #d8e2e8;
    white-space: nowrap;
  }

  .error-panel {
    border-color: rgba(191, 86, 68, 0.6);
    background:
      linear-gradient(155deg, rgba(191, 86, 68, 0.16), transparent 45%),
      rgba(25, 16, 18, 0.78);
  }

  .spotlights {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .spotlight-card {
    border: 1px solid rgba(214, 176, 106, 0.32);
    border-radius: 0.75rem;
    background:
      linear-gradient(155deg, rgba(214, 176, 106, 0.07), transparent 50%),
      rgba(11, 21, 32, 0.78);
    padding: 1rem 1.1rem;
    display: grid;
    gap: 0.25rem;
  }

  .spotlight-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #b0c4d0;
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .spotlight-icon {
    width: 0.95rem;
    height: 0.95rem;
    flex-shrink: 0;
  }

  .spotlight-value {
    margin: 0.35rem 0 0;
    font-family: 'Cinzel', serif;
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight: 700;
    color: #f1d9a9;
    line-height: 1;
  }

  .spotlight-name {
    margin: 0.3rem 0 0;
    font-size: 0.97rem;
    font-weight: 600;
  }

  @media (max-width: 860px) {
    .spotlights {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 480px) {
    .spotlights {
      grid-template-columns: 1fr;
    }
  }

  .table-wrap {
    margin-top: 0.85rem;
    overflow-x: auto;
    border: 1px solid rgba(214, 176, 106, 0.24);
    border-radius: 0.65rem;
    background: rgba(5, 10, 16, 0.55);
  }

  .pagination-controls {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid rgba(214, 176, 106, 0.18);
    background: rgba(15, 28, 43, 0.55);
  }

  .pagination-controls label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-right: 0.35rem;
    color: #e7d9bc;
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .pagination-controls select,
  .pagination-controls button {
    border: 1px solid rgba(214, 176, 106, 0.42);
    border-radius: 0.45rem;
    background: rgba(7, 14, 22, 0.85);
    color: #d8e2e8;
    height: 2rem;
    padding: 0 0.6rem;
    font-size: 0.9rem;
  }

  .pagination-controls button {
    cursor: pointer;
  }

  .pagination-controls button:disabled {
    opacity: 0.45;
    cursor: default;
  }

  #roster-page-info {
    min-width: 7.8rem;
    text-align: center;
    color: #d8e2e8;
    font-size: 0.9rem;
  }

  .roster-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 980px;
  }

  .roster-table th,
  .roster-table td {
    border-bottom: 1px solid rgba(214, 176, 106, 0.18);
    padding: 0.58rem 0.65rem;
    text-align: left;
    color: #d8e2e8;
    font-size: 0.95rem;
  }

  .roster-table thead th {
    background: rgba(15, 28, 43, 0.88);
    position: sticky;
    top: 0;
    z-index: 1;
  }

  .roster-table tbody tr:hover {
    background: rgba(214, 176, 106, 0.08);
  }

  .sort-btn {
    width: 100%;
    border: 0;
    background: transparent;
    color: #e4c27a;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    font-size: 0.78rem;
    text-align: left;
    cursor: pointer;
    padding: 0;
  }

  .sort-btn[aria-sort='asc']::after {
    content: ' ▲';
    font-size: 0.7rem;
  }

  .sort-btn[aria-sort='desc']::after {
    content: ' ▼';
    font-size: 0.7rem;
  }

  .name-pill {
    color: var(--class-color, #d8e2e8);
    font-weight: 700;
  }


  @media (max-width: 1000px) {
    .controls {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .results-count {
      margin-left: 0;
      text-align: left;
      width: 100%;
    }

    .pagination-controls {
      flex-wrap: wrap;
      row-gap: 0.55rem;
    }
  }

  @media (max-width: 640px) {
    .controls {
      grid-template-columns: 1fr;
    }
  }
</style>
