---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { env } from 'cloudflare:workers';
import { loadRosterWithCache } from '../lib/roster-cache';

interface EnrichedMember {
  blizzardCharId: number;
  name: string;
  realm: string;
  realmSlug: string;
  className: string;
  raceName: string;
  level: number;
  rank: number;
  achievementPoints: number;
  questCount: number;
  deathsCount: number;
  critterCount: number;
  mountCount: number;
  petCount: number;
  toyCount: number;
  detailsSyncedAt: number | null;
}

const CLASS_COLORS: Record<string, string> = {
  'Death Knight': '#C41E3A',
  'Demon Hunter': '#A330C9',
  'Druid': '#FF7C0A',
  'Evoker': '#33937F',
  'Hunter': '#AAD372',
  'Mage': '#3FC7EB',
  'Monk': '#00FF98',
  'Paladin': '#F48CBA',
  'Priest': '#FFFFFF',
  'Rogue': '#FFF468',
  'Shaman': '#0070DD',
  'Warlock': '#8788EE',
  'Warrior': '#C69B3A',
};

const { members, status, errorMessage } = await loadRosterWithCache();

const mainLinkResult = await env.DB.prepare(
  `SELECT
      c.blizzard_char_id AS alt_char_id,
      main_c.blizzard_char_id AS main_char_id
   FROM characters c
   JOIN characters main_c
     ON main_c.user_id = c.user_id
    AND main_c.is_main = 1
   JOIN roster_members_cache alt_rmc
     ON alt_rmc.blizzard_char_id = c.blizzard_char_id
   JOIN roster_members_cache main_rmc
     ON main_rmc.blizzard_char_id = main_c.blizzard_char_id
   JOIN roster_members_cache rmc
     ON rmc.blizzard_char_id = c.blizzard_char_id
   WHERE c.blizzard_char_id <> main_c.blizzard_char_id`
).all<{ alt_char_id: number; main_char_id: number }>();

const altToMainMap = new Map<number, number>(
  ((mainLinkResult.results ?? []) as Array<{ alt_char_id: number; main_char_id: number }>).map((row) => [
    row.alt_char_id,
    row.main_char_id,
  ])
);

const sortedMembers = [...members].sort((a, b) => {
  if (a.rank !== b.rank) return a.rank - b.rank;
  return a.name.localeCompare(b.name);
});

const membersById = new Map<number, EnrichedMember>(
  sortedMembers.map((member) => [member.blizzardCharId, member as EnrichedMember])
);

const classOptions = [...new Set(sortedMembers.map((member) => member.className))].sort((a, b) =>
  a.localeCompare(b)
);

const rankOptions = [...new Set(sortedMembers.map((member) => member.rank))].sort((a, b) => a - b);

const RANK_NAMES: Record<number, string> = {
  0: 'Guild Master',
  1: 'Guild Admin',
  2: 'Guild Officer',
  3: 'Officer Alt',
  4: 'Raider',
  5: 'Trial',
  6: 'Junior Raider',
  7: 'Guild Friend',
  8: 'Alt',
};

function rankLabel(rank: number): string {
  return RANK_NAMES[rank] ?? String(rank);
}

function classAbbrev(className: string): string {
  const normalized = className.trim().toLowerCase();
  const map: Record<string, string> = {
    'death knight': 'DK',
    'demon hunter': 'DH',
    druid: 'DR',
    evoker: 'EV',
    hunter: 'HU',
    mage: 'MA',
    monk: 'MO',
    paladin: 'PA',
    priest: 'PR',
    rogue: 'RO',
    shaman: 'SH',
    warlock: 'WL',
    warrior: 'WR',
  };

  return map[normalized] ?? className.slice(0, 2).toUpperCase();
}

function topBy(field: keyof Pick<EnrichedMember, 'achievementPoints' | 'questCount' | 'deathsCount' | 'critterCount' | 'mountCount' | 'petCount' | 'toyCount'>) {
  const winner = sortedMembers.reduce(
    (best, member) =>
      member[field] > (best?.value ?? -1)
        ? { member, value: member[field] }
        : best,
    null as { member: EnrichedMember; value: number } | null
  );

  if (!winner) {
    return null;
  }

  const mainCharId = altToMainMap.get(winner.member.blizzardCharId);
  const mainMember = mainCharId ? membersById.get(mainCharId) ?? null : null;
  const displayMember = mainMember && mainMember[field] === winner.value ? mainMember : winner.member;

  return {
    name: displayMember.name,
    className: displayMember.className,
    value: winner.value,
  };
}

const spotlights = [
  { label: 'Achievements', icon: 'lucide:trophy', field: 'achievementPoints' as const, format: (n: number) => n.toLocaleString() },
  { label: 'Quests', icon: 'lucide:scroll-text', field: 'questCount' as const, format: (n: number) => n.toLocaleString() },
  { label: 'Deaths', icon: 'lucide:skull', field: 'deathsCount' as const, format: (n: number) => n.toLocaleString() },
  { label: 'Critters Killed', icon: 'lucide:bug', field: 'critterCount' as const, format: (n: number) => n.toLocaleString() },
  { label: 'Mounts', icon: 'lucide:dog', field: 'mountCount' as const, format: (n: number) => String(n) },
  { label: 'Pets', icon: 'lucide:paw-print', field: 'petCount' as const, format: (n: number) => String(n) },
  { label: 'Toys', icon: 'lucide:puzzle', field: 'toyCount' as const, format: (n: number) => String(n) },
].map(({ label, icon, field, format }) => {
  const top = topBy(field);
  return {
    label,
    icon,
    name: top?.name ?? '—',
    className: top?.className ?? '',
    value: top ? format(top.value) : '—',
    showPetaAction: field === 'critterCount',
  };
});

---

<Layout title="The Hidden Lodge | Roster" description="Full guild roster sourced live from the Blizzard API.">
  <section>
    <h1 class="title-row"><Icon name="lucide:users-round" class="title-icon" aria-hidden="true" />Roster</h1>
  </section>

  {!errorMessage && (
    <section class="spotlights" aria-label="Top players">
      {spotlights.map(({ label, icon, name, className, value, showPetaAction }) => {
        const classColor = CLASS_COLORS[className] ?? '#d8e2e8';
        return (
          <div class="spotlight-slot">
            <div class="spotlight-top-row">
              {showPetaAction && (
                <button
                  type="button"
                  class="spotlight-joke-btn"
                  data-peta-button
                  aria-describedby="peta-snitch-tooltip"
                >
                  Report to PETA
                </button>
                <span
                  id="peta-snitch-tooltip"
                  class="spotlight-tooltip"
                  data-peta-tooltip
                  role="tooltip"
                  aria-hidden="true"
                >
                  Minus 50 DKP for snitching
                </span>
              )}
            </div>
            <article class="spotlight-card">
              <header class="spotlight-header">
                <Icon name={icon} class="spotlight-icon" aria-hidden="true" />
                <span class="spotlight-label">{label}</span>
              </header>
              <p class="spotlight-value">{value}</p>
              <p class="spotlight-name" style={`color: ${classColor}`}>{name}</p>
            </article>
          </div>
        );
      })}
    </section>
  )}

  {
    errorMessage ? (
      <section class="panel error-panel">
        <h2 class="title-row"><Icon name="lucide:triangle-alert" class="title-icon" aria-hidden="true" />Roster Unavailable</h2>
        <p class="panel-text">{errorMessage}</p>
      </section>
    ) : (
      <section class="panel">
        <h2 class="title-row"><Icon name="lucide:list" class="title-icon" aria-hidden="true" />Guild Members ({sortedMembers.length})</h2>
        <div class="controls" aria-label="Roster controls">
          <label>
            Search
            <input id="roster-search" type="search" placeholder="Character name..." autocomplete="off" />
          </label>
          <label>
            Class
            <select id="roster-class-filter">
              <option value="all">All Classes</option>
              {
                classOptions.map((className) => (
                  <option value={className}>{className}</option>
                ))
              }
            </select>
          </label>
          <label>
            Rank
            <select id="roster-rank-filter">
              <option value="all">All Ranks</option>
              {
                rankOptions.map((rank) => (
                  <option value={String(rank)}>{rankLabel(rank)}</option>
                ))
              }
            </select>
          </label>
          <label>
            Level
            <select id="roster-level-filter">
              <option value="90" selected>Level 90</option>
              <option value="all">All Levels</option>
            </select>
          </label>
        </div>

        <div class="table-wrap">
          <div class="pagination-controls">
            <label>
              Per page
              <select id="roster-page-size">
                <option value="25" selected>25</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="200">200</option>
              </select>
            </label>
            <button id="roster-prev-page" type="button">Prev</button>
            <span id="roster-page-info">Page 1</span>
            <button id="roster-next-page" type="button">Next</button>
            <p id="roster-count" class="results-count" aria-live="polite">Showing {sortedMembers.length} members</p>
          </div>
          <table class="roster-table" id="roster-table">
            <thead>
              <tr>
                <th><button class="sort-btn" type="button" data-sort-key="name">Name</button></th>
                <th><button class="sort-btn" type="button" data-sort-key="class">Class</button></th>
                <th><button class="sort-btn" type="button" data-sort-key="level">Level</button></th>
                <th><button class="sort-btn" type="button" data-sort-key="rank">Rank</button></th>
                <th><button class="sort-btn" type="button" data-sort-key="achievementPoints">Achieves</button></th>
                <th><button class="sort-btn" type="button" data-sort-key="questCount">Quests</button></th>
                <th><button class="sort-btn" type="button" data-sort-key="deathsCount">Deaths</button></th>
                <th><button class="sort-btn" type="button" data-sort-key="critterCount">Critters</button></th>
                <th><button class="sort-btn" type="button" data-sort-key="mountCount">Mounts</button></th>
                <th><button class="sort-btn" type="button" data-sort-key="petCount">Pets</button></th>
                <th><button class="sort-btn" type="button" data-sort-key="toyCount">Toys</button></th>
                <th>Raider.IO</th>
              </tr>
            </thead>
            <tbody>
              {
                sortedMembers.map((member) => {
                  const classColor = CLASS_COLORS[member.className] ?? '#d8e2e8';
                  const isUnknownClass = member.className.trim().toLowerCase() === 'unknown';
                  return (
                    <tr
                      data-name={member.name.toLowerCase()}
                      data-class={member.className}
                      data-level={String(member.level)}
                      data-rank={String(member.rank)}
                      data-achievement-points={String(member.achievementPoints)}
                      data-quest-count={String(member.questCount)}
                      data-deaths-count={String(member.deathsCount)}
                      data-critter-count={String(member.critterCount)}
                      data-mount-count={String(member.mountCount)}
                      data-pet-count={String(member.petCount)}
                      data-toy-count={String(member.toyCount)}
                    >
                      <td><span class="name-pill" style={`--class-color: ${classColor}`}>{member.name}</span></td>
                      <td>
                        {isUnknownClass ? (
                          <span class="class-icon-wrap" aria-hidden="true"></span>
                        ) : (
                          <span class="class-icon-wrap" title={member.className} aria-label={member.className}>
                            {member.classIconUrl ? (
                              <img
                                src={member.classIconUrl}
                                alt={member.className}
                                loading="lazy"
                                decoding="async"
                                class="class-icon-img"
                              />
                            ) : (
                              <span
                                class="class-icon"
                                style={`--class-color: ${classColor}`}
                                aria-hidden="true"
                              >
                                {classAbbrev(member.className)}
                              </span>
                            )}
                          </span>
                        )}
                      </td>
                      <td>{member.level}</td>
                      <td>{rankLabel(member.rank)}</td>
                      <td>{member.achievementPoints > 0 ? member.achievementPoints.toLocaleString() : '—'}</td>
                      <td>{member.questCount > 0 ? member.questCount.toLocaleString() : '—'}</td>
                      <td>{member.deathsCount > 0 ? member.deathsCount.toLocaleString() : '—'}</td>
                      <td>{member.critterCount > 0 ? member.critterCount.toLocaleString() : '—'}</td>
                      <td>{member.mountCount > 0 ? member.mountCount : '—'}</td>
                      <td>{member.petCount > 0 ? member.petCount : '—'}</td>
                      <td>{member.toyCount > 0 ? member.toyCount : '—'}</td>
                      <td>
                        {member.name && member.realm ? (
                          <a
                            href={`https://raider.io/characters/us/${encodeURIComponent(member.realm.replace(/[' ]/g, '') )}/${encodeURIComponent(member.name)}`}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="rio-link"
                          >View</a>
                        ) : '—'}
                      </td>
                    </tr>
                  );
                })
              }
            </tbody>
          </table>
        </div>
      </section>
    )
  }
</Layout>

<script>
  const pageSizeSelect = document.querySelector<HTMLSelectElement>('#roster-page-size');
  const prevPageBtn = document.querySelector<HTMLButtonElement>('#roster-prev-page');
  const nextPageBtn = document.querySelector<HTMLButtonElement>('#roster-next-page');
  const pageInfo = document.querySelector<HTMLSpanElement>('#roster-page-info');

  let currentPage = 1;
  let pageSize = 25;

  const searchInput = document.querySelector<HTMLInputElement>('#roster-search');
  const classFilter = document.querySelector<HTMLSelectElement>('#roster-class-filter');
  const rankFilter = document.querySelector<HTMLSelectElement>('#roster-rank-filter');
  const levelFilter = document.querySelector<HTMLSelectElement>('#roster-level-filter');
  const countLabel = document.querySelector<HTMLParagraphElement>('#roster-count');
  const table = document.querySelector<HTMLTableElement>('#roster-table');
  const tableBody = table?.querySelector('tbody');
  const sortButtons = [...document.querySelectorAll<HTMLButtonElement>('.sort-btn')];

  let sortKey = 'rank';
  let sortDirection = 'asc';

  const compareText = (a: string, b: string) => a.localeCompare(b, undefined, { sensitivity: 'base' });

  function applyFiltersAndSort() {
    if (!tableBody) return;

    const query = searchInput?.value.trim().toLowerCase() ?? '';
    const selectedClass = classFilter?.value ?? 'all';
    const selectedRank = rankFilter?.value ?? 'all';
    const selectedLevel = levelFilter?.value ?? '90';

    const rows = [...tableBody.querySelectorAll('tr')];
    const visibleRows = rows.filter((row) => {
      const rowName = row.dataset.name ?? '';
      const rowClass = row.dataset.class ?? '';
      const rowRank = row.dataset.rank ?? '';
      const rowLevel = row.dataset.level ?? '';

      const matchesSearch = query.length === 0 || rowName.includes(query);
      const matchesClass = selectedClass === 'all' || rowClass === selectedClass;
      const matchesRank = selectedRank === 'all' || rowRank === selectedRank;
      const matchesLevel = selectedLevel === 'all' || rowLevel === selectedLevel;

      return matchesSearch && matchesClass && matchesRank && matchesLevel;
    });

    rows.forEach((row) => {
      row.hidden = !visibleRows.includes(row);
    });

  visibleRows.sort((rowA, rowB) => {
      const toAttr = (key: string) => key.replace(/[A-Z]/g, (c) => `-${c.toLowerCase()}`);
      const valueA = rowA.dataset[toAttr(sortKey)] ?? rowA.dataset[sortKey] ?? '';
      const valueB = rowB.dataset[toAttr(sortKey)] ?? rowB.dataset[sortKey] ?? '';
    const isNumericSort =
      sortKey === 'level' ||
      sortKey === 'rank' ||
      sortKey === 'achievementPoints' ||
      sortKey === 'questCount' ||
      sortKey === 'deathsCount' ||
      sortKey === 'critterCount' ||
      sortKey === 'mountCount' ||
      sortKey === 'petCount' ||
      sortKey === 'toyCount';

      let order = 0;
      if (isNumericSort) {
        order = Number(valueA) - Number(valueB);
      } else {
        order = compareText(valueA, valueB);
      }

      return sortDirection === 'asc' ? order : order * -1;
    });

      const totalPages = Math.max(1, Math.ceil(visibleRows.length / pageSize));
      if (currentPage > totalPages) currentPage = totalPages;
      const startIdx = (currentPage - 1) * pageSize;
      const endIdx = startIdx + pageSize;
      const pageRows = visibleRows.slice(startIdx, endIdx);

      rows.forEach((row) => {
        row.hidden = !pageRows.includes(row);
      });

      if (pageInfo) pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
      if (prevPageBtn) prevPageBtn.disabled = currentPage <= 1;
      if (nextPageBtn) nextPageBtn.disabled = currentPage >= totalPages;

    visibleRows.forEach((row) => tableBody.appendChild(row));
    if (countLabel) {
        countLabel.textContent = `Showing ${visibleRows.length} member${visibleRows.length === 1 ? '' : 's'} (page ${currentPage})`;
    }

    sortButtons.forEach((button) => {
      const isActive = button.dataset.sortKey === sortKey;
      button.setAttribute('aria-sort', isActive ? sortDirection : 'none');
    });
  }

    pageSizeSelect?.addEventListener('change', () => {
      pageSize = Number(pageSizeSelect.value) || 25;
      currentPage = 1;
      applyFiltersAndSort();
    });

    prevPageBtn?.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage -= 1;
        applyFiltersAndSort();
      }
    });

    nextPageBtn?.addEventListener('click', () => {
      currentPage += 1;
      applyFiltersAndSort();
    });

  searchInput?.addEventListener('input', applyFiltersAndSort);
  classFilter?.addEventListener('change', applyFiltersAndSort);
  rankFilter?.addEventListener('change', applyFiltersAndSort);
  levelFilter?.addEventListener('change', applyFiltersAndSort);

  sortButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const nextKey = button.dataset.sortKey;
      if (!nextKey) return;

      if (nextKey === sortKey) {
        sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
      } else {
        sortKey = nextKey;
        sortDirection = 'asc';
      }

      applyFiltersAndSort();
    });
  });

  const petaButton = document.querySelector<HTMLButtonElement>('[data-peta-button]');
  const petaTooltip = document.querySelector<HTMLSpanElement>('[data-peta-tooltip]');
  let petaTooltipTimer: number | undefined;

  petaButton?.addEventListener('click', () => {
    if (!petaTooltip) return;

    petaTooltip.classList.add('is-visible');
    petaTooltip.setAttribute('aria-hidden', 'false');

    if (petaTooltipTimer) {
      window.clearTimeout(petaTooltipTimer);
    }

    petaTooltipTimer = window.setTimeout(() => {
      petaTooltip?.classList.remove('is-visible');
      petaTooltip?.setAttribute('aria-hidden', 'true');
    }, 2200);
  });

  applyFiltersAndSort();
</script>

<style>
  h1 {
    margin-top: 0;
    font-size: clamp(2rem, 3.1vw, 2.95rem);
  }

  p {
    max-width: 70ch;
    color: #d8e2e8;
    font-size: 1.05rem;
  }

  .panel {
    margin-top: 1rem;
    border: 1px solid rgba(214, 176, 106, 0.38);
    border-radius: 0.75rem;
    background:
      linear-gradient(155deg, rgba(214, 176, 106, 0.08), transparent 45%),
      rgba(11, 21, 32, 0.78);
    padding: 1rem;
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.22);
  }

  .cache-panel {
    padding-block: 0.85rem;
  }

  h2 {
    margin: 0;
    color: #e4c27a;
  }

  .title-row {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .title-icon {
    width: 1rem;
    height: 1rem;
    color: #f1d9a9;
  }

  .panel-text {
    margin: 0.75rem 0 0;
  }

  .controls {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.65rem;
    align-items: end;
  }

  .controls label {
    display: grid;
    gap: 0.4rem;
    color: #e7d9bc;
    font-size: 0.86rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .controls input,
  .controls select {
    border: 1px solid rgba(214, 176, 106, 0.4);
    border-radius: 0.45rem;
    background: rgba(7, 14, 22, 0.85);
    color: #d8e2e8;
    padding: 0.5rem 0.6rem;
    font-size: 0.94rem;
  }

  .results-count {
    margin: 0 0 0 auto;
    text-align: right;
    font-size: 0.95rem;
    color: #d8e2e8;
    white-space: nowrap;
  }

  .error-panel {
    border-color: rgba(191, 86, 68, 0.6);
    background:
      linear-gradient(155deg, rgba(191, 86, 68, 0.16), transparent 45%),
      rgba(25, 16, 18, 0.78);
  }

  .spotlights {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .spotlight-card {
    border: 1px solid rgba(214, 176, 106, 0.32);
    border-radius: 0.75rem;
    background:
      linear-gradient(155deg, rgba(214, 176, 106, 0.07), transparent 50%),
      rgba(11, 21, 32, 0.78);
    padding: 1rem 1.1rem;
    display: grid;
    grid-template-rows: auto minmax(2.1rem, auto) minmax(1.4rem, auto);
    align-content: start;
    gap: 0.25rem;
  }

  .spotlight-slot {
    display: grid;
    grid-template-rows: 1rem auto;
    gap: 0.2rem;
  }

  .spotlight-top-row {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 1rem;
  }

  .spotlight-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #b0c4d0;
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .spotlight-icon {
    width: 0.95rem;
    height: 0.95rem;
    flex-shrink: 0;
  }

  .spotlight-value {
    margin: 0.35rem 0 0;
    font-family: 'Cinzel', serif;
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight: 700;
    color: #f1d9a9;
    line-height: 1;
  }

  .spotlight-name {
    margin: 0.3rem 0 0;
    font-size: 0.97rem;
    font-weight: 600;
    min-height: 1.4rem;
  }

  .spotlight-joke-btn {
    border: 0;
    background: transparent;
    font: inherit;
    color: rgba(241, 217, 169, 0.82);
    padding: 0;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    text-decoration: underline;
    text-decoration-color: rgba(241, 217, 169, 0.4);
    text-underline-offset: 0.14rem;
  }

  .spotlight-joke-btn:hover {
    color: #f1d9a9;
    text-decoration-color: rgba(241, 217, 169, 0.78);
  }

  .spotlight-tooltip {
    position: absolute;
    left: 50%;
    top: calc(100% + 0.45rem);
    transform: translateX(-50%) translateY(-4px);
    z-index: 2;
    min-width: 12rem;
    max-width: 16rem;
    border: 1px solid rgba(214, 176, 106, 0.38);
    border-radius: 0.55rem;
    background: rgba(8, 14, 22, 0.97);
    color: #f4e7c7;
    padding: 0.45rem 0.6rem;
    font-size: 0.8rem;
    line-height: 1.3;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.28);
    opacity: 0;
    pointer-events: none;
    transition: opacity 120ms ease, transform 120ms ease;
  }

