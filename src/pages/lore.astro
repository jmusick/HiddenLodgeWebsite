<Layout title="The Hidden Lodge | Lore" description="Fictional stories from The Hidden Lodge featuring guild characters and dungeon chaos.">
  <section class="hero" aria-labelledby="lore-title">
    <p class="eyebrow">Guild Lore Archive</p>
    <h1 id="lore-title">Stories from the Lodge</h1>
    <p class="intro">
      Fictional (maybe?) tales inspired by raid nights, Mythic+ disasters, and the strange chemistry that keeps this guild together.
    </p>
  </section>

  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Story image full size" hidden>
    <button class="lightbox-close" id="lightbox-close" aria-label="Close">&times;</button>
    <img id="lightbox-img" src="" alt="" />
  </div>

  {
    !selectedStory && (
      <section class="story-picker" aria-labelledby="story-picker-title">
        <div class="story-picker-head">
          <h2 id="story-picker-title">Choose Your Story</h2>
          <p>Pick a tale to open the full archive entry.</p>
        </div>

        <div class="story-grid" role="list">
          {
            orderedStories.map((story) => (
              <article class="story-preview" role="listitem">
                <a class="preview-image-link" href={`/lore?story=${story.id}`} aria-label={`Read story: ${story.title}`}>
                  <img class="preview-image" src={story.imageSrc} alt={story.imageAlt} loading="lazy" />
                </a>
                <div class="preview-content">
                  <h3>
                    <a class="story-title-link" href={`/lore?story=${story.id}`}>{story.title}</a>
                  </h3>
                  <p>{story.lead}</p>
                  <div class="chips" aria-label="Featured characters">
                    {
                      story.characters.map((name) => (
                        <span class="chip">
                          <Icon name="lucide:user-round" aria-hidden="true" />
                          {name}
                        </span>
                      ))
                    }
                  </div>
                  <a class="open-story" href={`/lore?story=${story.id}`}>
                    <Icon name="lucide:book-open-text" aria-hidden="true" />
                    Read Story
                  </a>
                </div>
              </article>
            ))
          }
        </div>
      </section>
    )
  }

  {
    selectedStory && (
      <section class="stories" aria-label="Selected lore story">
        <div class="story-toolbar">
          <a class="back-to-list" href="/lore">
            <Icon name="lucide:arrow-left" aria-hidden="true" />
            Back to story list
          </a>

          <form class="story-switcher" method="get" action="/lore">
            <label for="story-select">Jump to story</label>
            <select id="story-select" name="story" onchange="this.form.submit()">
              {
                orderedStories.map((story) => (
                  <option value={story.id} selected={story.id === selectedStory.id}>
                    {story.title}
                  </option>
                ))
              }
            </select>
            <noscript>
              <button type="submit">Go</button>
            </noscript>
          </form>
        </div>

        <article class:list={["story-card", usesAsideStoryImage && 'story-card--floating-image']} id={selectedStory.id}>
          <header class="story-head">
            <h2>{selectedStory.title}</h2>
            <p>{selectedStory.lead}</p>
            <div class="chips" aria-label="Featured characters">
              {
                selectedStory.characters.map((name) => (
                  <span class="chip">
                    <Icon name="lucide:user-round" aria-hidden="true" />
                    {name}
                  </span>
                ))
              }
            </div>
          </header>

          <div class:list={["story-body", usesAsideStoryImage && 'story-body--with-aside-image']}>
            {
              usesTopStoryImage && (
                <button
                  class="story-image-button"
                  data-lightbox-src={selectedStory.imageSrc}
                  data-lightbox-alt={selectedStory.imageAlt}
                  aria-label={`View full image for ${selectedStory.title}`}
                  type="button"
                >
                  <img class="story-image" src={selectedStory.imageSrc} alt={selectedStory.imageAlt} loading="lazy" />
                </button>
              )
            }
            {
              usesAsideStoryImage && (
                <button
                  class="story-image-button story-image-button--aside"
                  data-lightbox-src={selectedStory.imageSrc}
                  data-lightbox-alt={selectedStory.imageAlt}
                  aria-label={`View full image for ${selectedStory.title}`}
                  type="button"
                >
                  <img
                    class="story-image story-image--aside"
                    src={selectedStory.imageSrc}
                    alt={selectedStory.imageAlt}
                    loading="lazy"
                  />
                </button>
              )
            }
            {
              selectedStoryBlocks.map((block) =>
                block.type === 'paragraph' && block.isIncidentHeading ? (
                  <h3 class="story-incident-heading">{block.paragraph}</h3>
                ) : block.type === 'paragraph' ? (
                  <p>{block.paragraph}</p>
                ) : block.type === 'list' ? (
                  <ul class="story-inline-list">
                    {block.items.map((item) => <li>{item}</li>)}
                  </ul>
                ) : (
                  <figure class="story-inline-figure">
                    <button
                      class="story-image-button story-image-button--inline"
                      data-lightbox-src={block.image.src}
                      data-lightbox-alt={block.image.alt}
                      aria-label={`View full image for ${selectedStory.title}`}
                      type="button"
                    >
                      <img class="story-image story-image--inline" src={block.image.src} alt={block.image.alt} loading="lazy" />
                    </button>
                    {block.image.caption && <figcaption>{block.image.caption}</figcaption>}
                  </figure>
                )
              )
            }
          </div>
        </article>
      </section>
    )
  }

  <script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const closeBtn = document.getElementById('lightbox-close');

    function openLightbox(src: string, alt: string) {
      if (!(lightbox instanceof HTMLElement) || !(lightboxImg instanceof HTMLImageElement)) return;
      lightboxImg.src = src;
      lightboxImg.alt = alt;
      lightbox.hidden = false;
      lightbox.focus();
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      if (!(lightbox instanceof HTMLElement) || !(lightboxImg instanceof HTMLImageElement)) return;
      lightbox.hidden = true;
      lightboxImg.src = '';
      lightboxImg.alt = '';
      document.body.style.overflow = '';
    }

    document.querySelectorAll('[data-lightbox-src]').forEach((button) => {
      button.addEventListener('click', () => {
        if (!(button instanceof HTMLElement)) return;
        openLightbox(button.dataset.lightboxSrc ?? '', button.dataset.lightboxAlt ?? '');
      });
    });

    if (closeBtn) closeBtn.addEventListener('click', closeLightbox);

    if (lightbox) {
      lightbox.addEventListener('click', (event) => {
        if (event.target === lightbox) closeLightbox();
      });
    }

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && lightbox instanceof HTMLElement && !lightbox.hidden) {
        closeLightbox();
      }
    });
  </script>
</Layout>

