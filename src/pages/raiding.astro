---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { env } from 'cloudflare:workers';
import { fallbackClassIconUrl } from '../lib/class-icons';
import { getSessionUser } from '../lib/auth';

interface RecentGuildLog {
  title: string;
  url: string;
  owner: string | null;
  publishedLabel: string | null;
}

interface RecentLogsResult {
  logs: RecentGuildLog[];
  hasMetadata: boolean;
  metadataNotice: string | null;
}

interface WclAuthConfig {
  clientId: string;
  clientSecret: string;
}

interface WclReportsResponse {
  data?: {
    reportData?: {
      reports?: {
        data?: Array<{
          code?: string;
          title?: string;
          startTime?: number;
          owner?: {
            name?: string;
          } | null;
        }>;
      };
    };
  };
  errors?: Array<{ message?: string }>;
}

const GUILD_REPORTS_LIST_URL = 'https://www.warcraftlogs.com/guild/reports-list/781707';
const REPORT_LINK_REGEX = /<a[^>]+href="(\/reports\/[A-Za-z0-9]+)"[^>]*>([\s\S]*?)<\/a>/gi;
const WCL_OAUTH_URL = 'https://www.warcraftlogs.com/oauth/token';
const WCL_GRAPHQL_URL = 'https://www.warcraftlogs.com/api/v2/client';
const WCL_GUILD_ID = 781707;

let wclTokenCache: { accessToken: string; expiresAt: number } | null = null;

function nowInSeconds(): number {
  return Math.floor(Date.now() / 1000);
}

function readEnv(key: string): string | undefined {
  const runtimeValue = (env as unknown as Record<string, string | undefined>)[key];
  if (runtimeValue && runtimeValue.trim()) {
    return runtimeValue;
  }

  const viteValue = (import.meta.env as Record<string, string | undefined>)[key];
  if (viteValue && viteValue.trim()) {
    return viteValue;
  }

  return undefined;
}

function getWclAuthConfig(): WclAuthConfig | null {
  const clientId = readEnv('WCL_CLIENT_ID');
  const clientSecret = readEnv('WCL_CLIENT_SECRET');

  if (!clientId || !clientSecret) {
    return null;
  }

  return { clientId, clientSecret };
}

async function getWclAccessToken(config: WclAuthConfig): Promise<string | null> {
  const now = nowInSeconds();
  if (wclTokenCache && wclTokenCache.expiresAt > now) {
    return wclTokenCache.accessToken;
  }

  const response = await fetch(WCL_OAUTH_URL, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/x-www-form-urlencoded',
      Authorization: `Basic ${btoa(`${config.clientId}:${config.clientSecret}`)}`,
    },
    body: 'grant_type=client_credentials',
  });

  if (!response.ok) {
    return null;
  }

  const data = (await response.json()) as { access_token?: string; expires_in?: number };
  if (!data.access_token) {
    return null;
  }

  const ttl = Math.max(60, Number(data.expires_in ?? 0) || 0);
  wclTokenCache = {
    accessToken: data.access_token,
    expiresAt: now + Math.max(60, ttl - 60),
  };
  return data.access_token;
}

function stripHtml(value: string): string {
  return value.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
}

function decodeHtmlEntities(value: string): string {
  return value
    .replace(/&amp;/g, '&')
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&nbsp;/g, ' ')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>');
}

function parseRecentGuildLogs(html: string, limit: number): RecentGuildLog[] {
  const reports: RecentGuildLog[] = [];
  const seen = new Set<string>();

  for (const match of html.matchAll(REPORT_LINK_REGEX)) {
    const href = match[1]?.trim() ?? '';
    if (!href || seen.has(href)) continue;

    const rawTitle = match[2] ?? '';
    const title = decodeHtmlEntities(stripHtml(rawTitle));
    if (!title) continue;

    seen.add(href);
    reports.push({
      title,
      url: `https://www.warcraftlogs.com${href}`,
      owner: null,
      publishedLabel: null,
    });

    if (reports.length >= limit) {
      break;
    }
  }

  return reports;
}

function formatPublishedLabel(startTimeMs: number | null | undefined): string | null {
  if (!startTimeMs || !Number.isFinite(startTimeMs)) {
    return null;
  }

  const date = new Date(startTimeMs);
  if (Number.isNaN(date.getTime())) {
    return null;
  }

  return new Intl.DateTimeFormat('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
  }).format(date);
}

async function loadRecentGuildLogs(limit = 5): Promise<RecentLogsResult> {
  const sanitizedLimit = Math.max(1, limit);
  const config = getWclAuthConfig();
  let metadataNotice = 'Add WCL_CLIENT_ID and WCL_CLIENT_SECRET to show uploader and publish time.';

  if (config) {
    try {
      const accessToken = await getWclAccessToken(config);
      if (!accessToken) {
        metadataNotice = 'Warcraft Logs authentication failed. Verify WCL_CLIENT_ID/WCL_CLIENT_SECRET in Cloudflare production secrets.';
      } else {
        const response = await fetch(WCL_GRAPHQL_URL, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${accessToken}`,
          },
          body: JSON.stringify({
            query: `
              query RecentGuildReports($guildID: Int!, $limit: Int!) {
                reportData {
                  reports(guildID: $guildID, limit: $limit, page: 1) {
                    data {
                      code
                      title
                      startTime
                      owner {
                        name
                      }
                    }
                  }
                }
              }
            `,
            variables: {
              guildID: WCL_GUILD_ID,
              limit: sanitizedLimit,
            },
          }),
        });

        if (!response.ok) {
          metadataNotice = `Warcraft Logs API request failed (${response.status}).`;
        } else {
          const payload = (await response.json()) as WclReportsResponse;
          if ((payload.errors?.length ?? 0) > 0) {
            metadataNotice = 'Warcraft Logs API returned an error for guild reports metadata.';
          } else {
            const rows = payload.data?.reportData?.reports?.data ?? [];
            const logs = rows
              .map((row) => {
                const code = row.code?.trim() ?? '';
                if (!code) return null;
                return {
                  title: row.title?.trim() || 'Untitled Report',
                  url: `https://www.warcraftlogs.com/reports/${code}`,
                  owner: row.owner?.name?.trim() || null,
                  publishedLabel: formatPublishedLabel(row.startTime),
                } as RecentGuildLog;
              })
              .filter((row): row is RecentGuildLog => row !== null);

            if (logs.length > 0) {
              return { logs, hasMetadata: true, metadataNotice: null };
            }

            metadataNotice = 'Warcraft Logs API returned no reports for this guild.';
          }
        }
      }
    } catch {
      metadataNotice = 'Warcraft Logs metadata lookup failed unexpectedly.';
    }
  }

  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 7000);

  try {
    const response = await fetch(GUILD_REPORTS_LIST_URL, {
      signal: controller.signal,
      headers: {
        'user-agent': 'HiddenLodgeWebsite/1.0 (+https://www.thehiddenlodge.com)',
      },
    });

    if (!response.ok) {
      return {
        logs: [],
        hasMetadata: false,
        metadataNotice: 'Uploader and publish time are unavailable right now.',
      };
    }

    const html = await response.text();
    const reports = parseRecentGuildLogs(html, sanitizedLimit);
    return {
      logs: reports,
      hasMetadata: false,
      metadataNotice,
    };
  } catch {
    return {
      logs: [],
      hasMetadata: false,
      metadataNotice: 'Recent logs are temporarily unavailable.',
    };
  } finally {
    clearTimeout(timeout);
  }
}

const recentLogsResult = await loadRecentGuildLogs(5);
const recentLogs = recentLogsResult.logs;

// ── Raiding page editable content ──────────────────────────────────────────
interface RaidingContentRow { key: string; content: string; }
interface RaidingAddonRow   { id: number; name: string; url: string; sort_order: number; }
interface RecruitmentNeedRow { id: number; class: string; role: string; priority: string; }

const [raidingContentResult, raidingAddonsResult, recruitmentNeedsResult] = await env.DB.batch([
  env.DB.prepare(`SELECT key, content FROM raiding_content WHERE key IN ('schedule','raid_expectations','recruitment')`),
  env.DB.prepare(`SELECT id, name, url, sort_order FROM raiding_addons ORDER BY sort_order ASC, id ASC`),
  env.DB.prepare(`SELECT id, class, role, priority FROM recruitment_needs ORDER BY sort_order ASC, id ASC`),
]);

const raidingContentMap = new Map<string, string>();
for (const row of (raidingContentResult.results ?? []) as RaidingContentRow[]) {
  if (row.content.trim()) raidingContentMap.set(row.key, row.content);
}

const raidingAddons = (raidingAddonsResult.results ?? []) as RaidingAddonRow[];
const recruitmentNeeds = (recruitmentNeedsResult.results ?? []) as RecruitmentNeedRow[];

const scheduleHtml     = raidingContentMap.get('schedule')          ?? '';
const expectationsHtml = raidingContentMap.get('raid_expectations') ?? '';
const recruitmentHtml  = raidingContentMap.get('recruitment')       ?? '';

const blizzardClientId = readEnv('BLIZZARD_CLIENT_ID') ?? '';

// Check if logged-in Blizzard user has a matching application
const sessionUser = await getSessionUser(env.DB, Astro.request);
let myApplication: { id: number; status: string } | null = null;
if (sessionUser) {
  const appRow = await env.DB.prepare(
    `SELECT a.id, a.status
     FROM applications a
     WHERE (
       (a.battletag != '' AND LOWER(a.battletag) = LOWER(?))
       OR EXISTS (
         SELECT 1 FROM application_characters ac
         JOIN characters c ON LOWER(c.name) = LOWER(ac.char_name) AND c.realm_slug = ac.realm_slug
         WHERE ac.application_id = a.id AND c.user_id = ?
       )
     )
     ORDER BY a.submitted_at DESC
     LIMIT 1`
  ).bind(sessionUser.battleTag, sessionUser.id).first<{ id: number; status: string }>();
  myApplication = appRow ?? null;
}

const APP_STATUS_LABELS: Record<string, string> = {
  received:  'Received — we\'ll review your application soon.',
  reviewed:  'Reviewed — an officer has looked over your application.',
  contacted: 'Contacted — check your Discord, an officer has reached out!',
  rejected:  'Not a fit right now — thank you for your interest in The Hidden Lodge.',
  trial:     'Trial — welcome! Check Discord for next steps.',
};
const APP_STATUS_THEME: Record<string, string> = {
  received:  'blue',
  reviewed:  'amber',
  contacted: 'purple',
  rejected:  'red',
  trial:     'green',
};
---

<Layout title="The Hidden Lodge | Raiding" description="Raid schedule and expectations for The Hidden Lodge.">
  <section>
    <h1 class="title-row"><Icon name="lucide:swords" class="title-icon" aria-hidden="true" />Raiding</h1>
    <p>
      We raid with purpose and respect everyone's time. Two nights a week, hard pulls from the first minute,
      and clear expectations so every raider knows exactly where they stand.
    </p>
  </section>

  <div class="raiding-grid">
    <div class="raiding-column">
      <section class="panel">
        <h2 class="title-row"><Icon name="lucide:calendar-days" class="title-icon" aria-hidden="true" />Schedule</h2>
        {scheduleHtml ? (
          <div class="rich-content" set:html={scheduleHtml} />
        ) : (
          <ul>
            <li><strong>Thursday:</strong> 9:00 PM – 12:00 AM Eastern</li>
            <li><strong>Friday:</strong> 9:00 PM – 12:00 AM Eastern</li>
            <li>Alt raid nights are common and are a solid way to gear up or mess around on alts, but they are never mandatory.</li>
          </ul>
        )}
      </section>

      <section class="panel">
        <h2 class="title-row"><Icon name="lucide:clipboard-check" class="title-icon" aria-hidden="true" />Raid Expectations</h2>
        {expectationsHtml ? (
          <div class="rich-content" set:html={expectationsHtml} />
        ) : (
          <ul>
            <li><strong>Come prepared.</strong> Show up on time, fully enchanted, gemmed, and stocked with your own consumables. The guild provides feasts. We pull at 9:00 PM sharp — not 9:05.</li>
            <li><strong>Keep comms clean.</strong> During progression, voice chat is reserved for the raid lead, tanks, and officers. The only exception is fights that specifically require call-outs from other roles — you'll be told when that applies.</li>
            <li><strong>BoE guild tax is 20%.</strong> All BoE drops carry a 20% guild tax. These funds go directly into the guild bank and are returned to raiders in the form of cauldrons, feasts, Vantus runes, and other raid consumables.</li>
            <li><strong>Benching happens — don't take it personally.</strong> There will be nights where someone sits out due to performance needs or tuning requirements. This is a roster decision, not a personal one. Stay positive and be ready to step back in.</li>
            <li><strong>Loot is distributed via Loot Council (RC LootCouncil addon required).</strong> Priority goes to raiders who show up on time, fill their Great Vault, and perform. Consistent effort is rewarded. If you fall short on any of those fronts, loot priority reflects that.</li>
            <li><strong>Sign up for raid.</strong> If you can't make it, post in the attendance channel ahead of time. No-shows with no notice are not acceptable.</li>
            <li><strong>No alts on progression.</strong> The only exception is if your alt is at a comparable item level to your main AND fills a role the team genuinely needs. This requires officer approval.</li>
            <li><strong>Want to swap classes?</strong> Reach out to an officer first. If approved, we'll do our best to help you gear it up to a competitive level before bringing it to progression.</li>
          </ul>
        )}
      </section>

      <section class="panel">
        <h2 class="title-row"><Icon name="lucide:puzzle" class="title-icon" aria-hidden="true" />Required Addons</h2>
        <ul class="addon-links">
          {raidingAddons.map((addon) => (
            <li>
              <a href={addon.url} target="_blank" rel="noopener noreferrer">{addon.name}</a>
            </li>
          ))}
        </ul>
      </section>

      <section class="panel recent-logs-panel">
        <h2 class="title-row"><Icon name="lucide:scroll" class="title-icon" aria-hidden="true" />Recent Logs</h2>
        {recentLogs.length === 0 ? (
          <p class="panel-text">
            Recent logs are temporarily unavailable.
            <a href="https://www.warcraftlogs.com/guild/reports-list/781707" target="_blank" rel="noopener noreferrer"> View all reports.</a>
          </p>
        ) : (
          <>
            <ul class="recent-logs-list">
              {recentLogs.map((log) => (
                <li>
                  <a href={log.url} target="_blank" rel="noopener noreferrer">{log.title}</a>
                  {recentLogsResult.hasMetadata && (log.owner || log.publishedLabel) && (
                    <span class="recent-log-meta">
                      {log.owner && <span> — {log.owner}</span>}
                      {log.publishedLabel && <span>, {log.publishedLabel}</span>}
                    </span>
                  )}
                </li>
              ))}
            </ul>
            {!recentLogsResult.hasMetadata && recentLogsResult.metadataNotice && (
              <p class="recent-logs-note">{recentLogsResult.metadataNotice}</p>
            )}
          </>
        )}
      </section>
    </div>

    <div class="raiding-column">
      <section class="panel" id="recruitment">
        <h2 class="title-row"><Icon name="lucide:users" class="title-icon" aria-hidden="true" />Recruitment</h2>
        {recruitmentHtml ? (
          <div class="rich-content" set:html={recruitmentHtml} />
        ) : (
          <p class="panel-text">
            We recruit players who value consistency, preparation, and a positive progression mindset.
            Exceptional applicants are always welcome.
          </p>
        )}
      </section>

      <section class="panel">
        <h2 class="title-row"><Icon name="lucide:target" class="title-icon" aria-hidden="true" />Current Needs</h2>
        {recruitmentNeeds.length === 0 ? (
          <p class="panel-text">We are not actively recruiting for any specific class or role at this time. However, we are always open to exceptional players who bring skill, dedication, and a great attitude.</p>
        ) : (
          <div class="needs-table">
            <div class="needs-row needs-row--header">
              <span class="needs-col-header">Class</span>
              <span class="needs-col-header">Role</span>
              <span class="needs-col-header">Need</span>
            </div>
            {recruitmentNeeds.map((need) => {
              const iconUrl = fallbackClassIconUrl(need.class);
              return (
                <div class="needs-row">
                  <span class="need-class-identity">
                    {iconUrl && (
                      <img src={iconUrl} alt="" aria-hidden="true" class="need-class-icon" loading="lazy" decoding="async" />
                    )}
                    <span class="need-class-name">{need.class}</span>
                  </span>
                  <span class="need-role">{need.role}</span>
                  <span class={`need-priority need-priority--${need.priority}`}>
                    {need.priority.charAt(0).toUpperCase() + need.priority.slice(1)}
                  </span>
                </div>
              );
            })}
          </div>
        )}
        <p class="needs-footnote">We always welcome applications from exceptional and highly qualified players, regardless of current needs.</p>
      </section>

      <section class="panel" id="apply">
        <h2 class="title-row"><Icon name="lucide:scroll-text" class="title-icon" aria-hidden="true" />How to Apply</h2>
        <p class="apply-intro">Fill out the form below and we&rsquo;ll review your application and reach out in game or through Discord using the contact information you provide.</p>

        {myApplication && (
          <div class={`app-status-banner app-status-banner--${APP_STATUS_THEME[myApplication.status]}`}>
            <strong>Your application status:</strong> {APP_STATUS_LABELS[myApplication.status] ?? myApplication.status}
          </div>
        )}

        <form class="apply-form" id="apply-form" novalidate>

          <fieldset class="apply-fieldset">
            <legend class="apply-legend">Contact</legend>
            <div class="form-row">
              <label for="discord-name" class="form-label">Discord Username</label>
              <input type="text" id="discord-name" name="discord" class="form-input" placeholder="Username" autocomplete="off" spellcheck="false" />
            </div>
          </fieldset>

          <fieldset class="apply-fieldset">
            <legend class="apply-legend">About You</legend>
            <div class="form-row">
              <label for="raid-history" class="form-label">Raid History</label>
              <textarea id="raid-history" name="raid_history" class="form-input form-textarea" rows="2" placeholder="Briefly summarize your raiding experience — progression tiers, roles, guilds…"></textarea>
            </div>
            <div class="form-row">
              <label for="wow-goals" class="form-label">Goals in WoW</label>
              <textarea id="wow-goals" name="wow_goals" class="form-input form-textarea" rows="2" placeholder="What are you looking to accomplish in WoW?"></textarea>
            </div>
          </fieldset>

          <fieldset class="apply-fieldset">
            <legend class="apply-legend">WoW Info</legend>

            <div class="form-row">
              <label for="battletag" class="form-label">Battle.net Tag</label>
              <div class="battletag-row">
                <input type="text" id="battletag" name="battletag" class="form-input" placeholder="YourName#1234 (required)" autocomplete="off" spellcheck="false" />
                <span class="battletag-or">or</span>
                <button type="button" class="btn-blizzard" id="blizzard-login-btn"
                  data-client-id={blizzardClientId}
                  title={blizzardClientId ? 'Login with Blizzard to auto-fill your characters' : 'Blizzard OAuth not configured'}
                  disabled={!blizzardClientId || undefined}>
                  <svg class="blizzard-icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 2.5a7.5 7.5 0 1 1 0 15 7.5 7.5 0 0 1 0-15zm-.5 3v5.25l4.5 2.25-.75 1.5L10 13.75V7.5h1.5z"/></svg>
                  <span id="blizzard-btn-label">Login with Blizzard</span>
                </button>
              </div>
              <p class="battletag-help">Logging in with Blizzard lets us verify your characters and allows you to <a href="/raiding#apply" class="battletag-help-link">check your application status</a> on this page after submitting. <a href="https://community.developer.battle.net/documentation/guides/using-oauth" target="_blank" rel="noopener noreferrer" class="battletag-help-link">Learn about Blizzard OAuth&nbsp;&nearr;</a></p>
            </div>

            <div id="char-blocks">
              <div class="char-block">
                <div class="char-block-header">
                  <span class="char-block-label">Main Character</span>
                  <button type="button" class="btn-remove-char" hidden aria-label="Remove character">✕ Remove</button>
                </div>
                <div class="char-block-fields">
                  <div class="form-row char-blizzard-row" hidden style="grid-column: 1 / -1">
                    <label class="form-label">Select Character</label>
                    <select class="form-input char-blizzard-select">
                      <option value="">— Select a character —</option>
                    </select>
                  </div>
                  <div class="form-row char-manual-row">
                    <label class="form-label">Character Name</label>
                    <input type="text" name="char_name" class="form-input char-name" autocomplete="off" spellcheck="false" />
                  </div>
                  <div class="form-row char-manual-row">
                    <label class="form-label">Realm</label>
                    <input type="text" name="char_realm" class="form-input char-realm" list="realm-list" autocomplete="off" spellcheck="false" placeholder="Type to search…" />
                  </div>
                </div>
                <div class="char-status-area">
                  <p class="char-checking" hidden aria-live="polite">Looking up character…</p>
                  <div class="char-links">
                    <a class="char-link char-link--rio char-link--disabled" href="#" target="_blank" rel="noopener noreferrer" aria-disabled="true" tabindex="-1"><span class="char-link-check" hidden aria-hidden="true">✓ </span>Raider.io <span class="ext-icon" aria-hidden="true">↗</span></a>
                    <a class="char-link char-link--wcl char-link--disabled" href="#" target="_blank" rel="noopener noreferrer" aria-disabled="true" tabindex="-1"><span class="char-link-check" hidden aria-hidden="true">✓ </span>Warcraft Logs <span class="ext-icon" aria-hidden="true">↗</span></a>
                  </div>
                  <p class="char-not-found" hidden aria-live="polite">Character not found — double-check the name and realm spelling.</p>
                </div>
              </div>
            </div>

            <button type="button" id="add-char-btn" class="btn-add-char">+ Add Another Character</button>
          </fieldset>

          <div class="apply-actions">
            <button type="submit" class="btn-submit" id="apply-submit-btn">Submit Application</button>
            <span class="apply-feedback" id="apply-feedback" hidden></span>
          </div>

        </form>

        <datalist id="realm-list"></datalist>
      </section>
    </div>
  </div>
</Layout>

<style>
  h1 {
    margin-top: 0;
    font-size: clamp(2rem, 3.1vw, 2.95rem);
  }

  p {
    max-width: 70ch;
    color: #d8e2e8;
    font-size: 1.05rem;
  }

  .panel {
    border: 1px solid rgba(214, 176, 106, 0.38);
    border-radius: 0.75rem;
    background:
      linear-gradient(155deg, rgba(214, 176, 106, 0.08), transparent 45%),
      rgba(11, 21, 32, 0.78);
    padding: 1rem;
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.22);
  }

  .raiding-grid {
    margin-top: 1rem;
    display: grid;
    gap: 1rem;
  }

  .raiding-column {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  @media (min-width: 960px) {
    .raiding-grid {
      grid-template-columns: minmax(0, 1.55fr) minmax(0, 1fr);
      gap: 1.25rem;
      align-items: start;
    }
  }

  h2 {
    margin: 0;
    color: #e4c27a;
  }

  .title-row {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .title-icon {
    width: 1rem;
    height: 1rem;
    color: #f1d9a9;
  }

  ul {
    margin: 0.8rem 0 0;
    padding-left: 1.1rem;
    line-height: 1.6;
    color: #d8e2e8;
  }

  .addon-links a {
    color: #f0d39d;
    text-decoration: underline;
    text-decoration-color: rgba(240, 211, 157, 0.55);
    text-underline-offset: 0.14em;
  }

  .addon-links a:hover,
  .addon-links a:focus-visible {
    color: #ffe6b5;
  }

