// Convert a realm display name to an API/URL slug
function realmToSlug(name) {
  return name.toLowerCase().replace(/'/g, '').replace(/\s+/g, '-');
}

// Enable/disable the RIO + WCL profile link badges
function setLinksDisabled(block, disabled) {
  var rioLink = block.querySelector('.char-link--rio');
  var wclLink = block.querySelector('.char-link--wcl');
  [rioLink, wclLink].forEach(function (link) {
    if (!link) return;
    if (disabled) {
      link.classList.add('char-link--disabled');
      link.setAttribute('aria-disabled', 'true');
      link.setAttribute('tabindex', '-1');
      link.href = '#';
      var check = link.querySelector('.char-link-check');
      if (check) check.hidden = true;
    } else {
      link.classList.remove('char-link--disabled');
      link.removeAttribute('aria-disabled');
      link.setAttribute('tabindex', '0');
    }
  });
}

function lookupChar(block) {
  var nameEl  = block.querySelector('.char-name');
  var realmEl = block.querySelector('.char-realm');
  var name    = nameEl  ? nameEl.value.trim()  : '';
  var realm   = realmEl ? realmEl.value.trim() : '';
  var checkingEl = block.querySelector('.char-checking');
  var notFoundEl = block.querySelector('.char-not-found');

  function hide(el) { if (el) el.hidden = true; }
  function show(el) { if (el) el.hidden = false; }

  if (!name || !realm) {
    setLinksDisabled(block, true);
    hide(checkingEl);
    hide(notFoundEl);
    return;
  }

  var slug = realmToSlug(realm);
  setLinksDisabled(block, true);
  show(checkingEl);
  hide(notFoundEl);

  var apiUrl = 'https://raider.io/api/v1/characters/profile'
    + '?region=us'
    + '&realm=' + encodeURIComponent(slug)
    + '&name=' + encodeURIComponent(name)
    + '&fields=gear';

  var controller = new AbortController();
  var timer = setTimeout(function () { controller.abort(); }, 8000);

  fetch(apiUrl, { signal: controller.signal })
    .then(function (res) {
      clearTimeout(timer);
      hide(checkingEl);
      if (res.ok) {
        var encodedName = encodeURIComponent(name.toLowerCase());
        var rioLink = block.querySelector('.char-link--rio');
        var wclLink = block.querySelector('.char-link--wcl');
        if (rioLink) rioLink.href = 'https://raider.io/characters/us/' + slug + '/' + encodedName;
        if (wclLink) wclLink.href = 'https://www.warcraftlogs.com/character/us/' + slug + '/' + encodedName;
        setLinksDisabled(block, false);
        block.querySelectorAll('.char-link-check').forEach(function (el) { el.hidden = false; });
        block.dataset.validated = '1';
      } else {
        delete block.dataset.validated;
        show(notFoundEl);
      }
    })
    .catch(function () {
      clearTimeout(timer);
      hide(checkingEl);
      // Network error: silently reset
      delete block.dataset.validated;
    });
}

function wireBlock(block) {
  var nameInput  = block.querySelector('.char-name');
  var realmInput = block.querySelector('.char-realm');

  // Blizzard character picker inside this block
  var bSelect = block.querySelector('.char-blizzard-select');
  if (bSelect) {
    bSelect.addEventListener('change', function () {
      if (!bSelect.value) {
        delete block.dataset.validated;
        return;
      }
      try {
        var char = JSON.parse(bSelect.value);
        if (nameInput)  nameInput.value  = char.name;
        if (realmInput) realmInput.value = char.realm;
        block.dataset.validated = '1'; // Blizzard OAuth character — inherently valid
        lookupChar(block); // also kicks off Raider.io lookup for the links
      } catch (_) {}
    });
  }

  // Clear disabled state immediately when either field is emptied while typing
  function onInput(el) {
    if (!el.value.trim()) {
      setLinksDisabled(block, true);
      delete block.dataset.validated;
      var notFoundEl = block.querySelector('.char-not-found');
      if (notFoundEl) notFoundEl.hidden = true;
    }
  }
  if (nameInput)  nameInput.addEventListener('input',  function () { onInput(nameInput); });
  if (realmInput) realmInput.addEventListener('input',  function () { onInput(realmInput); });

  // Lookup fires only on blur (tab-out), so we don't search prematurely
  if (nameInput)  nameInput.addEventListener('blur',   function () { lookupChar(block); });
  if (realmInput) realmInput.addEventListener('blur',   function () { lookupChar(block); });
}

// Wire the initial block
var _initialBlock = document.querySelector('.char-block');
if (_initialBlock) wireBlock(_initialBlock);

// "Add Another Character"
var _altCount = 0;
var addBtn = document.getElementById('add-char-btn');
if (addBtn) {
  addBtn.addEventListener('click', function () {
    var template = document.querySelector('.char-block');
    if (!template) return;

    _altCount++;
    var newBlock = template.cloneNode(true);

    // Label
    var label = newBlock.querySelector('.char-block-label');
    if (label) label.textContent = _altCount > 1 ? 'Alt Character ' + _altCount : 'Alt Character';

    // Show remove button and wire it
    var removeBtn = newBlock.querySelector('.btn-remove-char');
    if (removeBtn) {
      removeBtn.hidden = false;
      removeBtn.addEventListener('click', function () {
        newBlock.remove();
        renumberBlocks();
      });
    }

    // Reset inputs, status, and Blizzard picker
    newBlock.querySelectorAll('.char-name, .char-realm').forEach(function (el) { el.value = ''; });
    var newSelect = newBlock.querySelector('.char-blizzard-select');
    if (newSelect && _blizzardChars.length) {
      switchToBlizzardPicker(newBlock);
    }
    setLinksDisabled(newBlock, true);
    var notFoundEl = newBlock.querySelector('.char-not-found');
    var checkingEl = newBlock.querySelector('.char-checking');
    if (notFoundEl) notFoundEl.hidden = true;
    if (checkingEl) checkingEl.hidden = true;

    wireBlock(newBlock);
    var container = document.getElementById('char-blocks');
    if (container) container.appendChild(newBlock);
  });
}

function renumberBlocks() {
  document.querySelectorAll('.char-block').forEach(function (block, i) {
    var label     = block.querySelector('.char-block-label');
    var removeBtn = block.querySelector('.btn-remove-char');
    if (i === 0) {
      if (label)     label.textContent = 'Main Character';
      if (removeBtn) removeBtn.hidden  = true;
    } else {
      if (label) label.textContent = i > 1 ? 'Alt Character ' + i : 'Alt Character';
    }
  });
  _altCount = document.querySelectorAll('.char-block').length - 1;
}

// ── Blizzard OAuth popup flow ───────────────────────────────────────────────
var _blizzardChars = [];

function populateCharSelect(select) {
  select.innerHTML = '<option value="">\u2014 Select a character \u2014</option>';
  _blizzardChars.forEach(function (char) {
    var opt = document.createElement('option');
    opt.value = JSON.stringify({ name: char.name, realm: char.realm, realmSlug: char.realmSlug });
    opt.textContent = char.name + ' \u2013 ' + char.realm + ' (' + char.className + ', ' + char.level + ')';
    select.appendChild(opt);
  });
}

function switchToBlizzardPicker(block) {
  var select = block.querySelector('.char-blizzard-select');
  var row    = block.querySelector('.char-blizzard-row');
  if (select) populateCharSelect(select);
  if (row)    row.hidden = false;
  block.querySelectorAll('.char-manual-row').forEach(function (el) { el.hidden = true; });
}

(function () {
  var bnetBtn = document.getElementById('blizzard-login-btn');

  function onLogin() {
    var loginUrl = '/auth/login?popup=1';
    var popup = window.open(loginUrl, 'blizzard-login', 'width=600,height=720,left=200,top=80');
    if (!popup) {
      window.location.href = loginUrl;
    }
  }

  if (bnetBtn) {
    bnetBtn.addEventListener('click', onLogin);
  }

  function applyBlizzardData(data) {
    if (!data || data.error) return;

    // Populate battletag field
    if (data.battletag) {
      var btagInput = document.getElementById('battletag');
      if (btagInput) btagInput.value = data.battletag;
    }

    // Switch button to logout mode
    var btn = document.getElementById('blizzard-login-btn');
    var btnLabel = document.getElementById('blizzard-btn-label');
    if (btn) {
      btn.removeEventListener('click', onLogin);
      btn.title = data.battletag ? ('Logged in as ' + data.battletag + ' \u2014 click to log out') : 'Logged in \u2014 click to log out';
      btn.classList.add('btn-blizzard--logout');
      if (btnLabel) btnLabel.textContent = data.battletag || 'Logged in';
      btn.addEventListener('click', function onLogout() {
        btn.removeEventListener('click', onLogout);
        btn.classList.remove('btn-blizzard--logout');
        btn.title = 'Login with Blizzard to auto-fill your characters';
        if (btnLabel) btnLabel.textContent = 'Login with Blizzard';
        _blizzardChars = [];
        // Restore manual fields on all blocks
        document.querySelectorAll('.char-block').forEach(function (block) {
          var row = block.querySelector('.char-blizzard-row');
          if (row) row.hidden = true;
          block.querySelectorAll('.char-manual-row').forEach(function (el) { el.hidden = false; });
          block.querySelectorAll('.char-name, .char-realm').forEach(function (el) { el.value = ''; });
          setLinksDisabled(block, true);
          delete block.dataset.validated;
        });
        btn.addEventListener('click', onLogin);
      });
    }

    var chars = data.characters;
    if (!chars || !chars.length) return;
    _blizzardChars = chars;

    // Populate the select inside every existing char-block and hide manual fields
    document.querySelectorAll('.char-block').forEach(function (block) {
      switchToBlizzardPicker(block);
    });
  }

  // Handle postMessage from popup callback
  window.addEventListener('message', function (event) {
    if (event.origin !== window.location.origin) return;
    if (!event.data || event.data.type !== 'blizzard-auth') return;
    applyBlizzardData(event.data);
  });

  // Handle fallback via sessionStorage (when popup was blocked)
  try {
    var stored = sessionStorage.getItem('blizzard-chars');
    if (stored) {
      sessionStorage.removeItem('blizzard-chars');
      applyBlizzardData(JSON.parse(stored));
    }
  } catch (_) {}
}());

// ── Application form submission ─────────────────────────────────────────────
(function () {
  var form = document.getElementById('apply-form');
  var submitBtn = document.getElementById('apply-submit-btn');
  var feedback = document.getElementById('apply-feedback');

  if (!form || !submitBtn || !feedback) return;

  form.addEventListener('submit', async function (e) {
    e.preventDefault();

    // Collect basic fields
    var discord = (form.querySelector('#discord-name') || {}).value || '';
    discord = discord.trim();
    if (!discord) {
      showFeedback('Discord username is required.', false);
      return;
    }

    var battletag = (form.querySelector('#battletag') || {}).value || '';
    battletag = battletag.trim();
    if (!battletag) {
      showFeedback('A Battle.net Tag is required. Enter it manually or use Login with Blizzard.', false);
      return;
    }
    var raidHistory = (form.querySelector('#raid-history') || {}).value || '';
    var goals = (form.querySelector('#wow-goals') || {}).value || '';

    // Collect characters from all char-blocks
    var characters = [];
    form.querySelectorAll('.char-block').forEach(function (block, i) {
      // If the Blizzard picker row is visible, read from the select
      var blizzardRow = block.querySelector('.char-blizzard-row');
      var blizzardSelect = block.querySelector('.char-blizzard-select');
      if (blizzardRow && !blizzardRow.hidden && blizzardSelect && blizzardSelect.value) {
        try {
          var parsed = JSON.parse(blizzardSelect.value);
          if (parsed && parsed.name) {
            characters.push({ name: parsed.name, realm: parsed.realm || '', realmSlug: parsed.realmSlug || '', isMain: i === 0 });
          }
        } catch (_) {}
        return;
      }
      // Fall back to manual inputs
      var nameEl  = block.querySelector('.char-name');
      var realmEl = block.querySelector('.char-realm');
      var name  = nameEl  ? nameEl.value.trim()  : '';
      var realm = realmEl ? realmEl.value.trim() : '';
      if (!name) return;
      var realmSlug = block.dataset.realmSlug || realmToSlug(realm);
      characters.push({ name: name, realm: realm, realmSlug: realmSlug, isMain: i === 0 });
    });

    if (!characters.length) {
      showFeedback('Please enter at least one character name.', false);
      return;
    }

    // At least one character must be validated (Raider.io found or Blizzard OAuth)
    var anyValidated = Array.prototype.some.call(
      form.querySelectorAll('.char-block'),
      function (b) { return !!b.dataset.validated; }
    );
    if (!anyValidated) {
      showFeedback('Please verify at least one character — enter a name and realm so Raider.io can confirm it, or use Login with Blizzard.', false);
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting\u2026';
    feedback.hidden = true;

    try {
      var res = await fetch('/api/apply', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          discord_username: discord,
          battletag: battletag.trim(),
          raid_history: raidHistory.trim(),
          goals: goals.trim(),
          characters: characters,
        }),
      });
      var data;
      try { data = await res.json(); } catch (_) { data = {}; }
      if (!res.ok) {
        showFeedback(data.error || ('Submission failed (' + res.status + '). Please try again.'), false);
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit Application';
        return;
      }
      // Success
      showFeedback('Application submitted! We\u2019ll be in touch via Discord.', true);
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitted';
    } catch {
      showFeedback('Network error. Please try again.', false);
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Application';
    }
  });

  function realmToSlug(name) {
    return name.toLowerCase().replace(/'/g, '').replace(/\s+/g, '-');
  }

  function showFeedback(msg, ok) {
    feedback.textContent = msg;
    feedback.className = 'apply-feedback ' + (ok ? 'ok' : 'err');
    feedback.hidden = false;
  }
}());
</script>
