<script is:inline>
// Handle postMessage from OAuth popup (session ID and auth data)
window.addEventListener('message', function(event) {
  if (event.origin !== window.location.origin) return;
  if (!event.data) return;
  
  // Handle session ID from popup (set cookie)
  if (event.data.type === 'blizzard-session' && event.data.sessionId) {
    var expiresDate = new Date();
    expiresDate.setTime(expiresDate.getTime() + (7 * 24 * 60 * 60 * 1000)); // 7 days
    document.cookie = 'hl_session=' + encodeURIComponent(event.data.sessionId) + '; path=/; expires=' + expiresDate.toUTCString();
    setTimeout(function() { window.location.reload(); }, 100);
    return;
  }
  
  // Handle blizzard-auth from popup (has battletag, may have sessionId)
  if (event.data.type === 'blizzard-auth') {
    if (event.data.sessionId) {
      var expiresDate = new Date();
      expiresDate.setTime(expiresDate.getTime() + (7 * 24 * 60 * 60 * 1000));
      document.cookie = 'hl_session=' + encodeURIComponent(event.data.sessionId) + '; path=/; expires=' + expiresDate.toUTCString();
    }
    applyBlizzardData(event.data);
  }
});

