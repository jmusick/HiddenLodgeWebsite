---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { env } from 'cloudflare:workers';
import { resolveUserTimeZone } from '../lib/time-zones';

const user = Astro.locals.user;
if (!user) {
	return Astro.redirect('/auth/login');
}

const isOfficer = Astro.locals.isAdmin;

interface LootHistoryRow {
	id: number;
	owner_blizzard_char_id: number | null;
	resolved_owner_blizzard_char_id: number | null;
	owner_name: string;
	owner_realm: string | null;
	instance_name: string | null;
	boss_name: string | null;
	difficulty_id: number | null;
	response_text: string | null;
	item_id: number | null;
	item_name: string | null;
	awarded_date: string | null;
	awarded_time: string | null;
	awarded_at_epoch: number | null;
	is_excluded: number;
	exclude_note: string | null;
}

interface UserSettingsRow {
	time_zone: string | null;
	time_zone_set: number | null;
}

interface RaiderOptionRow {
	blizzard_char_id: number;
	name: string;
	realm: string | null;
	awarded_count: number;
}

interface ComparisonCountRow {
	blizzard_char_id: number;
	response_text: string;
	awarded_count: number;
}

const searchParams = new URL(Astro.request.url).searchParams;
const rawQuery = (searchParams.get('q') ?? '').trim();
const rawDiff = (searchParams.get('difficulty') ?? '').trim();
const rawResponse = (searchParams.get('response') ?? '').trim();
const selectedMemberIds = Array.from(
	new Set(
		searchParams
			.getAll('members')
			.flatMap((value) => value.split(','))
			.map((value) => Number.parseInt(value.trim(), 10))
			.filter((value) => Number.isFinite(value) && value > 0)
	)
).slice(0, 20);
const pageRaw = Number.parseInt(searchParams.get('page') ?? '1', 10);
const page = Number.isFinite(pageRaw) && pageRaw > 0 ? pageRaw : 1;
const pageSize = 75;
const offset = (page - 1) * pageSize;

const RAID_DIFFICULTIES = new Set([14, 15, 16]);
const parsedDifficulty = Number.parseInt(rawDiff, 10);
const difficultyFilter = RAID_DIFFICULTIES.has(parsedDifficulty) ? parsedDifficulty : 16;
const hasDifficultyFilter = true;

const whereParts: string[] = [
	'owner_blizzard_char_id IN (SELECT blizzard_char_id FROM roster_members_cache)',
	'is_excluded = 0',
];
const binds: (string | number)[] = [];

if (rawQuery) {
	whereParts.push(`(
		LOWER(owner_name) LIKE ?
		OR LOWER(owner_realm) LIKE ?
		OR LOWER(item_name) LIKE ?
		OR LOWER(instance_name) LIKE ?
		OR LOWER(boss_name) LIKE ?
	)`);
	const q = `%${rawQuery.toLowerCase()}%`;
	binds.push(q, q, q, q, q);
}

if (hasDifficultyFilter) {
	whereParts.push('difficulty_id = ?');
	binds.push(difficultyFilter);
}

if (rawResponse) {
	whereParts.push('LOWER(response_text) = ?');
	binds.push(rawResponse.toLowerCase());
}

const whereSql = whereParts.length > 0 ? `WHERE ${whereParts.join(' AND ')}` : '';

const countStmt = env.DB.prepare(`SELECT COUNT(*) AS total FROM loot_history ${whereSql}`).bind(...binds);
const rowsStmt = env.DB.prepare(
	`SELECT
		id,
		owner_blizzard_char_id,
		CASE
			WHEN owner_blizzard_char_id IS NOT NULL THEN owner_blizzard_char_id
			ELSE (
				SELECT CASE WHEN COUNT(*) = 1 THEN MAX(rmc.blizzard_char_id) ELSE NULL END
				FROM raider_metrics_cache rmc
				WHERE LOWER(rmc.name) = LOWER(loot_history.owner_name)
			)
		END AS resolved_owner_blizzard_char_id,
		owner_name,
		owner_realm,
		instance_name,
		boss_name,
		difficulty_id,
		response_text,
		item_id,
		item_name,
		awarded_date,
		awarded_time,
		awarded_at_epoch,
		is_excluded,
		exclude_note
	 FROM loot_history
	 ${whereSql}
	 ORDER BY COALESCE(awarded_at_epoch, 0) DESC, id DESC
	 LIMIT ? OFFSET ?`
).bind(...binds, pageSize, offset);

const responseOptionsStmt = env.DB.prepare(
	`SELECT DISTINCT TRIM(response_text) AS response_text
	 FROM loot_history
	 WHERE response_text IS NOT NULL AND TRIM(response_text) != ''
	 ORDER BY response_text COLLATE NOCASE ASC`
);

const userSettingsStmt = env.DB.prepare(
	`SELECT time_zone, time_zone_set
	 FROM users
	 WHERE id = ?`
).bind(user.id);

const raiderOptionsStmt = env.DB.prepare(
	`SELECT
		lh.owner_blizzard_char_id AS blizzard_char_id,
		COALESCE(MAX(NULLIF(TRIM(rmc.name), '')), MAX(NULLIF(TRIM(lh.owner_name), ''))) AS name,
		MAX(COALESCE(NULLIF(TRIM(rmc.realm), ''), NULLIF(TRIM(lh.owner_realm), ''), '')) AS realm,
		COUNT(*) AS awarded_count
	 FROM loot_history lh
	 LEFT JOIN roster_members_cache rmc
		ON rmc.blizzard_char_id = lh.owner_blizzard_char_id
	 WHERE lh.owner_blizzard_char_id IS NOT NULL
	 GROUP BY lh.owner_blizzard_char_id
	 HAVING TRIM(name) != ''
	 ORDER BY LOWER(name) ASC, LOWER(realm) ASC`
);

const [countResult, rowsResult, responseOptionsResult, userSettingsResult, raiderOptionsResult] = await env.DB.batch([
	countStmt,
	rowsStmt,
	responseOptionsStmt,
	userSettingsStmt,
	raiderOptionsStmt,
]);

const total = Number((countResult.results?.[0] as { total?: number } | undefined)?.total ?? 0);
const rows = (rowsResult.results ?? []) as LootHistoryRow[];
const responseOptions = (responseOptionsResult.results ?? []).map((row) => String((row as { response_text?: string }).response_text ?? '').trim()).filter((value) => value !== '');
const userSettings = (userSettingsResult.results?.[0] as UserSettingsRow | undefined) ?? undefined;
const raiderOptions = (raiderOptionsResult.results ?? []) as RaiderOptionRow[];
const userTimeZone = resolveUserTimeZone(userSettings);
const awardedFormatter = new Intl.DateTimeFormat('en-US', {
	timeZone: userTimeZone,
	year: 'numeric',
	month: '2-digit',
	day: '2-digit',
	hour: '2-digit',
	minute: '2-digit',
	second: '2-digit',
	hour12: true,
});

const totalPages = Math.max(1, Math.ceil(total / pageSize));
const currentPage = Math.min(page, totalPages);
const selectedMemberSet = new Set<number>(selectedMemberIds);
const selectedRaiders = raiderOptions.filter((raider) => selectedMemberSet.has(raider.blizzard_char_id));

let comparisonCounts: ComparisonCountRow[] = [];
if (selectedMemberIds.length > 0) {
	const placeholders = selectedMemberIds.map(() => '?').join(', ');
	const comparisonBinds: number[] = [...selectedMemberIds];
	let comparisonDifficultySql = '';
	if (hasDifficultyFilter) {
		comparisonDifficultySql = ' AND difficulty_id = ?';
		comparisonBinds.push(difficultyFilter);
	}
	const comparisonStmt = env.DB.prepare(
		`SELECT
			owner_blizzard_char_id AS blizzard_char_id,
			COALESCE(NULLIF(TRIM(response_text), ''), 'Unspecified') AS response_text,
			COUNT(*) AS awarded_count
		 FROM loot_history
		 WHERE owner_blizzard_char_id IN (${placeholders})${comparisonDifficultySql}
		 GROUP BY owner_blizzard_char_id, COALESCE(NULLIF(TRIM(response_text), ''), 'Unspecified')`
	).bind(...comparisonBinds);

	const comparisonResult = await comparisonStmt.all();
	comparisonCounts = (comparisonResult.results ?? []) as ComparisonCountRow[];
}

const responseBreakdown = Array.from(new Set(comparisonCounts.map((row) => row.response_text))).sort((a, b) =>
	a.localeCompare(b, undefined, { sensitivity: 'base' })
);

const comparisonByMember = new Map<number, Map<string, number>>();
for (const row of comparisonCounts) {
	const perResponse = comparisonByMember.get(row.blizzard_char_id) ?? new Map<string, number>();
	perResponse.set(row.response_text, row.awarded_count);
	comparisonByMember.set(row.blizzard_char_id, perResponse);
}

function difficultyLabel(difficultyId: number | null): string {
	if (difficultyId === 17) return 'LFR';
	if (difficultyId === 14) return 'Normal';
	if (difficultyId === 15) return 'Heroic';
	if (difficultyId === 16) return 'Mythic';
	if (difficultyId === 8) return 'Mythic+';
	if (difficultyId === null) return '-';
	return `ID ${difficultyId}`;
}

function responseClass(response: string | null): string {
	const raw = String(response ?? '').toLowerCase();
	if (raw.includes('personal loot')) return 'pill pl';
	if (raw.includes('major')) return 'pill major';
	if (raw.includes('minor')) return 'pill minor';
	if (raw.includes('pass')) return 'pill pass';
	if (raw.includes('autopass')) return 'pill autopass';
	if (raw.includes('track')) return 'pill track';
	return 'pill';
}

function formatOwner(name: string): string {
	return name;
}

function formatAwardedAt(row: LootHistoryRow): string {
	let epoch = typeof row.awarded_at_epoch === 'number' && row.awarded_at_epoch > 0
		? row.awarded_at_epoch
		: null;

	if (epoch === null && row.awarded_date && row.awarded_time) {
		const dateMatch = row.awarded_date.match(/^(\d{4})\/(\d{2})\/(\d{2})$/);
		const timeMatch = row.awarded_time.match(/^(\d{2}):(\d{2})(?::(\d{2}))?$/);
		if (dateMatch && timeMatch) {
			const year = Number.parseInt(dateMatch[1], 10);
			const month = Number.parseInt(dateMatch[2], 10);
			const day = Number.parseInt(dateMatch[3], 10);
			const hour = Number.parseInt(timeMatch[1], 10);
			const minute = Number.parseInt(timeMatch[2], 10);
			const second = Number.parseInt(timeMatch[3] ?? '0', 10);
			epoch = Math.floor(Date.UTC(year, month - 1, day, hour, minute, second) / 1000);
		}
	}

	if (epoch !== null && Number.isFinite(epoch)) {
		return awardedFormatter.format(new Date(epoch * 1000));
	}

	return '-';
}

function displayItemName(row: LootHistoryRow): string {
	const name = String(row.item_name ?? '').trim();
	if (name) return name;
	if (row.item_id) return `Item ${row.item_id}`;
	return '-';
}

function pageHref(targetPage: number): string {
	const params = new URLSearchParams();
	if (rawQuery) params.set('q', rawQuery);
	if (hasDifficultyFilter) params.set('difficulty', String(difficultyFilter));
	if (rawResponse) params.set('response', rawResponse);
	for (const memberId of selectedMemberIds) params.append('members', String(memberId));
	params.set('page', String(targetPage));
	const qs = params.toString();
	return qs ? `/loot-history?${qs}` : '/loot-history';
}

function filterOnlyHref(): string {
	const params = new URLSearchParams();
	if (rawQuery) params.set('q', rawQuery);
	if (hasDifficultyFilter) params.set('difficulty', String(difficultyFilter));
	if (rawResponse) params.set('response', rawResponse);
	const qs = params.toString();
	return qs ? `/loot-history?${qs}` : '/loot-history';
}

function raiderLabel(raider: RaiderOptionRow): string {
	return raider.name;
}

function comparisonCountFor(memberId: number, response: string): number {
	return comparisonByMember.get(memberId)?.get(response) ?? 0;
}

function comparisonTotalFor(memberId: number): number {
	const perResponse = comparisonByMember.get(memberId);
	if (!perResponse) return 0;
	let totalCount = 0;
	for (const value of perResponse.values()) totalCount += value;
	return totalCount;
}
---

<Layout title="Loot History | The Hidden Lodge">
	<div class="loot-history-page">
		<header class="page-head">
			<h1>Loot History</h1>
			<p>Recent RCLootCouncil awards synced from desktop clients.</p>
		</header>

		<section class="comparison" aria-label="Loot comparison">
			<header class="comparison-head">
				<h2>Raider Comparison</h2>
				<p>Pick multiple raiders to compare total awarded items by response type.</p>
			</header>

			<form method="GET" action="/loot-history" class="comparison-form">
				{rawQuery && <input type="hidden" name="q" value={rawQuery} />}
				{rawResponse && <input type="hidden" name="response" value={rawResponse} />}

				<label>
					<span>Members (click tags to toggle)</span>
					<div class="tag-cloud" role="group" aria-label="Select members for comparison">
						{raiderOptions.map((raider) => (
							<label class:list={["member-tag", { selected: selectedMemberSet.has(raider.blizzard_char_id) }]}>
								<input
									type="checkbox"
									name="members"
									value={raider.blizzard_char_id}
									checked={selectedMemberSet.has(raider.blizzard_char_id)}
								/>
								<span class="member-name">{raiderLabel(raider)}</span>
								<span class="member-badge" title="Total awarded items">{raider.awarded_count}</span>
							</label>
						))}
					</div>
				</label>

				<div class="comparison-controls">
					<label class="difficulty-control">
						<span>Difficulty</span>
						<select name="difficulty">
							<option value="14" selected={difficultyFilter === 14}>Normal</option>
							<option value="15" selected={difficultyFilter === 15}>Heroic</option>
							<option value="16" selected={difficultyFilter === 16}>Mythic</option>
						</select>
					</label>

					<div class="actions">
						<button type="submit">Compare</button>
						<a href={filterOnlyHref()}>Clear Selection</a>
					</div>
				</div>
			</form>

			{selectedMemberIds.length === 0 ? (
				<p class="empty">Select raiders above to view their response breakdown.</p>
			) : (
				<div class="table-wrap">
					<table id="comparison-table" class="sortable-table">
						<thead>
							<tr>
								<th><button type="button" class="sort-btn" data-sort-type="text">Raider</button></th>
								<th><button type="button" class="sort-btn" data-sort-type="number">Total</button></th>
								{responseBreakdown.map((response) => (
									<th><button type="button" class="sort-btn" data-sort-type="number">{response}</button></th>
								))}
							</tr>
						</thead>
						<tbody>
							{selectedRaiders.map((raider) => (
								<tr>
									<td>{raiderLabel(raider)}</td>
									<td>{comparisonTotalFor(raider.blizzard_char_id)}</td>
									{responseBreakdown.map((response) => (
										<td>{comparisonCountFor(raider.blizzard_char_id, response)}</td>
									))}
								</tr>
							))}
						</tbody>
					</table>
				</div>
			)}
		</section>

		<section class="filters" aria-label="Loot history filters">
			<form method="GET" action="/loot-history" class="filter-form" id="loot-history-filter-form">
				{selectedMemberIds.map((memberId) => (
					<input type="hidden" name="members" value={memberId} />
				))}
				<label>
					<span>Search</span>
					<input
						type="search"
						name="q"
						id="loot-history-search"
						value={rawQuery}
						placeholder="Player, item, boss, instance"
						autocomplete="off"
					/>
				</label>

				<label>
					<span>Difficulty</span>
					<select name="difficulty">
						<option value="14" selected={difficultyFilter === 14}>Normal</option>
						<option value="15" selected={difficultyFilter === 15}>Heroic</option>
						<option value="16" selected={difficultyFilter === 16}>Mythic</option>
					</select>
				</label>

				<label>
					<span>Response</span>
					<select name="response">
						<option value="">All</option>
						{responseOptions.map((option) => (
							<option value={option} selected={option.toLowerCase() === rawResponse.toLowerCase()}>{option}</option>
						))}
					</select>
				</label>

				<div class="actions">
					<button type="submit">Apply</button>
					<a href="/loot-history">Reset</a>
				</div>
			</form>
			<p class="summary">Showing {rows.length} of {total} entries.</p>
		</section>

		<section class="results" aria-label="Loot history results">
			<header class="table-section-head">
				<h2>Loot Log</h2>
				<p>Recent awarded items matching the current filters.</p>
			</header>

			{rows.length === 0 ? (
				<p class="empty">No loot history entries match your filters.</p>
			) : (
				<div class="table-wrap">
					<table>
						<thead>
							<tr>
								<th>Awarded</th>
								<th>Player</th>
								<th>Item</th>
								<th>Boss</th>
								<th>Instance</th>
								<th>Diff</th>
								<th>Response</th>
								{isOfficer && <th></th>}
							</tr>
						</thead>
						<tbody>
							{rows.map((row) => (
								<tr data-loot-id={row.id}>
									<td>{formatAwardedAt(row)}</td>
									<td>
										{row.resolved_owner_blizzard_char_id ? (
											<a href={`/raiders/${row.resolved_owner_blizzard_char_id}`}>{formatOwner(row.owner_name)}</a>
										) : (
											formatOwner(row.owner_name)
										)}
									</td>
									<td>
										{row.item_id ? (
											<a href={`https://www.wowhead.com/item=${row.item_id}`} target="_blank" rel="noopener noreferrer">
												{displayItemName(row)}
											</a>
										) : (
											displayItemName(row)
										)}
									</td>
									<td>{row.boss_name ?? '-'}</td>
									<td>{row.instance_name ?? '-'}</td>
									<td>{difficultyLabel(row.difficulty_id)}</td>
									<td><span class={responseClass(row.response_text)}>{row.response_text ?? '-'}</span></td>
									{isOfficer && (
										<td class="action-cell">
											<button
												type="button"
												class="btn-exclude"
												data-entry-id={row.id}
												aria-label={`Exclude loot entry for ${row.owner_name}`}
											>Exclude</button>
										</td>
									)}
								</tr>
							))}
						</tbody>
					</table>
				</div>
			)}
		</section>

		{totalPages > 1 && (
			<nav class="pagination" aria-label="Loot history pages">
				<a class:list={[{ disabled: currentPage <= 1 }]} href={currentPage <= 1 ? undefined : pageHref(currentPage - 1)}>Previous</a>
				<span>Page {currentPage} of {totalPages}</span>
				<a class:list={[{ disabled: currentPage >= totalPages }]} href={currentPage >= totalPages ? undefined : pageHref(currentPage + 1)}>Next</a>
			</nav>
		)}
	</div>

	{isOfficer && (
		<dialog id="exclude-dialog" aria-labelledby="exclude-dialog-title">
			<form id="exclude-form" method="dialog">
				<h2 id="exclude-dialog-title">Exclude Loot Entry</h2>
				<p class="exclude-warning">This will permanently hide the entry from loot history. Provide a reason so other officers understand why.</p>
				<label>
					<span>Reason <span class="required-mark" aria-hidden="true">*</span></span>
					<textarea id="exclude-note" name="note" rows="4" maxlength="1000" placeholder="Why is this entry being excluded?"></textarea>
				</label>
				<div class="exclude-error" id="exclude-error" role="alert" aria-live="polite"></div>
				<div class="exclude-actions">
					<button type="button" id="exclude-cancel">Cancel</button>
					<button type="button" class="btn-confirm-exclude" id="exclude-submit">Confirm Exclude</button>
				</div>
			</form>
		</dialog>
	)}
</Layout>

<script is:inline>
	(() => {
		const form = document.getElementById('loot-history-filter-form');
		if (!(form instanceof HTMLFormElement)) return;

		const searchInput = document.getElementById('loot-history-search');
		const difficultySelect = form.querySelector('select[name="difficulty"]');
		const responseSelect = form.querySelector('select[name="response"]');
		let searchTimer = null;

		const submitFilters = () => {
			const url = new URL(form.action, window.location.origin);
			const params = new URLSearchParams(new FormData(form));
			const query = (params.get('q') || '').toString().trim();
			const difficulty = (params.get('difficulty') || '').toString().trim();
			const response = (params.get('response') || '').toString().trim();

			if (query) url.searchParams.set('q', query);
			if (difficulty) url.searchParams.set('difficulty', difficulty);
			if (response) url.searchParams.set('response', response);
			url.searchParams.set('page', '1');

			const nextUrl = `${url.pathname}?${url.searchParams.toString()}`;
			const currentUrl = `${window.location.pathname}${window.location.search}`;
			if (nextUrl !== currentUrl) {
				window.location.assign(nextUrl);
			}
		};

		if (searchInput instanceof HTMLInputElement) {
			searchInput.addEventListener('input', () => {
				if (searchTimer !== null) {
					window.clearTimeout(searchTimer);
				}
				searchTimer = window.setTimeout(submitFilters, 275);
			});
		}

		if (difficultySelect instanceof HTMLSelectElement) {
			difficultySelect.addEventListener('change', submitFilters);
		}

		if (responseSelect instanceof HTMLSelectElement) {
			responseSelect.addEventListener('change', submitFilters);
		}
	})();

	(() => {
		const form = document.querySelector('.comparison-form');
		if (!(form instanceof HTMLFormElement)) return;

		const checkboxes = Array.from(form.querySelectorAll('input[type="checkbox"][name="members"]'));
		if (checkboxes.length === 0) return;
		const comparisonDifficultySelect = form.querySelector('select[name="difficulty"]');

		const syncTagState = () => {
			for (const checkbox of checkboxes) {
				const label = checkbox.closest('.member-tag');
				if (!(label instanceof HTMLElement)) continue;
				label.classList.toggle('selected', checkbox.checked);
			}
		};

		const submitComparison = () => {
			const url = new URL(form.action, window.location.origin);
			const params = new URLSearchParams(new FormData(form));
			const query = (params.get('q') || '').toString().trim();
			const difficulty = (params.get('difficulty') || '').toString().trim();
			const response = (params.get('response') || '').toString().trim();

			if (query) url.searchParams.set('q', query);
			if (difficulty) url.searchParams.set('difficulty', difficulty);
			if (response) url.searchParams.set('response', response);

			for (const memberValue of params.getAll('members')) {
				const value = memberValue.toString().trim();
				if (value) url.searchParams.append('members', value);
			}

			url.searchParams.set('page', '1');
			window.location.assign(`${url.pathname}?${url.searchParams.toString()}`);
		};

		syncTagState();
		for (const checkbox of checkboxes) {
			checkbox.addEventListener('change', () => {
				syncTagState();
				submitComparison();
			});
		}

		if (comparisonDifficultySelect instanceof HTMLSelectElement) {
			comparisonDifficultySelect.addEventListener('change', submitComparison);
		}
	})();

	(() => {
		const table = document.getElementById('comparison-table');
		if (!(table instanceof HTMLTableElement)) return;

		const body = table.tBodies.item(0);
		if (!(body instanceof HTMLTableSectionElement)) return;

		const headers = Array.from(table.querySelectorAll('thead th .sort-btn'));
		if (headers.length === 0) return;

		const compareValues = (aRaw, bRaw, sortType, direction) => {
			if (sortType === 'number') {
				const aNum = Number.parseFloat(aRaw);
				const bNum = Number.parseFloat(bRaw);
				const aVal = Number.isFinite(aNum) ? aNum : 0;
				const bVal = Number.isFinite(bNum) ? bNum : 0;
				return direction === 'asc' ? aVal - bVal : bVal - aVal;
			}

			return direction === 'asc'
				? aRaw.localeCompare(bRaw, undefined, { sensitivity: 'base' })
				: bRaw.localeCompare(aRaw, undefined, { sensitivity: 'base' });
		};

		const clearHeaderState = (exceptButton) => {
			for (const btn of headers) {
				if (btn === exceptButton) continue;
				btn.dataset.sortDir = '';
				btn.classList.remove('is-asc', 'is-desc');
			}
		};

		for (const button of headers) {
			button.addEventListener('click', () => {
				const th = button.closest('th');
				if (!(th instanceof HTMLTableCellElement)) return;

				const columnIndex = th.cellIndex;
				const sortType = button.dataset.sortType === 'number' ? 'number' : 'text';
				const nextDirection = button.dataset.sortDir === 'asc' ? 'desc' : 'asc';

				const rows = Array.from(body.rows);
				rows.sort((rowA, rowB) => {
					const aCell = rowA.cells.item(columnIndex);
					const bCell = rowB.cells.item(columnIndex);
					const aRaw = (aCell?.textContent ?? '').trim();
					const bRaw = (bCell?.textContent ?? '').trim();
					return compareValues(aRaw, bRaw, sortType, nextDirection);
				});

				for (const row of rows) body.appendChild(row);

				clearHeaderState(button);
				button.dataset.sortDir = nextDirection;
				button.classList.toggle('is-asc', nextDirection === 'asc');
				button.classList.toggle('is-desc', nextDirection === 'desc');
			});
		}
	})();

	(() => {
		const dialog = document.getElementById('exclude-dialog');
		if (!(dialog instanceof HTMLDialogElement)) return;

		const noteInput = document.getElementById('exclude-note');
		const errorEl = document.getElementById('exclude-error');
		const submitBtn = document.getElementById('exclude-submit');
		const cancelBtn = document.getElementById('exclude-cancel');

		let pendingEntryId = null;
		let pendingRow = null;

		function showError(msg) {
			if (errorEl) errorEl.textContent = msg;
		}

		function clearError() {
			if (errorEl) errorEl.textContent = '';
		}

		function openDialog(entryId, row) {
			pendingEntryId = entryId;
			pendingRow = row;
			if (noteInput instanceof HTMLTextAreaElement) noteInput.value = '';
			clearError();
			dialog.showModal();
			noteInput?.focus();
		}

		cancelBtn?.addEventListener('click', () => {
			dialog.close();
		});

		dialog.addEventListener('close', () => {
			pendingEntryId = null;
			pendingRow = null;
			clearError();
		});

		submitBtn?.addEventListener('click', async () => {
			const note = noteInput instanceof HTMLTextAreaElement ? noteInput.value.trim() : '';
			if (!note) {
				showError('A reason is required.');
				noteInput?.focus();
				return;
			}

			submitBtn.disabled = true;
			submitBtn.textContent = 'Excluding…';
			clearError();

			try {
				const res = await fetch('/api/admin/loot-history/exclude', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ id: pendingEntryId, note }),
				});

				if (res.ok) {
					dialog.close();
					if (pendingRow instanceof HTMLTableRowElement) {
						pendingRow.remove();
					}
				} else {
					const data = await res.json().catch(() => ({}));
					showError(data.error ?? 'Something went wrong. Please try again.');
				}
			} catch {
				showError('Network error. Please try again.');
			} finally {
				submitBtn.disabled = false;
				submitBtn.textContent = 'Confirm Exclude';
			}
		});

		document.addEventListener('click', (e) => {
			const btn = e.target?.closest?.('.btn-exclude');
			if (!btn) return;
			const entryId = Number.parseInt(btn.dataset.entryId ?? '', 10);
			const row = btn.closest('tr');
			if (Number.isFinite(entryId) && entryId > 0) {
				openDialog(entryId, row);
			}
		});
	})();
</script>

