{
  "name": "hiddenlodgewebsite",
  "type": "module",
  "version": "1.27.3",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/dev-with-cron.mjs",
    "dev:site": "astro dev",
    "build": "astro build && node scripts/patch-wrangler-config.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "cron:local": "node scripts/local-cron-refresh.mjs",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "db:setup": "npm run db:bootstrap:local",
    "db:bootstrap:local": "node scripts/bootstrap-d1.mjs --local",
    "db:bootstrap:prod:empty": "node scripts/bootstrap-d1.mjs --remote --require-empty",
    "db:migrate:local": "node scripts/run-d1-migration.mjs --local",
    "db:migrate:prod": "node scripts/run-d1-migration.mjs --remote",
    "db:check:migrations": "node scripts/check-migrations.mjs",
    "db:copy-prod": "node scripts/copy-prod-data.mjs",
    "db:compare-schema": "node scripts/compare-d1-schema.mjs --target=local",
    "db:compare-schema:remote": "node scripts/compare-d1-schema.mjs --target=remote",
    "db:reconcile-local": "node scripts/reconcile-local-d1.mjs",
    "db:seed:test-notes": "wrangler d1 execute hidden-lodge-db --local --file=db-seeds/seed_test_notes.sql"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.2",
    "@iconify-json/lucide": "^1.2.98",
    "astro": "^6.0.4",
    "astro-icon": "^1.1.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@cloudflare/workers-types": "^4.20260317.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.76.0"
  }
}
