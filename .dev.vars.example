# Copy this file to .dev.vars and fill in real values for local development.
# .dev.vars is gitignored and is only used by Wrangler's local dev server.
# For production, set these as secrets in the Cloudflare Pages dashboard.

# From https://develop.battle.net/access/clients
BLIZZARD_CLIENT_ID=your_client_id_here
BLIZZARD_CLIENT_SECRET=your_client_secret_here

# The OAuth redirect URI registered in your Blizzard app.
# For local dev use: http://localhost:4321/auth/callback
# For production use your Pages domain: https://yourdomain.pages.dev/auth/callback
BLIZZARD_REDIRECT_URI=http://localhost:4321/auth/callback

# From https://www.warcraftlogs.com/api/clients/
# Required for Recent Logs uploader/time metadata on the Raiding page.
WCL_CLIENT_ID=your_wcl_client_id_here
WCL_CLIENT_SECRET=your_wcl_client_secret_here

# Shared secret for /api/cron/refresh-roster.
# Use the same value in your LOCAL_CRON_SECRET environment variable when running npm run cron:local.
CRON_SECRET=replace_with_a_local_secret
